	<query id="getVspusuariosNumPorCicloEmpexternaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CICLO, ANO, PERIODO, CONCAT(NOMBRES,CONCAT(' ',CONCAT(PRIMERAPELLIDO,CONCAT(' ',SEGUNDOAPELLIDO) ) ) ) NOMBRE, CODIGORUTA, CODIGOINTERNO, EMPRESAASEOEXT,(TO_CHAR(FECHAINGASEOEXT,'DD/MM/YYYY HH24:MI:SS')) FECHAINGASEOEXT,(CASE ASEO WHEN 0 THEN 'false' ELSE 'true' END) ASEO, CODIGO_EXTERNO, CASE ESTADO WHEN 'A' THEN 'Activo' WHEN 'S' THEN 'Suspendido' WHEN 'C' THEN 'Cortado' WHEN 'R' THEN 'Retirado' END  ESTADO,(CASE ASEOBARRIDO WHEN 0 THEN 'false' ELSE 'true' END) ASEOBARRIDO,(CASE PINTADEUDATERCE WHEN 0 THEN 'false' ELSE 'true' END) PINTADEUDATERCE FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN EMPRESAASEOEXT IS NULL THEN ' ' ELSE UPPER(EMPRESAASEOEXT) END) LIKE UPPER(CONCAT(CONCAT('%',:EMPRESAASEOEXT), '%')) AND (CASE WHEN FECHAINGASEOEXT IS NULL THEN ' ' ELSE UPPER(FECHAINGASEOEXT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAINGASEOEXT), '%')) AND (CASE WHEN ASEO IS NULL THEN ' ' ELSE UPPER(ASEO) END) LIKE UPPER(CONCAT(:ASEO, '%')) AND (CASE WHEN CODIGO_EXTERNO IS NULL THEN ' ' ELSE UPPER(CODIGO_EXTERNO) END) LIKE UPPER(CONCAT(:CODIGO_EXTERNO, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN ASEOBARRIDO IS NULL THEN ' ' ELSE UPPER(ASEOBARRIDO) END) LIKE UPPER(CONCAT(:ASEOBARRIDO, '%')) AND (CASE WHEN PINTADEUDATERCE IS NULL THEN ' ' ELSE UPPER(PINTADEUDATERCE) END) LIKE UPPER(CONCAT(:PINTADEUDATERCE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
