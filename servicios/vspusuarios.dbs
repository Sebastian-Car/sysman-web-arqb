	<query id="updateVspusuariosTipocobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET TIPOCOBRO = :TITPOCOBRO WHERE COMPANIA = :COMPANIA AND CICLO      = :CICLO AND CODIGORUTA = :CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TITPOCOBRO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="vspusuarios/tipocobro">
		<call-query href="updateVspusuariosTipocobro">
			<with-param name="TITPOCOBRO" query-param="TITPOCOBRO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
