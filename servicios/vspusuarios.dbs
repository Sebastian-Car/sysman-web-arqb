<data name="vspusuarios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getVspusuariosOrigendatosfacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, NOMBRE_PERIODO, NOMBRE, CODIGOINTERNO, CODIGOANTERIOR, DIRTECNICA, DIRGUIA, USO, ESTRATO, AREA,(CASE ACUEDUCTO WHEN 0 THEN 'false' ELSE 'true' END) ACUEDUCTO,(CASE ASEO WHEN 0 THEN 'false' ELSE 'true' END) ASEO,(CASE ASEOBARRIDO WHEN 0 THEN 'false' ELSE 'true' END) ASEOBARRIDO,(CASE ALCANTARILLADO WHEN 0 THEN 'false' ELSE 'true' END) ALCANTARILLADO,(CASE ALUMBRADO WHEN 0 THEN 'false' ELSE 'true' END) ALUMBRADO, PORCENTAJEAPLICAR, ESTRATOASEO, PESOASEO, FRECUENCIAASEOSEMANA, ESTADO, COMENTARIOS, NOTACREDITO, MEDIDOR, NUMERODIGITOS, AFORADOR, LECTURA1, LECTURA2, LECTURA3, LECTURA4, LECTURA5, LECTURA6, LECTURA, LECTURAAFORO, PERIODOSATRASO, BANCOPERANTERIOR, TO_CHAR(FECHAPAGOPERANTERIOR,'DD/MM/YYYY') FECHAPAGOPERANTERIOR, PAQUETEPAGOPERANTERIOR, NOFECHAPAGOPERANTERIOR, BANCOPERPROCESO, TO_CHAR(FECHAPAGOPERPROCESO,'DD/MM/YYYY') FECHAPAGOPERPROCESO, PAQUETEPAGOPERPROCESO, NOFECHAPAGOPERPROCESO, TOTFACTURAPERACTUAL, CONSUMO1, CONSUMO2, CONSUMO3, CONSUMO4, CONSUMO5, CONSUMO6, CONSUMO, CONSUMOPROM, CONSUMOAFORO, PERIODOSNOCOBROFIN, PERIODOSNOCOBROFAC, PERIODOSINLECTURA, ACUMULADO, FIMM, TIPOLECTURA, ESTRATOALUMBRADO, INQUILINATOS, FACTURA,(CASE INDDESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) INDDESHABITADO, TOTALIZADOR, ESTADOMEDIDOR,(CASE CHAPETAS WHEN 0 THEN 'false' ELSE 'true' END) CHAPETAS, FRECUENCIARECOLECCION, TIPOCOBRO, TASACAR, NOUNDMULTIUSUARIO, ACSINMEDICION, ALSINMEDICION, INDRECAUDADO, NOTADEBITO,(CASE SEPARACIONENFUENTE WHEN 0 THEN 'false' ELSE 'true' END) SEPARACIONENFUENTE,(CASE NOPUERTAPUERTA WHEN 0 THEN 'false' ELSE 'true' END) NOPUERTAPUERTA,(CASE APARTAMENTO WHEN 0 THEN 'false' ELSE 'true' END) APARTAMENTO, CODIGO_EXTERNO,(CASE AUTORIZAMODIFICACION WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZAMODIFICACION,(CASE AUTORIZARBORRADO WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZARBORRADO, PLANTA, TOTFACTURAPERANTERIOR, TOTALDEUDA, SUBSINMEDICION, SOBRESINMEDICION, SUBALCSINMEDICION, SOBREALCSINMEDICION, DEUDA, CARGOFIJO, CARGOFIJOAL, CONSUMOBASICO, VALORBASICO, VALORCOMPLEMENTARIO, VALORSUNTUARIO, VALORALCBASICO, TOTALALUMBRADO, TOTALACUEDUCTO, TOTALALCANTARILLADO, TOTALASEO, VASEOUNICO, VASEODOMICILIARIO, VASEOBARRIDO, VASEOCONSUMO, SUBSIDIO, SOBREPRECIO, SUBACUEDUCTO, SUBALCANTARILLADO, SUBASEO, SUBFIJO, SUBFIJOALC, SUBCONSUMOAC, SUBCONSUMOAL, SOBREACUEDUCTO, SOBREALCANTARILLADO, SOBREASEO, SOBREFIJO, SOBREFIJOALC, SOBRECONSUMOAC, SOBRECONSUMOAL, VALORALCCOMPLEMENTARIO, VALORALCSUNTUARIO, CONSUMOCOMPLEMENTARIO, CONSUMOSUNTUARIO, ALCBASICO, ALCCOMPLEMENTARIO, ALCSUNTUARIO,(CASE DESVIOSIGNIFICATIVO WHEN 0 THEN 'false' ELSE 'true' END) DESVIOSIGNIFICATIVO, EMPRESAASEOEXT,(CASE PINTADEUDATERCE WHEN 0 THEN 'false' ELSE 'true' END) PINTADEUDATERCE, VDESHABITADO, VTRAMOEXCEDENTE, SUBBARR_LIM, SOBBARR_LIM, SUBDISP_FINAL, SOBDISP_FINAL, SUBMANEJO_REC, SOBMANEJO_REC, SUBRECOLECCION, SOBRECOLECCION, SUBTRAMO, SOBTRAMO, SUBDESHABITADO, SOBDESHABITADO, CODTOTALIZADOR, FREC_RECO, FREC_BARRI, TIPODEAFORO,(CASE HOGAR_COMUNITARIO WHEN 0 THEN 'false' ELSE 'true' END) HOGAR_COMUNITARIO,(CASE CARACTERIZACION_ALC WHEN 0 THEN 'false' ELSE 'true' END) CARACTERIZACION_ALC, BARRIO, CONSUMOBASICOALC, CONSUMOCOMPLEMENTARIOALC, CONSUMOSUNTUARIOALC, CONSUMOALC, CONSUMOACU,(CASE CONSUMOMANUAL WHEN 0 THEN 'false' ELSE 'true' END) CONSUMOMANUAL, CODMACROMEDIDOR,(CASE AUTORIZARBORRADO WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZARBORRADO,(CASE PORMICRO WHEN 0 THEN 'false' ELSE 'true' END) PORMICRO,(CASE SINDESCUENTO WHEN 0 THEN 'false' ELSE 'true' END) SINDESCUENTO, VALASEOCCS_720, SUBCCS_720, SOBCCS_720, VALASEOCBLS_720, SUBCBLS_720, SOBCBLS_720, VALASEOCLUS_720, SUBCLUS_720, SOBCLUS_720, VALASEOCRT_720, SUBCRT_720, SOBCRT_720, VALASEOCDF_720, SUBCDF_720, SOBCDF_720, VALASEOCTL_720, SUBCTL_720, SOBCTL_720, VALASEOVBA_720, SUBVBA_720, SOBVBA_720, SERVNORECLAMADO, VALORASEO, TO_CHAR(FECHA_PAGO,'DD/MM/YYYY') FECHA_PAGO, BANCO_PAGO, PAQUETE_PAGO, NOM_BANCO_PAGO_TER, NOM_BANCOPERPROCESO, TOTAL_CONV, TO_CHAR(FECHA_PAGO_CONV,'DD/MM/YYYY') FECHA_PAGO_CONV, BANCO_PAGO_CONV, PAQUETE_PAGO_CONV, NOM_BANCO_PAGO_CONV, NOM_BANCOPERANTERIOR, VALORASEO_ANT, TO_CHAR(FECHA_PAGO_ANT,'DD/MM/YYYY') FECHA_PAGO_ANT, BANCO_PAGO_ANT, PAQUETE_PAGO_ANT, NOM_BANCO_PAGO_TER_ANT, TOTAL_CONV_ANT, TO_CHAR(FECHA_PAGO_CONV_ANT,'DD/MM/YYYY') FECHA_PAGO_CONV_ANT, BANCO_PAGO_CONV_ANT, PAQUETE_PAGO_CONV_ANT, NOM_BANCO_PAGO_CONV_ANT, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM V_SP_USUARIOS SP_USUARIO WHERE SP_USUARIO.COMPANIA = :KEY_COMPANIA AND SP_USUARIO.CICLO = :KEY_CICLO AND SP_USUARIO.CODIGORUTA = :KEY_CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","NOMBRE_PERIODO":"$NOMBRE_PERIODO","NOMBRE":"$NOMBRE","CODIGOINTERNO":"$CODIGOINTERNO","CODIGOANTERIOR":"$CODIGOANTERIOR","DIRTECNICA":"$DIRTECNICA","DIRGUIA":"$DIRGUIA","USO":"$USO","ESTRATO":"$ESTRATO","AREA":"$AREA","ACUEDUCTO":"$ACUEDUCTO(type:boolean)","ASEO":"$ASEO(type:boolean)","ASEOBARRIDO":"$ASEOBARRIDO(type:boolean)","ALCANTARILLADO":"$ALCANTARILLADO(type:boolean)","ALUMBRADO":"$ALUMBRADO(type:boolean)","PORCENTAJEAPLICAR":"$PORCENTAJEAPLICAR","ESTRATOASEO":"$ESTRATOASEO","PESOASEO":"$PESOASEO","FRECUENCIAASEOSEMANA":"$FRECUENCIAASEOSEMANA(type:integer)","ESTADO":"$ESTADO","COMENTARIOS":"$COMENTARIOS","NOTACREDITO":"$NOTACREDITO","MEDIDOR":"$MEDIDOR","NUMERODIGITOS":"$NUMERODIGITOS(type:integer)","AFORADOR":"$AFORADOR","LECTURA1":"$LECTURA1","LECTURA2":"$LECTURA2","LECTURA3":"$LECTURA3","LECTURA4":"$LECTURA4","LECTURA5":"$LECTURA5","LECTURA6":"$LECTURA6","LECTURA":"$LECTURA","LECTURAAFORO":"$LECTURAAFORO","PERIODOSATRASO":"$PERIODOSATRASO(type:integer)","BANCOPERANTERIOR":"$BANCOPERANTERIOR","FECHAPAGOPERANTERIOR":"$FECHAPAGOPERANTERIOR","PAQUETEPAGOPERANTERIOR":"$PAQUETEPAGOPERANTERIOR","NOFECHAPAGOPERANTERIOR":"$NOFECHAPAGOPERANTERIOR","BANCOPERPROCESO":"$BANCOPERPROCESO","FECHAPAGOPERPROCESO":"$FECHAPAGOPERPROCESO","PAQUETEPAGOPERPROCESO":"$PAQUETEPAGOPERPROCESO","NOFECHAPAGOPERPROCESO":"$NOFECHAPAGOPERPROCESO","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","CONSUMO1":"$CONSUMO1","CONSUMO2":"$CONSUMO2","CONSUMO3":"$CONSUMO3","CONSUMO4":"$CONSUMO4","CONSUMO5":"$CONSUMO5","CONSUMO6":"$CONSUMO6","CONSUMO":"$CONSUMO","CONSUMOPROM":"$CONSUMOPROM","CONSUMOAFORO":"$CONSUMOAFORO","PERIODOSNOCOBROFIN":"$PERIODOSNOCOBROFIN(type:integer)","PERIODOSNOCOBROFAC":"$PERIODOSNOCOBROFAC(type:integer)","PERIODOSINLECTURA":"$PERIODOSINLECTURA(type:integer)","ACUMULADO":"$ACUMULADO","FIMM":"$FIMM","TIPOLECTURA":"$TIPOLECTURA","ESTRATOALUMBRADO":"$ESTRATOALUMBRADO","INQUILINATOS":"$INQUILINATOS(type:integer)","FACTURA":"$FACTURA","INDDESHABITADO":"$INDDESHABITADO(type:boolean)","TOTALIZADOR":"$TOTALIZADOR","ESTADOMEDIDOR":"$ESTADOMEDIDOR","CHAPETAS":"$CHAPETAS(type:boolean)","FRECUENCIARECOLECCION":"$FRECUENCIARECOLECCION(type:integer)","TIPOCOBRO":"$TIPOCOBRO","TASACAR":"$TASACAR","NOUNDMULTIUSUARIO":"$NOUNDMULTIUSUARIO","ACSINMEDICION":"$ACSINMEDICION","ALSINMEDICION":"$ALSINMEDICION","INDRECAUDADO":"$INDRECAUDADO","NOTADEBITO":"$NOTADEBITO","SEPARACIONENFUENTE":"$SEPARACIONENFUENTE(type:boolean)","NOPUERTAPUERTA":"$NOPUERTAPUERTA(type:boolean)","APARTAMENTO":"$APARTAMENTO(type:boolean)","CODIGO_EXTERNO":"$CODIGO_EXTERNO","AUTORIZAMODIFICACION":"$AUTORIZAMODIFICACION(type:boolean)","AUTORIZARBORRADO":"$AUTORIZARBORRADO(type:boolean)","PLANTA":"$PLANTA(type:integer)","TOTFACTURAPERANTERIOR":"$TOTFACTURAPERANTERIOR","TOTALDEUDA":"$TOTALDEUDA","SUBSINMEDICION":"$SUBSINMEDICION","SOBRESINMEDICION":"$SOBRESINMEDICION","SUBALCSINMEDICION":"$SUBALCSINMEDICION","SOBREALCSINMEDICION":"$SOBREALCSINMEDICION","DEUDA":"$DEUDA","CARGOFIJO":"$CARGOFIJO","CARGOFIJOAL":"$CARGOFIJOAL","CONSUMOBASICO":"$CONSUMOBASICO","VALORBASICO":"$VALORBASICO","VALORCOMPLEMENTARIO":"$VALORCOMPLEMENTARIO","VALORSUNTUARIO":"$VALORSUNTUARIO","VALORALCBASICO":"$VALORALCBASICO","TOTALALUMBRADO":"$TOTALALUMBRADO","TOTALACUEDUCTO":"$TOTALACUEDUCTO","TOTALALCANTARILLADO":"$TOTALALCANTARILLADO","TOTALASEO":"$TOTALASEO","VASEOUNICO":"$VASEOUNICO","VASEODOMICILIARIO":"$VASEODOMICILIARIO","VASEOBARRIDO":"$VASEOBARRIDO","VASEOCONSUMO":"$VASEOCONSUMO","SUBSIDIO":"$SUBSIDIO","SOBREPRECIO":"$SOBREPRECIO","SUBACUEDUCTO":"$SUBACUEDUCTO","SUBALCANTARILLADO":"$SUBALCANTARILLADO","SUBASEO":"$SUBASEO","SUBFIJO":"$SUBFIJO","SUBFIJOALC":"$SUBFIJOALC","SUBCONSUMOAC":"$SUBCONSUMOAC","SUBCONSUMOAL":"$SUBCONSUMOAL","SOBREACUEDUCTO":"$SOBREACUEDUCTO","SOBREALCANTARILLADO":"$SOBREALCANTARILLADO","SOBREASEO":"$SOBREASEO","SOBREFIJO":"$SOBREFIJO","SOBREFIJOALC":"$SOBREFIJOALC","SOBRECONSUMOAC":"$SOBRECONSUMOAC","SOBRECONSUMOAL":"$SOBRECONSUMOAL","VALORALCCOMPLEMENTARIO":"$VALORALCCOMPLEMENTARIO","VALORALCSUNTUARIO":"$VALORALCSUNTUARIO","CONSUMOCOMPLEMENTARIO":"$CONSUMOCOMPLEMENTARIO","CONSUMOSUNTUARIO":"$CONSUMOSUNTUARIO","ALCBASICO":"$ALCBASICO","ALCCOMPLEMENTARIO":"$ALCCOMPLEMENTARIO","ALCSUNTUARIO":"$ALCSUNTUARIO","DESVIOSIGNIFICATIVO":"$DESVIOSIGNIFICATIVO(type:boolean)","EMPRESAASEOEXT":"$EMPRESAASEOEXT","PINTADEUDATERCE":"$PINTADEUDATERCE(type:boolean)","VDESHABITADO":"$VDESHABITADO","VTRAMOEXCEDENTE":"$VTRAMOEXCEDENTE","SUBBARR_LIM":"$SUBBARR_LIM","SOBBARR_LIM":"$SOBBARR_LIM","SUBDISP_FINAL":"$SUBDISP_FINAL","SOBDISP_FINAL":"$SOBDISP_FINAL","SUBMANEJO_REC":"$SUBMANEJO_REC","SOBMANEJO_REC":"$SOBMANEJO_REC","SUBRECOLECCION":"$SUBRECOLECCION","SOBRECOLECCION":"$SOBRECOLECCION","SUBTRAMO":"$SUBTRAMO","SOBTRAMO":"$SOBTRAMO","SUBDESHABITADO":"$SUBDESHABITADO","SOBDESHABITADO":"$SOBDESHABITADO","CODTOTALIZADOR":"$CODTOTALIZADOR","FREC_RECO":"$FREC_RECO","FREC_BARRI":"$FREC_BARRI","TIPODEAFORO":"$TIPODEAFORO(type:integer)","HOGAR_COMUNITARIO":"$HOGAR_COMUNITARIO(type:boolean)","CARACTERIZACION_ALC":"$CARACTERIZACION_ALC(type:boolean)","BARRIO":"$BARRIO","CONSUMOBASICOALC":"$CONSUMOBASICOALC","CONSUMOCOMPLEMENTARIOALC":"$CONSUMOCOMPLEMENTARIOALC","CONSUMOSUNTUARIOALC":"$CONSUMOSUNTUARIOALC","CONSUMOALC":"$CONSUMOALC","CONSUMOACU":"$CONSUMOACU","CONSUMOMANUAL":"$CONSUMOMANUAL(type:boolean)","CODMACROMEDIDOR":"$CODMACROMEDIDOR","AUTORIZARBORRADO":"$AUTORIZARBORRADO(type:boolean)","PORMICRO":"$PORMICRO(type:boolean)","SINDESCUENTO":"$SINDESCUENTO(type:boolean)","VALASEOCCS_720":"$VALASEOCCS_720","SUBCCS_720":"$SUBCCS_720","SOBCCS_720":"$SOBCCS_720","VALASEOCBLS_720":"$VALASEOCBLS_720","SUBCBLS_720":"$SUBCBLS_720","SOBCBLS_720":"$SOBCBLS_720","VALASEOCLUS_720":"$VALASEOCLUS_720","SUBCLUS_720":"$SUBCLUS_720","SOBCLUS_720":"$SOBCLUS_720","VALASEOCRT_720":"$VALASEOCRT_720","SUBCRT_720":"$SUBCRT_720","SOBCRT_720":"$SOBCRT_720","VALASEOCDF_720":"$VALASEOCDF_720","SUBCDF_720":"$SUBCDF_720","SOBCDF_720":"$SOBCDF_720","VALASEOCTL_720":"$VALASEOCTL_720","SUBCTL_720":"$SUBCTL_720","SOBCTL_720":"$SOBCTL_720","VALASEOVBA_720":"$VALASEOVBA_720","SUBVBA_720":"$SUBVBA_720","SOBVBA_720":"$SOBVBA_720","SERVNORECLAMADO":"$SERVNORECLAMADO","VALORASEO":"$VALORASEO(type:integer)","FECHA_PAGO":"$FECHA_PAGO","BANCO_PAGO":"$BANCO_PAGO","PAQUETE_PAGO":"$PAQUETE_PAGO","NOM_BANCO_PAGO_TER":"$NOM_BANCO_PAGO_TER","NOM_BANCOPERPROCESO":"$NOM_BANCOPERPROCESO","TOTAL_CONV":"$TOTAL_CONV(type:integer)","FECHA_PAGO_CONV":"$FECHA_PAGO_CONV","BANCO_PAGO_CONV":"$BANCO_PAGO_CONV","PAQUETE_PAGO_CONV":"$PAQUETE_PAGO_CONV","NOM_BANCO_PAGO_CONV":"$NOM_BANCO_PAGO_CONV","NOM_BANCOPERANTERIOR":"$NOM_BANCOPERANTERIOR","VALORASEO_ANT":"$VALORASEO_ANT(type:integer)","FECHA_PAGO_ANT":"$FECHA_PAGO_ANT","BANCO_PAGO_ANT":"$BANCO_PAGO_ANT","PAQUETE_PAGO_ANT":"$PAQUETE_PAGO_ANT","NOM_BANCO_PAGO_TER_ANT":"$NOM_BANCO_PAGO_TER_ANT","TOTAL_CONV_ANT":"$TOTAL_CONV_ANT(type:integer)","FECHA_PAGO_CONV_ANT":"$FECHA_PAGO_CONV_ANT","BANCO_PAGO_CONV_ANT":"$BANCO_PAGO_CONV_ANT","PAQUETE_PAGO_CONV_ANT":"$PAQUETE_PAGO_CONV_ANT","NOM_BANCO_PAGO_CONV_ANT":"$NOM_BANCO_PAGO_CONV_ANT","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vspusuarios/origendatosfactura">
		<call-query href="getVspusuariosOrigendatosfacturaQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getVspusuariosPagOrigengrillafacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CICLO, CODIGORUTA, NOMBRE, DIRTECNICA, CODIGOINTERNO, MATRICULA, MEDIDOR  FROM V_SP_USUARIOS WHERE V_SP_USUARIOS.COMPANIA = :COMPANIA AND V_SP_USUARIOS.CICLO = :CICLOACTUAL) WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRTECNICA IS NULL THEN ' ' ELSE UPPER(DIRTECNICA) END)  LIKE UPPER( '%' || :DIRTECNICA || '%')  AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END)  LIKE UPPER(:CODIGOINTERNO || '%')  AND (CASE WHEN MATRICULA IS NULL THEN ' ' ELSE UPPER(MATRICULA) END)  LIKE UPPER(:MATRICULA || '%')  AND (CASE WHEN MEDIDOR IS NULL THEN ' ' ELSE UPPER(MEDIDOR) END)  LIKE UPPER(:MEDIDOR || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","DIRTECNICA":"$DIRTECNICA","CODIGOINTERNO":"$CODIGOINTERNO","MATRICULA":"$MATRICULA","MEDIDOR":"$MEDIDOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRTECNICA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="MATRICULA" sqlType="STRING"/>
		<param name="MEDIDOR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="vspusuarios/origengrillafactura/pag">
		<call-query href="getVspusuariosPagOrigengrillafacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOACTUAL" query-param="CICLOACTUAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRTECNICA" query-param="DIRTECNICA"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="MATRICULA" query-param="MATRICULA"/>
			<with-param name="MEDIDOR" query-param="MEDIDOR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getVspusuariosNumOrigengrillafacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CICLO, CODIGORUTA, NOMBRE, DIRTECNICA, CODIGOINTERNO, MATRICULA, MEDIDOR  FROM V_SP_USUARIOS WHERE V_SP_USUARIOS.COMPANIA = :COMPANIA AND V_SP_USUARIOS.CICLO = :CICLOACTUAL) WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN DIRTECNICA IS NULL THEN ' ' ELSE UPPER(DIRTECNICA) END)  LIKE UPPER( '%' || :DIRTECNICA || '%')  AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END)  LIKE UPPER( '%' || :CODIGOINTERNO || '%')  AND (CASE WHEN MATRICULA IS NULL THEN ' ' ELSE UPPER(MATRICULA) END)  LIKE UPPER( '%' || :MATRICULA || '%')  AND (CASE WHEN MEDIDOR IS NULL THEN ' ' ELSE UPPER(MEDIDOR) END)  LIKE UPPER( '%' || :MEDIDOR || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRTECNICA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="MATRICULA" sqlType="STRING"/>
		<param name="MEDIDOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="vspusuarios/origengrillafactura/num">
		<call-query href="getVspusuariosNumOrigengrillafacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOACTUAL" query-param="CICLOACTUAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="DIRTECNICA" query-param="DIRTECNICA"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="MATRICULA" query-param="MATRICULA"/>
			<with-param name="MEDIDOR" query-param="MEDIDOR"/>

		</call-query>
	</resource>
	<query id="getVspusuariosPagTodosPorCompaniaYCicloQuery"  useConfig="sysmandsunist">
