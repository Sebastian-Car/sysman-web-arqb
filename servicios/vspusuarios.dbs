	<query id="getVspusuariosTodosPorCodigorutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SP_USUARIO.CODIGORUTA, CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ) NOMBRECODIGORUTA , SP_USUARIO.CODIGOINTERNO, SP_USUARIO.ANO, SP_USUARIO.PERIODO FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND SP_USUARIO.CODIGORUTA =:CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRECODIGORUTA":"$NOMBRECODIGORUTA","CODIGOINTERNO":"$CODIGOINTERNO","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO"}]}}		</result>
