<data name="familiares" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getFamiliaresPagPorCompaniaYIdQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PERSONAL.COMPANIA, PERSONAL.SUCURSAL, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, FAMILIARES.IDENTIFICACION, FAMILIARES.NOMBRE, FAMILIARES.APELLIDO1, PARENTESCO.DESCRIPCION PARENTESCO  FROM FAMILIARES INNER JOIN PERSONAL ON PERSONAL.COMPANIA = FAMILIARES.COMPANIA AND PERSONAL.ID_DE_EMPLEADO = FAMILIARES.ID_DE_EMPLEADO INNER JOIN PARENTESCO ON PARENTESCO.COMPANIA = FAMILIARES.COMPANIA AND PARENTESCO.PARENTESCO = FAMILIARES.PARENTESCO WHERE FAMILIARES.COMPANIA = :COMPANIA AND FAMILIARES.ID_DE_EMPLEADO = CASE (:ESTADO) WHEN '1' THEN TO_NUMBER(:IDEMPLEADO) ELSE FAMILIARES.ID_DE_EMPLEADO END) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END)  LIKE UPPER(:IDENTIFICACION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN APELLIDO1 IS NULL THEN ' ' ELSE UPPER(APELLIDO1) END)  LIKE UPPER( '%' || :APELLIDO1 || '%')  AND (CASE WHEN PARENTESCO IS NULL THEN ' ' ELSE UPPER(PARENTESCO) END)  LIKE UPPER(:PARENTESCO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","NUMERO_DCTO":"$NUMERO_DCTO","NOMBRECOMPLETO":"$NOMBRECOMPLETO","IDENTIFICACION":"$IDENTIFICACION","NOMBRE":"$NOMBRE","APELLIDO1":"$APELLIDO1","PARENTESCO":"$PARENTESCO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="IDEMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="APELLIDO1" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="familiares/porcompaniayid/pag">
		<call-query href="getFamiliaresPagPorCompaniaYIdQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="IDEMPLEADO" query-param="IDEMPLEADO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="APELLIDO1" query-param="APELLIDO1"/>
			<with-param name="PARENTESCO" query-param="PARENTESCO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFamiliaresNumPorCompaniaYIdQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PERSONAL.COMPANIA, PERSONAL.SUCURSAL, PERSONAL.NUMERO_DCTO, PERSONAL.NOMBRECOMPLETO, FAMILIARES.IDENTIFICACION, FAMILIARES.NOMBRE, FAMILIARES.APELLIDO1, PARENTESCO.DESCRIPCION PARENTESCO  FROM FAMILIARES INNER JOIN PERSONAL ON PERSONAL.COMPANIA = FAMILIARES.COMPANIA AND PERSONAL.ID_DE_EMPLEADO = FAMILIARES.ID_DE_EMPLEADO INNER JOIN PARENTESCO ON PARENTESCO.COMPANIA = FAMILIARES.COMPANIA AND PARENTESCO.PARENTESCO = FAMILIARES.PARENTESCO WHERE FAMILIARES.COMPANIA = :COMPANIA AND FAMILIARES.ID_DE_EMPLEADO = CASE (:ESTADO) WHEN '1' THEN TO_NUMBER(:IDEMPLEADO) ELSE FAMILIARES.ID_DE_EMPLEADO END) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER(:SUCURSAL || '%')  AND (CASE WHEN NUMERO_DCTO IS NULL THEN ' ' ELSE UPPER(NUMERO_DCTO) END)  LIKE UPPER(:NUMERO_DCTO || '%')  AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END)  LIKE UPPER( '%' || :NOMBRECOMPLETO || '%')  AND (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END)  LIKE UPPER(:IDENTIFICACION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN APELLIDO1 IS NULL THEN ' ' ELSE UPPER(APELLIDO1) END)  LIKE UPPER( '%' || :APELLIDO1 || '%')  AND (CASE WHEN PARENTESCO IS NULL THEN ' ' ELSE UPPER(PARENTESCO) END)  LIKE UPPER(:PARENTESCO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="IDEMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="APELLIDO1" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="familiares/porcompaniayid/num">
		<call-query href="getFamiliaresNumPorCompaniaYIdQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="IDEMPLEADO" query-param="IDEMPLEADO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="NOMBRECOMPLETO" query-param="NOMBRECOMPLETO"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="APELLIDO1" query-param="APELLIDO1"/>
			<with-param name="PARENTESCO" query-param="PARENTESCO"/>

		</call-query>
	</resource>
	<query id="getFamiliaresPagIdenNomPorCompaniaIdentQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  F.COMPANIA, F.DCTO_IDENTIDAD, F.IDENTIFICACION, F.SUCURSAL, F.DCTO_EMPLEADO, F.SUCURSAL_EMPLEADO, F.NOMBRE,(CASE F.INSCRIBIR WHEN 0 THEN 'false' ELSE 'true' END) INSCRIBIR, F.PARENTESCO, P.DESCRIPCION , TD.DESCRIPCION DOCUMENTO  FROM FAMILIARES F LEFT JOIN TIPOS_DOCUMENTOS TD ON F.COMPANIA = TD.COMPANIA AND F.DCTO_IDENTIDAD = TD.DCTO_IDENTIDAD INNER JOIN PARENTESCO P ON F.COMPANIA = P.COMPANIA AND F.PARENTESCO = P.PARENTESCO WHERE F.COMPANIA = :COMPANIA AND F.DCTO_EMPLEADO = :DCTO_EMPLEADO AND F.SUCURSAL_EMPLEADO = :SUCURSAL_EMPLEADO) WHERE (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END)  LIKE UPPER( '%' || :IDENTIFICACION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN INSCRIBIR IS NULL THEN ' ' ELSE UPPER(INSCRIBIR) END)  LIKE UPPER( '%' || :INSCRIBIR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END)  LIKE UPPER( '%' || :DOCUMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","IDENTIFICACION":"$IDENTIFICACION","SUCURSAL":"$SUCURSAL","DCTO_EMPLEADO":"$DCTO_EMPLEADO","SUCURSAL_EMPLEADO":"$SUCURSAL_EMPLEADO","NOMBRE":"$NOMBRE","INSCRIBIR":"$INSCRIBIR(type:boolean)","PARENTESCO":"$PARENTESCO","DESCRIPCION":"$DESCRIPCION","DOCUMENTO":"$DOCUMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="INSCRIBIR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="familiares/idennomporcompaniaident/pag">
		<call-query href="getFamiliaresPagIdenNomPorCompaniaIdentQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DCTO_EMPLEADO" query-param="DCTO_EMPLEADO"/>
			<with-param name="SUCURSAL_EMPLEADO" query-param="SUCURSAL_EMPLEADO"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="INSCRIBIR" query-param="INSCRIBIR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFamiliaresNumIdenNomPorCompaniaIdentQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  F.COMPANIA, F.DCTO_IDENTIDAD, F.IDENTIFICACION, F.SUCURSAL, F.DCTO_EMPLEADO, F.SUCURSAL_EMPLEADO, F.NOMBRE,(CASE F.INSCRIBIR WHEN 0 THEN 'false' ELSE 'true' END) INSCRIBIR, F.PARENTESCO, P.DESCRIPCION , TD.DESCRIPCION DOCUMENTO  FROM FAMILIARES F LEFT JOIN TIPOS_DOCUMENTOS TD ON F.COMPANIA = TD.COMPANIA AND F.DCTO_IDENTIDAD = TD.DCTO_IDENTIDAD INNER JOIN PARENTESCO P ON F.COMPANIA = P.COMPANIA AND F.PARENTESCO = P.PARENTESCO WHERE F.COMPANIA = :COMPANIA AND F.DCTO_EMPLEADO = :DCTO_EMPLEADO AND F.SUCURSAL_EMPLEADO = :SUCURSAL_EMPLEADO) WHERE (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END)  LIKE UPPER( '%' || :IDENTIFICACION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN INSCRIBIR IS NULL THEN ' ' ELSE UPPER(INSCRIBIR) END)  LIKE UPPER( '%' || :INSCRIBIR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END)  LIKE UPPER( '%' || :DOCUMENTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="INSCRIBIR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="familiares/idennomporcompaniaident/num">
		<call-query href="getFamiliaresNumIdenNomPorCompaniaIdentQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DCTO_EMPLEADO" query-param="DCTO_EMPLEADO"/>
			<with-param name="SUCURSAL_EMPLEADO" query-param="SUCURSAL_EMPLEADO"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="INSCRIBIR" query-param="INSCRIBIR"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DOCUMENTO" query-param="DOCUMENTO"/>

		</call-query>
	</resource>
	<query id="insertFamiliaresIdenNomPorCompaniaIdent" keyColumns="COMPANIA,DCTO_EMPLEADO,SUCURSAL_EMPLEADO,IDENTIFICACION,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FAMILIARES (COMPANIA, NOMBRE, PARENTESCO, DCTO_IDENTIDAD, IDENTIFICACION, DCTO_EMPLEADO, INSCRIBIR, SUCURSAL_EMPLEADO, SUCURSAL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NOMBRE, :PARENTESCO, :DCTO_IDENTIDAD, :IDENTIFICACION, :DCTO_EMPLEADO, :INSCRIBIR, :SUCURSAL_EMPLEADO, :SUCURSAL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DCTO_EMPLEADO":"$DCTO_EMPLEADO","KEY_SUCURSAL_EMPLEADO":"$SUCURSAL_EMPLEADO","KEY_IDENTIFICACION":"$IDENTIFICACION","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>
		<param defaultValue="" name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="IDENTIFICACION" sqlType="STRING"/>
		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="0" name="INSCRIBIR" sqlType="STRING"/>
		<param name="SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="familiares/idennomporcompaniaident">
		<call-query href="insertFamiliaresIdenNomPorCompaniaIdent">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PARENTESCO" query-param="PARENTESCO"/>
			<with-param name="DCTO_IDENTIDAD" query-param="DCTO_IDENTIDAD"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="DCTO_EMPLEADO" query-param="DCTO_EMPLEADO"/>
			<with-param name="INSCRIBIR" query-param="INSCRIBIR"/>
			<with-param name="SUCURSAL_EMPLEADO" query-param="SUCURSAL_EMPLEADO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="updateFamiliaresIdenNomPorCompaniaIdent" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FAMILIARES SET DCTO_IDENTIDAD=:DCTO_IDENTIDAD, NOMBRE=:NOMBRE, PARENTESCO=:PARENTESCO, IDENTIFICACION=:IDENTIFICACION, INSCRIBIR=:INSCRIBIR, SUCURSAL=:SUCURSAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FAMILIARES.COMPANIA= :KEY_COMPANIA AND FAMILIARES.DCTO_EMPLEADO= :KEY_DCTO_EMPLEADO AND FAMILIARES.SUCURSAL_EMPLEADO= :KEY_SUCURSAL_EMPLEADO AND FAMILIARES.IDENTIFICACION= :KEY_IDENTIFICACION AND FAMILIARES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="INSCRIBIR" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_IDENTIFICACION" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="familiares/idennomporcompaniaident">
		<call-query href="updateFamiliaresIdenNomPorCompaniaIdent">
			<with-param name="DCTO_IDENTIDAD" query-param="DCTO_IDENTIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PARENTESCO" query-param="PARENTESCO"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="INSCRIBIR" query-param="INSCRIBIR"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DCTO_EMPLEADO" query-param="KEY_DCTO_EMPLEADO"/>
			<with-param name="KEY_SUCURSAL_EMPLEADO" query-param="KEY_SUCURSAL_EMPLEADO"/>
			<with-param name="KEY_IDENTIFICACION" query-param="KEY_IDENTIFICACION"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getFamiliaresIdenNomPorCompaniaIdentQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IDENTIFICACION, NOMBRE,(CASE INSCRIBIR WHEN 0 THEN 'false' ELSE 'true' END) INSCRIBIR FROM FAMILIARES</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDENTIFICACION":"$IDENTIFICACION","NOMBRE":"$NOMBRE","INSCRIBIR":"$INSCRIBIR(type:boolean)"}]}}		</result>
 
	</query>
	<resource method="GET" path="familiares/idennomporcompaniaident">
		<call-query href="getFamiliaresIdenNomPorCompaniaIdentQuery">
 
		</call-query>
	</resource>
	<query id="deleteFamiliaresFamiliaresIdenNomPorCompaniaIdent"  useConfig="sysmandsunist">
		<sql>SELECT  F.COMPANIA, F.DCTO_IDENTIDAD, F.IDENTIFICACION, F.NOMBRE,(CASE F.INSCRIBIR WHEN 0 THEN 'false' ELSE 'true' END) INSCRIBIR, F.PARENTESCO, P.DESCRIPCION  FROM FAMILIARES F INNER JOIN PARENTESCO P ON F.COMPANIA = P.COMPANIA AND F.PARENTESCO = P.PARENTESCO WHERE F.COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","IDENTIFICACION":"$IDENTIFICACION","NOMBRE":"$NOMBRE","INSCRIBIR":"$INSCRIBIR(type:boolean)","PARENTESCO":"$PARENTESCO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="familiares/familiaresidennomporcompaniaident">
		<call-query href="deleteFamiliaresFamiliaresIdenNomPorCompaniaIdent">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertFamiliares" keyColumns="COMPANIA,DCTO_EMPLEADO,SUCURSAL_EMPLEADO,IDENTIFICACION,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO FAMILIARES (COMPANIA, DCTO_EMPLEADO, SUCURSAL, SUCURSAL_EMPLEADO, SALUD, CAJAS_COMP, DCTO_IDENTIDAD, IDENTIFICACION, NOMBRE, SEXO, PARENTESCO, FECHANCTO, OCUPACION, FECHA_AFIL_BEN, FECHA_RET_BEN, ESTADO_ACTUAL, OBSERVACIONES, TELEFONO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :DCTO_EMPLEADO, :SUCURSAL, :SUCURSAL_EMPLEADO, :SALUD, :CAJAS_COMP, :DCTO_IDENTIDAD, :IDENTIFICACION, :NOMBRE, :SEXO, :PARENTESCO, TO_DATE(:FECHANCTO,'DD/MM/YYYY HH24:MI:SS'), :OCUPACION, TO_DATE(:FECHA_AFIL_BEN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_RET_BEN,'DD/MM/YYYY HH24:MI:SS'), :ESTADO_ACTUAL, :OBSERVACIONES, :TELEFONO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_DCTO_EMPLEADO":"$DCTO_EMPLEADO","KEY_SUCURSAL_EMPLEADO":"$SUCURSAL_EMPLEADO","KEY_IDENTIFICACION":"$IDENTIFICACION","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param name="SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="0" name="SALUD" sqlType="STRING"/>
		<param defaultValue="0" name="CAJAS_COMP" sqlType="STRING"/>
		<param name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="SEXO" sqlType="STRING"/>
