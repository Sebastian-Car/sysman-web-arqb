	<query id="getFamiliaresNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT FAMILIARES.COMPANIA, FAMILIARES.DCTO_EMPLEADO, FAMILIARES.SUCURSAL_EMPLEADO, FAMILIARES.IDENTIFICACION, FAMILIARES.SUCURSAL, NAT_DATOS_PERSONALES.CODIGO ID_DE_EMPLEADO, CONCAT(NAT_DATOS_PERSONALES.APELLIDO1,CONCAT(' ',CONCAT(NAT_DATOS_PERSONALES.APELLIDO2,CONCAT(' ',NAT_DATOS_PERSONALES.NOMBRES ) ) ) ) NOMBRECOMPLETO, FAMILIARES.NOMBRE, FAMILIARES.APELLIDO1, PARENTESCO.DESCRIPCION PARENTESCO FROM FAMILIARES INNER JOIN NAT_DATOS_PERSONALES ON NAT_DATOS_PERSONALES.COMPANIA = FAMILIARES.COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO = FAMILIARES.DCTO_EMPLEADO AND NAT_DATOS_PERSONALES.SUCURSAL = FAMILIARES.SUCURSAL_EMPLEADO LEFT JOIN PARENTESCO ON PARENTESCO.COMPANIA = FAMILIARES.COMPANIA AND PARENTESCO.PARENTESCO = FAMILIARES.PARENTESCO WHERE FAMILIARES.COMPANIA =:COMPANIA AND FAMILIARES.DCTO_EMPLEADO = CASE (:ESTADO ) WHEN '1' THEN :DCTOEMPLEADO ELSE FAMILIARES.DCTO_EMPLEADO END AND FAMILIARES.SUCURSAL_EMPLEADO = CASE (:ESTADO ) WHEN '1' THEN :SUCURSAL_EMPLEADO ELSE FAMILIARES.SUCURSAL_EMPLEADO END AND NAT_DATOS_PERSONALES.NUMERO_DCTO NOT IN ('999999999999999999')) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN DCTO_EMPLEADO IS NULL THEN ' ' ELSE UPPER(DCTO_EMPLEADO) END) LIKE UPPER(CONCAT(:DCTO_EMPLEADO, '%')) AND (CASE WHEN SUCURSAL_EMPLEADO IS NULL THEN ' ' ELSE UPPER(SUCURSAL_EMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:SUCURSAL_EMPLEADO), '%')) AND (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END) LIKE UPPER(CONCAT(:IDENTIFICACION, '%')) AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END) LIKE UPPER(CONCAT(:SUCURSAL, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_DE_EMPLEADO), '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN APELLIDO1 IS NULL THEN ' ' ELSE UPPER(APELLIDO1) END) LIKE UPPER(CONCAT(CONCAT('%',:APELLIDO1), '%')) AND (CASE WHEN PARENTESCO IS NULL THEN ' ' ELSE UPPER(PARENTESCO) END) LIKE UPPER(CONCAT(CONCAT('%',:PARENTESCO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="DCTOEMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="APELLIDO1" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>

	</query>
