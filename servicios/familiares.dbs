	<query id="updateFamiliares" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE FAMILIARES SET DCTO_EMPLEADO=:DCTO_EMPLEADO, SUCURSAL=:SUCURSAL, SALUD=:SALUD, CAJAS_COMP=:CAJAS_COMP, DCTO_IDENTIDAD=:DCTO_IDENTIDAD, IDENTIFICACION=:IDENTIFICACION, NOMBRE=:NOMBRE, SEXO=:SEXO, PARENTESCO=:PARENTESCO, FECHANCTO=TO_DATE(:FECHANCTO,'DD/MM/YYYY HH24:MI:SS'), OCUPACION=:OCUPACION, FECHA_AFIL_BEN=TO_DATE(:FECHA_AFIL_BEN,'DD/MM/YYYY HH24:MI:SS'), FECHA_RET_BEN=TO_DATE(:FECHA_RET_BEN,'DD/MM/YYYY HH24:MI:SS'), ESTADO_ACTUAL=:ESTADO_ACTUAL, OBSERVACIONES=:OBSERVACIONES, TELEFONO=:TELEFONO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE FAMILIARES.COMPANIA= :KEY_COMPANIA AND FAMILIARES.DCTO_EMPLEADO= :KEY_DCTO_EMPLEADO AND FAMILIARES.SUCURSAL_EMPLEADO= :KEY_SUCURSAL_EMPLEADO AND FAMILIARES.IDENTIFICACION= :KEY_IDENTIFICACION AND FAMILIARES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="SALUD" sqlType="STRING"/>
		<param name="CAJAS_COMP" sqlType="STRING"/>
		<param name="DCTO_IDENTIDAD" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="SEXO" sqlType="STRING"/>
