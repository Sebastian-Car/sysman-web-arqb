		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="familiares/idennomporcompania">
		<call-query href="deleteFamiliaresIdenNomPorCompania">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_DCTO_EMPLEADO" query-param="KEY_DCTO_EMPLEADO"/>
			<with-param name="KEY_SUCURSAL_EMPLEADO" query-param="KEY_SUCURSAL_EMPLEADO"/>
			<with-param name="KEY_IDENTIFICACION" query-param="KEY_IDENTIFICACION"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getFamiliaresPagIdNombresFamPorDctoempQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT IDENTIFICACION, CONCAT(NOMBRE,CONCAT(' ',CONCAT(APELLIDO1,CONCAT(' ',APELLIDO2) ) ) ) NOMBRES, SUCURSAL FROM FAMILIARES WHERE FAMILIARES.COMPANIA =:COMPANIA AND FAMILIARES.DCTO_EMPLEADO =:DCTO_EMPLEADO) INI WHERE (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END) LIKE UPPER(CONCAT(:IDENTIFICACION, '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"IDENTIFICACION":"$IDENTIFICACION","NOMBRES":"$NOMBRES","SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="familiares/idnombresfampordctoemp/pag">
