	<query id="deleteFamiliaresIdenNomPorCompania" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM FAMILIARES WHERE FAMILIARES.COMPANIA= :KEY_COMPANIA AND FAMILIARES.DCTO_EMPLEADO= :KEY_DCTO_EMPLEADO AND FAMILIARES.SUCURSAL_EMPLEADO= :KEY_SUCURSAL_EMPLEADO AND FAMILIARES.IDENTIFICACION= :KEY_IDENTIFICACION AND FAMILIARES.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
