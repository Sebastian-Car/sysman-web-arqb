			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getFamiliaresNumIdNombresFamPorDctoempQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT IDENTIFICACION, CONCAT(NOMBRE,CONCAT(' ',CONCAT(APELLIDO1,CONCAT(' ',APELLIDO2) ) ) ) NOMBRES, SUCURSAL FROM FAMILIARES WHERE FAMILIARES.COMPANIA =:COMPANIA AND FAMILIARES.DCTO_EMPLEADO =:DCTO_EMPLEADO) INI WHERE (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END) LIKE UPPER(CONCAT(:IDENTIFICACION, '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>

	</query>
	<resource method="GET" path="familiares/idnombresfampordctoemp/num">
