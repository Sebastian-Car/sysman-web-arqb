	<query id="getFamiliaresRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FAMILIARES.COMPANIA, FAMILIARES.DCTO_EMPLEADO, FAMILIARES.SUCURSAL_EMPLEADO, FAMILIARES.IDENTIFICACION, FAMILIARES.SUCURSAL,(CASE FAMILIARES.SALUD WHEN 0 THEN 'false' ELSE 'true' END) SALUD,(CASE FAMILIARES.CAJAS_COMP WHEN 0 THEN 'false' ELSE 'true' END) CAJAS_COMP, FAMILIARES.DCTO_IDENTIDAD, FAMILIARES.NOMBRE, NAT_DATOS_PERSONALES.NOMBRES, FAMILIARES.SEXO, FAMILIARES.PARENTESCO,(TO_CHAR(FAMILIARES.FECHANCTO,'DD/MM/YYYY HH24:MI:SS')) FECHANCTO, FAMILIARES.OCUPACION,(TO_CHAR(FAMILIARES.FECHA_AFIL_BEN,'DD/MM/YYYY HH24:MI:SS')) FECHA_AFIL_BEN,(TO_CHAR(FAMILIARES.FECHA_RET_BEN,'DD/MM/YYYY HH24:MI:SS')) FECHA_RET_BEN, FAMILIARES.ESTADO_ACTUAL, FAMILIARES.OBSERVACIONES , FAMILIARES.TELEFONO  FROM FAMILIARES INNER JOIN NAT_DATOS_PERSONALES ON NAT_DATOS_PERSONALES.COMPANIA = FAMILIARES.COMPANIA AND NAT_DATOS_PERSONALES.NUMERO_DCTO = FAMILIARES.DCTO_EMPLEADO AND NAT_DATOS_PERSONALES.SUCURSAL = FAMILIARES.SUCURSAL_EMPLEADO LEFT JOIN PARENTESCO ON PARENTESCO.COMPANIA = FAMILIARES.COMPANIA AND PARENTESCO.PARENTESCO = FAMILIARES.PARENTESCO WHERE FAMILIARES.COMPANIA= :KEY_COMPANIA AND FAMILIARES.DCTO_EMPLEADO= :KEY_DCTO_EMPLEADO AND FAMILIARES.SUCURSAL_EMPLEADO= :KEY_SUCURSAL_EMPLEADO AND FAMILIARES.IDENTIFICACION= :KEY_IDENTIFICACION AND FAMILIARES.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DCTO_EMPLEADO":"$DCTO_EMPLEADO","SUCURSAL_EMPLEADO":"$SUCURSAL_EMPLEADO","IDENTIFICACION":"$IDENTIFICACION","SUCURSAL":"$SUCURSAL","SALUD":"$SALUD(type:boolean)","CAJAS_COMP":"$CAJAS_COMP(type:boolean)","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","NOMBRE":"$NOMBRE","NOMBRES":"$NOMBRES","SEXO":"$SEXO","PARENTESCO":"$PARENTESCO","FECHANCTO":"$FECHANCTO","OCUPACION":"$OCUPACION","FECHA_AFIL_BEN":"$FECHA_AFIL_BEN","FECHA_RET_BEN":"$FECHA_RET_BEN","ESTADO_ACTUAL":"$ESTADO_ACTUAL","OBSERVACIONES":"$OBSERVACIONES","TELEFONO":"$TELEFONO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_IDENTIFICACION" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
