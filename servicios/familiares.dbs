	</resource>
	<query id="getFamiliaresPagFamiliaresNoInscritosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  F.COMPANIA, F.DCTO_IDENTIDAD, F.IDENTIFICACION, F.SUCURSAL, F.DCTO_EMPLEADO, F.SUCURSAL_EMPLEADO, F.NOMBRE,(CASE F.INSCRIBIR WHEN 0 THEN 'false' ELSE 'true' END) INSCRIBIR, F.PARENTESCO, P.DESCRIPCION , TD.DESCRIPCION DOCUMENTO  FROM FAMILIARES F LEFT JOIN TIPOS_DOCUMENTOS TD ON F.COMPANIA = TD.COMPANIA AND F.DCTO_IDENTIDAD = TD.DCTO_IDENTIDAD INNER JOIN PARENTESCO P ON F.COMPANIA = P.COMPANIA AND F.PARENTESCO = P.PARENTESCO LEFT JOIN (SELECT * FROM NAT_ACTIVIDADESINSCRITOS WHERE COMPANIA = :COMPANIA AND TIPOEVENTO = :TIPOEVENTO AND IDEVENTO = :IDEVENTO ) I ON F.COMPANIA = I.COMPANIA AND F.IDENTIFICACION = I.NUMERO_DCTO AND F.SUCURSAL = I.SUCURSAL WHERE F.COMPANIA = :COMPANIA AND F.DCTO_EMPLEADO = :DCTO_EMPLEADO AND F.SUCURSAL_EMPLEADO = :SUCURSAL_EMPLEADO AND I.COMPANIA IS NULL) WHERE (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END)  LIKE UPPER( '%' || :IDENTIFICACION || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER(:NOMBRE || '%')  AND (CASE WHEN INSCRIBIR IS NULL THEN ' ' ELSE UPPER(INSCRIBIR) END)  LIKE UPPER( '%' || :INSCRIBIR || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER(:DESCRIPCION || '%')  AND (CASE WHEN DOCUMENTO IS NULL THEN ' ' ELSE UPPER(DOCUMENTO) END)  LIKE UPPER( '%' || :DOCUMENTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","DCTO_IDENTIDAD":"$DCTO_IDENTIDAD","IDENTIFICACION":"$IDENTIFICACION","SUCURSAL":"$SUCURSAL","DCTO_EMPLEADO":"$DCTO_EMPLEADO","SUCURSAL_EMPLEADO":"$SUCURSAL_EMPLEADO","NOMBRE":"$NOMBRE","INSCRIBIR":"$INSCRIBIR(type:boolean)","PARENTESCO":"$PARENTESCO","DESCRIPCION":"$DESCRIPCION","DOCUMENTO":"$DOCUMENTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="DCTO_EMPLEADO" sqlType="STRING"/>
		<param name="SUCURSAL_EMPLEADO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="INSCRIBIR" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DOCUMENTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="familiares/familiaresnoinscritos/pag">
		<call-query href="getFamiliaresPagFamiliaresNoInscritosQuery">
