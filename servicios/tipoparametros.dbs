<data name="tipoparametros" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTipoparametrosTodosPorNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO TIPOPARAMETRO, NOMBRE NOMPARAMETRO  FROM TIPOPARAMETRO ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOPARAMETRO":"$TIPOPARAMETRO","NOMPARAMETRO":"$NOMPARAMETRO"}]}}		</result>
 
	</query>
	<resource method="GET" path="tipoparametros/todospornombre">
		<call-query href="getTipoparametrosTodosPorNombreQuery">
 
		</call-query>
	</resource>
	<query id="getTipoparametrosCodynombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, NOMBRE  FROM TIPOPARAMETRO ORDER BY NOMBRE</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="tipoparametros/codynombre">
		<call-query href="getTipoparametrosCodynombreQuery">
 
		</call-query>
	</resource>

</data>