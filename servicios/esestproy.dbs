	<query id="deleteEsestproy" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM ES_EST_PROY WHERE ES_EST_PROY.COMPANIA= :KEY_COMPANIA AND ES_EST_PROY.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_EST_PROY.COD_PROY= :KEY_COD_PROY AND ES_EST_PROY.T_COMPONENTE= :KEY_T_COMPONENTE AND ES_EST_PROY.COMPONENTE= :KEY_COMPONENTE AND ES_EST_PROY.ACTIVIDAD= :KEY_ACTIVIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_COD_PROY" sqlType="STRING"/>
