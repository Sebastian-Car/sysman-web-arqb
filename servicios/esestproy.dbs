		</call-query>
	</resource>
	<query id="getEsestproyPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  ES_EST_PROY.COMPANIA, ES_EST_PROY.COD_PROY, ES_EST_PROY.COD_ESTUDIO, ES_EST_PROY.T_COMPONENTE, ES_EST_PROY.COMPONENTE, ES_EST_PROY.ACTIVIDAD, PROYECTOS.NOMBREPROYECTO, BP_TIPOSCOMPONENTES.DESCRIPCION TIPO_COMPONENTE, COMPONENTES.NOMBRECOMPONENTE NOMCOMPONENTE, COMPONENTES_ACTIVIDADES.NOMBREACTIVIDAD  FROM ES_EST_PROY INNER JOIN PROYECTOS ON (ES_EST_PROY.COMPANIA = PROYECTOS.COMPANIA) AND (ES_EST_PROY.COD_PROY = PROYECTOS.CODIGO) INNER JOIN BP_TIPOSCOMPONENTES ON (ES_EST_PROY.COMPANIA = BP_TIPOSCOMPONENTES.COMPANIA) AND (ES_EST_PROY.T_COMPONENTE = BP_TIPOSCOMPONENTES.CODIGO) INNER JOIN COMPONENTES ON (ES_EST_PROY.COMPANIA = COMPONENTES.COMPANIA) AND (ES_EST_PROY.COD_PROY = COMPONENTES.CODIGOPROYECTO) AND (ES_EST_PROY.COMPONENTE = COMPONENTES.CODIGO) AND (ES_EST_PROY.T_COMPONENTE = COMPONENTES.TIPOCOMPONENTE) INNER JOIN COMPONENTES_ACTIVIDADES ON (ES_EST_PROY.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA) AND (ES_EST_PROY.COD_PROY = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO) AND (ES_EST_PROY.COMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE) AND (ES_EST_PROY.T_COMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE) AND (ES_EST_PROY.ACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD) WHERE ES_EST_PROY.COMPANIA = :COMPANIA AND ES_EST_PROY.COD_ESTUDIO = :COD_ESTUDIO) WHERE (CASE WHEN COD_PROY IS NULL THEN ' ' ELSE UPPER(COD_PROY) END)  LIKE UPPER(:COD_PROY || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%')  AND (CASE WHEN TIPO_COMPONENTE IS NULL THEN ' ' ELSE UPPER(TIPO_COMPONENTE) END)  LIKE UPPER( '%' || :TIPO_COMPONENTE || '%')  AND (CASE WHEN NOMCOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMCOMPONENTE) END)  LIKE UPPER( '%' || :NOMCOMPONENTE || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PROY":"$COD_PROY","COD_ESTUDIO":"$COD_ESTUDIO","T_COMPONENTE":"$T_COMPONENTE","COMPONENTE":"$COMPONENTE","ACTIVIDAD":"$ACTIVIDAD","NOMBREPROYECTO":"$NOMBREPROYECTO","TIPO_COMPONENTE":"$TIPO_COMPONENTE","NOMCOMPONENTE":"$NOMCOMPONENTE","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_PROY" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="TIPO_COMPONENTE" sqlType="STRING"/>
		<param name="NOMCOMPONENTE" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="esestproy">
		<call-query href="getEsestproyPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_PROY" query-param="COD_PROY"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="TIPO_COMPONENTE" query-param="TIPO_COMPONENTE"/>
			<with-param name="NOMCOMPONENTE" query-param="NOMCOMPONENTE"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEsestproyNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  ES_EST_PROY.COMPANIA, ES_EST_PROY.COD_PROY, ES_EST_PROY.COD_ESTUDIO, ES_EST_PROY.T_COMPONENTE, ES_EST_PROY.COMPONENTE, ES_EST_PROY.ACTIVIDAD, PROYECTOS.NOMBREPROYECTO, BP_TIPOSCOMPONENTES.DESCRIPCION TIPO_COMPONENTE, COMPONENTES.NOMBRECOMPONENTE NOMCOMPONENTE, COMPONENTES_ACTIVIDADES.NOMBREACTIVIDAD  FROM ES_EST_PROY INNER JOIN PROYECTOS ON (ES_EST_PROY.COMPANIA = PROYECTOS.COMPANIA) AND (ES_EST_PROY.COD_PROY = PROYECTOS.CODIGO) INNER JOIN BP_TIPOSCOMPONENTES ON (ES_EST_PROY.COMPANIA = BP_TIPOSCOMPONENTES.COMPANIA) AND (ES_EST_PROY.T_COMPONENTE = BP_TIPOSCOMPONENTES.CODIGO) INNER JOIN COMPONENTES ON (ES_EST_PROY.COMPANIA = COMPONENTES.COMPANIA) AND (ES_EST_PROY.COD_PROY = COMPONENTES.CODIGOPROYECTO) AND (ES_EST_PROY.COMPONENTE = COMPONENTES.CODIGO) AND (ES_EST_PROY.T_COMPONENTE = COMPONENTES.TIPOCOMPONENTE) INNER JOIN COMPONENTES_ACTIVIDADES ON (ES_EST_PROY.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA) AND (ES_EST_PROY.COD_PROY = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO) AND (ES_EST_PROY.COMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE) AND (ES_EST_PROY.T_COMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE) AND (ES_EST_PROY.ACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD) WHERE ES_EST_PROY.COMPANIA = :COMPANIA AND ES_EST_PROY.COD_ESTUDIO = :COD_ESTUDIO) WHERE (CASE WHEN COD_PROY IS NULL THEN ' ' ELSE UPPER(COD_PROY) END)  LIKE UPPER(:COD_PROY || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%')  AND (CASE WHEN TIPO_COMPONENTE IS NULL THEN ' ' ELSE UPPER(TIPO_COMPONENTE) END)  LIKE UPPER( '%' || :TIPO_COMPONENTE || '%')  AND (CASE WHEN NOMCOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMCOMPONENTE) END)  LIKE UPPER( '%' || :NOMCOMPONENTE || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="COD_PROY" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="TIPO_COMPONENTE" sqlType="STRING"/>
		<param name="NOMCOMPONENTE" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestproy/numero">
		<call-query href="getEsestproyNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>
			<with-param name="COD_PROY" query-param="COD_PROY"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="TIPO_COMPONENTE" query-param="TIPO_COMPONENTE"/>
			<with-param name="NOMCOMPONENTE" query-param="NOMCOMPONENTE"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>

		</call-query>
	</resource>
	<query id="getEsestproyRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  ES_EST_PROY.COMPANIA, ES_EST_PROY.COD_PROY, ES_EST_PROY.T_COMPONENTE, ES_EST_PROY.COMPONENTE, ES_EST_PROY.ACTIVIDAD, ES_EST_PROY.CANTIDAD, ES_EST_PROY.COSTOUNITARIO, ES_EST_PROY.COSTOTOTAL, ES_EST_PROY.VALORPROGRAMADO, ES_EST_PROY.VALOREJECUTADO, ES_EST_PROY.VIGENCIA, ES_EST_PROY.PORCEJECUTADO, ES_EST_PROY.VALOR_SOLICITADO_ACTIV, ES_EST_PROY.CANTIDAD_EJE, PR.NOMBREPROYECTO, BPT.DESCRIPCION NOMBRETIPO, C.NOMBRECOMPONENTE, COMACT.NOMBREACTIVIDAD, ES_EST_PROY.CREATED_BY,(TO_CHAR(ES_EST_PROY.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, ES_EST_PROY.MODIFIED_BY,(TO_CHAR(ES_EST_PROY.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM ES_EST_PROY INNER JOIN PROYECTOS PR ON (ES_EST_PROY.COMPANIA = PR.COMPANIA) AND (ES_EST_PROY.COD_PROY = PR.CODIGO) INNER JOIN BP_TIPOSCOMPONENTES BPT ON (ES_EST_PROY.COMPANIA = BPT.COMPANIA) AND (ES_EST_PROY.T_COMPONENTE = BPT.CODIGO) INNER JOIN COMPONENTES C ON (ES_EST_PROY.COMPANIA = C.COMPANIA) AND (ES_EST_PROY.COD_PROY = C.CODIGOPROYECTO) AND (ES_EST_PROY.COMPONENTE = C.CODIGO) AND (ES_EST_PROY.T_COMPONENTE = C.TIPOCOMPONENTE) INNER JOIN COMPONENTES_ACTIVIDADES COMACT ON (ES_EST_PROY.COMPANIA = COMACT.COMPANIA) AND (ES_EST_PROY.COD_PROY = COMACT.CODIGOPROYECTO) AND (ES_EST_PROY.COMPONENTE = COMACT.COMPONENTE) AND (ES_EST_PROY.T_COMPONENTE = COMACT.TIPOCOMPONENTE) AND (ES_EST_PROY.ACTIVIDAD = COMACT.ACTIVIDAD) WHERE ES_EST_PROY.COMPANIA= :KEY_COMPANIA AND ES_EST_PROY.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_EST_PROY.COD_PROY= :KEY_COD_PROY AND ES_EST_PROY.T_COMPONENTE= :KEY_T_COMPONENTE AND ES_EST_PROY.COMPONENTE= :KEY_COMPONENTE AND ES_EST_PROY.ACTIVIDAD= :KEY_ACTIVIDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","COD_PROY":"$COD_PROY","T_COMPONENTE":"$T_COMPONENTE","COMPONENTE":"$COMPONENTE","ACTIVIDAD":"$ACTIVIDAD","CANTIDAD":"$CANTIDAD","COSTOUNITARIO":"$COSTOUNITARIO","COSTOTOTAL":"$COSTOTOTAL","VALORPROGRAMADO":"$VALORPROGRAMADO","VALOREJECUTADO":"$VALOREJECUTADO","VIGENCIA":"$VIGENCIA(type:integer)","PORCEJECUTADO":"$PORCEJECUTADO","VALOR_SOLICITADO_ACTIV":"$VALOR_SOLICITADO_ACTIV","CANTIDAD_EJE":"$CANTIDAD_EJE","NOMBREPROYECTO":"$NOMBREPROYECTO","NOMBRETIPO":"$NOMBRETIPO","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_COD_ESTUDIO" sqlType="STRING"/>
		<param name="KEY_COD_PROY" sqlType="STRING"/>
		<param name="KEY_T_COMPONENTE" sqlType="STRING"/>
		<param name="KEY_COMPONENTE" sqlType="STRING"/>
		<param name="KEY_ACTIVIDAD" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestproy/data">
		<call-query href="getEsestproyRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_COD_ESTUDIO" query-param="KEY_COD_ESTUDIO"/>
			<with-param name="KEY_COD_PROY" query-param="KEY_COD_PROY"/>
			<with-param name="KEY_T_COMPONENTE" query-param="KEY_T_COMPONENTE"/>
			<with-param name="KEY_COMPONENTE" query-param="KEY_COMPONENTE"/>
