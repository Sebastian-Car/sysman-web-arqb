		</call-query>
	</resource>
	<query id="updateEsestproy" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE ES_EST_PROY SET COMPANIA=:COMPANIA, COD_PROY=:COD_PROY, COD_ESTUDIO=:COD_ESTUDIO, T_COMPONENTE=:T_COMPONENTE, COMPONENTE=:COMPONENTE, ACTIVIDAD=:ACTIVIDAD, CANTIDAD=:CANTIDAD, COSTOUNITARIO=:COSTOUNITARIO, COSTOTOTAL=:COSTOTOTAL, VALORPROGRAMADO=:VALORPROGRAMADO, VALOREJECUTADO=:VALOREJECUTADO, VIGENCIA=:VIGENCIA, PORCEJECUTADO=:PORCEJECUTADO, VALOR_SOLICITADO_ACTIV=:VALOR_SOLICITADO_ACTIV, CANTIDAD_EJE=:CANTIDAD_EJE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE ES_EST_PROY.COMPANIA= :KEY_COMPANIA AND ES_EST_PROY.COD_ESTUDIO= :KEY_COD_ESTUDIO AND ES_EST_PROY.COD_PROY= :KEY_COD_PROY AND ES_EST_PROY.T_COMPONENTE= :KEY_T_COMPONENTE AND ES_EST_PROY.COMPONENTE= :KEY_COMPONENTE AND ES_EST_PROY.ACTIVIDAD= :KEY_ACTIVIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

