	<query id="getEsestproyBuscarProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COD_PROY PROYECTO  FROM ES_EST_PROY WHERE COMPANIA = :COMPANIA AND COD_ESTUDIO =:COD_ESTUDIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PROYECTO":"$PROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="esestproy/buscarproyecto">
		<call-query href="getEsestproyBuscarProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_ESTUDIO" query-param="COD_ESTUDIO"/>

		</call-query>
	</resource>
	<query id="insertEsestproy" keyColumns="COMPANIA,COD_ESTUDIO,COD_PROY,T_COMPONENTE,COMPONENTE,ACTIVIDAD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO ES_EST_PROY (COMPANIA, COD_PROY, COD_ESTUDIO, T_COMPONENTE, COMPONENTE, ACTIVIDAD, CANTIDAD, COSTOUNITARIO, COSTOTOTAL, VALORPROGRAMADO, VALOREJECUTADO, VIGENCIA, PORCEJECUTADO, VALOR_SOLICITADO_ACTIV, CANTIDAD_EJE, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :COD_PROY, :COD_ESTUDIO, :T_COMPONENTE, :COMPONENTE, :ACTIVIDAD, :CANTIDAD, :COSTOUNITARIO, :COSTOTOTAL, :VALORPROGRAMADO, :VALOREJECUTADO, :VIGENCIA, :PORCEJECUTADO, :VALOR_SOLICITADO_ACTIV, :CANTIDAD_EJE, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_COD_ESTUDIO":"$COD_ESTUDIO","KEY_COD_PROY":"$COD_PROY","KEY_T_COMPONENTE":"$T_COMPONENTE","KEY_COMPONENTE":"$COMPONENTE","KEY_ACTIVIDAD":"$ACTIVIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PROY" sqlType="STRING"/>
		<param name="COD_ESTUDIO" sqlType="STRING"/>
		<param name="T_COMPONENTE" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="COSTOUNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="COSTOTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="VALORPROGRAMADO" sqlType="STRING"/>
		<param defaultValue="0" name="VALOREJECUTADO" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="PORCEJECUTADO" sqlType="STRING"/>
