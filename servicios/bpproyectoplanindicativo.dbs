			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpproyectoplanindicativoNumTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BP_PROYECTO_PLAN_INDICATIVO.PROYECTO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.CODIGOBPIM  FROM BP_PROYECTO_PLAN_INDICATIVO LEFT JOIN PROYECTOS ON (BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = PROYECTOS.CODIGO) AND (BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = PROYECTOS.COMPANIA) WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND PROYECTOS.DEPENDENCIA = :DEPENDENCIA ORDER BY BP_PROYECTO_PLAN_INDICATIVO.PROYECTO) WHERE (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END)  LIKE UPPER(:PROYECTO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="INTEGER"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectoplanindicativo/todosporcompania/num">
