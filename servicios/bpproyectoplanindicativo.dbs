	<query id="getBpproyectoplanindicativoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  BP_PROYECTO_PLAN_INDICATIVO.COMPANIA, BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P, BP_PROYECTO_PLAN_INDICATIVO.PROYECTO, BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE, BP_PROYECTO_PLAN_INDICATIVO.PONDERACION_META, BP_PROYECTO_PLAN_INDICATIVO.VALOR_PROGRAMADO_META, BP_PROYECTO_PLAN_INDICATIVO.VALOR_EJECUTADO_META, BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD, BP_PROYECTO_PLAN_INDICATIVO.CANTIDAD_PROGRAMADA_P, BP_PROYECTO_PLAN_INDICATIVO.CANTIDAD_EJECUTADA_P, BP_PROYECTO_PLAN_INDICATIVO.DESCRIPCION_META, BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE, COMPONENTES_ACTIVIDADES.NOMBREACTIVIDAD, COMPONENTES.NOMBRECOMPONENTE, BP_TIPOSCOMPONENTES.DESCRIPCION NOMBRETIPOCOMPONENTE  FROM ( (BP_PROYECTO_PLAN_INDICATIVO INNER JOIN COMPONENTES_ACTIVIDADES ON BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD ) INNER JOIN COMPONENTES ON COMPONENTES_ACTIVIDADES.COMPANIA = COMPONENTES.COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO = COMPONENTES.CODIGOPROYECTO AND COMPONENTES_ACTIVIDADES.COMPONENTE = COMPONENTES.CODIGO AND COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE = COMPONENTES.TIPOCOMPONENTE ) INNER JOIN BP_TIPOSCOMPONENTES ON COMPONENTES.COMPANIA = BP_TIPOSCOMPONENTES.COMPANIA AND COMPONENTES.TIPOCOMPONENTE = BP_TIPOSCOMPONENTES.CODIGO WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA= :COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = :CODIGOPROYECTO AND -1 = CASE WHEN :VIGENCIA &lt;&gt; 'TODAS' THEN CASE WHEN BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P=:VIGENCIA THEN -1 ELSE 0 END ELSE -1 END AND -1= CASE WHEN :PROGRAMA &lt;&gt; '99999999999' THEN CASE WHEN BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P LIKE CONCAT(:PROGRAMA,'%') THEN -1 ELSE 0 END ELSE -1 END ORDER BY VIGENCIA_META_P) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN ID_PLAN_P IS NULL THEN ' ' ELSE UPPER(ID_PLAN_P) END)  LIKE UPPER(:ID_PLAN_P || '%')  AND (CASE WHEN VIGENCIA_PLAN_P IS NULL THEN ' ' ELSE UPPER(VIGENCIA_PLAN_P) END)  LIKE UPPER(:VIGENCIA_PLAN_P || '%')  AND (CASE WHEN VIGENCIA_META_P IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META_P) END)  LIKE UPPER(:VIGENCIA_META_P || '%')  AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END)  LIKE UPPER(:PROYECTO || '%')  AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END)  LIKE UPPER(:COMPONENTE || '%')  AND (CASE WHEN PONDERACION_META IS NULL THEN ' ' ELSE UPPER(PONDERACION_META) END)  LIKE UPPER(:PONDERACION_META || '%')  AND (CASE WHEN VALOR_PROGRAMADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_PROGRAMADO_META) END)  LIKE UPPER(:VALOR_PROGRAMADO_META || '%')  AND (CASE WHEN VALOR_EJECUTADO_META IS NULL THEN ' ' ELSE UPPER(VALOR_EJECUTADO_META) END)  LIKE UPPER(:VALOR_EJECUTADO_META || '%')  AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END)  LIKE UPPER(:ACTIVIDAD || '%')  AND (CASE WHEN CANTIDAD_PROGRAMADA_P IS NULL THEN ' ' ELSE UPPER(CANTIDAD_PROGRAMADA_P) END)  LIKE UPPER(:CANTIDAD_PROGRAMADA_P || '%')  AND (CASE WHEN CANTIDAD_EJECUTADA_P IS NULL THEN ' ' ELSE UPPER(CANTIDAD_EJECUTADA_P) END)  LIKE UPPER(:CANTIDAD_EJECUTADA_P || '%')  AND (CASE WHEN DESCRIPCION_META IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_META) END)  LIKE UPPER( '%' || :DESCRIPCION_META || '%')  AND (CASE WHEN TIPOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPONENTE) END)  LIKE UPPER(:TIPOCOMPONENTE || '%')  AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END)  LIKE UPPER( '%' || :NOMBREACTIVIDAD || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%')  AND (CASE WHEN NOMBRETIPOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRETIPOCOMPONENTE) END)  LIKE UPPER(:NOMBRETIPOCOMPONENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_PLAN_P":"$ID_PLAN_P","VIGENCIA_PLAN_P":"$VIGENCIA_PLAN_P(type:integer)","VIGENCIA_META_P":"$VIGENCIA_META_P(type:integer)","PROYECTO":"$PROYECTO","COMPONENTE":"$COMPONENTE","PONDERACION_META":"$PONDERACION_META","VALOR_PROGRAMADO_META":"$VALOR_PROGRAMADO_META","VALOR_EJECUTADO_META":"$VALOR_EJECUTADO_META","ACTIVIDAD":"$ACTIVIDAD","CANTIDAD_PROGRAMADA_P":"$CANTIDAD_PROGRAMADA_P","CANTIDAD_EJECUTADA_P":"$CANTIDAD_EJECUTADA_P","DESCRIPCION_META":"$DESCRIPCION_META","TIPOCOMPONENTE":"$TIPOCOMPONENTE","NOMBREACTIVIDAD":"$NOMBREACTIVIDAD","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE","NOMBRETIPOCOMPONENTE":"$NOMBRETIPOCOMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="ID_PLAN_P" sqlType="STRING"/>
		<param name="VIGENCIA_PLAN_P" sqlType="STRING"/>
		<param name="VIGENCIA_META_P" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="PONDERACION_META" sqlType="STRING"/>
		<param name="VALOR_PROGRAMADO_META" sqlType="STRING"/>
		<param name="VALOR_EJECUTADO_META" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="CANTIDAD_PROGRAMADA_P" sqlType="STRING"/>
		<param name="CANTIDAD_EJECUTADA_P" sqlType="STRING"/>
		<param name="DESCRIPCION_META" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="NOMBRETIPOCOMPONENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpproyectoplanindicativo">
		<call-query href="getBpproyectoplanindicativoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PROGRAMA" query-param="PROGRAMA"/>
