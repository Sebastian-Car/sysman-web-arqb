	<query id="insertBpproyectoplanindicativo" keyColumns="COMPANIA,ID_PLAN_P,VIGENCIA_PLAN_P,VIGENCIA_META_P,PROYECTO,TIPOCOMPONENTE,COMPONENTE,ACTIVIDAD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_PROYECTO_PLAN_INDICATIVO (COMPANIA, ID_PLAN_P, VIGENCIA_PLAN_P, VIGENCIA_META_P, PROYECTO, TIPOCOMPONENTE, COMPONENTE, ACTIVIDAD, DESCRIPCION_META, PONDERACION_META, CANTIDAD_PROGRAMADA_P, CANTIDAD_EJECUTADA_P, VALOR_PROGRAMADO_META, VALOR_EJECUTADO_META, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_PLAN_P, :VIGENCIA_PLAN_P, :VIGENCIA_META_P, :PROYECTO, :TIPOCOMPONENTE, :COMPONENTE, :ACTIVIDAD, :DESCRIPCION_META, :PONDERACION_META, :CANTIDAD_PROGRAMADA_P, :CANTIDAD_EJECUTADA_P, :VALOR_PROGRAMADO_META, :VALOR_EJECUTADO_META, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_PLAN_P":"$ID_PLAN_P","KEY_VIGENCIA_PLAN_P":"$VIGENCIA_PLAN_P(type:integer)","KEY_VIGENCIA_META_P":"$VIGENCIA_META_P(type:integer)","KEY_PROYECTO":"$PROYECTO","KEY_TIPOCOMPONENTE":"$TIPOCOMPONENTE","KEY_COMPONENTE":"$COMPONENTE","KEY_ACTIVIDAD":"$ACTIVIDAD"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_PLAN_P" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_PLAN_P" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA_META_P" sqlType="STRING"/>
