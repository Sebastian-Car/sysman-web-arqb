			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="NOMBREPROYECTO" query-param="NOMBREPROYECTO"/>

		</call-query>
	</resource>
	<query id="getBpproyectoplanindicativoPagTodosPorCompaniaYCodproyQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE, COMPONENTES.NOMBRECOMPONENTE  FROM BP_PROYECTO_PLAN_INDICATIVO INNER JOIN COMPONENTES ON (BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = COMPONENTES.COMPANIA) AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = COMPONENTES.CODIGOPROYECTO AND (BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE = COMPONENTES.CODIGO) AND (BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = COMPONENTES.TIPOCOMPONENTE) WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = :COD_PROY AND COMPONENTES.VIGENCIA = :VIGENCIA AND BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = :TIPO_COMPROBANTE ORDER BY BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE) WHERE (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END)  LIKE UPPER(:COMPONENTE || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPONENTE":"$COMPONENTE","NOMBRECOMPONENTE":"$NOMBRECOMPONENTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PROY" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpproyectoplanindicativo/todosporcompaniaycodproy/pag">
		<call-query href="getBpproyectoplanindicativoPagTodosPorCompaniaYCodproyQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COD_PROY" query-param="COD_PROY"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="TIPO_COMPROBANTE" query-param="TIPO_COMPROBANTE"/>
