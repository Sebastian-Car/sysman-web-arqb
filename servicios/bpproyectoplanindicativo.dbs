		</call-query>
	</resource>
	<query id="getBpproyectoplanindicativoNumTodosPorCompaniaYCodproyQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE, COMPONENTES.NOMBRECOMPONENTE  FROM BP_PROYECTO_PLAN_INDICATIVO INNER JOIN COMPONENTES ON (BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = COMPONENTES.COMPANIA) AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = COMPONENTES.CODIGOPROYECTO AND (BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE = COMPONENTES.CODIGO) AND (BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = COMPONENTES.TIPOCOMPONENTE) WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = :COD_PROY AND COMPONENTES.VIGENCIA = :VIGENCIA AND BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = :TIPO_COMPROBANTE ORDER BY BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE) WHERE (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END)  LIKE UPPER(:COMPONENTE || '%')  AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END)  LIKE UPPER( '%' || :NOMBRECOMPONENTE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COD_PROY" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectoplanindicativo/todosporcompaniaycodproy/num">
