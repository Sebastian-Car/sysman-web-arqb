	</resource>
	<query id="getBpproyectoplanindicativoPagTodosPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BP_PROYECTO_PLAN_INDICATIVO.PROYECTO, PROYECTOS.NOMBREPROYECTO, PROYECTOS.CODIGOBPIM  FROM BP_PROYECTO_PLAN_INDICATIVO LEFT JOIN PROYECTOS ON (BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = PROYECTOS.CODIGO) AND (BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = PROYECTOS.COMPANIA) WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND PROYECTOS.DEPENDENCIA = :DEPENDENCIA ORDER BY BP_PROYECTO_PLAN_INDICATIVO.PROYECTO) WHERE (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END)  LIKE UPPER(:PROYECTO || '%')  AND (CASE WHEN NOMBREPROYECTO IS NULL THEN ' ' ELSE UPPER(NOMBREPROYECTO) END)  LIKE UPPER( '%' || :NOMBREPROYECTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PROYECTO":"$PROYECTO","NOMBREPROYECTO":"$NOMBREPROYECTO","CODIGOBPIM":"$CODIGOBPIM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="INTEGER"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="NOMBREPROYECTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpproyectoplanindicativo/todosporcompania/pag">
