	<query id="deleteBpproyectoplanindicativo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_PROYECTO_PLAN_INDICATIVO WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA= :KEY_COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P= :KEY_ID_PLAN_P AND BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P= :KEY_VIGENCIA_PLAN_P AND BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P= :KEY_VIGENCIA_META_P AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO= :KEY_PROYECTO AND BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE= :KEY_COMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD= :KEY_ACTIVIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_PLAN_P" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_PLAN_P" sqlType="INTEGER"/>
		<param name="KEY_VIGENCIA_META_P" sqlType="INTEGER"/>
