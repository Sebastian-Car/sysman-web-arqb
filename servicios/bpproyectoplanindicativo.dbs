	<query id="updateBpproyectoplanindicativo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_PROYECTO_PLAN_INDICATIVO SET COMPANIA=:COMPANIA, ID_PLAN_P=:ID_PLAN_P, VIGENCIA_PLAN_P=:VIGENCIA_PLAN_P, VIGENCIA_META_P=:VIGENCIA_META_P, PROYECTO=:PROYECTO, TIPOCOMPONENTE=:TIPOCOMPONENTE, COMPONENTE=:COMPONENTE, ACTIVIDAD=:ACTIVIDAD, DESCRIPCION_META=:DESCRIPCION_META, PONDERACION_META=:PONDERACION_META, CANTIDAD_PROGRAMADA_P=:CANTIDAD_PROGRAMADA_P, CANTIDAD_EJECUTADA_P=:CANTIDAD_EJECUTADA_P, VALOR_PROGRAMADO_META=:VALOR_PROGRAMADO_META, VALOR_EJECUTADO_META=:VALOR_EJECUTADO_META, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA= :KEY_COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P= :KEY_ID_PLAN_P AND BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P= :KEY_VIGENCIA_PLAN_P AND BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P= :KEY_VIGENCIA_META_P AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO= :KEY_PROYECTO AND BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE= :KEY_TIPOCOMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE= :KEY_COMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD= :KEY_ACTIVIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

