	<query id="getBpproyectoplanindicativoNumTodosPorCompaniaYVigencQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE, BP_TIPOSCOMPONENTES.DESCRIPCION  FROM BP_PROYECTO_PLAN_INDICATIVO LEFT JOIN BP_TIPOSCOMPONENTES ON (BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = BP_TIPOSCOMPONENTES.COMPANIA) AND (BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = BP_TIPOSCOMPONENTES.CODIGO) WHERE BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = :COD_PROY AND BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P = :VIGENCIA) WHERE (CASE WHEN TIPOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPONENTE) END)  LIKE UPPER(:TIPOCOMPONENTE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COD_PROY" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="INTEGER"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
