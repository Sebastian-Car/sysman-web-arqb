			<with-param name="CANTIDAD_EJECUTADA_P" query-param="CANTIDAD_EJECUTADA_P"/>
			<with-param name="DESCRIPCION_META" query-param="DESCRIPCION_META"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpproyectoplanindicativoNumMetasDeEstudiosPreviosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P, BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE, BP_PROYECTO_PLAN_INDICATIVO.COMPANIA, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P, BP_PROYECTO_PLAN_INDICATIVO.PROYECTO, BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE, BP_PROYECTO_PLAN_INDICATIVO.PONDERACION_META, BP_PROYECTO_PLAN_INDICATIVO.VALOR_PROGRAMADO_META, BP_PROYECTO_PLAN_INDICATIVO.VALOR_EJECUTADO_META, BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD, BP_PROYECTO_PLAN_INDICATIVO.CANTIDAD_PROGRAMADA_P, BP_PROYECTO_PLAN_INDICATIVO.CANTIDAD_EJECUTADA_P, BP_PROYECTO_PLAN_INDICATIVO.DESCRIPCION_META, SUBSTR(ID_PLAN_P,2,11) SUBPROGRAMA, SUBSTR(ID_PLAN_P,2,6) PROGRAMA, SUBSTR(ID_PLAN_P,2,4) SECTOR, SUBSTR(ID_PLAN_P,2,2) DIMENSION  FROM BP_PROYECTO_PLAN_INDICATIVO WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = :TIPOCOMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = :PROYECTO AND BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE = :COMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD = :ACTIVIDAD) WHERE (CASE WHEN ID_PLAN_P IS NULL THEN ' ' ELSE UPPER(ID_PLAN_P) END)  LIKE UPPER(:ID_PLAN_P || '%')  AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END)  LIKE UPPER( '%' || :PROYECTO || '%')  AND (CASE WHEN CANTIDAD_EJECUTADA_P IS NULL THEN ' ' ELSE UPPER(CANTIDAD_EJECUTADA_P) END)  LIKE UPPER( '%' || :CANTIDAD_EJECUTADA_P || '%')  AND (CASE WHEN DESCRIPCION_META IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_META) END)  LIKE UPPER( '%' || :DESCRIPCION_META || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="ID_PLAN_P" sqlType="STRING"/>
		<param name="CANTIDAD_EJECUTADA_P" sqlType="STRING"/>
		<param name="DESCRIPCION_META" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectoplanindicativo/metasdeestudiosprevios/num">
		<call-query href="getBpproyectoplanindicativoNumMetasDeEstudiosPreviosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPOCOMPONENTE" query-param="TIPOCOMPONENTE"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
