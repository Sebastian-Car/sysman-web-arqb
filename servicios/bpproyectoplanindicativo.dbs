	<query id="getBpproyectoplanindicativoNumIdynombreplanindporproyQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT BP_PROYECTO_PLAN_INDICATIVO.COMPANIA, BP_PROYECTO_PLAN_INDICATIVO.PROYECTO, BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P, BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P, BP_PLAN_INDICATIVO_METAS.DESCRIPCION NOMBRE, COMPONENTES.NOMBRECOMPONENTE, COMPONENTES_ACTIVIDADES.NOMBREACTIVIDAD, BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE, BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P, BP_PLAN_INDICATIVO_METAS.CANTIDAD_PROGRAMADA, BP_PLAN_INDICATIVO_METAS.CANTIDAD_EJECUTADA, BP_PLAN_INDICATIVO.TIPO_META_INDICADOR, BP_PLAN_INDICATIVO_METAS.VALOR_EJECUTADO_META, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META, BP_PLAN_INDICATIVO_METAS.VALOR_PROGRAMADO_META_OTROS, SECTORES.CODIGO, SECTORES.DESCRIPCION NOMBRE_SECTOR FROM BP_PROYECTO_PLAN_INDICATIVO INNER JOIN BP_PLAN_INDICATIVO_METAS ON BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = BP_PLAN_INDICATIVO_METAS.COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P = BP_PLAN_INDICATIVO_METAS.ID_PLAN AND BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_PLAN_P = BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN AND BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P = BP_PLAN_INDICATIVO_METAS.VIGENCIA_META INNER JOIN BP_PLAN_INDICATIVO ON BP_PLAN_INDICATIVO_METAS.COMPANIA = BP_PLAN_INDICATIVO.COMPANIA AND BP_PLAN_INDICATIVO_METAS.ID_PLAN = BP_PLAN_INDICATIVO.ID AND BP_PLAN_INDICATIVO_METAS.VIGENCIA_PLAN = BP_PLAN_INDICATIVO.VIGENCIA_INICIAL INNER JOIN COMPONENTES_ACTIVIDADES ON BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = COMPONENTES_ACTIVIDADES.COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = COMPONENTES_ACTIVIDADES.CODIGOPROYECTO AND BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE = COMPONENTES_ACTIVIDADES.COMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE AND BP_PROYECTO_PLAN_INDICATIVO.ACTIVIDAD = COMPONENTES_ACTIVIDADES.ACTIVIDAD INNER JOIN COMPONENTES ON COMPONENTES_ACTIVIDADES.COMPANIA = COMPONENTES.COMPANIA AND COMPONENTES_ACTIVIDADES.CODIGOPROYECTO = COMPONENTES.CODIGOPROYECTO AND COMPONENTES_ACTIVIDADES.COMPONENTE = COMPONENTES.CODIGO AND COMPONENTES_ACTIVIDADES.TIPOCOMPONENTE = COMPONENTES.TIPOCOMPONENTE LEFT JOIN SECTORES ON BP_PLAN_INDICATIVO.COMPANIA = SECTORES.COMPANIA AND BP_PLAN_INDICATIVO.SECTOR = SECTORES.CODIGO WHERE BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = :COMPANIA AND BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = :PROYECTO AND (:VIGENCIA IS NULL OR BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P = :VIGENCIA) ORDER BY BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P DESC, BP_PROYECTO_PLAN_INDICATIVO.ID_PLAN_P, BP_PROYECTO_PLAN_INDICATIVO.COMPONENTE) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN PROYECTO IS NULL THEN ' ' ELSE UPPER(PROYECTO) END) LIKE UPPER(CONCAT(CONCAT('%',:PROYECTO), '%')) AND (CASE WHEN ACTIVIDAD IS NULL THEN ' ' ELSE UPPER(ACTIVIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:ACTIVIDAD), '%')) AND (CASE WHEN VIGENCIA_META_P IS NULL THEN ' ' ELSE UPPER(VIGENCIA_META_P) END) LIKE UPPER(CONCAT(CONCAT('%',:VIGENCIA_META_P), '%')) AND (CASE WHEN ID_PLAN_P IS NULL THEN ' ' ELSE UPPER(ID_PLAN_P) END) LIKE UPPER(CONCAT(CONCAT('%',:ID_PLAN_P), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NOMBRECOMPONENTE IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPONENTE), '%')) AND (CASE WHEN NOMBREACTIVIDAD IS NULL THEN ' ' ELSE UPPER(NOMBREACTIVIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREACTIVIDAD), '%')) AND (CASE WHEN COMPONENTE IS NULL THEN ' ' ELSE UPPER(COMPONENTE) END) LIKE UPPER(CONCAT(CONCAT('%',:COMPONENTE), '%')) AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN NOMBRE_SECTOR IS NULL THEN ' ' ELSE UPPER(NOMBRE_SECTOR) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_SECTOR), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="VIGENCIA_META_P" sqlType="STRING"/>
		<param name="ID_PLAN_P" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NOMBRECOMPONENTE" sqlType="STRING"/>
		<param name="NOMBREACTIVIDAD" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="NOMBRE_SECTOR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectoplanindicativo/idynombreplanindporproy/num">
		<call-query href="getBpproyectoplanindicativoNumIdynombreplanindporproyQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="VIGENCIA_META_P" query-param="VIGENCIA_META_P"/>
			<with-param name="ID_PLAN_P" query-param="ID_PLAN_P"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NOMBRECOMPONENTE" query-param="NOMBRECOMPONENTE"/>
			<with-param name="NOMBREACTIVIDAD" query-param="NOMBREACTIVIDAD"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="NOMBRE_SECTOR" query-param="NOMBRE_SECTOR"/>

		</call-query>
	</resource>
	<query id="getBpproyectoplanindicativoDetallesNovedadesProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  PIM.DESCRIPCION NOMBRE, PIM.CANTIDAD_PROGRAMADA, PIM.CANTIDAD_EJECUTADA, PI.TIPO_META_INDICADOR, PIM.VALOR_EJECUTADO_META, PIM.VALOR_PROGRAMADO_META, PIM.VALOR_PROGRAMADO_META_OTROS, (PIM.CANTIDAD_PROGRAMADA+PIM.VALOR_PROGRAMADO_META_OTROS) VALORPROGRAMADO, SECTORES.DESCRIPCION NOMBRE_SECTOR, PI.LB, PI.META  FROM BP_PROYECTO_PLAN_INDICATIVO PPI INNER JOIN BP_PLAN_INDICATIVO_METAS PIM ON PPI.COMPANIA = PIM.COMPANIA AND PPI.ID_PLAN_P = PIM.ID_PLAN AND PPI.VIGENCIA_PLAN_P = PIM.VIGENCIA_PLAN AND PPI.VIGENCIA_META_P = PIM.VIGENCIA_META INNER JOIN BP_PLAN_INDICATIVO PI ON PIM.COMPANIA = PI.COMPANIA AND PIM.VIGENCIA_PLAN = PI.VIGENCIA_INICIAL AND PIM.ID_PLAN = PI.ID LEFT JOIN SECTORES ON PI.COMPANIA = SECTORES.COMPANIA AND PI.SECTOR = SECTORES.CODIGO WHERE PPI.COMPANIA = :COMPANIA AND PPI.PROYECTO = :PROYECTO AND PPI.ACTIVIDAD = :ACTIVIDAD AND PPI.COMPONENTE = :COMPONENTE AND PPI.ID_PLAN_P = :ID_PLAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NOMBRE":"$NOMBRE","CANTIDAD_PROGRAMADA":"$CANTIDAD_PROGRAMADA","CANTIDAD_EJECUTADA":"$CANTIDAD_EJECUTADA","TIPO_META_INDICADOR":"$TIPO_META_INDICADOR","VALOR_EJECUTADO_META":"$VALOR_EJECUTADO_META","VALOR_PROGRAMADO_META":"$VALOR_PROGRAMADO_META","VALOR_PROGRAMADO_META_OTROS":"$VALOR_PROGRAMADO_META_OTROS","VALORPROGRAMADO":"$VALORPROGRAMADO","NOMBRE_SECTOR":"$NOMBRE_SECTOR","LB":"$LB","META":"$META"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="ACTIVIDAD" sqlType="STRING"/>
		<param name="COMPONENTE" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectoplanindicativo/detallesnovedadesproyecto">
		<call-query href="getBpproyectoplanindicativoDetallesNovedadesProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="ACTIVIDAD" query-param="ACTIVIDAD"/>
			<with-param name="COMPONENTE" query-param="COMPONENTE"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>

		</call-query>
	</resource>

