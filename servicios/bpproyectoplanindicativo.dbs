	<query id="getBpproyectoplanindicativoPagTodosPorCompaniaYVigencQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE, BP_TIPOSCOMPONENTES.DESCRIPCION  FROM BP_PROYECTO_PLAN_INDICATIVO LEFT JOIN BP_TIPOSCOMPONENTES ON (BP_PROYECTO_PLAN_INDICATIVO.COMPANIA = BP_TIPOSCOMPONENTES.COMPANIA) AND (BP_PROYECTO_PLAN_INDICATIVO.TIPOCOMPONENTE = BP_TIPOSCOMPONENTES.CODIGO) WHERE BP_PROYECTO_PLAN_INDICATIVO.PROYECTO = :COD_PROY AND BP_PROYECTO_PLAN_INDICATIVO.VIGENCIA_META_P = :VIGENCIA) WHERE (CASE WHEN TIPOCOMPONENTE IS NULL THEN ' ' ELSE UPPER(TIPOCOMPONENTE) END)  LIKE UPPER(:TIPOCOMPONENTE || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TIPOCOMPONENTE":"$TIPOCOMPONENTE","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COD_PROY" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="INTEGER"/>
		<param name="TIPOCOMPONENTE" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
