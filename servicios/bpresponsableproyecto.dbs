<data name="bpresponsableproyecto" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpresponsableproyectoTodosPorNombreSegunTipoQuery"  useConfig="sysmandsunist">
		<sql>SELECT (TO_CHAR(BPRESPONSABLEPROYECTO.FECHARESPONSABLE,'DD/MM/YYYY HH24:MI:SS')) FECHARESPONSABLE, BPRESPONSABLEPROYECTO.NOMB_RESPONSABLE, DEPENDENCIA.NOMBRE DEPENDENCIA  FROM BPRESPONSABLEPROYECTO INNER JOIN DEPENDENCIA ON BPRESPONSABLEPROYECTO.COMPANIA = DEPENDENCIA.COMPANIA AND BPRESPONSABLEPROYECTO.DEPENDENCIA = DEPENDENCIA.CODIGO WHERE BPRESPONSABLEPROYECTO.COMPANIA = :COMPANIA AND BPRESPONSABLEPROYECTO.PROYECTO = :CODIGOPROYECTO AND BPRESPONSABLEPROYECTO.TIPORESPONSABLE = '001'</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FECHARESPONSABLE":"$FECHARESPONSABLE","NOMB_RESPONSABLE":"$NOMB_RESPONSABLE","DEPENDENCIA":"$DEPENDENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpresponsableproyecto/todospornombreseguntipo">
		<call-query href="getBpresponsableproyectoTodosPorNombreSegunTipoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>

		</call-query>
	</resource>
	<query id="insertBpresponsableproyecto" keyColumns="COMPANIA,PROYECTO,RESPONSABLE,SUCURSAL,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BPRESPONSABLEPROYECTO (COMPANIA, RESPONSABLE, CODIGO, FECHARESPONSABLE, ACTIVO, SUCURSAL, TIPORESPONSABLE, COMENTARIO, FECHAINACTIVO, DEPENDENCIA, NOMB_RESPONSABLE, PROYECTO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :RESPONSABLE, :CODIGO, TO_DATE(:FECHARESPONSABLE,'DD/MM/YYYY HH24:MI:SS'), :ACTIVO, :SUCURSAL, :TIPORESPONSABLE, :COMENTARIO, TO_DATE(:FECHAINACTIVO,'DD/MM/YYYY HH24:MI:SS'), :DEPENDENCIA, :NOMB_RESPONSABLE, :PROYECTO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PROYECTO":"$PROYECTO","KEY_RESPONSABLE":"$RESPONSABLE","KEY_SUCURSAL":"$SUCURSAL","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="RESPONSABLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="FECHARESPONSABLE" sqlType="STRING"/>
		<param defaultValue="0" name="ACTIVO" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="000" name="TIPORESPONSABLE" sqlType="STRING"/>
		<param defaultValue="" name="COMENTARIO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAINACTIVO" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="" name="NOMB_RESPONSABLE" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpresponsableproyecto">
		<call-query href="insertBpresponsableproyecto">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FECHARESPONSABLE" query-param="FECHARESPONSABLE"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPORESPONSABLE" query-param="TIPORESPONSABLE"/>
			<with-param name="COMENTARIO" query-param="COMENTARIO"/>
			<with-param name="FECHAINACTIVO" query-param="FECHAINACTIVO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMB_RESPONSABLE" query-param="NOMB_RESPONSABLE"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpresponsableproyecto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BPRESPONSABLEPROYECTO WHERE BPRESPONSABLEPROYECTO.COMPANIA= :KEY_COMPANIA AND BPRESPONSABLEPROYECTO.PROYECTO= :KEY_PROYECTO AND BPRESPONSABLEPROYECTO.RESPONSABLE= :KEY_RESPONSABLE AND BPRESPONSABLEPROYECTO.SUCURSAL= :KEY_SUCURSAL AND BPRESPONSABLEPROYECTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_RESPONSABLE" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpresponsableproyecto">
		<call-query href="deleteBpresponsableproyecto">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROYECTO" query-param="KEY_PROYECTO"/>
			<with-param name="KEY_RESPONSABLE" query-param="KEY_RESPONSABLE"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpresponsableproyectoPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, RESPONSABLE, CODIGO,(TO_CHAR(FECHARESPONSABLE,'DD/MM/YYYY HH24:MI:SS')) FECHARESPONSABLE,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO, SUCURSAL, TIPORESPONSABLE, CASE TIPORESPONSABLE WHEN '001' THEN 'Viabilidad Técnica' WHEN '002' THEN 'Emite Concepto sectorial' WHEN '003' THEN 'Hizo formulación' WHEN '004' THEN 'Desarrollo BPIM' WHEN '005' THEN 'Hizo Actualización' WHEN '006' THEN 'Responsable General' WHEN '007' THEN 'Hizo Registro' WHEN '008' THEN 'Hacer elaboración' ELSE 'Otro' END AS NOMBRETIPO, COMENTARIO,(TO_CHAR(FECHAINACTIVO,'DD/MM/YYYY HH24:MI:SS')) FECHAINACTIVO, DEPENDENCIA, NOMB_RESPONSABLE, PROYECTO  FROM BPRESPONSABLEPROYECTO WHERE COMPANIA = :COMPANIA AND PROYECTO = :CODIGOPROYECTO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN FECHARESPONSABLE IS NULL THEN ' ' ELSE UPPER(FECHARESPONSABLE) END)  LIKE UPPER( '%' || :FECHARESPONSABLE || '%')  AND (CASE WHEN ACTIVO IS NULL THEN ' ' ELSE UPPER(ACTIVO) END)  LIKE UPPER( '%' || :ACTIVO || '%')  AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END)  LIKE UPPER( '%' || :NOMBRETIPO || '%')  AND (CASE WHEN COMENTARIO IS NULL THEN ' ' ELSE UPPER(COMENTARIO) END)  LIKE UPPER( '%' || :COMENTARIO || '%')  AND (CASE WHEN FECHAINACTIVO IS NULL THEN ' ' ELSE UPPER(FECHAINACTIVO) END)  LIKE UPPER( '%' || :FECHAINACTIVO || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN NOMB_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMB_RESPONSABLE) END)  LIKE UPPER( '%' || :NOMB_RESPONSABLE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","RESPONSABLE":"$RESPONSABLE","CODIGO":"$CODIGO","FECHARESPONSABLE":"$FECHARESPONSABLE","ACTIVO":"$ACTIVO(type:boolean)","SUCURSAL":"$SUCURSAL","TIPORESPONSABLE":"$TIPORESPONSABLE","NOMBRETIPO":"$NOMBRETIPO","COMENTARIO":"$COMENTARIO","FECHAINACTIVO":"$FECHAINACTIVO","DEPENDENCIA":"$DEPENDENCIA","NOMB_RESPONSABLE":"$NOMB_RESPONSABLE","PROYECTO":"$PROYECTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="FECHARESPONSABLE" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="COMENTARIO" sqlType="STRING"/>
		<param name="FECHAINACTIVO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMB_RESPONSABLE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpresponsableproyecto">
		<call-query href="getBpresponsableproyectoPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="FECHARESPONSABLE" query-param="FECHARESPONSABLE"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="COMENTARIO" query-param="COMENTARIO"/>
			<with-param name="FECHAINACTIVO" query-param="FECHAINACTIVO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMB_RESPONSABLE" query-param="NOMB_RESPONSABLE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpresponsableproyectoNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, RESPONSABLE, CODIGO,(TO_CHAR(FECHARESPONSABLE,'DD/MM/YYYY HH24:MI:SS')) FECHARESPONSABLE,(CASE ACTIVO WHEN 0 THEN 'false' ELSE 'true' END) ACTIVO, SUCURSAL, TIPORESPONSABLE, CASE TIPORESPONSABLE WHEN '001' THEN 'Viabilidad Técnica' WHEN '002' THEN 'Emite Concepto sectorial' WHEN '003' THEN 'Hizo formulación' WHEN '004' THEN 'Desarrollo BPIM' WHEN '005' THEN 'Hizo Actualización' WHEN '006' THEN 'Responsable General' WHEN '007' THEN 'Hizo Registro' WHEN '008' THEN 'Hacer elaboración' ELSE 'Otro' END AS NOMBRETIPO, COMENTARIO,(TO_CHAR(FECHAINACTIVO,'DD/MM/YYYY HH24:MI:SS')) FECHAINACTIVO, DEPENDENCIA, NOMB_RESPONSABLE, PROYECTO  FROM BPRESPONSABLEPROYECTO WHERE COMPANIA = :COMPANIA AND PROYECTO = :CODIGOPROYECTO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER(:COMPANIA || '%')  AND (CASE WHEN RESPONSABLE IS NULL THEN ' ' ELSE UPPER(RESPONSABLE) END)  LIKE UPPER(:RESPONSABLE || '%')  AND (CASE WHEN FECHARESPONSABLE IS NULL THEN ' ' ELSE UPPER(FECHARESPONSABLE) END)  LIKE UPPER( '%' || :FECHARESPONSABLE || '%')  AND (CASE WHEN ACTIVO IS NULL THEN ' ' ELSE UPPER(ACTIVO) END)  LIKE UPPER( '%' || :ACTIVO || '%')  AND (CASE WHEN NOMBRETIPO IS NULL THEN ' ' ELSE UPPER(NOMBRETIPO) END)  LIKE UPPER( '%' || :NOMBRETIPO || '%')  AND (CASE WHEN COMENTARIO IS NULL THEN ' ' ELSE UPPER(COMENTARIO) END)  LIKE UPPER( '%' || :COMENTARIO || '%')  AND (CASE WHEN FECHAINACTIVO IS NULL THEN ' ' ELSE UPPER(FECHAINACTIVO) END)  LIKE UPPER( '%' || :FECHAINACTIVO || '%')  AND (CASE WHEN DEPENDENCIA IS NULL THEN ' ' ELSE UPPER(DEPENDENCIA) END)  LIKE UPPER( '%' || :DEPENDENCIA || '%')  AND (CASE WHEN NOMB_RESPONSABLE IS NULL THEN ' ' ELSE UPPER(NOMB_RESPONSABLE) END)  LIKE UPPER( '%' || :NOMB_RESPONSABLE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>
		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="FECHARESPONSABLE" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="NOMBRETIPO" sqlType="STRING"/>
		<param name="COMENTARIO" sqlType="STRING"/>
		<param name="FECHAINACTIVO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMB_RESPONSABLE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpresponsableproyecto/numero">
		<call-query href="getBpresponsableproyectoNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="FECHARESPONSABLE" query-param="FECHARESPONSABLE"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="NOMBRETIPO" query-param="NOMBRETIPO"/>
			<with-param name="COMENTARIO" query-param="COMENTARIO"/>
			<with-param name="FECHAINACTIVO" query-param="FECHAINACTIVO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMB_RESPONSABLE" query-param="NOMB_RESPONSABLE"/>

		</call-query>
	</resource>
	<query id="updateBpresponsableproyecto" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BPRESPONSABLEPROYECTO SET RESPONSABLE=:RESPONSABLE, CODIGO=:CODIGO, FECHARESPONSABLE=TO_DATE(:FECHARESPONSABLE,'DD/MM/YYYY HH24:MI:SS'), ACTIVO=:ACTIVO, SUCURSAL=:SUCURSAL, TIPORESPONSABLE=:TIPORESPONSABLE, COMENTARIO=:COMENTARIO, FECHAINACTIVO=TO_DATE(:FECHAINACTIVO,'DD/MM/YYYY HH24:MI:SS'), DEPENDENCIA=:DEPENDENCIA, NOMB_RESPONSABLE=:NOMB_RESPONSABLE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BPRESPONSABLEPROYECTO.COMPANIA= :KEY_COMPANIA AND BPRESPONSABLEPROYECTO.PROYECTO= :KEY_PROYECTO AND BPRESPONSABLEPROYECTO.RESPONSABLE= :KEY_RESPONSABLE AND BPRESPONSABLEPROYECTO.SUCURSAL= :KEY_SUCURSAL AND BPRESPONSABLEPROYECTO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="RESPONSABLE" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="FECHARESPONSABLE" sqlType="STRING"/>
		<param name="ACTIVO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPORESPONSABLE" sqlType="STRING"/>
		<param name="COMENTARIO" sqlType="STRING"/>
		<param name="FECHAINACTIVO" sqlType="STRING"/>
		<param name="DEPENDENCIA" sqlType="STRING"/>
		<param name="NOMB_RESPONSABLE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_RESPONSABLE" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpresponsableproyecto">
		<call-query href="updateBpresponsableproyecto">
			<with-param name="RESPONSABLE" query-param="RESPONSABLE"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="FECHARESPONSABLE" query-param="FECHARESPONSABLE"/>
			<with-param name="ACTIVO" query-param="ACTIVO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPORESPONSABLE" query-param="TIPORESPONSABLE"/>
			<with-param name="COMENTARIO" query-param="COMENTARIO"/>
			<with-param name="FECHAINACTIVO" query-param="FECHAINACTIVO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="NOMB_RESPONSABLE" query-param="NOMB_RESPONSABLE"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROYECTO" query-param="KEY_PROYECTO"/>
			<with-param name="KEY_RESPONSABLE" query-param="KEY_RESPONSABLE"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>