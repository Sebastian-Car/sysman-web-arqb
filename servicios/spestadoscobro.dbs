<data name="spestadoscobro" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpestadoscobroCodigodescripcionporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO, DESCRIPCION  FROM SP_ESTADOSCOBRO WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestadoscobro/codigodescripcionporcompania">
		<call-query href="getSpestadoscobroCodigodescripcionporcompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpestadoscobroPagTodosPorCodigoDescripcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CODIGO, DESCRIPCION  FROM SP_ESTADOSCOBRO WHERE COMPANIA = :COMPANIA UNION SELECT 'NNN' CODIGO, 'Sin Estado de Cobro' DESCRIPCION FROM COMPANIA WHERE CODIGO = :COMPANIA) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spestadoscobro/todosporcodigodescripcion/pag">
		<call-query href="getSpestadoscobroPagTodosPorCodigoDescripcionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpestadoscobroNumTodosPorCodigoDescripcionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CODIGO, DESCRIPCION  FROM SP_ESTADOSCOBRO WHERE COMPANIA = :COMPANIA UNION SELECT 'NNN' CODIGO, 'Sin Estado de Cobro' DESCRIPCION FROM COMPANIA WHERE CODIGO = :COMPANIA) WHERE (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestadoscobro/todosporcodigodescripcion/num">
		<call-query href="getSpestadoscobroNumTodosPorCodigoDescripcionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getSpestadoscobroTodosDiferenteNQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO  FROM SP_ESTADOSCOBRO WHERE COMPANIA = :COMPANIA AND PERTENECE_A NOT IN ('N')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestadoscobro/todosdiferenten">
		<call-query href="getSpestadoscobroTodosDiferenteNQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpestadoscobroTodosDiferenteEQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO  FROM SP_ESTADOSCOBRO WHERE COMPANIA = :COMPANIA AND PERTENECE_A NOT IN ('E')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestadoscobro/todosdiferentee">
		<call-query href="getSpestadoscobroTodosDiferenteEQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="insertSpestadoscobro" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_ESTADOSCOBRO (COMPANIA, CODIGO, DESCRIPCION, COD_EQUIVA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CODIGO, :DESCRIPCION, :COD_EQUIVA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="" name="COD_EQUIVA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spestadoscobro">
		<call-query href="insertSpestadoscobro">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COD_EQUIVA" query-param="COD_EQUIVA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSpestadoscobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_ESTADOSCOBRO WHERE SP_ESTADOSCOBRO.COMPANIA= :KEY_COMPANIA AND SP_ESTADOSCOBRO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spestadoscobro">
		<call-query href="deleteSpestadoscobro">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getSpestadoscobroPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGO, DESCRIPCION, COD_EQUIVA, PERTENECE_A, (CASE PERTENECE_A WHEN 'E' THEN 'Ejecutivo' WHEN 'N' THEN 'Normal o Defecto' WHEN 'P' THEN 'Persuasivo' END) NOMBREPERTENECE  FROM SP_ESTADOSCOBRO WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN COD_EQUIVA IS NULL THEN ' ' ELSE UPPER(COD_EQUIVA) END)  LIKE UPPER( '%' || :COD_EQUIVA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","COD_EQUIVA":"$COD_EQUIVA","PERTENECE_A":"$PERTENECE_A","NOMBREPERTENECE":"$NOMBREPERTENECE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="COD_EQUIVA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spestadoscobro">
		<call-query href="getSpestadoscobroPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COD_EQUIVA" query-param="COD_EQUIVA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpestadoscobroNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CODIGO, DESCRIPCION, COD_EQUIVA, PERTENECE_A, (CASE PERTENECE_A WHEN 'E' THEN 'Ejecutivo' WHEN 'N' THEN 'Normal o Defecto' WHEN 'P' THEN 'Persuasivo' END) NOMBREPERTENECE  FROM SP_ESTADOSCOBRO WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%')  AND (CASE WHEN COD_EQUIVA IS NULL THEN ' ' ELSE UPPER(COD_EQUIVA) END)  LIKE UPPER( '%' || :COD_EQUIVA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="COD_EQUIVA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spestadoscobro/numero">
		<call-query href="getSpestadoscobroNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COD_EQUIVA" query-param="COD_EQUIVA"/>

		</call-query>
	</resource>
	<query id="updateSpestadoscobro" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_ESTADOSCOBRO SET CODIGO=:CODIGO, DESCRIPCION=:DESCRIPCION, COD_EQUIVA=:COD_EQUIVA, PERTENECE_A=:PERTENECE_A, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_ESTADOSCOBRO.COMPANIA= :KEY_COMPANIA AND SP_ESTADOSCOBRO.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="COD_EQUIVA" sqlType="STRING"/>
		<param name="PERTENECE_A" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spestadoscobro">
		<call-query href="updateSpestadoscobro">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="COD_EQUIVA" query-param="COD_EQUIVA"/>
			<with-param name="PERTENECE_A" query-param="PERTENECE_A"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>