<data name="cmcausacionautomatica" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCmcausacionautomaticaPagCodigotipocomprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGO COMPROBANTE, TIPO_COMPROBANTE NOMBRE_TIPO_COMPROBANTE FROM CM_CAUSACION_AUTOMATICA WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN NOMBRE_TIPO_COMPROBANTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO_COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TIPO_COMPROBANTE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPROBANTE":"$COMPROBANTE","NOMBRE_TIPO_COMPROBANTE":"$NOMBRE_TIPO_COMPROBANTE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="NOMBRE_TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cmcausacionautomatica/codigotipocomprobante/pag">
		<call-query href="getCmcausacionautomaticaPagCodigotipocomprobanteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="NOMBRE_TIPO_COMPROBANTE" query-param="NOMBRE_TIPO_COMPROBANTE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCmcausacionautomaticaNumCodigotipocomprobanteQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGO COMPROBANTE, TIPO_COMPROBANTE NOMBRE_TIPO_COMPROBANTE FROM CM_CAUSACION_AUTOMATICA WHERE COMPANIA = :COMPANIA) INI WHERE (CASE WHEN COMPROBANTE IS NULL THEN ' ' ELSE UPPER(COMPROBANTE) END) LIKE UPPER(CONCAT(:COMPROBANTE, '%')) AND (CASE WHEN NOMBRE_TIPO_COMPROBANTE IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO_COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TIPO_COMPROBANTE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="NOMBRE_TIPO_COMPROBANTE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmcausacionautomatica/codigotipocomprobante/num">
		<call-query href="getCmcausacionautomaticaNumCodigotipocomprobanteQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="COMPROBANTE" query-param="COMPROBANTE"/>
			<with-param name="NOMBRE_TIPO_COMPROBANTE" query-param="NOMBRE_TIPO_COMPROBANTE"/>

		</call-query>
	</resource>
	<query id="insertCmcausacionautomatica" keyColumns="COMPANIA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CM_CAUSACION_AUTOMATICA (COMPANIA, CODIGO, TIPO_COMPROBANTE, SQL, CREATED_BY, DATE_CREATED) VALUES (:COMPANIA, :CODIGO, :TIPO_COMPROBANTE, :SQL, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param defaultValue="" name="SQL" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cmcausacionautomatica">
		<call-query href="insertCmcausacionautomatica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPO_COMPROBANTE" query-param="TIPO_COMPROBANTE"/>
			<with-param name="SQL" query-param="SQL"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteCmcausacionautomatica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CM_CAUSACION_AUTOMATICA WHERE CM_CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CM_CAUSACION_AUTOMATICA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="cmcausacionautomatica">
		<call-query href="deleteCmcausacionautomatica">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getCmcausacionautomaticaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CODIGO, TIPO_COMPROBANTE, DSS FROM CM_CAUSACION_AUTOMATICA WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN TIPO_COMPROBANTE IS NULL THEN ' ' ELSE UPPER(TIPO_COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_COMPROBANTE), '%')) AND (CASE WHEN DSS IS NULL THEN ' ' ELSE UPPER(DSS) END) LIKE UPPER(CONCAT(CONCAT('%',:DSS), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","TIPO_COMPROBANTE":"$TIPO_COMPROBANTE","DSS":"$DSS"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="DSS" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cmcausacionautomatica">
		<call-query href="getCmcausacionautomaticaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPO_COMPROBANTE" query-param="TIPO_COMPROBANTE"/>
			<with-param name="DSS" query-param="DSS"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCmcausacionautomaticaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CODIGO, TIPO_COMPROBANTE, DSS FROM CM_CAUSACION_AUTOMATICA WHERE COMPANIA = :COMPANIA ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGO), '%')) AND (CASE WHEN TIPO_COMPROBANTE IS NULL THEN ' ' ELSE UPPER(TIPO_COMPROBANTE) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_COMPROBANTE), '%')) AND (CASE WHEN DSS IS NULL THEN ' ' ELSE UPPER(DSS) END) LIKE UPPER(CONCAT(CONCAT('%',:DSS), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="DSS" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmcausacionautomatica/numero">
		<call-query href="getCmcausacionautomaticaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPO_COMPROBANTE" query-param="TIPO_COMPROBANTE"/>
			<with-param name="DSS" query-param="DSS"/>

		</call-query>
	</resource>
	<query id="getCmcausacionautomaticaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CODIGO, TIPO_COMPROBANTE, DSS, SQL, CREATED_BY, MODIFIED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM CM_CAUSACION_AUTOMATICA WHERE CM_CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CM_CAUSACION_AUTOMATICA.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGO":"$CODIGO","TIPO_COMPROBANTE":"$TIPO_COMPROBANTE","DSS":"$DSS","SQL":"$SQL","CREATED_BY":"$CREATED_BY","MODIFIED_BY":"$MODIFIED_BY","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cmcausacionautomatica/data">
		<call-query href="getCmcausacionautomaticaRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateCmcausacionautomatica" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CM_CAUSACION_AUTOMATICA SET COMPANIA=:COMPANIA, CODIGO=:CODIGO, TIPO_COMPROBANTE=:TIPO_COMPROBANTE, DSS=:DSS, SQL=:SQL, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE CM_CAUSACION_AUTOMATICA.COMPANIA= :KEY_COMPANIA AND CM_CAUSACION_AUTOMATICA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="TIPO_COMPROBANTE" sqlType="STRING"/>
		<param name="DSS" sqlType="STRING"/>
		<param name="SQL" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cmcausacionautomatica">
		<call-query href="updateCmcausacionautomatica">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="TIPO_COMPROBANTE" query-param="TIPO_COMPROBANTE"/>
			<with-param name="DSS" query-param="DSS"/>
			<with-param name="SQL" query-param="SQL"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>