<data name="beneficiariosupc" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertBeneficiariosupc" keyColumns="COMPANIA,ID_DE_EMPLEADO,IDENTIFICACION,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BENEFICIARIOS_UPC (COMPANIA, ID_DE_EMPLEADO, IDENTIFICACION, SUCURSAL, TIPO_DCTO_IDENTIDAD, PARENTESCO, FECHAN_NCTO, APELLIDO1B, APELLIDO2B, NOMBRE1B, NOMBRE2B, VALORUPC, ESTADO_ACTUALUPC, FECHAN_RETIROUPC, FECHAN_INGRESOUPC, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ID_DE_EMPLEADO, :IDENTIFICACION, :SUCURSAL, :TIPO_DCTO_IDENTIDAD, :PARENTESCO, TO_DATE(:FECHAN_NCTO,'DD/MM/YYYY HH24:MI:SS'), :APELLIDO1B, :APELLIDO2B, :NOMBRE1B, :NOMBRE2B, :VALORUPC, :ESTADO_ACTUALUPC, TO_DATE(:FECHAN_RETIROUPC,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHAN_INGRESOUPC,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_IDENTIFICACION":"$IDENTIFICACION","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param defaultValue="999999999999999999" name="IDENTIFICACION" sqlType="STRING"/>
		<param defaultValue="999" name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_DCTO_IDENTIDAD" sqlType="STRING"/>
		<param defaultValue="" name="PARENTESCO" sqlType="STRING"/>
		<param defaultValue="" name="FECHAN_NCTO" sqlType="STRING"/>
		<param defaultValue="" name="APELLIDO1B" sqlType="STRING"/>
		<param defaultValue="" name="APELLIDO2B" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE1B" sqlType="STRING"/>
		<param defaultValue="" name="NOMBRE2B" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUPC" sqlType="STRING"/>
		<param defaultValue="0" name="ESTADO_ACTUALUPC" sqlType="STRING"/>
		<param defaultValue="" name="FECHAN_RETIROUPC" sqlType="STRING"/>
		<param defaultValue="" name="FECHAN_INGRESOUPC" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="beneficiariosupc">
		<call-query href="insertBeneficiariosupc">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPO_DCTO_IDENTIDAD" query-param="TIPO_DCTO_IDENTIDAD"/>
			<with-param name="PARENTESCO" query-param="PARENTESCO"/>
			<with-param name="FECHAN_NCTO" query-param="FECHAN_NCTO"/>
			<with-param name="APELLIDO1B" query-param="APELLIDO1B"/>
			<with-param name="APELLIDO2B" query-param="APELLIDO2B"/>
			<with-param name="NOMBRE1B" query-param="NOMBRE1B"/>
			<with-param name="NOMBRE2B" query-param="NOMBRE2B"/>
			<with-param name="VALORUPC" query-param="VALORUPC"/>
			<with-param name="ESTADO_ACTUALUPC" query-param="ESTADO_ACTUALUPC"/>
			<with-param name="FECHAN_RETIROUPC" query-param="FECHAN_RETIROUPC"/>
			<with-param name="FECHAN_INGRESOUPC" query-param="FECHAN_INGRESOUPC"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBeneficiariosupc" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BENEFICIARIOS_UPC WHERE BENEFICIARIOS_UPC.COMPANIA= :KEY_COMPANIA AND BENEFICIARIOS_UPC.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND BENEFICIARIOS_UPC.IDENTIFICACION= :KEY_IDENTIFICACION AND BENEFICIARIOS_UPC.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_IDENTIFICACION" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="beneficiariosupc">
		<call-query href="deleteBeneficiariosupc">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_IDENTIFICACION" query-param="KEY_IDENTIFICACION"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getBeneficiariosupcPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT B.COMPANIA, B.SUCURSAL, T.DESCRIPCION TIPO_DOC, B.IDENTIFICACION IDENTIFICACION, B.ID_DE_EMPLEADO, CONCAT(B.APELLIDO1B,CONCAT(' ',CONCAT(B.APELLIDO2B,CONCAT(' ',CONCAT(B.NOMBRE1B,CONCAT(' ',B.NOMBRE2B) ) ) ) ) ) NOMBRE, P.DESCRIPCION PARENTESCO, CASE B.ESTADO_ACTUALUPC WHEN 1 THEN 'Activo' WHEN 3 THEN 'Retirado' ELSE 'Otro' END ESTADO FROM BENEFICIARIOS_UPC B LEFT JOIN TIPOS_DOCUMENTOS T ON B.COMPANIA = T.COMPANIA AND B.TIPO_DCTO_IDENTIDAD = T.DCTO_IDENTIDAD LEFT JOIN PARENTESCO P ON B.COMPANIA = P.COMPANIA AND B.PARENTESCO = P.PARENTESCO WHERE B.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN TIPO_DOC IS NULL THEN ' ' ELSE UPPER(TIPO_DOC) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_DOC), '%')) AND (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END) LIKE UPPER(CONCAT(:IDENTIFICACION, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PARENTESCO IS NULL THEN ' ' ELSE UPPER(PARENTESCO) END) LIKE UPPER(CONCAT(CONCAT('%',:PARENTESCO), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","SUCURSAL":"$SUCURSAL","TIPO_DOC":"$TIPO_DOC","IDENTIFICACION":"$IDENTIFICACION","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","NOMBRE":"$NOMBRE","PARENTESCO":"$PARENTESCO","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_DOC" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="beneficiariosupc">
		<call-query href="getBeneficiariosupcPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_DOC" query-param="TIPO_DOC"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PARENTESCO" query-param="PARENTESCO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBeneficiariosupcNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT B.COMPANIA, B.SUCURSAL, T.DESCRIPCION TIPO_DOC, B.IDENTIFICACION IDENTIFICACION, B.ID_DE_EMPLEADO, CONCAT(B.APELLIDO1B,CONCAT(' ',CONCAT(B.APELLIDO2B,CONCAT(' ',CONCAT(B.NOMBRE1B,CONCAT(' ',B.NOMBRE2B) ) ) ) ) ) NOMBRE, P.DESCRIPCION PARENTESCO, CASE B.ESTADO_ACTUALUPC WHEN 1 THEN 'Activo' WHEN 3 THEN 'Retirado' ELSE 'Otro' END ESTADO FROM BENEFICIARIOS_UPC B LEFT JOIN TIPOS_DOCUMENTOS T ON B.COMPANIA = T.COMPANIA AND B.TIPO_DCTO_IDENTIDAD = T.DCTO_IDENTIDAD LEFT JOIN PARENTESCO P ON B.COMPANIA = P.COMPANIA AND B.PARENTESCO = P.PARENTESCO WHERE B.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN TIPO_DOC IS NULL THEN ' ' ELSE UPPER(TIPO_DOC) END) LIKE UPPER(CONCAT(CONCAT('%',:TIPO_DOC), '%')) AND (CASE WHEN IDENTIFICACION IS NULL THEN ' ' ELSE UPPER(IDENTIFICACION) END) LIKE UPPER(CONCAT(:IDENTIFICACION, '%')) AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END) LIKE UPPER(CONCAT(:ID_DE_EMPLEADO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN PARENTESCO IS NULL THEN ' ' ELSE UPPER(PARENTESCO) END) LIKE UPPER(CONCAT(CONCAT('%',:PARENTESCO), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO_DOC" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="beneficiariosupc/numero">
		<call-query href="getBeneficiariosupcNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO_DOC" query-param="TIPO_DOC"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PARENTESCO" query-param="PARENTESCO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getBeneficiariosupcRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  BENEFICIARIOS_UPC.COMPANIA, BENEFICIARIOS_UPC.ID_DE_EMPLEADO, BENEFICIARIOS_UPC.IDENTIFICACION, BENEFICIARIOS_UPC.SUCURSAL, BENEFICIARIOS_UPC.TIPO_DCTO_IDENTIDAD, BENEFICIARIOS_UPC.PARENTESCO,(TO_CHAR(BENEFICIARIOS_UPC.FECHAN_NCTO,'DD/MM/YYYY HH24:MI:SS')) FECHAN_NCTO, BENEFICIARIOS_UPC.APELLIDO1B, BENEFICIARIOS_UPC.APELLIDO2B, BENEFICIARIOS_UPC.NOMBRE1B, BENEFICIARIOS_UPC.NOMBRE2B, BENEFICIARIOS_UPC.VALORUPC, BENEFICIARIOS_UPC.ESTADO_ACTUALUPC,(TO_CHAR(BENEFICIARIOS_UPC.FECHAN_RETIROUPC,'DD/MM/YYYY HH24:MI:SS')) FECHAN_RETIROUPC,(TO_CHAR(BENEFICIARIOS_UPC.FECHAN_INGRESOUPC,'DD/MM/YYYY HH24:MI:SS')) FECHAN_INGRESOUPC, BENEFICIARIOS_UPC.CREATED_BY,(TO_CHAR(BENEFICIARIOS_UPC.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, BENEFICIARIOS_UPC.MODIFIED_BY,(TO_CHAR(BENEFICIARIOS_UPC.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, PERSONAL.NOMBRECOMPLETO  FROM BENEFICIARIOS_UPC LEFT JOIN PERSONAL ON BENEFICIARIOS_UPC.COMPANIA= PERSONAL.COMPANIA AND BENEFICIARIOS_UPC.ID_DE_EMPLEADO= PERSONAL.ID_DE_EMPLEADO WHERE BENEFICIARIOS_UPC.COMPANIA= :KEY_COMPANIA AND BENEFICIARIOS_UPC.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND BENEFICIARIOS_UPC.IDENTIFICACION= :KEY_IDENTIFICACION AND BENEFICIARIOS_UPC.SUCURSAL= :KEY_SUCURSAL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","IDENTIFICACION":"$IDENTIFICACION","SUCURSAL":"$SUCURSAL","TIPO_DCTO_IDENTIDAD":"$TIPO_DCTO_IDENTIDAD","PARENTESCO":"$PARENTESCO","FECHAN_NCTO":"$FECHAN_NCTO","APELLIDO1B":"$APELLIDO1B","APELLIDO2B":"$APELLIDO2B","NOMBRE1B":"$NOMBRE1B","NOMBRE2B":"$NOMBRE2B","VALORUPC":"$VALORUPC","ESTADO_ACTUALUPC":"$ESTADO_ACTUALUPC(type:integer)","FECHAN_RETIROUPC":"$FECHAN_RETIROUPC","FECHAN_INGRESOUPC":"$FECHAN_INGRESOUPC","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_IDENTIFICACION" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="GET" path="beneficiariosupc/data">
		<call-query href="getBeneficiariosupcRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_IDENTIFICACION" query-param="KEY_IDENTIFICACION"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="updateBeneficiariosupc" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BENEFICIARIOS_UPC SET COMPANIA=:COMPANIA, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, IDENTIFICACION=:IDENTIFICACION, SUCURSAL=:SUCURSAL, TIPO_DCTO_IDENTIDAD=:TIPO_DCTO_IDENTIDAD, PARENTESCO=:PARENTESCO, FECHAN_NCTO=TO_DATE(:FECHAN_NCTO,'DD/MM/YYYY HH24:MI:SS'), APELLIDO1B=:APELLIDO1B, APELLIDO2B=:APELLIDO2B, NOMBRE1B=:NOMBRE1B, NOMBRE2B=:NOMBRE2B, VALORUPC=:VALORUPC, ESTADO_ACTUALUPC=:ESTADO_ACTUALUPC, FECHAN_RETIROUPC=TO_DATE(:FECHAN_RETIROUPC,'DD/MM/YYYY HH24:MI:SS'), FECHAN_INGRESOUPC=TO_DATE(:FECHAN_INGRESOUPC,'DD/MM/YYYY HH24:MI:SS'), DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BENEFICIARIOS_UPC.COMPANIA= :KEY_COMPANIA AND BENEFICIARIOS_UPC.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND BENEFICIARIOS_UPC.IDENTIFICACION= :KEY_IDENTIFICACION AND BENEFICIARIOS_UPC.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="IDENTIFICACION" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="TIPO_DCTO_IDENTIDAD" sqlType="STRING"/>
		<param name="PARENTESCO" sqlType="STRING"/>
		<param name="FECHAN_NCTO" sqlType="STRING"/>
		<param name="APELLIDO1B" sqlType="STRING"/>
		<param name="APELLIDO2B" sqlType="STRING"/>
		<param name="NOMBRE1B" sqlType="STRING"/>
		<param name="NOMBRE2B" sqlType="STRING"/>
		<param name="VALORUPC" sqlType="STRING"/>
		<param name="ESTADO_ACTUALUPC" sqlType="STRING"/>
		<param name="FECHAN_RETIROUPC" sqlType="STRING"/>
		<param name="FECHAN_INGRESOUPC" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_IDENTIFICACION" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="beneficiariosupc">
		<call-query href="updateBeneficiariosupc">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="IDENTIFICACION" query-param="IDENTIFICACION"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="TIPO_DCTO_IDENTIDAD" query-param="TIPO_DCTO_IDENTIDAD"/>
			<with-param name="PARENTESCO" query-param="PARENTESCO"/>
			<with-param name="FECHAN_NCTO" query-param="FECHAN_NCTO"/>
			<with-param name="APELLIDO1B" query-param="APELLIDO1B"/>
			<with-param name="APELLIDO2B" query-param="APELLIDO2B"/>
			<with-param name="NOMBRE1B" query-param="NOMBRE1B"/>
			<with-param name="NOMBRE2B" query-param="NOMBRE2B"/>
			<with-param name="VALORUPC" query-param="VALORUPC"/>
			<with-param name="ESTADO_ACTUALUPC" query-param="ESTADO_ACTUALUPC"/>
			<with-param name="FECHAN_RETIROUPC" query-param="FECHAN_RETIROUPC"/>
			<with-param name="FECHAN_INGRESOUPC" query-param="FECHAN_INGRESOUPC"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_IDENTIFICACION" query-param="KEY_IDENTIFICACION"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>

</data>