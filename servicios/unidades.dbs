<data name="unidades" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getUnidadesPagTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  UNIDAD.UNIDAD, UNIDAD.NOMBRE  FROM UNIDAD) WHERE (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"UNIDAD":"$UNIDAD","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="unidades/todos/pag">
		<call-query href="getUnidadesPagTodosQuery">
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getUnidadesNumTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  UNIDAD.UNIDAD, UNIDAD.NOMBRE  FROM UNIDAD) WHERE (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER(:UNIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="unidades/todos/num">
		<call-query href="getUnidadesNumTodosQuery">
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getUnidadesPorunidadQuery"  useConfig="sysmandsunist">
		<sql>SELECT  UNIDAD.UNIDAD, UNIDAD.NOMBRE  FROM UNIDAD</sql>
		<result outputType="json">{"elementos":{"elemento":[{"UNIDAD":"$UNIDAD","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="unidades/porunidad">
		<call-query href="getUnidadesPorunidadQuery">
 
		</call-query>
	</resource>
	<query id="insertUnidades" keyColumns="UNIDAD" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO UNIDAD (UNIDAD, NOMBRE, CODIGO_DIAN, CREATED_BY, DATE_CREATED) VALUES (:UNIDAD, :NOMBRE, :CODIGO_DIAN, :CREATED_BY, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_UNIDAD":"$UNIDAD"}]}}		</result>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param defaultValue="" name="CODIGO_DIAN" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="unidades">
		<call-query href="insertUnidades">
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_DIAN" query-param="CODIGO_DIAN"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="deleteUnidades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM UNIDAD WHERE UNIDAD.UNIDAD= :KEY_UNIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_UNIDAD" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="unidades">
		<call-query href="deleteUnidades">
			<with-param name="KEY_UNIDAD" query-param="KEY_UNIDAD"/>

		</call-query>
	</resource>
	<query id="getUnidadesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  UNIDAD, NOMBRE,CODIGO_DIAN, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM UNIDAD ORDER BY UNIDAD) WHERE (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER( '%' || :UNIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGO_DIAN IS NULL THEN ' ' ELSE UPPER(CODIGO_DIAN) END)  LIKE UPPER( '%' || :CODIGO_DIAN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"UNIDAD":"$UNIDAD","NOMBRE":"$NOMBRE","CODIGO_DIAN":"$CODIGO_DIAN","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_DIAN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="unidades">
		<call-query href="getUnidadesPaginaQuery">
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_DIAN" query-param="CODIGO_DIAN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getUnidadesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  UNIDAD, NOMBRE,CODIGO_DIAN, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM UNIDAD ORDER BY UNIDAD) WHERE (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END)  LIKE UPPER( '%' || :UNIDAD || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%')  AND (CASE WHEN CODIGO_DIAN IS NULL THEN ' ' ELSE UPPER(CODIGO_DIAN) END)  LIKE UPPER( '%' || :CODIGO_DIAN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_DIAN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="unidades/numero">
		<call-query href="getUnidadesNumeroQuery">
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_DIAN" query-param="CODIGO_DIAN"/>

		</call-query>
	</resource>
	<query id="updateUnidades" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE UNIDAD SET UNIDAD=:UNIDAD, NOMBRE=:NOMBRE, CODIGO_DIAN=:CODIGO_DIAN, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE UNIDAD.UNIDAD= :KEY_UNIDAD</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="UNIDAD" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGO_DIAN" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_UNIDAD" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="unidades">
		<call-query href="updateUnidades">
			<with-param name="UNIDAD" query-param="UNIDAD"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGO_DIAN" query-param="CODIGO_DIAN"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_UNIDAD" query-param="KEY_UNIDAD"/>

		</call-query>
	</resource>

</data>