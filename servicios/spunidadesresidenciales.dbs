<data name="spunidadesresidenciales" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertSpunidadesresidenciales" keyColumns="COMPANIA,CICLO,CODIGORUTA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO SP_UNIDADESRESIDENCIALES (COMPANIA, CICLO, CODIGORUTA, CONSECUTIVO, USO, ESTRATOASEO, PESOASEO, DESHABITADO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CICLO, :CODIGORUTA, :CONSECUTIVO, :USO, :ESTRATOASEO, :PESOASEO, :DESHABITADO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CICLO":"$CICLO(type:integer)","KEY_CODIGORUTA":"$CODIGORUTA","KEY_CONSECUTIVO":"$CONSECUTIVO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATOASEO" sqlType="STRING"/>
		<param defaultValue="1" name="PESOASEO" sqlType="STRING"/>
		<param defaultValue="0" name="DESHABITADO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="spunidadesresidenciales">
		<call-query href="insertSpunidadesresidenciales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATOASEO" query-param="ESTRATOASEO"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="DESHABITADO" query-param="DESHABITADO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteSpunidadesresidenciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM SP_UNIDADESRESIDENCIALES WHERE SP_UNIDADESRESIDENCIALES.COMPANIA= :KEY_COMPANIA AND SP_UNIDADESRESIDENCIALES.CICLO= :KEY_CICLO AND SP_UNIDADESRESIDENCIALES.CODIGORUTA= :KEY_CODIGORUTA AND SP_UNIDADESRESIDENCIALES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="INTEGER"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="spunidadesresidenciales">
		<call-query href="deleteSpunidadesresidenciales">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getSpunidadesresidencialesPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CICLO, CODIGORUTA, CONSECUTIVO, USO, ESTRATOASEO, PESOASEO,(CASE DESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) DESHABITADO FROM SP_UNIDADESRESIDENCIALES WHERE COMPANIA = :COMPANIA AND CICLO = :CICLOACTUAL AND CODIGORUTA = :CODIGORUTAACTUAL) WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN USO IS NULL THEN ' ' ELSE UPPER(USO) END)  LIKE UPPER(:USO || '%')  AND (CASE WHEN ESTRATOASEO IS NULL THEN ' ' ELSE UPPER(ESTRATOASEO) END)  LIKE UPPER(:ESTRATOASEO || '%')  AND (CASE WHEN PESOASEO IS NULL THEN ' ' ELSE UPPER(PESOASEO) END)  LIKE UPPER( '%' || :PESOASEO || '%')  AND (CASE WHEN DESHABITADO IS NULL THEN ' ' ELSE UPPER(DESHABITADO) END)  LIKE UPPER( '%' || :DESHABITADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","CONSECUTIVO":"$CONSECUTIVO","USO":"$USO","ESTRATOASEO":"$ESTRATOASEO","PESOASEO":"$PESOASEO","DESHABITADO":"$DESHABITADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTAACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATOASEO" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="DESHABITADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spunidadesresidenciales">
		<call-query href="getSpunidadesresidencialesPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOACTUAL" query-param="CICLOACTUAL"/>
			<with-param name="CODIGORUTAACTUAL" query-param="CODIGORUTAACTUAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATOASEO" query-param="ESTRATOASEO"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="DESHABITADO" query-param="DESHABITADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpunidadesresidencialesNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, CICLO, CODIGORUTA, CONSECUTIVO, USO, ESTRATOASEO, PESOASEO,(CASE DESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) DESHABITADO FROM SP_UNIDADESRESIDENCIALES WHERE COMPANIA = :COMPANIA AND CICLO = :CICLOACTUAL AND CODIGORUTA = :CODIGORUTAACTUAL) WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER( '%' || :CODIGORUTA || '%')  AND (CASE WHEN USO IS NULL THEN ' ' ELSE UPPER(USO) END)  LIKE UPPER( '%' || :USO || '%')  AND (CASE WHEN ESTRATOASEO IS NULL THEN ' ' ELSE UPPER(ESTRATOASEO) END)  LIKE UPPER( '%' || :ESTRATOASEO || '%')  AND (CASE WHEN PESOASEO IS NULL THEN ' ' ELSE UPPER(PESOASEO) END)  LIKE UPPER( '%' || :PESOASEO || '%')  AND (CASE WHEN DESHABITADO IS NULL THEN ' ' ELSE UPPER(DESHABITADO) END)  LIKE UPPER( '%' || :DESHABITADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTAACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATOASEO" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="DESHABITADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spunidadesresidenciales/numero">
		<call-query href="getSpunidadesresidencialesNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLOACTUAL" query-param="CICLOACTUAL"/>
			<with-param name="CODIGORUTAACTUAL" query-param="CODIGORUTAACTUAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATOASEO" query-param="ESTRATOASEO"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="DESHABITADO" query-param="DESHABITADO"/>

		</call-query>
	</resource>
	<query id="updateSpunidadesresidenciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_UNIDADESRESIDENCIALES SET COMPANIA=:COMPANIA, CICLO=:CICLO, CODIGORUTA=:CODIGORUTA, CONSECUTIVO=:CONSECUTIVO, USO=:USO, ESTRATOASEO=:ESTRATOASEO, PESOASEO=:PESOASEO, DESHABITADO=:DESHABITADO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_UNIDADESRESIDENCIALES.COMPANIA= :KEY_COMPANIA AND SP_UNIDADESRESIDENCIALES.CICLO= :KEY_CICLO AND SP_UNIDADESRESIDENCIALES.CODIGORUTA= :KEY_CODIGORUTA AND SP_UNIDADESRESIDENCIALES.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="ESTRATOASEO" sqlType="STRING"/>
		<param name="PESOASEO" sqlType="STRING"/>
		<param name="DESHABITADO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spunidadesresidenciales">
		<call-query href="updateSpunidadesresidenciales">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="USO" query-param="USO"/>
			<with-param name="ESTRATOASEO" query-param="ESTRATOASEO"/>
			<with-param name="PESOASEO" query-param="PESOASEO"/>
			<with-param name="DESHABITADO" query-param="DESHABITADO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>