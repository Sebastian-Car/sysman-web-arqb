<data name="nattipoidiomas" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getNattipoidiomasTodosCodigoYNombreQuery"  useConfig="sysmandsunist">
		<sql>SELECT  I_CODIGO, I_NOMBRE  FROM NAT_TIPO_IDIOMAS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"I_CODIGO":"$I_CODIGO","I_NOMBRE":"$I_NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="nattipoidiomas/todoscodigoynombre">
		<call-query href="getNattipoidiomasTodosCodigoYNombreQuery">
 
		</call-query>
	</resource>
	<query id="getNattipoidiomasTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  I_CODIGO CODIGO, I_NOMBRE NOMBRE  FROM NAT_TIPO_IDIOMAS</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","NOMBRE":"$NOMBRE"}]}}		</result>
 
	</query>
	<resource method="GET" path="nattipoidiomas/todos">
		<call-query href="getNattipoidiomasTodosQuery">
 
		</call-query>
	</resource>

</data>