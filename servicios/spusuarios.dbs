	</resource>
	<query id="getSpusuariosPagTodosPorCodigoRutaCompaniaCicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE, CICLO, CODIGOINTERNO, MATRICULA, FIMM FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO ORDER BY CICLO, CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(CONCAT('%',:CICLO), '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOINTERNO), '%')) AND (CASE WHEN MATRICULA IS NULL THEN ' ' ELSE UPPER(MATRICULA) END) LIKE UPPER(CONCAT(CONCAT('%',:MATRICULA), '%')) AND (CASE WHEN FIMM IS NULL THEN ' ' ELSE UPPER(FIMM) END) LIKE UPPER(CONCAT(CONCAT('%',:FIMM), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","CICLO":"$CICLO(type:integer)","CODIGOINTERNO":"$CODIGOINTERNO","MATRICULA":"$MATRICULA","FIMM":"$FIMM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="MATRICULA" sqlType="STRING"/>
		<param name="FIMM" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
