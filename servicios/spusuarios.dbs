	<query id="updateSpusuariosAforoIncentivo" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET AFOROINCENTIVO = :APLICAINCENTIVO,      DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),      MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA   AND CICLO = :CICLO   AND BARRIO = :BARRIO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="APLICAINCENTIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="BARRIO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/aforoincentivo">
		<call-query href="updateSpusuariosAforoIncentivo">
			<with-param name="APLICAINCENTIVO" query-param="APLICAINCENTIVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="BARRIO" query-param="BARRIO"/>

		</call-query>
	</resource>
