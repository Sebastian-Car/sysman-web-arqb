	<query id="getSpusuariosPagUsuarioCodigoCatastralErradoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CICLO, CODIGOINTERNO, CODIGORUTA, TRIM(CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) ) NOMBRES, CODIGOCATASTRAL, LENGTH(CODIGOCATASTRAL) AS LARGO FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO AND LENGTH(CODIGOCATASTRAL) &lt;&gt; 15) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGORUTA), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN CODIGOCATASTRAL IS NULL THEN ' ' ELSE UPPER(CODIGOCATASTRAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCATASTRAL), '%')) AND (CASE WHEN LARGO IS NULL THEN ' ' ELSE UPPER(LARGO) END) LIKE UPPER(CONCAT(:LARGO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGOINTERNO":"$CODIGOINTERNO","CODIGORUTA":"$CODIGORUTA","NOMBRES":"$NOMBRES","CODIGOCATASTRAL":"$CODIGOCATASTRAL","LARGO":"$LARGO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="CODIGOCATASTRAL" sqlType="STRING"/>
		<param name="LARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
