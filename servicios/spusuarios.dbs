		<sql>SELECT  COUNT(1) CUENTA  FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA = :COMPANIA AND SP_USUARIO.CODIGORUTA BETWEEN :CODIGOINICIAL AND :CODIGOFINAL AND SP_USUARIO.CICLO BETWEEN :CICLOINICIAL AND :CICLOFINAL AND SP_USUARIO.ESTADO &lt;&gt; 'R' AND SP_USUARIO.ASEO IN (0) AND (SP_USUARIO.VASEOUNICO+SP_USUARIO.VASEODOMICILIARIO+SP_USUARIO.VASEOBARRIDO+SP_USUARIO.VASEOCONSUMO+SP_USUARIO.VDESHABITADO+SP_USUARIO.VTRAMOEXCEDENTE&lt;&gt;0)</sql>
