	<query id="updateSpusuariosCodSusLecturaConsumoAforoConsumos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET AFOROCONSMANUAL=:AFOROCONSMANUAL, CONSUMOACUMANUAL=:CONSUMOACUMANUAL, CONSUMOALCMANUAL=:CONSUMOALCMANUAL, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="AFOROCONSMANUAL" sqlType="STRING"/>
