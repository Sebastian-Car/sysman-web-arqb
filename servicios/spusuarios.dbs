			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumPorCicloYEstadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE, LECTURA1,(TO_CHAR(FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS')) FECHALECTURAAFORO FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO AND ESTADO NOT IN (:ESTADO) ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN LECTURA1 IS NULL THEN ' ' ELSE UPPER(LECTURA1) END) LIKE UPPER(CONCAT(:LECTURA1, '%')) AND (CASE WHEN FECHALECTURAAFORO IS NULL THEN ' ' ELSE UPPER(FECHALECTURAAFORO) END) LIKE UPPER(CONCAT(:FECHALECTURAAFORO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="LECTURA1" sqlType="STRING"/>
		<param name="FECHALECTURAAFORO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/porcicloyestado/num">
		<call-query href="getSpusuariosNumPorCicloYEstadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="LECTURA1" query-param="LECTURA1"/>
			<with-param name="FECHALECTURAAFORO" query-param="FECHALECTURAAFORO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosConsultarMedidoresRepetidosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO.COMPANIA , SP_USUARIO.CICLO, SP_USUARIO.MEDIDOR, COUNT(SP_USUARIO.MEDIDOR) REPETIDOS  FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA = :COMPANIA GROUP BY SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.MEDIDOR HAVING COUNT(SP_USUARIO.MEDIDOR) &gt; 1 ORDER BY COUNT(SP_USUARIO.MEDIDOR)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","MEDIDOR":"$MEDIDOR","REPETIDOS":"$REPETIDOS(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
