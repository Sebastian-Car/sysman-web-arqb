			<with-param name="DEUDAINICIAL" query-param="DEUDAINICIAL"/>
			<with-param name="NUMERODIGITOS" query-param="NUMERODIGITOS"/>
			<with-param name="PERIODOSATRASOINICIAL" query-param="PERIODOSATRASOINICIAL"/>
			<with-param name="CONSUMOPROM" query-param="CONSUMOPROM"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumListarDatosInicialesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, SP_USUARIO.ANO, SP_USUARIO.PERIODO, CONCAT(NVL(SP_USUARIO.PRIMERAPELLIDO,''),CONCAT(' ',CONCAT(NVL(SP_USUARIO.SEGUNDOAPELLIDO,''),CONCAT(' ',NVL(SP_USUARIO.NOMBRES ,'') ) ) ) ) NOMBRE, SP_USUARIO.CODIGOINTERNO, SP_USUARIO.LECTURA, SP_USUARIO.LECTURA1, SP_USUARIO.DEUDA, SP_USUARIO.LECTURAINICIAL, SP_USUARIO.LECTURAANTINICIAL, SP_USUARIO.DEUDAINICIAL, SP_USUARIO.LECTURAAFORO, SP_USUARIO.NUMERODIGITOS, SP_USUARIO.PERIODOSATRASOINICIAL, SP_USUARIO.CONSUMOPROM FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND SP_USUARIO.ANO =:ANO AND SP_USUARIO.PERIODO =:PERIODO) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGORUTA), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOINTERNO), '%')) AND (CASE WHEN DEUDA IS NULL THEN ' ' ELSE UPPER(DEUDA) END) LIKE UPPER(CONCAT(CONCAT('%',:DEUDA), '%')) AND (CASE WHEN LECTURAINICIAL IS NULL THEN ' ' ELSE UPPER(LECTURAINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURAINICIAL), '%')) AND (CASE WHEN LECTURAANTINICIAL IS NULL THEN ' ' ELSE UPPER(LECTURAANTINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURAANTINICIAL), '%')) AND (CASE WHEN DEUDAINICIAL IS NULL THEN ' ' ELSE UPPER(DEUDAINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:DEUDAINICIAL), '%')) AND (CASE WHEN NUMERODIGITOS IS NULL THEN ' ' ELSE UPPER(NUMERODIGITOS) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERODIGITOS), '%')) AND (CASE WHEN PERIODOSATRASOINICIAL IS NULL THEN ' ' ELSE UPPER(PERIODOSATRASOINICIAL) END) LIKE UPPER(CONCAT(CONCAT('%',:PERIODOSATRASOINICIAL), '%')) AND (CASE WHEN CONSUMOPROM IS NULL THEN ' ' ELSE UPPER(CONSUMOPROM) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMOPROM), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="DEUDA" sqlType="STRING"/>
		<param name="LECTURAINICIAL" sqlType="STRING"/>
		<param name="LECTURAANTINICIAL" sqlType="STRING"/>
		<param name="DEUDAINICIAL" sqlType="STRING"/>
		<param name="NUMERODIGITOS" sqlType="STRING"/>
		<param name="PERIODOSATRASOINICIAL" sqlType="STRING"/>
		<param name="CONSUMOPROM" sqlType="STRING"/>

	</query>
