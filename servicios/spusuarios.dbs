		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT SP_USUARIO.CODIGOINTERNO, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) EXPR1, SP_USUARIO.CODIGORUTA, SP_USUARIO.COMPANIA, SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.CICLO, SP_USUARIO.TOTFACTURAPERACTUAL, NVL(FIMM,'') EXPR2, NVL(BANCOPERPROCESO,'') EXPR3, SP_USUARIO.ESTADO, SP_USUARIO.BANCOPERPROCESO FROM SP_USUARIO WHERE ( SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND NVL(FIMM,'') NOT IN ('P') AND SP_USUARIO.ESTADO NOT IN ('R','S') AND SP_USUARIO.BANCOPERPROCESO IS NULL OR NVL(FIMM,'') NOT IN ('P') ) ORDER BY SP_USUARIO.CODIGORUTA, SP_USUARIO.COMPANIA, SP_USUARIO.CICLO) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN EXPR1 IS NULL THEN ' ' ELSE UPPER(EXPR1) END) LIKE UPPER(CONCAT(CONCAT('%',:EXPR1), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOINTERNO":"$CODIGOINTERNO","EXPR1":"$EXPR1","CODIGORUTA":"$CODIGORUTA","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CICLO":"$CICLO(type:integer)","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","EXPR2":"$EXPR2","EXPR3":"$EXPR3","ESTADO":"$ESTADO","BANCOPERPROCESO":"$BANCOPERPROCESO"}]}}		</result>
