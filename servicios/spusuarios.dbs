	<query id="getSpusuariosPagCodSusLecturaConsumoAforoConsumosPorCicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CICLO, CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE, LECTURA, LECTURAAFORO, ( LECTURAAFORO - LECTURA ) CONSUMO,(CASE AFOROCONSMANUAL WHEN 0 THEN 'false' ELSE 'true' END) AFOROCONSMANUAL, CONSUMOACUMANUAL, CONSUMOALCMANUAL, TOTALIZADOR FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO AND TOTALIZADOR IS NULL) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGORUTA), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN LECTURA IS NULL THEN ' ' ELSE UPPER(LECTURA) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURA), '%')) AND (CASE WHEN LECTURAAFORO IS NULL THEN ' ' ELSE UPPER(LECTURAAFORO) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURAAFORO), '%')) AND (CASE WHEN CONSUMO IS NULL THEN ' ' ELSE UPPER(CONSUMO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMO), '%')) AND (CASE WHEN AFOROCONSMANUAL IS NULL THEN ' ' ELSE UPPER(AFOROCONSMANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:AFOROCONSMANUAL), '%')) AND (CASE WHEN CONSUMOACUMANUAL IS NULL THEN ' ' ELSE UPPER(CONSUMOACUMANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMOACUMANUAL), '%')) AND (CASE WHEN CONSUMOALCMANUAL IS NULL THEN ' ' ELSE UPPER(CONSUMOALCMANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMOALCMANUAL), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","LECTURA":"$LECTURA","LECTURAAFORO":"$LECTURAAFORO","CONSUMO":"$CONSUMO(type:integer)","AFOROCONSMANUAL":"$AFOROCONSMANUAL(type:boolean)","CONSUMOACUMANUAL":"$CONSUMOACUMANUAL","CONSUMOALCMANUAL":"$CONSUMOALCMANUAL","TOTALIZADOR":"$TOTALIZADOR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="LECTURA" sqlType="STRING"/>
		<param name="LECTURAAFORO" sqlType="STRING"/>
		<param name="CONSUMO" sqlType="STRING"/>
		<param name="AFOROCONSMANUAL" sqlType="STRING"/>
		<param name="CONSUMOACUMANUAL" sqlType="STRING"/>
		<param name="CONSUMOALCMANUAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/codsuslecturaconsumoaforoconsumosporciclo/pag">
		<call-query href="getSpusuariosPagCodSusLecturaConsumoAforoConsumosPorCicloQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
