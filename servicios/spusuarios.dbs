	<query id="getSpusuariosPagPorCicloYEstadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE, LECTURA1,(TO_CHAR(FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS')) FECHALECTURAAFORO FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO AND ESTADO NOT IN (:ESTADO) ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN LECTURA1 IS NULL THEN ' ' ELSE UPPER(LECTURA1) END) LIKE UPPER(CONCAT(:LECTURA1, '%')) AND (CASE WHEN FECHALECTURAAFORO IS NULL THEN ' ' ELSE UPPER(FECHALECTURAAFORO) END) LIKE UPPER(CONCAT(:FECHALECTURAAFORO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","LECTURA1":"$LECTURA1","FECHALECTURAAFORO":"$FECHALECTURAAFORO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="LECTURA1" sqlType="STRING"/>
		<param name="FECHALECTURAAFORO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/porcicloyestado/pag">
