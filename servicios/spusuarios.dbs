	<query id="getSpusuariosNumTodosPorPrincipalGrillaCorreccionCriticaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) ) NOMBRE, SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.CODIGOINTERNO, SP_USUARIO.DIRTECNICA, SP_USOS.NOMBRE USO, SP_USUARIO.NUMERODIGITOS, SP_USUARIO.LECTURA, SP_USUARIO.LECTURAAFORO,(TO_CHAR(SP_USUARIO.FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS')) FECHALECTURAAFORO, TERCERO.NOMBRE AS AFORADOR,(CASE SP_USUARIO.INDDESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) INDDESHABITADO FROM SP_USUARIO INNER JOIN SP_AFORADORES ON SP_USUARIO.COMPANIA = SP_AFORADORES.COMPANIA AND SP_USUARIO.AFORADOR = SP_AFORADORES.CODIGO INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL INNER JOIN SP_TARIFAS ON SP_TARIFAS.COMPANIA = SP_USUARIO.COMPANIA AND SP_TARIFAS.ANO = SP_USUARIO.ANO AND SP_TARIFAS.PERIODO = SP_USUARIO.PERIODO AND SP_TARIFAS.USO = SP_USUARIO.USO AND SP_TARIFAS.ESTRATO = SP_USUARIO.ESTRATO INNER JOIN SP_USOS ON SP_TARIFAS.COMPANIA = SP_USOS.COMPANIA AND SP_TARIFAS.USO = SP_USOS.CODIGO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO ORDER BY SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA) INI WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN DIRTECNICA IS NULL THEN ' ' ELSE UPPER(DIRTECNICA) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRTECNICA), '%')) AND (CASE WHEN USO IS NULL THEN ' ' ELSE UPPER(USO) END) LIKE UPPER(CONCAT(:USO, '%')) AND (CASE WHEN NUMERODIGITOS IS NULL THEN ' ' ELSE UPPER(NUMERODIGITOS) END) LIKE UPPER(CONCAT(:NUMERODIGITOS, '%')) AND (CASE WHEN LECTURA IS NULL THEN ' ' ELSE UPPER(LECTURA) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURA), '%')) AND (CASE WHEN LECTURAAFORO IS NULL THEN ' ' ELSE UPPER(LECTURAAFORO) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURAAFORO), '%')) AND (CASE WHEN FECHALECTURAAFORO IS NULL THEN ' ' ELSE UPPER(FECHALECTURAAFORO) END) LIKE UPPER(CONCAT(:FECHALECTURAAFORO, '%')) AND (CASE WHEN AFORADOR IS NULL THEN ' ' ELSE UPPER(AFORADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:AFORADOR), '%')) AND (CASE WHEN INDDESHABITADO IS NULL THEN ' ' ELSE UPPER(INDDESHABITADO) END) LIKE UPPER(CONCAT(:INDDESHABITADO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
