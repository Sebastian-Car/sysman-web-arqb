	<resource method="GET" path="spusuarios/data">
		<call-query href="getSpusuariosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="updateSpusuarios" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET ANO=:ANO, PERIODO=:PERIODO, PRIMERAPELLIDO=:PRIMERAPELLIDO, SEGUNDOAPELLIDO=:SEGUNDOAPELLIDO, NOMBRES=:NOMBRES, TOTFACTURAPERACTUAL=:TOTFACTURAPERACTUAL, CODIGOINTERNO=:CODIGOINTERNO, CODIGOANTERIOR=:CODIGOANTERIOR, DIRTECNICA=:DIRTECNICA, DIRGUIA=:DIRGUIA, DIRCORRESPONDENCIA=:DIRCORRESPONDENCIA, TELEFONO=:TELEFONO, TIPODOCUMENTO=:TIPODOCUMENTO, NIT=:NIT, FAX=:FAX, EMAIL=:EMAIL, CODIGOCATASTRAL=:CODIGOCATASTRAL, CODIGOMAPA=:CODIGOMAPA, USO=:USO, ESTRATO=:ESTRATO, ACUEDUCTO=:ACUEDUCTO, ASEO=:ASEO, ASEOBARRIDO=:ASEOBARRIDO, ALCANTARILLADO=:ALCANTARILLADO, PORCENTAJEAPLICAR=:PORCENTAJEAPLICAR, ESTRATOASEO=:ESTRATOASEO, PESOASEO=:PESOASEO, FRECUENCIAASEOSEMANA=:FRECUENCIAASEOSEMANA, ESTADO=:ESTADO, COMENTARIOS=:COMENTARIOS, MEDIDOR=:MEDIDOR, NUMERODIGITOS=:NUMERODIGITOS, AFORADOR=:AFORADOR, PERIODOSATRASO=:PERIODOSATRASO, NOTACREDITO=:NOTACREDITO, INDFACTURADO=:INDFACTURADO, INDPREPARADO=:INDPREPARADO, INDESTADISTICAS=:INDESTADISTICAS, INDCALCULADO=:INDCALCULADO, INDIMPRESION=:INDIMPRESION, AUTORIZAMODIFICACION=:AUTORIZAMODIFICACION, AUTORIZARBORRADO=:AUTORIZARBORRADO, NUMEROREGISTRO=:NUMEROREGISTRO, OPERACION=:OPERACION, PERIODOSINLECTURA=:PERIODOSINLECTURA, ACUMULADO=:ACUMULADO, TIPOCALCULO=:TIPOCALCULO, IND_MEDIDORNUEVO=:IND_MEDIDORNUEVO, FIMM=:FIMM, ALUMBRADO=:ALUMBRADO, ESTRATOALUMBRADO=:ESTRATOALUMBRADO, INQUILINATOS=:INQUILINATOS, CREDITOABONADO=:CREDITOABONADO, FACTURA=:FACTURA, TIPOPREDIO=:TIPOPREDIO, MULTIFAMILIAR=:MULTIFAMILIAR, PISO=:PISO, FECHAINSCRIPCION=TO_DATE(:FECHAINSCRIPCION,'DD/MM/YYYY HH24:MI:SS'), CODIGO_EXTERNO=:CODIGO_EXTERNO, DIAMETROACOMETIDA=:DIAMETROACOMETIDA, INDFINANINICIAL=:INDFINANINICIAL, FECHAINSTALACION=TO_DATE(:FECHAINSTALACION,'DD/MM/YYYY HH24:MI:SS'), ABONOS=:ABONOS, ESTADOMEDIDOR=:ESTADOMEDIDOR, INDBANCOS=:INDBANCOS, CHAPETAS=:CHAPETAS, PSLM3=:PSLM3, PLANTA=:PLANTA, CIIU=:CIIU, NUMEROACOMETIDA=:NUMEROACOMETIDA, FRECUENCIARECOLECCION=:FRECUENCIARECOLECCION, TIPOCOBRO=:TIPOCOBRO, INDMEDCAMBIADO=:INDMEDCAMBIADO, TIPOLECFIMM=:TIPOLECFIMM, SUBSINMEDICION=:SUBSINMEDICION, SOBRESINMEDICION=:SOBRESINMEDICION, TASACAR=:TASACAR, SELLOFIMM=:SELLOFIMM, NOUNDMULTIUSUARIO=:NOUNDMULTIUSUARIO, ACSINMEDICION=:ACSINMEDICION, ALSINMEDICION=:ALSINMEDICION, SECTHIDRAULICO=:SECTHIDRAULICO, SUBSECTOR=:SUBSECTOR, REDHIDRAULICA=:REDHIDRAULICA, SECCION=:SECCION, MANZANA=:MANZANA, EXCLUIRCARTERA=:EXCLUIRCARTERA, LECTURACRITICA=:LECTURACRITICA, MATRICULA=:MATRICULA, SUBALCSINMEDICION=:SUBALCSINMEDICION, SOBREALCSINMEDICION=:SOBREALCSINMEDICION, INDRECAUDADO=:INDRECAUDADO, NOTADEBITO=:NOTADEBITO, SEPARACIONENFUENTE=:SEPARACIONENFUENTE, NOPUERTAPUERTA=:NOPUERTAPUERTA, APARTAMENTO=:APARTAMENTO, FECHALIMITE2=TO_DATE(:FECHALIMITE2,'DD/MM/YYYY HH24:MI:SS'), POSICION_MEDIDOR=:POSICION_MEDIDOR, SECTOR=:SECTOR, CODIGODANE=:CODIGODANE, LADO=:LADO, RECARGOALC=:RECARGOALC, FECHACAMBIOEST=TO_DATE(:FECHACAMBIOEST,'DD/MM/YYYY HH24:MI:SS'), FECHARENTRADANUEVOUSUARIO=TO_DATE(:FECHARENTRADANUEVOUSUARIO,'DD/MM/YYYY HH24:MI:SS'), PERENTRADANUEVOUSUARIO=:PERENTRADANUEVOUSUARIO, ANOENTRADANUEVOUSUARIO=:ANOENTRADANUEVOUSUARIO, PERIODOSNOCOBROFIN=:PERIODOSNOCOBROFIN, PERIODOSNOCOBROFAC=:PERIODOSNOCOBROFAC, FECHASALIOUSUARIO=TO_DATE(:FECHASALIOUSUARIO,'DD/MM/YYYY HH24:MI:SS'), TOTALIZADOR=:TOTALIZADOR, BANCOPERPROCESO=:BANCOPERPROCESO, DEUDA=:DEUDA, TOTALDEUDA=:TOTALDEUDA, FECHAPAGOPERPROCESO=TO_DATE(:FECHAPAGOPERPROCESO,'DD/MM/YYYY HH24:MI:SS'), PAQUETEPAGOPERPROCESO=:PAQUETEPAGOPERPROCESO, NOFECHAPAGOPERPROCESO=:NOFECHAPAGOPERPROCESO, RECAUDADOPROCESO=:RECAUDADOPROCESO, GEOREFERENCIACION=:GEOREFERENCIACION, TIPODEAFORO=:TIPODEAFORO, EMPRESAASEOEXT=:EMPRESAASEOEXT, FECHAINGASEOEXT=TO_DATE(:FECHAINGASEOEXT,'DD/MM/YYYY HH24:MI:SS'), PINTADEUDATERCE=:PINTADEUDATERCE, FREC_RECO=:FREC_RECO, FREC_BARRI=:FREC_BARRI, CARACTERIZACION_ALC=:CARACTERIZACION_ALC, HOGAR_COMUNITARIO=:HOGAR_COMUNITARIO, INDDESHABITADO=:INDDESHABITADO, POSTAL=:POSTAL, INDMULTIUSUARIO=:INDMULTIUSUARIO, BARRIO=:BARRIO, CODMACROMEDIDOR=:CODMACROMEDIDOR, CODTOTALIZADOR=:CODTOTALIZADOR, RUTARECOLECCION_720=:RUTARECOLECCION_720, MICRORUTARECOLECCION_720=:MICRORUTARECOLECCION_720, AREA=:AREA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

