			<with-param name="CONSUMOPROM" query-param="CONSUMOPROM"/>

		</call-query>
	</resource>
	<query id="updateSpusuariosDatosIniciales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET CODIGORUTA=:CODIGORUTA, CODIGOINTERNO=:CODIGOINTERNO, DEUDA=:DEUDA, LECTURAINICIAL=:LECTURAINICIAL, LECTURAANTINICIAL=:LECTURAANTINICIAL, DEUDAINICIAL=:DEUDAINICIAL, NUMERODIGITOS=:NUMERODIGITOS, PERIODOSATRASOINICIAL=:PERIODOSATRASOINICIAL, CONSUMOPROM=:CONSUMOPROM, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="DEUDA" sqlType="STRING"/>
		<param name="LECTURAINICIAL" sqlType="STRING"/>
		<param name="LECTURAANTINICIAL" sqlType="STRING"/>
		<param name="DEUDAINICIAL" sqlType="STRING"/>
		<param name="NUMERODIGITOS" sqlType="STRING"/>
		<param name="PERIODOSATRASOINICIAL" sqlType="STRING"/>
		<param name="CONSUMOPROM" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/datosiniciales">
