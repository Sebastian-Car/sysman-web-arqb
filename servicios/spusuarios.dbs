	<query id="getSpusuariosTodosPorBancoprocesoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO.BANCOPERPROCESO  FROM SP_USUARIO INNER JOIN SP_DESVIACIONES ON SP_USUARIO.COMPANIA = SP_DESVIACIONES.COMPANIA AND SP_USUARIO.CICLO = SP_DESVIACIONES.CICLO AND SP_USUARIO.CODIGORUTA = SP_DESVIACIONES.CODIGORUTA WHERE SP_DESVIACIONES.COMPANIA = :COMPANIA AND SP_USUARIO.CICLO = :CICLO AND SP_USUARIO.CODIGORUTA = :CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"BANCOPERPROCESO":"$BANCOPERPROCESO"}]}}		</result>
