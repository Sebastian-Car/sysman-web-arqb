	<query id="getSpusuariosPagOrigenusuariossincodQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CICLO, CODIGORUTA, CODIGOINTERNO, TRIM(CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) ) NOMBRES, CODIGOCATASTRAL FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLOFILTRO AND CODIGOCATASTRAL IS NULL ORDER BY CODIGORUTA, TRIM(CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) )) INI WHERE (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN CODIGOCATASTRAL IS NULL THEN ' ' ELSE UPPER(CODIGOCATASTRAL) END) LIKE UPPER(CONCAT(:CODIGOCATASTRAL, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","CODIGOINTERNO":"$CODIGOINTERNO","NOMBRES":"$NOMBRES","CODIGOCATASTRAL":"$CODIGOCATASTRAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOFILTRO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="CODIGOCATASTRAL" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
