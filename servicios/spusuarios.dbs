	<query id="getSpusuariosPrimerYUltimaFechaPorCicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT (TO_CHAR(MAX(FECHAPAGOPERPROCESO),'DD/MM/YYYY HH24:MI:SS')) ULTIMAFECHA,(TO_CHAR(MIN(FECHAPAGOPERPROCESO),'DD/MM/YYYY HH24:MI:SS')) PRIMERAFECHA FROM SP_USUARIO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO</sql>
