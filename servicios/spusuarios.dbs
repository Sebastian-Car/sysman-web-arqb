	<query id="getSpusuariosPagPorCicloEmpexternaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.ANO, SP_USUARIO.PERIODO, CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ) NOMBRE, SP_USUARIO.CODIGORUTA, SP_USUARIO.CODIGOINTERNO, SP_USUARIO.EMPRESAASEOEXT, SP_EMPRESAS_TERCERIZA.NOMBRE NOMBREEMPRESA,(TO_CHAR(SP_USUARIO.FECHAINGASEOEXT,'DD/MM/YYYY HH24:MI:SS')) FECHAINGASEOEXT,(CASE SP_USUARIO.ASEO WHEN 0 THEN 'false' ELSE 'true' END) ASEO, SP_USUARIO.CODIGO_EXTERNO, CASE SP_USUARIO.ESTADO WHEN 'A' THEN 'Activo' WHEN 'S' THEN 'Suspendido' WHEN 'C' THEN 'Cortado' WHEN 'R' THEN 'Retirado' END  ESTADO,(CASE SP_USUARIO.ASEOBARRIDO WHEN 0 THEN 'false' ELSE 'true' END) ASEOBARRIDO,(CASE SP_USUARIO.PINTADEUDATERCE WHEN 0 THEN 'false' ELSE 'true' END) PINTADEUDATERCE FROM SP_USUARIO INNER JOIN SP_EMPRESAS_TERCERIZA ON SP_USUARIO.COMPANIA = SP_EMPRESAS_TERCERIZA.COMPANIA AND SP_USUARIO.EMPRESAASEOEXT = SP_EMPRESAS_TERCERIZA.ID WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO ORDER BY CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ), CODIGORUTA) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN NOMBREEMPRESA IS NULL THEN ' ' ELSE UPPER(NOMBREEMPRESA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREEMPRESA), '%')) AND (CASE WHEN FECHAINGASEOEXT IS NULL THEN ' ' ELSE UPPER(FECHAINGASEOEXT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAINGASEOEXT), '%')) AND (CASE WHEN ASEO IS NULL THEN ' ' ELSE UPPER(ASEO) END) LIKE UPPER(CONCAT(:ASEO, '%')) AND (CASE WHEN CODIGO_EXTERNO IS NULL THEN ' ' ELSE UPPER(CODIGO_EXTERNO) END) LIKE UPPER(CONCAT(:CODIGO_EXTERNO, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN ASEOBARRIDO IS NULL THEN ' ' ELSE UPPER(ASEOBARRIDO) END) LIKE UPPER(CONCAT(:ASEOBARRIDO, '%')) AND (CASE WHEN PINTADEUDATERCE IS NULL THEN ' ' ELSE UPPER(PINTADEUDATERCE) END) LIKE UPPER(CONCAT(:PINTADEUDATERCE, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","NOMBRE":"$NOMBRE","CODIGORUTA":"$CODIGORUTA","CODIGOINTERNO":"$CODIGOINTERNO","EMPRESAASEOEXT":"$EMPRESAASEOEXT","NOMBREEMPRESA":"$NOMBREEMPRESA","FECHAINGASEOEXT":"$FECHAINGASEOEXT","ASEO":"$ASEO(type:boolean)","CODIGO_EXTERNO":"$CODIGO_EXTERNO","ESTADO":"$ESTADO","ASEOBARRIDO":"$ASEOBARRIDO(type:boolean)","PINTADEUDATERCE":"$PINTADEUDATERCE(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="NOMBREEMPRESA" sqlType="STRING"/>
		<param name="FECHAINGASEOEXT" sqlType="STRING"/>
		<param name="ASEO" sqlType="STRING"/>
		<param name="CODIGO_EXTERNO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="ASEOBARRIDO" sqlType="STRING"/>
		<param name="PINTADEUDATERCE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/porcicloempexterna/pag">
		<call-query href="getSpusuariosPagPorCicloEmpexternaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="NOMBREEMPRESA" query-param="NOMBREEMPRESA"/>
			<with-param name="FECHAINGASEOEXT" query-param="FECHAINGASEOEXT"/>
			<with-param name="ASEO" query-param="ASEO"/>
			<with-param name="CODIGO_EXTERNO" query-param="CODIGO_EXTERNO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="ASEOBARRIDO" query-param="ASEOBARRIDO"/>
			<with-param name="PINTADEUDATERCE" query-param="PINTADEUDATERCE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumPorCicloEmpexternaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.ANO, SP_USUARIO.PERIODO, CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ) NOMBRE, SP_USUARIO.CODIGORUTA, SP_USUARIO.CODIGOINTERNO, SP_USUARIO.EMPRESAASEOEXT, SP_EMPRESAS_TERCERIZA.NOMBRE NOMBREEMPRESA,(TO_CHAR(SP_USUARIO.FECHAINGASEOEXT,'DD/MM/YYYY HH24:MI:SS')) FECHAINGASEOEXT,(CASE SP_USUARIO.ASEO WHEN 0 THEN 'false' ELSE 'true' END) ASEO, SP_USUARIO.CODIGO_EXTERNO, CASE SP_USUARIO.ESTADO WHEN 'A' THEN 'Activo' WHEN 'S' THEN 'Suspendido' WHEN 'C' THEN 'Cortado' WHEN 'R' THEN 'Retirado' END  ESTADO,(CASE SP_USUARIO.ASEOBARRIDO WHEN 0 THEN 'false' ELSE 'true' END) ASEOBARRIDO,(CASE SP_USUARIO.PINTADEUDATERCE WHEN 0 THEN 'false' ELSE 'true' END) PINTADEUDATERCE FROM SP_USUARIO INNER JOIN SP_EMPRESAS_TERCERIZA ON SP_USUARIO.COMPANIA = SP_EMPRESAS_TERCERIZA.COMPANIA AND SP_USUARIO.EMPRESAASEOEXT = SP_EMPRESAS_TERCERIZA.ID WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO ORDER BY CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ), CODIGORUTA) INI WHERE (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN NOMBREEMPRESA IS NULL THEN ' ' ELSE UPPER(NOMBREEMPRESA) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREEMPRESA), '%')) AND (CASE WHEN FECHAINGASEOEXT IS NULL THEN ' ' ELSE UPPER(FECHAINGASEOEXT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAINGASEOEXT), '%')) AND (CASE WHEN ASEO IS NULL THEN ' ' ELSE UPPER(ASEO) END) LIKE UPPER(CONCAT(:ASEO, '%')) AND (CASE WHEN CODIGO_EXTERNO IS NULL THEN ' ' ELSE UPPER(CODIGO_EXTERNO) END) LIKE UPPER(CONCAT(:CODIGO_EXTERNO, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN ASEOBARRIDO IS NULL THEN ' ' ELSE UPPER(ASEOBARRIDO) END) LIKE UPPER(CONCAT(:ASEOBARRIDO, '%')) AND (CASE WHEN PINTADEUDATERCE IS NULL THEN ' ' ELSE UPPER(PINTADEUDATERCE) END) LIKE UPPER(CONCAT(:PINTADEUDATERCE, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="NOMBREEMPRESA" sqlType="STRING"/>
		<param name="FECHAINGASEOEXT" sqlType="STRING"/>
		<param name="ASEO" sqlType="STRING"/>
		<param name="CODIGO_EXTERNO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="ASEOBARRIDO" sqlType="STRING"/>
		<param name="PINTADEUDATERCE" sqlType="STRING"/>

	</query>
