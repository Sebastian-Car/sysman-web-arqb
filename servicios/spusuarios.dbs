	<query id="getSpusuariosPagTodosConNombrePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT 'TODOS' CODIGORUTA, 'TODOS' NOMBRE FROM DUAL UNION SELECT DISTINCT U.CODIGORUTA, CONCAT(NVL(U.NOMBRES,' '),CONCAT(' ',CONCAT(NVL(U.PRIMERAPELLIDO,' '),CONCAT(' ',NVL(U.SEGUNDOAPELLIDO,' ') ) ) ) ) NOMBRE FROM SP_USUARIO U INNER JOIN SP_INFO_TIPO_OPERACION ITO ON U.COMPANIA = ITO.COMPANIA AND U.CICLO = ITO.CICLO AND U.CODIGORUTA = ITO.CODIGORUTA WHERE U.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/todosconnombreporcompania/pag">
		<call-query href="getSpusuariosPagTodosConNombrePorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumTodosConNombrePorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT 'TODOS' CODIGORUTA, 'TODOS' NOMBRE FROM DUAL UNION SELECT DISTINCT U.CODIGORUTA, CONCAT(NVL(U.NOMBRES,' '),CONCAT(' ',CONCAT(NVL(U.PRIMERAPELLIDO,' '),CONCAT(' ',NVL(U.SEGUNDOAPELLIDO,' ') ) ) ) ) NOMBRE FROM SP_USUARIO U INNER JOIN SP_INFO_TIPO_OPERACION ITO ON U.COMPANIA = ITO.COMPANIA AND U.CICLO = ITO.CICLO AND U.CODIGORUTA = ITO.CODIGORUTA WHERE U.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
