		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","USO":"$USO","ESTRATO":"$ESTRATO","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","FIMM":"$FIMM"}]}}		</result>
