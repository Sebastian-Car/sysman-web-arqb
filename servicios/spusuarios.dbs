	<query id="updateSpusuariosConsumoManualAcuedYAlcant" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO    SET AFOROCONSMANUAL = :AFOROCONSMANUAL,        CONSUMOACUMANUAL = :CONSUMOACUMANUAL,        CONSUMOALCMANUAL = :CONSUMOALCMANUAL,        DATE_MODIFIED   = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),         MODIFIED_BY     = :MODIFIED_BY  WHERE COMPANIA        = :COMPANIA    AND CICLO           = :CICLO    AND CODIGORUTA      = :CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="AFOROCONSMANUAL" sqlType="STRING"/>
		<param name="CONSUMOACUMANUAL" sqlType="STRING"/>
		<param name="CONSUMOALCMANUAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/consumomanualacuedyalcant">
		<call-query href="updateSpusuariosConsumoManualAcuedYAlcant">
			<with-param name="AFOROCONSMANUAL" query-param="AFOROCONSMANUAL"/>
			<with-param name="CONSUMOACUMANUAL" query-param="CONSUMOACUMANUAL"/>
			<with-param name="CONSUMOALCMANUAL" query-param="CONSUMOALCMANUAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagTodosPorListaCedulaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT USUARIO.NIT, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRES_USUARIO, NVL(RECARGOACUEDUCTO,0) + NVL(RECARGOASEO,0) TOTALRECARGO, TOTFACTURAPERACTUAL - TOTALDEUDA - TOTALASEO - TOTALALCANTARILLADO - TOTALACUEDUCTO OTROSCARGOS, VALCONSUMO + VALCONSUMOPROM + ACSINMEDICION TOTALVALORCONSUMO, USUARIO.ESTADO FROM SP_USUARIO USUARIO WHERE USUARIO.COMPANIA =:COMPANIA AND USUARIO.ESTADO NOT IN ('R','S') AND USUARIO.CICLO = CASE WHEN :CICLO =-1 THEN USUARIO.CICLO ELSE TO_NUMBER(:CICLO) END AND USUARIO.NIT IS NOT NULL AND USUARIO.NIT &lt;&gt; '0' AND USUARIO.CODIGORUTA BETWEEN :CODIGOINICIAL AND :CODIGOFINAL AND CONCAT(USO,ESTRATO) BETWEEN CONCAT(:USOINICIAL,:ESTRATOINI) AND CONCAT(:USOFIN,:ESTRATOFIN) ORDER BY USUARIO.NIT, USUARIO.COMPANIA, USUARIO.CICLO) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRES_USUARIO IS NULL THEN ' ' ELSE UPPER(NOMBRES_USUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES_USUARIO), '%')) AND (CASE WHEN TOTALRECARGO IS NULL THEN ' ' ELSE UPPER(TOTALRECARGO) END) LIKE UPPER(CONCAT(:TOTALRECARGO, '%')) AND (CASE WHEN OTROSCARGOS IS NULL THEN ' ' ELSE UPPER(OTROSCARGOS) END) LIKE UPPER(CONCAT(:OTROSCARGOS, '%')) AND (CASE WHEN TOTALVALORCONSUMO IS NULL THEN ' ' ELSE UPPER(TOTALVALORCONSUMO) END) LIKE UPPER(CONCAT(:TOTALVALORCONSUMO, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NIT":"$NIT","NOMBRES_USUARIO":"$NOMBRES_USUARIO","TOTALRECARGO":"$TOTALRECARGO(type:integer)","OTROSCARGOS":"$OTROSCARGOS(type:integer)","TOTALVALORCONSUMO":"$TOTALVALORCONSUMO(type:integer)","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="USOINICIAL" sqlType="STRING"/>
		<param name="ESTRATOINI" sqlType="STRING"/>
		<param name="USOFIN" sqlType="STRING"/>
		<param name="ESTRATOFIN" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRES_USUARIO" sqlType="STRING"/>
		<param name="TOTALRECARGO" sqlType="STRING"/>
		<param name="OTROSCARGOS" sqlType="STRING"/>
		<param name="TOTALVALORCONSUMO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/todosporlistacedula/pag">
		<call-query href="getSpusuariosPagTodosPorListaCedulaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>
			<with-param name="USOINICIAL" query-param="USOINICIAL"/>
			<with-param name="ESTRATOINI" query-param="ESTRATOINI"/>
			<with-param name="USOFIN" query-param="USOFIN"/>
			<with-param name="ESTRATOFIN" query-param="ESTRATOFIN"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="NOMBRES_USUARIO" query-param="NOMBRES_USUARIO"/>
			<with-param name="TOTALRECARGO" query-param="TOTALRECARGO"/>
			<with-param name="OTROSCARGOS" query-param="OTROSCARGOS"/>
			<with-param name="TOTALVALORCONSUMO" query-param="TOTALVALORCONSUMO"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumTodosPorListaCedulaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT USUARIO.NIT, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRES_USUARIO, NVL(RECARGOACUEDUCTO,0) + NVL(RECARGOASEO,0) TOTALRECARGO, TOTFACTURAPERACTUAL - TOTALDEUDA - TOTALASEO - TOTALALCANTARILLADO - TOTALACUEDUCTO OTROSCARGOS, VALCONSUMO + VALCONSUMOPROM + ACSINMEDICION TOTALVALORCONSUMO, USUARIO.ESTADO FROM SP_USUARIO USUARIO WHERE USUARIO.COMPANIA =:COMPANIA AND USUARIO.ESTADO NOT IN ('R','S') AND USUARIO.CICLO = CASE WHEN :CICLO =-1 THEN USUARIO.CICLO ELSE TO_NUMBER(:CICLO) END AND USUARIO.NIT IS NOT NULL AND USUARIO.NIT &lt;&gt; '0' AND USUARIO.CODIGORUTA BETWEEN :CODIGOINICIAL AND :CODIGOFINAL AND CONCAT(USO,ESTRATO) BETWEEN CONCAT(:USOINICIAL,:ESTRATOINI) AND CONCAT(:USOFIN,:ESTRATOFIN) ORDER BY USUARIO.NIT, USUARIO.COMPANIA, USUARIO.CICLO) INI WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN NOMBRES_USUARIO IS NULL THEN ' ' ELSE UPPER(NOMBRES_USUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES_USUARIO), '%')) AND (CASE WHEN TOTALRECARGO IS NULL THEN ' ' ELSE UPPER(TOTALRECARGO) END) LIKE UPPER(CONCAT(:TOTALRECARGO, '%')) AND (CASE WHEN OTROSCARGOS IS NULL THEN ' ' ELSE UPPER(OTROSCARGOS) END) LIKE UPPER(CONCAT(:OTROSCARGOS, '%')) AND (CASE WHEN TOTALVALORCONSUMO IS NULL THEN ' ' ELSE UPPER(TOTALVALORCONSUMO) END) LIKE UPPER(CONCAT(:TOTALVALORCONSUMO, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="USOINICIAL" sqlType="STRING"/>
		<param name="ESTRATOINI" sqlType="STRING"/>
		<param name="USOFIN" sqlType="STRING"/>
		<param name="ESTRATOFIN" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="NOMBRES_USUARIO" sqlType="STRING"/>
		<param name="TOTALRECARGO" sqlType="STRING"/>
		<param name="OTROSCARGOS" sqlType="STRING"/>
		<param name="TOTALVALORCONSUMO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
