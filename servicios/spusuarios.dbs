	<query id="deleteSpusuariosCorreccionCriticaDeRegistroLectura"  useConfig="sysmandsunist">
		<sql>SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) ) NOMBRE, SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.CODIGOINTERNO, SP_USUARIO.DIRTECNICA, SP_USUARIO.USO, SP_USUARIO.NUMERODIGITOS, SP_USUARIO.LECTURA, SP_USUARIO.LECTURAAFORO,(TO_CHAR(SP_USUARIO.FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS')) FECHALECTURAAFORO, SP_USUARIO.AFORADOR,(CASE SP_USUARIO.INDDESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) INDDESHABITADO FROM SP_USUARIO</sql>
