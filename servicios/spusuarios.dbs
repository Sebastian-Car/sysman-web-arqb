	<query id="updateSpusuariosUbicacionPorCompania" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO  SET NOTADEBITO=:UBICACION,
DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),
MODIFIED_BY=:MODIFIED_BY  WHERE COMPANIA= :COMPANIA   AND CICLO= :CICLO  AND CODIGORUTA BETWEEN  :CODIGOINICIAL   AND :CODIGOFINAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="UBICACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/ubicacionporcompania">
		<call-query href="updateSpusuariosUbicacionPorCompania">
			<with-param name="UBICACION" query-param="UBICACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>

		</call-query>
	</resource>
