	<query id="getSpusuariosValidaUsuarioFimmQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO.FIMM  FROM SP_USUARIO INNER JOIN SP_DESVIACIONES ON SP_USUARIO.COMPANIA = SP_DESVIACIONES.COMPANIA AND SP_USUARIO.CICLO = SP_DESVIACIONES.CICLO AND SP_USUARIO.CODIGORUTA = SP_DESVIACIONES.CODIGORUTA WHERE SP_USUARIO.COMPANIA = :COMPANIA AND SP_USUARIO.CICLO = :CICLO AND SP_USUARIO.CODIGORUTA = :CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FIMM":"$FIMM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
