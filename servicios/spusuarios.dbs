	<query id="updateSpusuariosActualizaEmpresaExterna" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET ANO=:ANO, EMPRESAASEOEXT=:EMPRESAASEOEXT, FECHAINGASEOEXT=TO_DATE(:FECHAINGASEOEXT,'DD/MM/YYYY HH24:MI:SS'), ASEO=:ASEO, CODIGO_EXTERNO=:CODIGO_EXTERNO, PINTADEUDATERCE=:PINTADEUDATERCE, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="EMPRESAASEOEXT" sqlType="STRING"/>
		<param name="FECHAINGASEOEXT" sqlType="STRING"/>
		<param name="ASEO" sqlType="STRING"/>
		<param name="CODIGO_EXTERNO" sqlType="STRING"/>
		<param name="PINTADEUDATERCE" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/actualizaempresaexterna">
		<call-query href="updateSpusuariosActualizaEmpresaExterna">
