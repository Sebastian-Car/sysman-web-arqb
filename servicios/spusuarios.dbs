	<query id="getSpusuariosMatriculaPorAnoYMesActualQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUBSTR(MATRICULA,7) MATRICULA FROM SP_USUARIO WHERE MATRICULA IS NOT NULL AND SUBSTR(MATRICULA,1,6) = ( CONCAT(EXTRACT(YEAR FROM SYSDATE),LPAD(EXTRACT(MONTH FROM SYSDATE),2,'0') ) ) ORDER BY TO_NUMBER(MATRICULA) DESC</sql>
		<result outputType="json">{"elementos":{"elemento":[{"MATRICULA":"$MATRICULA"}]}}		</result>
 
	</query>
