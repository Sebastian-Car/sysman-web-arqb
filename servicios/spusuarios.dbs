			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpusuariosCuentaAcueductoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(1) CUENTA  FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA = :COMPANIA AND SP_USUARIO.CODIGORUTA BETWEEN :CODIGOINICIAL AND :CODIGOFINAL AND SP_USUARIO.CICLO BETWEEN :CICLOINICIAL AND :CICLOFINAL AND SP_USUARIO.ESTADO &lt;&gt; 'R' AND SP_USUARIO.ACUEDUCTO IN (0) AND (VALORBASICO+VALORCOMPLEMENTARIO+VALORSUNTUARIO&lt;&gt;0 or CARGOFIJO+SUBFIJO-SOBREFIJO&lt;&gt;0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUENTA":"$CUENTA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="CICLOINICIAL" sqlType="STRING"/>
		<param name="CICLOFINAL" sqlType="STRING"/>

	</query>
