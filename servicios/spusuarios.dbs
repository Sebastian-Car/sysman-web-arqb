	<query id="getSpusuariosNumTodosporcicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGORUTA, CONCAT(NVL(PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(NOMBRES,' ') ) ) ) ) NOMBRE, BANCOPERPROCESO, TOTFACTURAPERACTUAL, DEUDA, TOTALDEUDA, PERIODOSATRASO, PERIODO, ANO, CODIGOINTERNO, ESTADO, CICLO, FACTURA, DIRTECNICA, PERIODOSNOCOBROFIN FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:MI_CICLO ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN BANCOPERPROCESO IS NULL THEN ' ' ELSE UPPER(BANCOPERPROCESO) END) LIKE UPPER(CONCAT(:BANCOPERPROCESO, '%')) AND (CASE WHEN TOTFACTURAPERACTUAL IS NULL THEN ' ' ELSE UPPER(TOTFACTURAPERACTUAL) END) LIKE UPPER(CONCAT(:TOTFACTURAPERACTUAL, '%')) AND (CASE WHEN DEUDA IS NULL THEN ' ' ELSE UPPER(DEUDA) END) LIKE UPPER(CONCAT(:DEUDA, '%')) AND (CASE WHEN TOTALDEUDA IS NULL THEN ' ' ELSE UPPER(TOTALDEUDA) END) LIKE UPPER(CONCAT(:TOTALDEUDA, '%')) AND (CASE WHEN PERIODOSATRASO IS NULL THEN ' ' ELSE UPPER(PERIODOSATRASO) END) LIKE UPPER(CONCAT(:PERIODOSATRASO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN FACTURA IS NULL THEN ' ' ELSE UPPER(FACTURA) END) LIKE UPPER(CONCAT(:FACTURA, '%')) AND (CASE WHEN DIRTECNICA IS NULL THEN ' ' ELSE UPPER(DIRTECNICA) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRTECNICA), '%')) AND (CASE WHEN PERIODOSNOCOBROFIN IS NULL THEN ' ' ELSE UPPER(PERIODOSNOCOBROFIN) END) LIKE UPPER(CONCAT(:PERIODOSNOCOBROFIN, '%')) ) A) FIN</sql>
