	<query id="getSpusuariosPagPorCicloPeriodoatrasoBancoperprocesoNuloQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) NOMBRE,(TO_CHAR(SP_USUARIO.FECHAACTASUSPEN,'DD/MM/YYYY HH24:MI:SS')) FECHAACTASUSPEN, SP_USUARIO.PERIODOSATRASO,(TO_CHAR(SP_USUARIO.FECHA_POST_SUSP,'DD/MM/YYYY HH24:MI:SS')) FECHA_POST_SUSP, SP_USUARIO.USUARIO_POST_SUSP FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND SP_USUARIO.PERIODOSATRASO &gt;:PERIODOATRASO AND SP_USUARIO.BANCOPERPROCESO IS NULL ORDER BY SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN FECHAACTASUSPEN IS NULL THEN ' ' ELSE UPPER(FECHAACTASUSPEN) END) LIKE UPPER(CONCAT(:FECHAACTASUSPEN, '%')) AND (CASE WHEN PERIODOSATRASO IS NULL THEN ' ' ELSE UPPER(PERIODOSATRASO) END) LIKE UPPER(CONCAT(:PERIODOSATRASO, '%')) AND (CASE WHEN FECHA_POST_SUSP IS NULL THEN ' ' ELSE UPPER(FECHA_POST_SUSP) END) LIKE UPPER(CONCAT(:FECHA_POST_SUSP, '%')) AND (CASE WHEN USUARIO_POST_SUSP IS NULL THEN ' ' ELSE UPPER(USUARIO_POST_SUSP) END) LIKE UPPER(CONCAT(:USUARIO_POST_SUSP, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","FECHAACTASUSPEN":"$FECHAACTASUSPEN","PERIODOSATRASO":"$PERIODOSATRASO(type:integer)","FECHA_POST_SUSP":"$FECHA_POST_SUSP","USUARIO_POST_SUSP":"$USUARIO_POST_SUSP"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="PERIODOATRASO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="FECHAACTASUSPEN" sqlType="STRING"/>
		<param name="PERIODOSATRASO" sqlType="STRING"/>
		<param name="FECHA_POST_SUSP" sqlType="STRING"/>
		<param name="USUARIO_POST_SUSP" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
