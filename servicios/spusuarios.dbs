	<query id="updateSpusuariosActualizarconsultafacturacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET AREA=:AREA, ASEOBARRIDO=:ASEOBARRIDO, ESTRATOASEO=:ESTRATOASEO, NOTACREDITO=:NOTACREDITO, MEDIDOR=:MEDIDOR, NUMERODIGITOS=:NUMERODIGITOS, LECTURA=:LECTURA, CONSUMOAFORO=:CONSUMOAFORO, PERIODOSNOCOBROFIN=:PERIODOSNOCOBROFIN, PERIODOSNOCOBROFAC=:PERIODOSNOCOBROFAC, ACUMULADO=:ACUMULADO, ESTRATOALUMBRADO=:ESTRATOALUMBRADO, INQUILINATOS=:INQUILINATOS, TOTALIZADOR=:TOTALIZADOR, ESTADOMEDIDOR=:ESTADOMEDIDOR, CHAPETAS=:CHAPETAS, FRECUENCIARECOLECCION=:FRECUENCIARECOLECCION, TIPOCOBRO=:TIPOCOBRO, TASACAR=:TASACAR, NOUNDMULTIUSUARIO=:NOUNDMULTIUSUARIO, NOTADEBITO=:NOTADEBITO, SEPARACIONENFUENTE=:SEPARACIONENFUENTE, NOPUERTAPUERTA=:NOPUERTAPUERTA, APARTAMENTO=:APARTAMENTO, PLANTA=:PLANTA, DESVIOSIGNIFICATIVO=:DESVIOSIGNIFICATIVO, CODTOTALIZADOR=:CODTOTALIZADOR, FREC_RECO=:FREC_RECO, FREC_BARRI=:FREC_BARRI, TIPODEAFORO=:TIPODEAFORO, HOGAR_COMUNITARIO=:HOGAR_COMUNITARIO, CARACTERIZACION_ALC=:CARACTERIZACION_ALC, CODMACROMEDIDOR=:CODMACROMEDIDOR, PESOASEO=:PESOASEO, ACUEDUCTO=:ACUEDUCTO, ALCANTARILLADO=:ALCANTARILLADO, ALUMBRADO=:ALUMBRADO, ASEO=:ASEO, INDDESHABITADO=:INDDESHABITADO, PORCENTAJEAPLICAR=:PORCENTAJEAPLICAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

