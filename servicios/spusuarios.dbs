	<query id="getSpusuariosPagListadoporciclosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRECOMPLETO FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO BETWEEN :CICLOINICIAL AND :CICLOFINAL ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRECOMPLETO IS NULL THEN ' ' ELSE UPPER(NOMBRECOMPLETO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRECOMPLETO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRECOMPLETO":"$NOMBRECOMPLETO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOINICIAL" sqlType="STRING"/>
		<param name="CICLOFINAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRECOMPLETO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
