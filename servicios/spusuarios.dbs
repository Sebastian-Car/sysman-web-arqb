	<query id="getSpusuariosPagTodosCodigointernoYUsoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT SP_USUARIO.CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) EXPR1, SP_USUARIO.ANO, SP_USUARIO.USO, SP_USUARIO.PERIODO, SP_USUARIO.ESTRATO, SP_USUARIO.CICLO, SP_USUARIO.TOTFACTURAPERACTUAL, SP_USUARIO.CODIGOINTERNO, ( NVL(FIMM,'') ) FIMM, ( NVL(BANCOPERPROCESO,'') ) EXPR3, SP_USUARIO.ESTADO, SP_USUARIO.BANCOPERPROCESO FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND SP_USUARIO.ESTADO NOT IN ('R','S') AND SP_USUARIO.BANCOPERPROCESO IS NULL ORDER BY SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN EXPR1 IS NULL THEN ' ' ELSE UPPER(EXPR1) END) LIKE UPPER(CONCAT(CONCAT('%',:EXPR1), '%')) AND (CASE WHEN FIMM IS NULL THEN ' ' ELSE UPPER(FIMM) END) LIKE UPPER(CONCAT(CONCAT('%',:FIMM), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","EXPR1":"$EXPR1","ANO":"$ANO(type:integer)","USO":"$USO","PERIODO":"$PERIODO","ESTRATO":"$ESTRATO","CICLO":"$CICLO(type:integer)","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","CODIGOINTERNO":"$CODIGOINTERNO","FIMM":"$FIMM","EXPR3":"$EXPR3","ESTADO":"$ESTADO","BANCOPERPROCESO":"$BANCOPERPROCESO"}]}}		</result>
