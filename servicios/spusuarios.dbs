	<query id="getSpusuariosPagCodrutaEntreCiclosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT SP_USUARIO.CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE FROM SP_USUARIO INNER JOIN SP_USOS ON SP_USUARIO.COMPANIA = SP_USOS.COMPANIA AND SP_USUARIO.USO = SP_USOS.CODIGO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO BETWEEN :CICLOINICIAL AND :CICLOFINAL ORDER BY SP_USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOINICIAL" sqlType="STRING"/>
		<param name="CICLOFINAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
