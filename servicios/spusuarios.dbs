	<query id="updateSpusuariosActualizarTotales" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET TOTFACTURAPERACTUAL= :TOTFACTURAPERACTUAL                     ,TOTFACTURAPAGO2 = :TOTFACTURAPAGO2                     ,DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')                     , MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA= :COMPANIA  AND CICLO= :CICLO AND CODIGORUTA = :CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TOTFACTURAPERACTUAL" sqlType="STRING"/>
		<param name="TOTFACTURAPAGO2" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/actualizartotales">
		<call-query href="updateSpusuariosActualizarTotales">
			<with-param name="TOTFACTURAPERACTUAL" query-param="TOTFACTURAPERACTUAL"/>
			<with-param name="TOTFACTURAPAGO2" query-param="TOTFACTURAPAGO2"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSpusuariosConsultarUsuariosFacturadosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  USUARIO.CODIGORUTA  FROM SP_USUARIO USUARIO LEFT JOIN SP_FACTURADO FACTURADO ON USUARIO.COMPANIA = FACTURADO.COMPANIA AND USUARIO.CICLO = FACTURADO.CICLO AND USUARIO.CODIGORUTA = FACTURADO.CODIGORUTA WHERE (USUARIO.COMPANIA = :COMPANIA AND USUARIO.CICLO = :CICLO AND USUARIO.ESTADO NOT IN ('R','S') AND USUARIO.BANCOPERPROCESO IS NULL AND FACTURADO.VALOR_FACTURADO&lt;&gt;0 AND FACTURADO.CONCEPTO =49) AND USUARIO.CODIGORUTA= :CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/consultarusuariosfacturados">
		<call-query href="getSpusuariosConsultarUsuariosFacturadosQuery">
