	<query id="getSpusuariosCodigototalizadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT CODIGOINTERNO, CODIGORUTA, CONCAT(NOMBRES,CONCAT(' ',CONCAT(PRIMERAPELLIDO,CONCAT(' ',SEGUNDOAPELLIDO) ) ) ) NOMBRE, MATRICULA FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLOACTUAL AND CODIGORUTA &gt;:CODIGORUTAACTUAL AND TOTALIZADOR =:TIPO_TOTALIZADOR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOINTERNO":"$CODIGOINTERNO","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","MATRICULA":"$MATRICULA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOACTUAL" sqlType="STRING"/>
		<param name="CODIGORUTAACTUAL" sqlType="STRING"/>
		<param name="TIPO_TOTALIZADOR" sqlType="STRING"/>

	</query>
