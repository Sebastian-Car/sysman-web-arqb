	<query id="updateSpusuariosFechapostergaUsuarioposterga" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET FECHAACTASUSPEN=TO_DATE(:FECHAACTASUSPEN,'DD/MM/YYYY HH24:MI:SS'), PERIODOSATRASO=:PERIODOSATRASO, FECHA_POST_SUSP=TO_DATE(:FECHA_POST_SUSP,'DD/MM/YYYY HH24:MI:SS'), USUARIO_POST_SUSP=:USUARIO_POST_SUSP, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHAACTASUSPEN" sqlType="STRING"/>
		<param name="PERIODOSATRASO" sqlType="STRING"/>
		<param name="FECHA_POST_SUSP" sqlType="STRING"/>
		<param name="USUARIO_POST_SUSP" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>

	</query>
