	<query id="getSpusuariosNumCargasublecturaPorCicloCodinternoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CICLO, CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRES, CODTOTALIZADOR, LECTURA, LECTURAAFORO, CASE WHEN LECTURA = LECTURAAFORO THEN CONSUMOPROM ELSE CONSUMO END CONSUMO1, CONSUMOACU, CONSUMOALC,(CASE AFOROCONSMANUAL WHEN 0 THEN 'false' ELSE 'true' END) AFOROCONSMANUAL, CONSUMOPROM, TIPOCALCULO FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO AND CODTOTALIZADOR =:CODIGOINTERNO) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGORUTA), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN CODTOTALIZADOR IS NULL THEN ' ' ELSE UPPER(CODTOTALIZADOR) END) LIKE UPPER(CONCAT(CONCAT('%',:CODTOTALIZADOR), '%')) AND (CASE WHEN LECTURA IS NULL THEN ' ' ELSE UPPER(LECTURA) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURA), '%')) AND (CASE WHEN LECTURAAFORO IS NULL THEN ' ' ELSE UPPER(LECTURAAFORO) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURAAFORO), '%')) AND (CASE WHEN CONSUMO1 IS NULL THEN ' ' ELSE UPPER(CONSUMO1) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMO1), '%')) AND (CASE WHEN CONSUMOACU IS NULL THEN ' ' ELSE UPPER(CONSUMOACU) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMOACU), '%')) AND (CASE WHEN CONSUMOALC IS NULL THEN ' ' ELSE UPPER(CONSUMOALC) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMOALC), '%')) AND (CASE WHEN AFOROCONSMANUAL IS NULL THEN ' ' ELSE UPPER(AFOROCONSMANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:AFOROCONSMANUAL), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRES" sqlType="STRING"/>
		<param name="CODTOTALIZADOR" sqlType="STRING"/>
		<param name="LECTURA" sqlType="STRING"/>
		<param name="LECTURAAFORO" sqlType="STRING"/>
		<param name="CONSUMO1" sqlType="STRING"/>
		<param name="CONSUMOACU" sqlType="STRING"/>
		<param name="CONSUMOALC" sqlType="STRING"/>
		<param name="AFOROCONSMANUAL" sqlType="STRING"/>

	</query>
