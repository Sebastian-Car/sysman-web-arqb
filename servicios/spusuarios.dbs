		<call-query href="getSpusuariosPagTodosPorCompaniaCicloPeriodoMayorQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumTodosPorCompaniaCicloPeriodoMayorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT DISTINCT USUARIO.COMPANIA, USUARIO.CICLO, USUARIO.CODIGORUTA, CONCAT(USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',USUARIO.NOMBRES) ) ) ) NOMBRE, USUARIO.PERIODO, FINANCIABLES.PERIODO PERIODOFINAN, USUARIO.TOTFACTURAPERACTUAL, FINANCIABLES.ANO FROM SP_USUARIO USUARIO INNER JOIN SP_FINANCIABLES FINANCIABLES ON USUARIO.COMPANIA = FINANCIABLES.COMPANIA AND USUARIO.CICLO = FINANCIABLES.CICLO AND USUARIO.CODIGORUTA = FINANCIABLES.CODIGORUTA WHERE USUARIO.COMPANIA =:COMPANIA AND USUARIO.CICLO =:CICLO AND USUARIO.PERIODO &gt;=:PERIODO AND ( CASE WHEN USUARIO.PERIODO &lt;&gt; '12' THEN CASE WHEN FINANCIABLES.PERIODO &gt;=:PERIODO THEN 1 ELSE 0 END ELSE CASE WHEN FINANCIABLES.PERIODO &gt;=:PERIODO OR FINANCIABLES.PERIODO &gt;= '01' THEN 1 ELSE 0 END END ) &lt;&gt; 0 ORDER BY USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/todosporcompaniacicloperiodomayor/num">
