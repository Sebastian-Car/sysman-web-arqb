	<query id="getSpusuariosLecturasAforadorQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, PERIODO, CICLO, CODIGORUTA, LEAD(CODIGORUTA) OVER( ORDER BY CODIGORUTA ) SIGUIENTE, ANO ANOACTUAL, AFORADOR, USO, LECTURA, LECTURAAFORO,(CASE CHAPETAS WHEN 0 THEN 'false' ELSE 'true' END) CHAPETAS,(CASE INDDESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) INDDESHABITADO,(TO_CHAR(FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS')) FECHALECTURAAFORO, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE, NVL(NUMERODIGITOS,0) NUMERODIGITOS,(CASE CARGOS_FIJOS_CERO WHEN 0 THEN 'false' ELSE 'true' END) CARGOS_FIJOS_CERO FROM SP_USUARIO WHERE COMPANIA =:KEY_COMPANIA AND CICLO =:KEY_CICLO AND CODIGORUTA =:KEY_CODIGORUTA AND ESTADO NOT IN ('R')</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","SIGUIENTE":"$SIGUIENTE","ANOACTUAL":"$ANOACTUAL(type:integer)","AFORADOR":"$AFORADOR","USO":"$USO","LECTURA":"$LECTURA","LECTURAAFORO":"$LECTURAAFORO","CHAPETAS":"$CHAPETAS(type:boolean)","INDDESHABITADO":"$INDDESHABITADO(type:boolean)","FECHALECTURAAFORO":"$FECHALECTURAAFORO","NOMBRE":"$NOMBRE","NUMERODIGITOS":"$NUMERODIGITOS(type:integer)","CARGOS_FIJOS_CERO":"$CARGOS_FIJOS_CERO(type:boolean)"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>

	</query>
