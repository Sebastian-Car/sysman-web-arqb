	<query id="getSpusuariosCorreccionHistoriaPorAnoPeriodoCicloCodigoClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, LECTURA, CONSUMO, CONSUMOPROM,(CASE DESVIACION WHEN 0 THEN 'false' ELSE 'true' END) DESVIACION, CLASE, PER, CASE WHEN PER = PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(:COMPANIA,:ANO,:PERIODO,'M') AND DESVIACION = 0 AND NOMBRE IS NOT NULL THEN 'true' ELSE 'false' END PERIODOACTUAL, NOMBRE NOMBREPROBLEMA, OBSERVACION, LECTURAPROBLEMA, PROBLEMA FROM ( WITH QRY_CORRECCIONHISTORIA AS ( SELECT SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.LECTURA, SP_USUARIO_PROBLEMA.OBSERVACION, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_PROBLEMA.NOMBRE FROM SP_USUARIO_PROBLEMA INNER JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO WHERE SP_USUARIO_PROBLEMA.COMPANIA =:COMPANIA AND CONCAT(SP_USUARIO_PROBLEMA.ANO , SP_USUARIO_PROBLEMA.PERIODO) BETWEEN :PERIODOINICIOHIST AND :PERIODOFINHIST AND SP_USUARIO_PROBLEMA.CICLO =:CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA =:CODIGORUTA AND SP_USUARIO_PROBLEMA.CLASE =:CLASE ) SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.LECTURA, SP_USUARIO.CONSUMO, SP_USUARIO.CONSUMOPROM, SP_USUARIO.DESVIOSIGNIFICATIVO AS DESVIACION, CONCAT( '' ,CONCAT( PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(:COMPANIA,:ANO,:PERIODO,:FRECUENCIA) , '' )) PER, QRY_CORRECCIONHISTORIA.NOMBRE, QRY_CORRECCIONHISTORIA.OBSERVACION, QRY_CORRECCIONHISTORIA.LECTURA AS LECTURAPROBLEMA, QRY_CORRECCIONHISTORIA.CLASE, QRY_CORRECCIONHISTORIA.PROBLEMA FROM SP_USUARIO LEFT JOIN QRY_CORRECCIONHISTORIA ON SP_USUARIO.COMPANIA = QRY_CORRECCIONHISTORIA.COMPANIA AND SP_USUARIO.CICLO = QRY_CORRECCIONHISTORIA.CICLO AND SP_USUARIO.CODIGORUTA = QRY_CORRECCIONHISTORIA.CODIGORUTA AND SP_USUARIO.ANO = QRY_CORRECCIONHISTORIA.ANO AND SP_USUARIO.PERIODO = QRY_CORRECCIONHISTORIA.PERIODO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND SP_USUARIO.CODIGORUTA =:CODIGORUTA UNION ALL SELECT * FROM ( WITH QRY_CORRECCIONHISTORIA AS ( SELECT SP_USUARIO_PROBLEMA.COMPANIA, SP_USUARIO_PROBLEMA.CICLO, SP_USUARIO_PROBLEMA.CODIGORUTA, SP_USUARIO_PROBLEMA.ANO, SP_USUARIO_PROBLEMA.PERIODO, SP_USUARIO_PROBLEMA.LECTURA, SP_USUARIO_PROBLEMA.OBSERVACION, SP_USUARIO_PROBLEMA.PROBLEMA, SP_USUARIO_PROBLEMA.CLASE, SP_PROBLEMA.NOMBRE FROM SP_USUARIO_PROBLEMA INNER JOIN SP_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_PROBLEMA.COMPANIA AND SP_USUARIO_PROBLEMA.CLASE = SP_PROBLEMA.CLASEPROBLEMA AND SP_USUARIO_PROBLEMA.PROBLEMA = SP_PROBLEMA.CODIGO WHERE SP_USUARIO_PROBLEMA.COMPANIA =:COMPANIA AND CONCAT(SP_USUARIO_PROBLEMA.ANO , SP_USUARIO_PROBLEMA.PERIODO) BETWEEN :PERIODOINICIOHIST AND :PERIODOFINHIST AND SP_USUARIO_PROBLEMA.CICLO =:CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA =:CODIGORUTA AND SP_USUARIO_PROBLEMA.CLASE =:CLASE ) SELECT SP_HISTORIA.COMPANIA, SP_HISTORIA.CICLO, SP_HISTORIA.CODIGORUTA, SP_HISTORIA.ANO, SP_HISTORIA.PERIODO, SP_HISTORIA.LECTURA, SP_HISTORIA.CONSUMO, SP_HISTORIA.CONSUMOPROM, SP_HISTORIA.DESVIACION, PCK_SERVICIOS_PUBLICOS.FC_NOMBREPERIODO(SP_HISTORIA.COMPANIA,SP_HISTORIA.ANO,SP_HISTORIA.PERIODO,'M') AS PER , QRY_CORRECCIONHISTORIA.NOMBRE, QRY_CORRECCIONHISTORIA.OBSERVACION, QRY_CORRECCIONHISTORIA.LECTURA LECTURAPROBLEMA, QRY_CORRECCIONHISTORIA.CLASE, QRY_CORRECCIONHISTORIA.PROBLEMA FROM SP_HISTORIA LEFT JOIN QRY_CORRECCIONHISTORIA ON SP_HISTORIA.COMPANIA = QRY_CORRECCIONHISTORIA.COMPANIA AND SP_HISTORIA.CICLO = QRY_CORRECCIONHISTORIA.CICLO AND SP_HISTORIA.CODIGORUTA = QRY_CORRECCIONHISTORIA.CODIGORUTA AND SP_HISTORIA.ANO = QRY_CORRECCIONHISTORIA.ANO AND SP_HISTORIA.PERIODO = QRY_CORRECCIONHISTORIA.PERIODO WHERE SP_HISTORIA.COMPANIA =:COMPANIA AND SP_HISTORIA.CICLO =:CICLO AND SP_HISTORIA.CODIGORUTA =:CODIGORUTA AND CONCAT(SP_HISTORIA.ANO , SP_HISTORIA.PERIODO) BETWEEN :PERIODOINICIOHIST AND :PERIODOFINHIST ORDER BY SP_HISTORIA.ANO DESC, SP_HISTORIA.PERIODO DESC ) )</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","LECTURA":"$LECTURA","CONSUMO":"$CONSUMO","CONSUMOPROM":"$CONSUMOPROM(type:double)","DESVIACION":"$DESVIACION(type:boolean)","CLASE":"$CLASE","PER":"$PER","PERIODOACTUAL":"$PERIODOACTUAL","NOMBREPROBLEMA":"$NOMBREPROBLEMA","OBSERVACION":"$OBSERVACION","LECTURAPROBLEMA":"$LECTURAPROBLEMA","PROBLEMA":"$PROBLEMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="PERIODOINICIOHIST" sqlType="STRING"/>
		<param name="PERIODOFINHIST" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CLASE" sqlType="STRING"/>
		<param name="FRECUENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/correccionhistoriaporanoperiodociclocodigoclase">
		<call-query href="getSpusuariosCorreccionHistoriaPorAnoPeriodoCicloCodigoClaseQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="PERIODOINICIOHIST" query-param="PERIODOINICIOHIST"/>
			<with-param name="PERIODOFINHIST" query-param="PERIODOFINHIST"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CLASE" query-param="CLASE"/>
			<with-param name="FRECUENCIA" query-param="FRECUENCIA"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagCorreccionCriticaPorAnoPeriodoCicloCodigoClaseQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, SP_USUARIO.CODIGOINTERNO, SP_USUARIO.LECTURA, SP_USUARIO.LECTURAAFORO, TO_CHAR(SP_USUARIO.FECHALECTURAAFORO,'DD/MM/YYYY') FECHALECTURAAFORO, SP_USUARIO.MEDIDOR, SP_USUARIO.DIRTECNICA AS DIRGUIA, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) NOMBRE, SP_USUARIO.CONSUMO1, SP_USUARIO.CONSUMO2, SP_USUARIO.CONSUMO3, SP_USUARIO.CONSUMO4, SP_USUARIO.CONSUMO5, SP_USUARIO.CONSUMO6, SP_USUARIO.LECTURA1, SP_USUARIO.LECTURA2, SP_USUARIO.LECTURA3, SP_USUARIO.LECTURA4, SP_USUARIO.LECTURA5, SP_USUARIO.LECTURA6, SP_USUARIO.NUMERODIGITOS, SP_USUARIO.USO, SP_USOS.NOMBRE AS NOMBREUSO, SP_ESTRATOS.NOMBRE AS ESTRATO, SP_USUARIO.ESTADO AS ESTADO, :CONSUMOP AS CONSUMOP, :CONSUMO AS CONS, SP_USUARIO.DESVIACIONAFORO AS DESVIACIONAFORO, SP_USUARIO.AFOROCONSMANUAL AS AFOROCONSMANUAL, SP_USUARIO.CONSAFOROMICRO AS CONSMICRO, (:CRITICA ) AS CRITICA, SP_USUARIO.AFORADOR, TERCERO.NOMBRE AS AFORADORNOMBRE,(CASE SP_USUARIO.CHAPETAS WHEN 0 THEN 'false' ELSE 'true' END) CHAPETAS,(CASE SP_USUARIO.INDDESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) INDDESHABITADO, SP_USUARIO.CONSUMO, SP_USUARIO.METROSDESVIACIONAFORO AS METROSDESVIACION FROM SP_USUARIO INNER JOIN SP_USOS ON SP_USUARIO.COMPANIA = SP_USOS.COMPANIA AND SP_USUARIO.USO = SP_USOS.CODIGO INNER JOIN SP_ESTRATOS ON ( SP_USUARIO.COMPANIA = SP_ESTRATOS.COMPANIA AND SP_USUARIO.USO = SP_ESTRATOS.USO AND SP_USUARIO.ESTRATO = SP_ESTRATOS.CODIGO ) LEFT JOIN SP_AFORADORES ON ( SP_USUARIO.COMPANIA = SP_AFORADORES.COMPANIA AND SP_USUARIO.AFORADOR = SP_AFORADORES.CODIGO ) LEFT JOIN TERCERO ON ( SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL ) WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND SP_USUARIO.CODIGORUTA BETWEEN :CODIGOINICIAL AND :CODIGOFINAL AND SP_USUARIO.ANO =:ANO AND SP_USUARIO.PERIODO =:PERIODO) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGORUTA), '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOINTERNO), '%')) AND (CASE WHEN LECTURA IS NULL THEN ' ' ELSE UPPER(LECTURA) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURA), '%')) AND (CASE WHEN LECTURAAFORO IS NULL THEN ' ' ELSE UPPER(LECTURAAFORO) END) LIKE UPPER(CONCAT(CONCAT('%',:LECTURAAFORO), '%')) AND (CASE WHEN FECHALECTURAAFORO IS NULL THEN ' ' ELSE UPPER(FECHALECTURAAFORO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHALECTURAAFORO), '%')) AND (CASE WHEN MEDIDOR IS NULL THEN ' ' ELSE UPPER(MEDIDOR) END) LIKE UPPER(CONCAT(CONCAT('%',:MEDIDOR), '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NUMERODIGITOS IS NULL THEN ' ' ELSE UPPER(NUMERODIGITOS) END) LIKE UPPER(CONCAT(CONCAT('%',:NUMERODIGITOS), '%')) AND (CASE WHEN NOMBREUSO IS NULL THEN ' ' ELSE UPPER(NOMBREUSO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBREUSO), '%')) AND (CASE WHEN ESTRATO IS NULL THEN ' ' ELSE UPPER(ESTRATO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTRATO), '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(CONCAT('%',:ESTADO), '%')) AND (CASE WHEN CONSUMOP IS NULL THEN ' ' ELSE UPPER(CONSUMOP) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMOP), '%')) AND (CASE WHEN CONS IS NULL THEN ' ' ELSE UPPER(CONS) END) LIKE UPPER(CONCAT(CONCAT('%',:CONS), '%')) AND (CASE WHEN DESVIACIONAFORO IS NULL THEN ' ' ELSE UPPER(DESVIACIONAFORO) END) LIKE UPPER(CONCAT(CONCAT('%',:DESVIACIONAFORO), '%')) AND (CASE WHEN AFOROCONSMANUAL IS NULL THEN ' ' ELSE UPPER(AFOROCONSMANUAL) END) LIKE UPPER(CONCAT(CONCAT('%',:AFOROCONSMANUAL), '%')) AND (CASE WHEN CONSMICRO IS NULL THEN ' ' ELSE UPPER(CONSMICRO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSMICRO), '%')) AND (CASE WHEN CRITICA IS NULL THEN ' ' ELSE UPPER(CRITICA) END) LIKE UPPER(CONCAT(CONCAT('%',:CRITICA), '%')) AND (CASE WHEN AFORADORNOMBRE IS NULL THEN ' ' ELSE UPPER(AFORADORNOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:AFORADORNOMBRE), '%')) AND (CASE WHEN CONSUMO IS NULL THEN ' ' ELSE UPPER(CONSUMO) END) LIKE UPPER(CONCAT(CONCAT('%',:CONSUMO), '%')) AND (CASE WHEN METROSDESVIACION IS NULL THEN ' ' ELSE UPPER(METROSDESVIACION) END) LIKE UPPER(CONCAT(CONCAT('%',:METROSDESVIACION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","CODIGOINTERNO":"$CODIGOINTERNO","LECTURA":"$LECTURA","LECTURAAFORO":"$LECTURAAFORO","FECHALECTURAAFORO":"$FECHALECTURAAFORO","MEDIDOR":"$MEDIDOR","DIRGUIA":"$DIRGUIA","NOMBRE":"$NOMBRE","CONSUMO1":"$CONSUMO1","CONSUMO2":"$CONSUMO2","CONSUMO3":"$CONSUMO3","CONSUMO4":"$CONSUMO4","CONSUMO5":"$CONSUMO5","CONSUMO6":"$CONSUMO6","LECTURA1":"$LECTURA1","LECTURA2":"$LECTURA2","LECTURA3":"$LECTURA3","LECTURA4":"$LECTURA4","LECTURA5":"$LECTURA5","LECTURA6":"$LECTURA6","NUMERODIGITOS":"$NUMERODIGITOS(type:integer)","USO":"$USO","NOMBREUSO":"$NOMBREUSO","ESTRATO":"$ESTRATO","ESTADO":"$ESTADO","CONSUMOP":"$CONSUMOP","CONS":"$CONS","DESVIACIONAFORO":"$DESVIACIONAFORO(type:boolean)","AFOROCONSMANUAL":"$AFOROCONSMANUAL(type:boolean)","CONSMICRO":"$CONSMICRO","CRITICA":"$CRITICA","AFORADOR":"$AFORADOR","AFORADORNOMBRE":"$AFORADORNOMBRE","CHAPETAS":"$CHAPETAS(type:boolean)","INDDESHABITADO":"$INDDESHABITADO(type:boolean)","CONSUMO":"$CONSUMO","METROSDESVIACION":"$METROSDESVIACION"}]}}		</result>
		<param name="CONSUMOP" sqlType="STRING"/>
		<param name="CONSUMO" sqlType="STRING"/>
		<param name="CRITICA" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="LECTURA" sqlType="STRING"/>
		<param name="LECTURAAFORO" sqlType="STRING"/>
		<param name="FECHALECTURAAFORO" sqlType="STRING"/>
		<param name="MEDIDOR" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NUMERODIGITOS" sqlType="STRING"/>
		<param name="NOMBREUSO" sqlType="STRING"/>
		<param name="ESTRATO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CONS" sqlType="STRING"/>
		<param name="DESVIACIONAFORO" sqlType="STRING"/>
		<param name="AFOROCONSMANUAL" sqlType="STRING"/>
		<param name="CONSMICRO" sqlType="STRING"/>
		<param name="AFORADORNOMBRE" sqlType="STRING"/>
