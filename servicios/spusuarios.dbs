	<query id="getSpusuariosTotalesLecturasPorCicloCodinternoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(LECTURA) SUMLECTURA, SUM(LECTURAAFORO) SUMAFORO, SUM( CASE WHEN LECTURA = LECTURAAFORO THEN CONSUMOPROM ELSE CONSUMO END ) SUMCONSUMO1, SUM(CONSUMOACU) SUMCONSUMOACU, SUM(CONSUMOALC) SUMCONSUMOALC  FROM SP_USUARIO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODTOTALIZADOR = :CODIGOINTERNO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUMLECTURA":"$SUMLECTURA","SUMAFORO":"$SUMAFORO","SUMCONSUMO1":"$SUMCONSUMO1","SUMCONSUMOACU":"$SUMCONSUMOACU","SUMCONSUMOALC":"$SUMCONSUMOALC"}]}}		</result>
