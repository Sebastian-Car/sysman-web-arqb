		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CICLO, CODIGOINTERNO, CODIGORUTA, TRIM(CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) ) NOMBRES, CODIGOCATASTRAL, LENGTH(CODIGOCATASTRAL) AS LARGO FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO AND LENGTH(CODIGOCATASTRAL) &lt;&gt; 15) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGORUTA), '%')) AND (CASE WHEN NOMBRES IS NULL THEN ' ' ELSE UPPER(NOMBRES) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRES), '%')) AND (CASE WHEN CODIGOCATASTRAL IS NULL THEN ' ' ELSE UPPER(CODIGOCATASTRAL) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCATASTRAL), '%')) AND (CASE WHEN LARGO IS NULL THEN ' ' ELSE UPPER(LARGO) END) LIKE UPPER(CONCAT(:LARGO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
