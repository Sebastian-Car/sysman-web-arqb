	<query id="getSpusuariosPagConsecutivo_cod_marcaporcicloycodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  M.CONSECUTIVO, M.CODIGO, M.MARCA, M.DIGITOS, M.ESTADO  FROM SP_USUARIO U INNER JOIN SP_MEDIDOR M ON M.COMPANIA = U.COMPANIA AND M.CICLO = U.CICLO AND M.CODIGORUTA = U.CODIGORUTA WHERE U.COMPANIA = :COMPANIA AND U.CICLO = :CICLO AND U.CODIGORUTA = :CODIGORUTA) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER(:DIGITOS || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSECUTIVO":"$CONSECUTIVO","CODIGO":"$CODIGO","MARCA":"$MARCA","DIGITOS":"$DIGITOS(type:integer)","ESTADO":"$ESTADO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/consecutivo_cod_marcaporcicloycodruta/pag">
		<call-query href="getSpusuariosPagConsecutivo_cod_marcaporcicloycodrutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumConsecutivo_cod_marcaporcicloycodrutaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  M.CONSECUTIVO, M.CODIGO, M.MARCA, M.DIGITOS, M.ESTADO  FROM SP_USUARIO U INNER JOIN SP_MEDIDOR M ON M.COMPANIA = U.COMPANIA AND M.CICLO = U.CICLO AND M.CODIGORUTA = U.CODIGORUTA WHERE U.COMPANIA = :COMPANIA AND U.CICLO = :CICLO AND U.CODIGORUTA = :CODIGORUTA) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER( '%' || :CODIGO || '%')  AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END)  LIKE UPPER( '%' || :MARCA || '%')  AND (CASE WHEN DIGITOS IS NULL THEN ' ' ELSE UPPER(DIGITOS) END)  LIKE UPPER( '%' || :DIGITOS || '%')  AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END)  LIKE UPPER( '%' || :ESTADO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="DIGITOS" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/consecutivo_cod_marcaporcicloycodruta/num">
		<call-query href="getSpusuariosNumConsecutivo_cod_marcaporcicloycodrutaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="MARCA" query-param="MARCA"/>
			<with-param name="DIGITOS" query-param="DIGITOS"/>
			<with-param name="ESTADO" query-param="ESTADO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagTodosporcicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGORUTA, CONCAT(NVL(PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(NOMBRES,' ') ) ) ) ) NOMBRE, BANCOPERPROCESO, TOTFACTURAPERACTUAL, DEUDA, TOTALDEUDA, PERIODOSATRASO, PERIODO, ANO, CODIGOINTERNO, ESTADO, CICLO, FACTURA, DIRTECNICA, PERIODOSNOCOBROFIN FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:MI_CICLO ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN BANCOPERPROCESO IS NULL THEN ' ' ELSE UPPER(BANCOPERPROCESO) END) LIKE UPPER(CONCAT(:BANCOPERPROCESO, '%')) AND (CASE WHEN TOTFACTURAPERACTUAL IS NULL THEN ' ' ELSE UPPER(TOTFACTURAPERACTUAL) END) LIKE UPPER(CONCAT(:TOTFACTURAPERACTUAL, '%')) AND (CASE WHEN DEUDA IS NULL THEN ' ' ELSE UPPER(DEUDA) END) LIKE UPPER(CONCAT(:DEUDA, '%')) AND (CASE WHEN TOTALDEUDA IS NULL THEN ' ' ELSE UPPER(TOTALDEUDA) END) LIKE UPPER(CONCAT(:TOTALDEUDA, '%')) AND (CASE WHEN PERIODOSATRASO IS NULL THEN ' ' ELSE UPPER(PERIODOSATRASO) END) LIKE UPPER(CONCAT(:PERIODOSATRASO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN FACTURA IS NULL THEN ' ' ELSE UPPER(FACTURA) END) LIKE UPPER(CONCAT(:FACTURA, '%')) AND (CASE WHEN DIRTECNICA IS NULL THEN ' ' ELSE UPPER(DIRTECNICA) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRTECNICA), '%')) AND (CASE WHEN PERIODOSNOCOBROFIN IS NULL THEN ' ' ELSE UPPER(PERIODOSNOCOBROFIN) END) LIKE UPPER(CONCAT(:PERIODOSNOCOBROFIN, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","BANCOPERPROCESO":"$BANCOPERPROCESO","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","DEUDA":"$DEUDA","TOTALDEUDA":"$TOTALDEUDA","PERIODOSATRASO":"$PERIODOSATRASO(type:integer)","PERIODO":"$PERIODO","ANO":"$ANO(type:integer)","CODIGOINTERNO":"$CODIGOINTERNO","ESTADO":"$ESTADO","CICLO":"$CICLO(type:integer)","FACTURA":"$FACTURA","DIRTECNICA":"$DIRTECNICA","PERIODOSNOCOBROFIN":"$PERIODOSNOCOBROFIN(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="MI_CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="BANCOPERPROCESO" sqlType="STRING"/>
		<param name="TOTFACTURAPERACTUAL" sqlType="STRING"/>
		<param name="DEUDA" sqlType="STRING"/>
		<param name="TOTALDEUDA" sqlType="STRING"/>
		<param name="PERIODOSATRASO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="FACTURA" sqlType="STRING"/>
		<param name="DIRTECNICA" sqlType="STRING"/>
		<param name="PERIODOSNOCOBROFIN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
