	<query id="getSpusuariosPagTodosPorCodigointernoDatosBasicosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGOINTERNO, CONCAT(NOMBRES,CONCAT(' ',CONCAT(PRIMERAPELLIDO,CONCAT(' ',SEGUNDOAPELLIDO) ) ) ) NOMUSUARIO, CODIGORUTA, TOTFACTURAPERACTUAL,(CASE AUTORIZARBORRADO WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZARBORRADO, BANCOPERPROCESO, FACTURA FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN NOMUSUARIO IS NULL THEN ' ' ELSE UPPER(NOMUSUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMUSUARIO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOINTERNO":"$CODIGOINTERNO","NOMUSUARIO":"$NOMUSUARIO","CODIGORUTA":"$CODIGORUTA","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","AUTORIZARBORRADO":"$AUTORIZARBORRADO(type:boolean)","BANCOPERPROCESO":"$BANCOPERPROCESO","FACTURA":"$FACTURA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="NOMUSUARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/todosporcodigointernodatosbasicos/pag">
		<call-query href="getSpusuariosPagTodosPorCodigointernoDatosBasicosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="NOMUSUARIO" query-param="NOMUSUARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumTodosPorCodigointernoDatosBasicosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGOINTERNO, CONCAT(NOMBRES,CONCAT(' ',CONCAT(PRIMERAPELLIDO,CONCAT(' ',SEGUNDOAPELLIDO) ) ) ) NOMUSUARIO, CODIGORUTA, TOTFACTURAPERACTUAL,(CASE AUTORIZARBORRADO WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZARBORRADO, BANCOPERPROCESO, FACTURA FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN NOMUSUARIO IS NULL THEN ' ' ELSE UPPER(NOMUSUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMUSUARIO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="NOMUSUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/todosporcodigointernodatosbasicos/num">
		<call-query href="getSpusuariosNumTodosPorCodigointernoDatosBasicosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="NOMUSUARIO" query-param="NOMUSUARIO"/>

		</call-query>
	</resource>
	<query id="updateSpusuariosAutorizacionAbonos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET ABONOACT = :ABONO,DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE COMPANIA = :COMPANIA AND CICLO =:CICLO AND CODIGORUTA =:CODIGORUTA AND ANO = :ANO AND PERIODO =:PERIODO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ABONO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/autorizacionabonos">
		<call-query href="updateSpusuariosAutorizacionAbonos">
			<with-param name="ABONO" query-param="ABONO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagTodosPorCompaniaCicloPeriodoMayorQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT DISTINCT USUARIO.COMPANIA, USUARIO.CICLO, USUARIO.CODIGORUTA, CONCAT(USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',USUARIO.NOMBRES) ) ) ) NOMBRE, USUARIO.PERIODO, FINANCIABLES.PERIODO PERIODOFINAN, USUARIO.TOTFACTURAPERACTUAL, FINANCIABLES.ANO FROM SP_USUARIO USUARIO INNER JOIN SP_FINANCIABLES FINANCIABLES ON USUARIO.COMPANIA = FINANCIABLES.COMPANIA AND USUARIO.CICLO = FINANCIABLES.CICLO AND USUARIO.CODIGORUTA = FINANCIABLES.CODIGORUTA WHERE USUARIO.COMPANIA =:COMPANIA AND USUARIO.CICLO =:CICLO AND USUARIO.PERIODO &gt;=:PERIODO AND ( CASE WHEN USUARIO.PERIODO &lt;&gt; '12' THEN CASE WHEN FINANCIABLES.PERIODO &gt;=:PERIODO THEN 1 ELSE 0 END ELSE CASE WHEN FINANCIABLES.PERIODO &gt;=:PERIODO OR FINANCIABLES.PERIODO &gt;= '01' THEN 1 ELSE 0 END END ) &lt;&gt; 0 ORDER BY USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","PERIODO":"$PERIODO","PERIODOFINAN":"$PERIODOFINAN","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","ANO":"$ANO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
