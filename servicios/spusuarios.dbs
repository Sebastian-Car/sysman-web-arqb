	<query id="updateSpusuariosCorreccionCriticaDeLecturas" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET NUMERODIGITOS=:NUMERODIGITOS, DIRTECNICA=:DIRTECNICA, ANO=:ANO, USO=:USO, COMPANIA=:COMPANIA, CICLO=:CICLO, CODIGORUTA=:CODIGORUTA, PERIODO=:PERIODO, CODIGOINTERNO=:CODIGOINTERNO, AFORADOR=:AFORADOR, FECHALECTURAAFORO=TO_DATE(:FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS'), INDDESHABITADO=:INDDESHABITADO, LECTURA=:LECTURA, LECTURAAFORO=:LECTURAAFORO, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="NUMERODIGITOS" sqlType="STRING"/>
		<param name="DIRTECNICA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="USO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="AFORADOR" sqlType="STRING"/>
		<param name="FECHALECTURAAFORO" sqlType="STRING"/>
		<param name="INDDESHABITADO" sqlType="STRING"/>
		<param name="LECTURA" sqlType="STRING"/>
		<param name="LECTURAAFORO" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>

	</query>
