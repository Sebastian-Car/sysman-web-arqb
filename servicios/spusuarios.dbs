	<query id="getSpusuariosTodosPorCodigoexternoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CICLO, CODIGORUTA, ANO, PERIODO, ESTADO, CODIGO_EXTERNO, FIMM  FROM SP_USUARIO WHERE COMPANIA = :COMPANIA AND CODIGO_EXTERNO= :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","ESTADO":"$ESTADO","CODIGO_EXTERNO":"$CODIGO_EXTERNO","FIMM":"$FIMM"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
