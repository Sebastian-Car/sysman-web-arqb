<data name="spusuarios" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getSpusuariosPorcodigoexternoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,ANO,PERIODO, CODIGORUTA, CODIGOINTERNO, ESTADO, CICLO  FROM SP_USUARIO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGO_EXTERNO = :CODEXTERNO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CODIGORUTA":"$CODIGORUTA","CODIGOINTERNO":"$CODIGOINTERNO","ESTADO":"$ESTADO","CICLO":"$CICLO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODEXTERNO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/porcodigoexterno">
		<call-query href="getSpusuariosPorcodigoexternoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODEXTERNO" query-param="CODEXTERNO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPorcodigoexternosincicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA,ANO,PERIODO, CODIGORUTA, CODIGOINTERNO, ESTADO, CICLO  FROM SP_USUARIO WHERE COMPANIA = :COMPANIA AND CODIGO_EXTERNO = :CODEXTERNO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CODIGORUTA":"$CODIGORUTA","CODIGOINTERNO":"$CODIGOINTERNO","ESTADO":"$ESTADO","CICLO":"$CICLO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODEXTERNO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/porcodigoexternosinciclo">
		<call-query href="getSpusuariosPorcodigoexternosincicloQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODEXTERNO" query-param="CODEXTERNO"/>

		</call-query>
	</resource>
	<query id="updateSpusuariosCambiarCodigoCatastral" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET  CODIGOCATASTRAL = REGEXP_REPLACE(CODIGOCATASTRAL,'[^0-9]+',''),DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY  WHERE COMPANIA = :COMPANIA   AND CICLO = :CICLO   AND CODIGOCATASTRAL IS NOT NULL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/cambiarcodigocatastral">
		<call-query href="updateSpusuariosCambiarCodigoCatastral">
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagCodrutaNombrecompletoPorCicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGORUTA, (CONCAT( NVL(PRIMERAPELLIDO,' ') ,CONCAT( ' ' ,CONCAT( NVL(SEGUNDOAPELLIDO,' ') ,CONCAT( ' ' , NVL(NOMBRES,' '))))) ) NOMBRE FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO = CASE WHEN :CICLO IN ('T') THEN CICLO ELSE TO_NUMBER(:CICLO) END ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/codrutanombrecompletoporciclo/pag">
		<call-query href="getSpusuariosPagCodrutaNombrecompletoPorCicloQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumCodrutaNombrecompletoPorCicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGORUTA, (CONCAT( NVL(PRIMERAPELLIDO,' ') ,CONCAT( ' ' ,CONCAT( NVL(SEGUNDOAPELLIDO,' ') ,CONCAT( ' ' , NVL(NOMBRES,' '))))) ) NOMBRE FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO = CASE WHEN :CICLO IN ('T') THEN CICLO ELSE TO_NUMBER(:CICLO) END ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/codrutanombrecompletoporciclo/num">
		<call-query href="getSpusuariosNumCodrutaNombrecompletoPorCicloQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagCodrutaNombrecompletoPorCicloYCodrutaMayoraCodinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGORUTA, CONCAT(NVL(PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(NOMBRES,' ') ) ) ) ) NOMBRE FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO = CASE WHEN :CICLO IN ( 'T' ) THEN CICLO ELSE TO_NUMBER(:CICLO) END AND CODIGORUTA &gt;=:CODIGOINICIAL ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/codrutanombrecompletoporcicloycodrutamayoracodinicial/pag">
		<call-query href="getSpusuariosPagCodrutaNombrecompletoPorCicloYCodrutaMayoraCodinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumCodrutaNombrecompletoPorCicloYCodrutaMayoraCodinicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGORUTA, CONCAT(NVL(PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(NOMBRES,' ') ) ) ) ) NOMBRE FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO = CASE WHEN :CICLO IN ( 'T' ) THEN CICLO ELSE TO_NUMBER(:CICLO) END AND CODIGORUTA &gt;=:CODIGOINICIAL ORDER BY CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/codrutanombrecompletoporcicloycodrutamayoracodinicial/num">
		<call-query href="getSpusuariosNumCodrutaNombrecompletoPorCicloYCodrutaMayoraCodinicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagTodosPorCodigorutaDatosBasicosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT CODIGORUTA, ( CONCAT(NOMBRES,CONCAT(' ',CONCAT(PRIMERAPELLIDO,CONCAT(' ',SEGUNDOAPELLIDO) ) ) ) ) NOMUSUARIO, CODIGOINTERNO, TOTFACTURAPERACTUAL,(CASE AUTORIZARBORRADO WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZARBORRADO, BANCOPERPROCESO, FACTURA FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMUSUARIO IS NULL THEN ' ' ELSE UPPER(NOMUSUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMUSUARIO), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMUSUARIO":"$NOMUSUARIO","CODIGOINTERNO":"$CODIGOINTERNO","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","AUTORIZARBORRADO":"$AUTORIZARBORRADO(type:boolean)","BANCOPERPROCESO":"$BANCOPERPROCESO","FACTURA":"$FACTURA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMUSUARIO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/todosporcodigorutadatosbasicos/pag">
		<call-query href="getSpusuariosPagTodosPorCodigorutaDatosBasicosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMUSUARIO" query-param="NOMUSUARIO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumTodosPorCodigorutaDatosBasicosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT CODIGORUTA, ( CONCAT(NOMBRES,CONCAT(' ',CONCAT(PRIMERAPELLIDO,CONCAT(' ',SEGUNDOAPELLIDO) ) ) ) ) NOMUSUARIO, CODIGOINTERNO, TOTFACTURAPERACTUAL,(CASE AUTORIZARBORRADO WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZARBORRADO, BANCOPERPROCESO, FACTURA FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMUSUARIO IS NULL THEN ' ' ELSE UPPER(NOMUSUARIO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMUSUARIO), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMUSUARIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/todosporcodigorutadatosbasicos/num">
		<call-query href="getSpusuariosNumTodosPorCodigorutaDatosBasicosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMUSUARIO" query-param="NOMUSUARIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, CICLO, CODIGOINTERNO, CODIGORUTA, ( CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) ) NOMBRE, NIT, DIRTECNICA, TELEFONO FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN DIRTECNICA IS NULL THEN ' ' ELSE UPPER(DIRTECNICA) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRTECNICA), '%')) AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END) LIKE UPPER(CONCAT(:TELEFONO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGOINTERNO":"$CODIGOINTERNO","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","NIT":"$NIT","DIRTECNICA":"$DIRTECNICA","TELEFONO":"$TELEFONO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="DIRTECNICA" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios">
		<call-query href="getSpusuariosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="DIRTECNICA" query-param="DIRTECNICA"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, CICLO, CODIGOINTERNO, CODIGORUTA, ( CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) ) NOMBRE, NIT, DIRTECNICA, TELEFONO FROM SP_USUARIO WHERE COMPANIA =:COMPANIA AND CICLO =:CICLO) INI WHERE (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(:CODIGOINTERNO, '%')) AND (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN DIRTECNICA IS NULL THEN ' ' ELSE UPPER(DIRTECNICA) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRTECNICA), '%')) AND (CASE WHEN TELEFONO IS NULL THEN ' ' ELSE UPPER(TELEFONO) END) LIKE UPPER(CONCAT(:TELEFONO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="DIRTECNICA" sqlType="STRING"/>
		<param name="TELEFONO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/numero">
		<call-query href="getSpusuariosNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="DIRTECNICA" query-param="DIRTECNICA"/>
			<with-param name="TELEFONO" query-param="TELEFONO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, CICLO, CODIGORUTA, ANO, PERIODO, PRIMERAPELLIDO, SEGUNDOAPELLIDO, NOMBRES, TOTFACTURAPERACTUAL, CODIGOINTERNO, CODIGOANTERIOR, DIRTECNICA, DIRGUIA, DIRCORRESPONDENCIA, TELEFONO, TIPODOCUMENTO, NIT, FAX, EMAIL, CODIGOCATASTRAL, CODIGOMAPA, USO, ESTRATO,(CASE ACUEDUCTO WHEN 0 THEN 'false' ELSE 'true' END) ACUEDUCTO,(CASE ASEO WHEN 0 THEN 'false' ELSE 'true' END) ASEO,(CASE ASEOBARRIDO WHEN 0 THEN 'false' ELSE 'true' END) ASEOBARRIDO,(CASE ALCANTARILLADO WHEN 0 THEN 'false' ELSE 'true' END) ALCANTARILLADO, PORCENTAJEAPLICAR, ESTRATOASEO, PESOASEO, FRECUENCIAASEOSEMANA, ESTADO, COMENTARIOS, MEDIDOR, NUMERODIGITOS, AFORADOR, PERIODOSATRASO, NOTACREDITO,(CASE INDFACTURADO WHEN 0 THEN 'false' ELSE 'true' END) INDFACTURADO,(CASE INDPREPARADO WHEN 0 THEN 'false' ELSE 'true' END) INDPREPARADO,(CASE INDESTADISTICAS WHEN 0 THEN 'false' ELSE 'true' END) INDESTADISTICAS,(CASE INDCALCULADO WHEN 0 THEN 'false' ELSE 'true' END) INDCALCULADO,(CASE INDIMPRESION WHEN 0 THEN 'false' ELSE 'true' END) INDIMPRESION,(CASE AUTORIZAMODIFICACION WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZAMODIFICACION,(CASE AUTORIZARBORRADO WHEN 0 THEN 'false' ELSE 'true' END) AUTORIZARBORRADO, NUMEROREGISTRO, OPERACION, PERIODOSINLECTURA, ACUMULADO, TIPOCALCULO,(CASE IND_MEDIDORNUEVO WHEN 0 THEN 'false' ELSE 'true' END) IND_MEDIDORNUEVO, FIMM,(CASE ALUMBRADO WHEN 0 THEN 'false' ELSE 'true' END) ALUMBRADO, ESTRATOALUMBRADO, INQUILINATOS, CREDITOABONADO, FACTURA, TIPOPREDIO, MULTIFAMILIAR, PISO,(TO_CHAR(FECHAINSCRIPCION,'DD/MM/YYYY HH24:MI:SS')) FECHAINSCRIPCION, CODIGO_EXTERNO, DIAMETROACOMETIDA,(CASE INDFINANINICIAL WHEN 0 THEN 'false' ELSE 'true' END) INDFINANINICIAL,(TO_CHAR(FECHAINSTALACION,'DD/MM/YYYY HH24:MI:SS')) FECHAINSTALACION, ABONOS, ESTADOMEDIDOR, INDBANCOS,(CASE CHAPETAS WHEN 0 THEN 'false' ELSE 'true' END) CHAPETAS, PSLM3, PLANTA, CIIU, NUMEROACOMETIDA, FRECUENCIARECOLECCION, TIPOCOBRO,(CASE INDMEDCAMBIADO WHEN 0 THEN 'false' ELSE 'true' END) INDMEDCAMBIADO, TIPOLECFIMM, SUBSINMEDICION, SOBRESINMEDICION, TASACAR, SELLOFIMM, NOUNDMULTIUSUARIO, ACSINMEDICION, ALSINMEDICION, SECTHIDRAULICO, SUBSECTOR, REDHIDRAULICA, SECCION, MANZANA,(CASE EXCLUIRCARTERA WHEN 0 THEN 'false' ELSE 'true' END) EXCLUIRCARTERA, LECTURACRITICA, MATRICULA, SUBALCSINMEDICION, SOBREALCSINMEDICION, INDRECAUDADO, NOTADEBITO,(CASE SEPARACIONENFUENTE WHEN 0 THEN 'false' ELSE 'true' END) SEPARACIONENFUENTE,(CASE NOPUERTAPUERTA WHEN 0 THEN 'false' ELSE 'true' END) NOPUERTAPUERTA,(CASE APARTAMENTO WHEN 0 THEN 'false' ELSE 'true' END) APARTAMENTO,(TO_CHAR(FECHALIMITE2,'DD/MM/YYYY HH24:MI:SS')) FECHALIMITE2, POSICION_MEDIDOR, SECTOR, CODIGODANE, LADO, RECARGOALC,(TO_CHAR(FECHACAMBIOEST,'DD/MM/YYYY HH24:MI:SS')) FECHACAMBIOEST,(TO_CHAR(FECHARENTRADANUEVOUSUARIO,'DD/MM/YYYY HH24:MI:SS')) FECHARENTRADANUEVOUSUARIO, PERENTRADANUEVOUSUARIO, ANOENTRADANUEVOUSUARIO, PERIODOSNOCOBROFIN, PERIODOSNOCOBROFAC,(TO_CHAR(FECHASALIOUSUARIO,'DD/MM/YYYY HH24:MI:SS')) FECHASALIOUSUARIO, TOTALIZADOR, BANCOPERPROCESO, DEUDA, TOTALDEUDA,(TO_CHAR(FECHAPAGOPERPROCESO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGOPERPROCESO, PAQUETEPAGOPERPROCESO, NOFECHAPAGOPERPROCESO, RECAUDADOPROCESO, GEOREFERENCIACION, TIPODEAFORO, EMPRESAASEOEXT,(TO_CHAR(FECHAINGASEOEXT,'DD/MM/YYYY HH24:MI:SS')) FECHAINGASEOEXT,(CASE PINTADEUDATERCE WHEN 0 THEN 'false' ELSE 'true' END) PINTADEUDATERCE, FREC_RECO, FREC_BARRI,(CASE CARACTERIZACION_ALC WHEN 0 THEN 'false' ELSE 'true' END) CARACTERIZACION_ALC,(CASE HOGAR_COMUNITARIO WHEN 0 THEN 'false' ELSE 'true' END) HOGAR_COMUNITARIO,(CASE INDDESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) INDDESHABITADO, POSTAL,(CASE INDMULTIUSUARIO WHEN 0 THEN 'false' ELSE 'true' END) INDMULTIUSUARIO, BARRIO, CODMACROMEDIDOR, CODTOTALIZADOR, RUTARECOLECCION_720, MICRORUTARECOLECCION_720, AREA, PAIS, DEPARTAMENTO, CIUDAD, CREATED_BY,(TO_CHAR(DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, MODIFIED_BY,(TO_CHAR(DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","PRIMERAPELLIDO":"$PRIMERAPELLIDO","SEGUNDOAPELLIDO":"$SEGUNDOAPELLIDO","NOMBRES":"$NOMBRES","TOTFACTURAPERACTUAL":"$TOTFACTURAPERACTUAL","CODIGOINTERNO":"$CODIGOINTERNO","CODIGOANTERIOR":"$CODIGOANTERIOR","DIRTECNICA":"$DIRTECNICA","DIRGUIA":"$DIRGUIA","DIRCORRESPONDENCIA":"$DIRCORRESPONDENCIA","TELEFONO":"$TELEFONO","TIPODOCUMENTO":"$TIPODOCUMENTO","NIT":"$NIT","FAX":"$FAX","EMAIL":"$EMAIL","CODIGOCATASTRAL":"$CODIGOCATASTRAL","CODIGOMAPA":"$CODIGOMAPA","USO":"$USO","ESTRATO":"$ESTRATO","ACUEDUCTO":"$ACUEDUCTO(type:boolean)","ASEO":"$ASEO(type:boolean)","ASEOBARRIDO":"$ASEOBARRIDO(type:boolean)","ALCANTARILLADO":"$ALCANTARILLADO(type:boolean)","PORCENTAJEAPLICAR":"$PORCENTAJEAPLICAR","ESTRATOASEO":"$ESTRATOASEO","PESOASEO":"$PESOASEO","FRECUENCIAASEOSEMANA":"$FRECUENCIAASEOSEMANA(type:integer)","ESTADO":"$ESTADO","COMENTARIOS":"$COMENTARIOS","MEDIDOR":"$MEDIDOR","NUMERODIGITOS":"$NUMERODIGITOS(type:integer)","AFORADOR":"$AFORADOR","PERIODOSATRASO":"$PERIODOSATRASO(type:integer)","NOTACREDITO":"$NOTACREDITO","INDFACTURADO":"$INDFACTURADO(type:boolean)","INDPREPARADO":"$INDPREPARADO(type:boolean)","INDESTADISTICAS":"$INDESTADISTICAS(type:boolean)","INDCALCULADO":"$INDCALCULADO(type:boolean)","INDIMPRESION":"$INDIMPRESION(type:boolean)","AUTORIZAMODIFICACION":"$AUTORIZAMODIFICACION(type:boolean)","AUTORIZARBORRADO":"$AUTORIZARBORRADO(type:boolean)","NUMEROREGISTRO":"$NUMEROREGISTRO","OPERACION":"$OPERACION","PERIODOSINLECTURA":"$PERIODOSINLECTURA(type:integer)","ACUMULADO":"$ACUMULADO","TIPOCALCULO":"$TIPOCALCULO","IND_MEDIDORNUEVO":"$IND_MEDIDORNUEVO(type:boolean)","FIMM":"$FIMM","ALUMBRADO":"$ALUMBRADO(type:boolean)","ESTRATOALUMBRADO":"$ESTRATOALUMBRADO","INQUILINATOS":"$INQUILINATOS(type:integer)","CREDITOABONADO":"$CREDITOABONADO","FACTURA":"$FACTURA","TIPOPREDIO":"$TIPOPREDIO","MULTIFAMILIAR":"$MULTIFAMILIAR","PISO":"$PISO","FECHAINSCRIPCION":"$FECHAINSCRIPCION","CODIGO_EXTERNO":"$CODIGO_EXTERNO","DIAMETROACOMETIDA":"$DIAMETROACOMETIDA","INDFINANINICIAL":"$INDFINANINICIAL(type:boolean)","FECHAINSTALACION":"$FECHAINSTALACION","ABONOS":"$ABONOS","ESTADOMEDIDOR":"$ESTADOMEDIDOR","INDBANCOS":"$INDBANCOS","CHAPETAS":"$CHAPETAS(type:boolean)","PSLM3":"$PSLM3(type:integer)","PLANTA":"$PLANTA(type:integer)","CIIU":"$CIIU","NUMEROACOMETIDA":"$NUMEROACOMETIDA","FRECUENCIARECOLECCION":"$FRECUENCIARECOLECCION(type:integer)","TIPOCOBRO":"$TIPOCOBRO","INDMEDCAMBIADO":"$INDMEDCAMBIADO(type:boolean)","TIPOLECFIMM":"$TIPOLECFIMM","SUBSINMEDICION":"$SUBSINMEDICION","SOBRESINMEDICION":"$SOBRESINMEDICION","TASACAR":"$TASACAR","SELLOFIMM":"$SELLOFIMM","NOUNDMULTIUSUARIO":"$NOUNDMULTIUSUARIO","ACSINMEDICION":"$ACSINMEDICION","ALSINMEDICION":"$ALSINMEDICION","SECTHIDRAULICO":"$SECTHIDRAULICO","SUBSECTOR":"$SUBSECTOR","REDHIDRAULICA":"$REDHIDRAULICA","SECCION":"$SECCION","MANZANA":"$MANZANA","EXCLUIRCARTERA":"$EXCLUIRCARTERA(type:boolean)","LECTURACRITICA":"$LECTURACRITICA","MATRICULA":"$MATRICULA","SUBALCSINMEDICION":"$SUBALCSINMEDICION","SOBREALCSINMEDICION":"$SOBREALCSINMEDICION","INDRECAUDADO":"$INDRECAUDADO","NOTADEBITO":"$NOTADEBITO","SEPARACIONENFUENTE":"$SEPARACIONENFUENTE(type:boolean)","NOPUERTAPUERTA":"$NOPUERTAPUERTA(type:boolean)","APARTAMENTO":"$APARTAMENTO(type:boolean)","FECHALIMITE2":"$FECHALIMITE2","POSICION_MEDIDOR":"$POSICION_MEDIDOR","SECTOR":"$SECTOR","CODIGODANE":"$CODIGODANE","LADO":"$LADO","RECARGOALC":"$RECARGOALC","FECHACAMBIOEST":"$FECHACAMBIOEST","FECHARENTRADANUEVOUSUARIO":"$FECHARENTRADANUEVOUSUARIO","PERENTRADANUEVOUSUARIO":"$PERENTRADANUEVOUSUARIO","ANOENTRADANUEVOUSUARIO":"$ANOENTRADANUEVOUSUARIO(type:integer)","PERIODOSNOCOBROFIN":"$PERIODOSNOCOBROFIN(type:integer)","PERIODOSNOCOBROFAC":"$PERIODOSNOCOBROFAC(type:integer)","FECHASALIOUSUARIO":"$FECHASALIOUSUARIO","TOTALIZADOR":"$TOTALIZADOR","BANCOPERPROCESO":"$BANCOPERPROCESO","DE