	<query id="getSpusuariosPagTodosPorCicloSinSuspensionJoinSpusosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT U.CODIGORUTA, CONCAT(NVL(U.PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(U.SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(U.NOMBRES,' ') ) ) ) ) NOMBRE FROM SP_USUARIO U INNER JOIN SP_USOS US ON U.COMPANIA = US.COMPANIA AND U.USO = US.CODIGO WHERE U.COMPANIA =:COMPANIA AND U.CICLO =:CICLO AND US.ACTA_SUSPENSION NOT IN (0) ORDER BY U.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
