	<query id="updateSpusuariosFechasLecAnteriorYActual" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO        SET FECHALECANTERIOR = TO_DATE(:FECHAANTERIOR,'DD/MM/YYYY HH24:MI:SS'), FECHALECACTUAL = TO_DATE(:FECHAACTUAL,'DD/MM/YYYY HH24:MI:SS'),  DATE_MODIFIED = TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY = :MODIFIED_BY     WHERE COMPANIA = :COMPANIA          AND CICLO    = :CICLO         AND PERIODO  = :PERIODO           AND ESTADO   = 'R'       AND CODIGORUTA BETWEEN :CODIGOINICIAL AND :CODIGOFINAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHAANTERIOR" sqlType="STRING"/>
		<param name="FECHAACTUAL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/fechaslecanterioryactual">
		<call-query href="updateSpusuariosFechasLecAnteriorYActual">
			<with-param name="FECHAANTERIOR" query-param="FECHAANTERIOR"/>
			<with-param name="FECHAACTUAL" query-param="FECHAACTUAL"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGOFINAL" query-param="CODIGOFINAL"/>

		</call-query>
	</resource>
	<query id="getSpusuariosValidacionFinanciableQuery"  useConfig="sysmandsunist">
		<sql>SELECT  FIMM, NVL(LECTURA,0) LECTURA, BANCOPERPROCESO, PERIODOSNOCOBROFAC, NVL(PERIODOSNOCOBROFIN,0) PERIODOSNOCOBROFIN , FACTURA, CODIGORUTA  FROM SP_USUARIO WHERE COMPANIA = :COMPANIA AND CICLO = :CICLO AND CODIGORUTA = :CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FIMM":"$FIMM","LECTURA":"$LECTURA(type:integer)","BANCOPERPROCESO":"$BANCOPERPROCESO","PERIODOSNOCOBROFAC":"$PERIODOSNOCOBROFAC(type:integer)","PERIODOSNOCOBROFIN":"$PERIODOSNOCOBROFIN(type:integer)","FACTURA":"$FACTURA","CODIGORUTA":"$CODIGORUTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
