			<with-param name="CONSUMOPROM" query-param="CONSUMOPROM"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagCodigosDeRutaporCicloFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  SP_USUARIO.CODIGORUTA  FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA = :COMPANIA AND SP_USUARIO.CICLO = CASE WHEN :CICLO = 'T' THEN SP_USUARIO.CICLO ELSE TO_NUMBER(:CICLO) END AND SP_USUARIO.CODIGORUTA &gt;= :CODIGOINICIAL ORDER BY SP_USUARIO.CODIGORUTA) WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END)  LIKE UPPER(:CODIGORUTA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
