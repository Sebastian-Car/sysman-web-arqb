	<query id="getSpusuariosTodosConInformeDeSubsidiosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(SP_USUARIO.SUBFIJO) SUBFIJOACU, SUM(SP_USUARIO.SUBCONSUMOAC) SUBCONSUMOACU, SUM(SP_USUARIO.SUBSINMEDICION) SUBSINMEDICACU, SUM(SP_USUARIO.SUBACUEDUCTO) TOTALSUBACU, SUM(SP_USUARIO.SUBFIJOALC) SUBFIJOALC, SUM(SP_USUARIO.SUBCONSUMOAL) SUBCONSUMOALC, SUM(SP_USUARIO.SUBALCSINMEDICION) SUBSINMEDIALC, SUM(SP_USUARIO.SUBALCANTARILLADO) TOTALSUBALC, SUM(SP_USUARIO.SUBASEO) SUBSASEO, SUM(SP_USUARIO.SUBBARR_LIM) SUBBARRIDOASEO, SUM(SP_USUARIO.SUBDISP_FINAL) SUBTRATAFINALASEO, SUM(SP_USUARIO.SUBMANEJO_REC) SUBCOMERASEO, SUM(SP_USUARIO.SUBRECOLECCION) SUBRECOLECASEO, SUM(SP_USUARIO.SUBTRAMO) SUBTEXECEASEO, SUM(SP_USUARIO.SOBREFIJO) SOBFIJOACU, SUM(SP_USUARIO.SOBRECONSUMOAC) SOBCONSUMOACU, SUM(SP_USUARIO.SOBRESINMEDICION) SOBSMEDIACU, SUM(SP_USUARIO.SOBREACUEDUCTO) TOTALSOBACU, SUM(SP_USUARIO.SOBREFIJOALC) SOBDIJOALCAN, SUM(SP_USUARIO.SOBRECONSUMOAL) SOBCONSUMOALC, SUM(SP_USUARIO.SOBREALCSINMEDICION) SOBSINMEDIALC, SUM(SP_USUARIO.SOBREALCANTARILLADO) TOTALSOBALC, SUM(SP_USUARIO.SOBREASEO) SOBASEO, SUM(SP_USUARIO.SOBBARR_LIM) SOBBARRIDOASEO, SUM(SP_USUARIO.SOBDISP_FINAL) SOBTRATAFINALASEO, SUM(SP_USUARIO.SOBMANEJO_REC) SOBCOMERASEO, SUM(SP_USUARIO.SOBRECOLECCION) SOBRECOLECASEO, SUM(SP_USUARIO.SOBTRAMO) SOBTEXECEASEO, SUM(SP_USUARIO.SUBSIDIO) TOTALSUBSIDIOS, SUM(SP_USUARIO.SOBREPRECIO) TOTALSOBRE  FROM SP_USUARIO INNER JOIN SP_ESTRATOS ON SP_USUARIO.ESTRATO = SP_ESTRATOS.CODIGO AND SP_USUARIO.USO = SP_ESTRATOS.USO AND SP_USUARIO.COMPANIA = SP_ESTRATOS.COMPANIA INNER JOIN SP_USOS ON SP_ESTRATOS.COMPANIA = SP_USOS.COMPANIA AND SP_ESTRATOS.USO = SP_USOS.CODIGO WHERE SP_USUARIO.COMPANIA = :COMPANIA AND SP_USUARIO.CICLO BETWEEN :CICLOINICIAL AND :CICLOFINAL AND SP_USUARIO.CODIGORUTA BETWEEN :CODIGOINICIAL AND :CODIGOFINAL AND SP_USUARIO.ESTADO &lt;&gt; 'R' AND SP_USOS.CODIGO = :CODIGOUSO AND SP_USUARIO.SUBSIDIO + SP_USUARIO.SOBREPRECIO &gt; CASE WHEN :PARSUBI IN('SI') THEN 0 ELSE SP_USUARIO.SUBSIDIO + SP_USUARIO.SOBREPRECIO-1 END</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SUBFIJOACU":"$SUBFIJOACU(type:integer)","SUBCONSUMOACU":"$SUBCONSUMOACU(type:integer)","SUBSINMEDICACU":"$SUBSINMEDICACU(type:integer)","TOTALSUBACU":"$TOTALSUBACU(type:integer)","SUBFIJOALC":"$SUBFIJOALC(type:integer)","SUBCONSUMOALC":"$SUBCONSUMOALC(type:integer)","SUBSINMEDIALC":"$SUBSINMEDIALC(type:integer)","TOTALSUBALC":"$TOTALSUBALC(type:integer)","SUBSASEO":"$SUBSASEO(type:integer)","SUBBARRIDOASEO":"$SUBBARRIDOASEO(type:integer)","SUBTRATAFINALASEO":"$SUBTRATAFINALASEO(type:integer)","SUBCOMERASEO":"$SUBCOMERASEO(type:integer)","SUBRECOLECASEO":"$SUBRECOLECASEO(type:integer)","SUBTEXECEASEO":"$SUBTEXECEASEO(type:integer)","SOBFIJOACU":"$SOBFIJOACU(type:integer)","SOBCONSUMOACU":"$SOBCONSUMOACU(type:integer)","SOBSMEDIACU":"$SOBSMEDIACU(type:integer)","TOTALSOBACU":"$TOTALSOBACU(type:integer)","SOBDIJOALCAN":"$SOBDIJOALCAN(type:integer)","SOBCONSUMOALC":"$SOBCONSUMOALC(type:integer)","SOBSINMEDIALC":"$SOBSINMEDIALC(type:integer)","TOTALSOBALC":"$TOTALSOBALC(type:integer)","SOBASEO":"$SOBASEO(type:integer)","SOBBARRIDOASEO":"$SOBBARRIDOASEO(type:integer)","SOBTRATAFINALASEO":"$SOBTRATAFINALASEO(type:integer)","SOBCOMERASEO":"$SOBCOMERASEO(type:integer)","SOBRECOLECASEO":"$SOBRECOLECASEO(type:integer)","SOBTEXECEASEO":"$SOBTEXECEASEO(type:integer)","TOTALSUBSIDIOS":"$TOTALSUBSIDIOS(type:integer)","TOTALSOBRE":"$TOTALSOBRE(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLOINICIAL" sqlType="STRING"/>
		<param name="CICLOFINAL" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGOFINAL" sqlType="STRING"/>
		<param name="CODIGOUSO" sqlType="STRING"/>
		<param name="PARSUBI" sqlType="STRING"/>

	</query>
