	<query id="getSpusuariosTodosPorPrincipalLecturaCorreccionCriticaQuery"  useConfig="sysmandsunist">
		<sql>SELECT SP_USUARIO_PROBLEMA.CLASE, SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) ) NOMBRE, SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.CODIGOINTERNO, SP_USUARIO.DIRTECNICA, SP_USUARIO.USO, SP_USUARIO.NUMERODIGITOS, SP_USUARIO.LECTURA, SP_USUARIO.LECTURAAFORO,(TO_CHAR(SP_USUARIO.FECHALECTURAAFORO,'DD/MM/YYYY HH24:MI:SS')) FECHALECTURAAFORO, SP_USUARIO.AFORADOR,(CASE SP_USUARIO.INDDESHABITADO WHEN 0 THEN 'false' ELSE 'true' END) INDDESHABITADO, TERCERO.NOMBRE NOMBREAFORADOR, SP_USUARIO.MODIFIED_BY,(TO_CHAR(SP_USUARIO.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, SP_USUARIO.CREATED_BY,(TO_CHAR(SP_USUARIO.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED FROM SP_USUARIO INNER JOIN SP_AFORADORES ON SP_USUARIO.COMPANIA = SP_AFORADORES.COMPANIA AND SP_USUARIO.AFORADOR = SP_AFORADORES.CODIGO INNER JOIN TERCERO ON SP_AFORADORES.COMPANIA = TERCERO.COMPANIA AND SP_AFORADORES.NIT = TERCERO.NIT AND SP_AFORADORES.SUCURSAL = TERCERO.SUCURSAL INNER JOIN SP_USUARIO_PROBLEMA ON SP_USUARIO_PROBLEMA.COMPANIA = SP_USUARIO.COMPANIA AND SP_USUARIO_PROBLEMA.CICLO = SP_USUARIO.CICLO AND SP_USUARIO_PROBLEMA.CODIGORUTA = SP_USUARIO.CODIGORUTA WHERE SP_USUARIO.COMPANIA =:KEY_COMPANIA AND SP_USUARIO.CICLO =:KEY_CICLO AND SP_USUARIO.CODIGORUTA =:KEY_CODIGORUTA ORDER BY SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASE":"$CLASE","COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CODIGOINTERNO":"$CODIGOINTERNO","DIRTECNICA":"$DIRTECNICA","USO":"$USO","NUMERODIGITOS":"$NUMERODIGITOS(type:integer)","LECTURA":"$LECTURA","LECTURAAFORO":"$LECTURAAFORO","FECHALECTURAAFORO":"$FECHALECTURAAFORO","AFORADOR":"$AFORADOR","INDDESHABITADO":"$INDDESHABITADO(type:boolean)","NOMBREAFORADOR":"$NOMBREAFORADOR","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>

	</query>
