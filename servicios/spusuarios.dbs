			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagTodosPorCicloSinSuspensionJoinSpusosFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT U.CODIGORUTA, CONCAT(NVL(U.PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(U.SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(U.NOMBRES,' ') ) ) ) ) NOMBRE FROM SP_USUARIO U INNER JOIN SP_USOS US ON U.COMPANIA = US.COMPANIA AND U.USO = US.CODIGO WHERE U.COMPANIA =:COMPANIA AND U.CICLO =:CICLO AND U.CODIGORUTA &gt;=:CODIGOINICIAL AND US.ACTA_SUSPENSION NOT IN (0) ORDER BY U.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/todosporciclosinsuspensionjoinspusosfinal/pag">
		<call-query href="getSpusuariosPagTodosPorCicloSinSuspensionJoinSpusosFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumTodosPorCicloSinSuspensionJoinSpusosFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT U.CODIGORUTA, CONCAT(NVL(U.PRIMERAPELLIDO,' '),CONCAT(' ',CONCAT(NVL(U.SEGUNDOAPELLIDO,' '),CONCAT(' ',NVL(U.NOMBRES,' ') ) ) ) ) NOMBRE FROM SP_USUARIO U INNER JOIN SP_USOS US ON U.COMPANIA = US.COMPANIA AND U.USO = US.CODIGO WHERE U.COMPANIA =:COMPANIA AND U.CICLO =:CICLO AND U.CODIGORUTA &gt;=:CODIGOINICIAL AND US.ACTA_SUSPENSION NOT IN (0) ORDER BY U.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGOINICIAL" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/todosporciclosinsuspensionjoinspusosfinal/num">
		<call-query href="getSpusuariosNumTodosPorCicloSinSuspensionJoinSpusosFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGOINICIAL" query-param="CODIGOINICIAL"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagPorCicloYBarrioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, SP_USUARIO.CODIGOINTERNO, CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ) SUSCRIPTOR , SP_USUARIO.DIRTECNICA, SP_USUARIO.BARRIO,(CASE SP_USUARIO.AFOROINCENTIVO WHEN 0 THEN 'false' ELSE 'true' END) AFOROINCENTIVO FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND SP_USUARIO.BARRIO =:BARRIO) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGORUTA), '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOINTERNO), '%')) AND (CASE WHEN SUSCRIPTOR IS NULL THEN ' ' ELSE UPPER(SUSCRIPTOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SUSCRIPTOR), '%')) AND (CASE WHEN AFOROINCENTIVO IS NULL THEN ' ' ELSE UPPER(AFOROINCENTIVO) END) LIKE UPPER(CONCAT(:AFOROINCENTIVO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA","CODIGOINTERNO":"$CODIGOINTERNO","SUSCRIPTOR":"$SUSCRIPTOR","DIRTECNICA":"$DIRTECNICA","BARRIO":"$BARRIO","AFOROINCENTIVO":"$AFOROINCENTIVO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="BARRIO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="SUSCRIPTOR" sqlType="STRING"/>
		<param name="AFOROINCENTIVO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/porcicloybarrio/pag">
		<call-query href="getSpusuariosPagPorCicloYBarrioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="BARRIO" query-param="BARRIO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="SUSCRIPTOR" query-param="SUSCRIPTOR"/>
			<with-param name="AFOROINCENTIVO" query-param="AFOROINCENTIVO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumPorCicloYBarrioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.CODIGORUTA, SP_USUARIO.CODIGOINTERNO, CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ) SUSCRIPTOR , SP_USUARIO.DIRTECNICA, SP_USUARIO.BARRIO,(CASE SP_USUARIO.AFOROINCENTIVO WHEN 0 THEN 'false' ELSE 'true' END) AFOROINCENTIVO FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO AND SP_USUARIO.BARRIO =:BARRIO) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGORUTA), '%')) AND (CASE WHEN CODIGOINTERNO IS NULL THEN ' ' ELSE UPPER(CODIGOINTERNO) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOINTERNO), '%')) AND (CASE WHEN SUSCRIPTOR IS NULL THEN ' ' ELSE UPPER(SUSCRIPTOR) END) LIKE UPPER(CONCAT(CONCAT('%',:SUSCRIPTOR), '%')) AND (CASE WHEN AFOROINCENTIVO IS NULL THEN ' ' ELSE UPPER(AFOROINCENTIVO) END) LIKE UPPER(CONCAT(:AFOROINCENTIVO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="BARRIO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="SUSCRIPTOR" sqlType="STRING"/>
		<param name="AFOROINCENTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/porcicloybarrio/num">
