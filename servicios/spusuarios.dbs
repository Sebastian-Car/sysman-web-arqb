	<query id="getSpusuariosValidaUsuarioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SP_USUARIO.COMPANIA, SP_USUARIO.CICLO , SP_USUARIO.CODIGORUTA  FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA = :COMPANIA AND SP_USUARIO.CICLO = :CICLO AND SP_USUARIO.CODIGORUTA = :CODIGORUTA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","CODIGORUTA":"$CODIGORUTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>

	</query>
