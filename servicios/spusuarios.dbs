		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","CICLO":"$CICLO(type:integer)","BANCOPERPROCESO":"$BANCOPERPROCESO","NOTACREDITO":"$NOTACREDITO"}]}}		</result>
