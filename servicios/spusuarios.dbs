			<with-param name="SUSCRIPTOR" query-param="SUSCRIPTOR"/>
			<with-param name="AFOROINCENTIVO" query-param="AFOROINCENTIVO"/>

		</call-query>
	</resource>
	<query id="updateSpusuariosPorCicloYBarrio" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE SP_USUARIO SET COMPANIA=:COMPANIA, CICLO=:CICLO, CODIGORUTA=:CODIGORUTA, CODIGOINTERNO=:CODIGOINTERNO, DIRTECNICA=:DIRTECNICA, BARRIO=:BARRIO, AFOROINCENTIVO=:AFOROINCENTIVO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE SP_USUARIO.COMPANIA= :KEY_COMPANIA AND SP_USUARIO.CICLO= :KEY_CICLO AND SP_USUARIO.CODIGORUTA= :KEY_CODIGORUTA</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CODIGOINTERNO" sqlType="STRING"/>
		<param name="DIRTECNICA" sqlType="STRING"/>
		<param name="BARRIO" sqlType="STRING"/>
		<param name="AFOROINCENTIVO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CICLO" sqlType="STRING"/>
		<param name="KEY_CODIGORUTA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="spusuarios/porcicloybarrio">
		<call-query href="updateSpusuariosPorCicloYBarrio">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CODIGOINTERNO" query-param="CODIGOINTERNO"/>
			<with-param name="DIRTECNICA" query-param="DIRTECNICA"/>
			<with-param name="BARRIO" query-param="BARRIO"/>
			<with-param name="AFOROINCENTIVO" query-param="AFOROINCENTIVO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CICLO" query-param="KEY_CICLO"/>
			<with-param name="KEY_CODIGORUTA" query-param="KEY_CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPrimeraYUltimaFechaQuery"  useConfig="sysmandsunist">
		<sql>SELECT (TO_CHAR(MAX(FECHAPAGOPERPROCESO),'DD/MM/YYYY HH24:MI:SS')) ULTIMAFECHA,(TO_CHAR(MIN(FECHAPAGOPERPROCESO),'DD/MM/YYYY HH24:MI:SS')) PRIMERAFECHA FROM SP_USUARIO WHERE COMPANIA = :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ULTIMAFECHA":"$ULTIMAFECHA","PRIMERAFECHA":"$PRIMERAFECHA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/primerayultimafecha">
		<call-query href="getSpusuariosPrimeraYUltimaFechaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="getSpusuariosCantidadRegistrosQuery"  useConfig="sysmandsunist">
