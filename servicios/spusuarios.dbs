	</resource>
	<query id="getSpusuariosNumTodosConNombrePorCompaniaYCicloQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT 'TODOS' CODIGORUTA, 'TODOS' NOMBRE FROM DUAL UNION SELECT DISTINCT U.CODIGORUTA, CONCAT(NVL(U.NOMBRES,' '),CONCAT(' ',CONCAT(NVL(U.PRIMERAPELLIDO,' '),CONCAT(' ',NVL(U.SEGUNDOAPELLIDO,' ') ) ) ) ) NOMBRE FROM SP_USUARIO U INNER JOIN SP_INFO_TIPO_OPERACION ITO ON U.COMPANIA = ITO.COMPANIA AND U.CICLO = ITO.CICLO AND U.CODIGORUTA = ITO.CODIGORUTA WHERE U.COMPANIA =:COMPANIA AND U.CICLO =:CICLO) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="spusuarios/todosconnombreporcompaniayciclo/num">
