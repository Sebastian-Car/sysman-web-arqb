			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagTodosPorHistoricosQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE, CASE WHEN BANCOPERPROCESO IS NULL THEN ANO1 ELSE ANO END ANOPYS, CASE WHEN BANCOPERPROCESO IS NULL THEN PERIODO1 ELSE PERIODO END PERIODOPYS,(TO_CHAR(CASE WHEN BANCOPERPROCESO IS NULL THEN FECHAPAGO1 ELSE FECHAPAGOPERPROCESO END,'DD/MM/YYYY HH24:MI:SS')) FECHAPYS, SP_USUARIO.BANCOPERPROCESO FROM SP_USUARIO INNER JOIN SP_USUARIO_HISTORICOS ON SP_USUARIO.COMPANIA = SP_USUARIO_HISTORICOS.COMPANIA AND SP_USUARIO.CICLO = SP_USUARIO_HISTORICOS.CICLO AND SP_USUARIO.CODIGORUTA = SP_USUARIO_HISTORICOS.CODIGORUTA WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO ORDER BY SP_USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","NOMBRE":"$NOMBRE","ANOPYS":"$ANOPYS(type:integer)","PERIODOPYS":"$PERIODOPYS","FECHAPYS":"$FECHAPYS","BANCOPERPROCESO":"$BANCOPERPROCESO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/todosporhistoricos/pag">
		<call-query href="getSpusuariosPagTodosPorHistoricosQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosNumTodosPorHistoricosQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_USUARIO.CODIGORUTA, CONCAT(PRIMERAPELLIDO,CONCAT(' ',CONCAT(SEGUNDOAPELLIDO,CONCAT(' ',NOMBRES) ) ) ) NOMBRE, CASE WHEN BANCOPERPROCESO IS NULL THEN ANO1 ELSE ANO END ANOPYS, CASE WHEN BANCOPERPROCESO IS NULL THEN PERIODO1 ELSE PERIODO END PERIODOPYS,(TO_CHAR(CASE WHEN BANCOPERPROCESO IS NULL THEN FECHAPAGO1 ELSE FECHAPAGOPERPROCESO END,'DD/MM/YYYY HH24:MI:SS')) FECHAPYS, SP_USUARIO.BANCOPERPROCESO FROM SP_USUARIO INNER JOIN SP_USUARIO_HISTORICOS ON SP_USUARIO.COMPANIA = SP_USUARIO_HISTORICOS.COMPANIA AND SP_USUARIO.CICLO = SP_USUARIO_HISTORICOS.CICLO AND SP_USUARIO.CODIGORUTA = SP_USUARIO_HISTORICOS.CODIGORUTA WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO ORDER BY SP_USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
