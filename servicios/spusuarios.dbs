	<query id="getSpusuariosPagTodosPorCodigoRutaFacturaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.CODIGORUTA, SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.NIT, SP_USUARIO.ESTADO, CONCAT(SP_USUARIO.NOMBRES,CONCAT(' ',CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',SP_USUARIO.SEGUNDOAPELLIDO) ) ) ) NOMBRE FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.ESTADO = 'A') INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","NIT":"$NIT","ESTADO":"$ESTADO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="spusuarios/todosporcodigorutafactura/pag">
		<call-query href="getSpusuariosPagTodosPorCodigoRutaFacturaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGORUTA" query-param="CODIGORUTA"/>
			<with-param name="CICLO" query-param="CICLO"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="PERIODO" query-param="PERIODO"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="ESTADO" query-param="ESTADO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getSpusuariosPagTodosPorEstadoActivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT SP_USUARIO.CODIGORUTA, SP_USUARIO.COMPANIA, SP_USUARIO.CICLO, SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.NIT, SP_USUARIO.ESTADO, CONCAT(NVL(SP_USUARIO.NOMBRES,''),CONCAT(' ',CONCAT(NVL(SP_USUARIO.PRIMERAPELLIDO,''),CONCAT(' ',NVL(SP_USUARIO.SEGUNDOAPELLIDO ,'') ) ) ) ) NOMBRE FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.ESTADO = 'A') INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END) LIKE UPPER(CONCAT(:COMPANIA, '%')) AND (CASE WHEN CICLO IS NULL THEN ' ' ELSE UPPER(CICLO) END) LIKE UPPER(CONCAT(:CICLO, '%')) AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END) LIKE UPPER(CONCAT(:ANO, '%')) AND (CASE WHEN PERIODO IS NULL THEN ' ' ELSE UPPER(PERIODO) END) LIKE UPPER(CONCAT(:PERIODO, '%')) AND (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END) LIKE UPPER(CONCAT(:NIT, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGORUTA":"$CODIGORUTA","COMPANIA":"$COMPANIA","CICLO":"$CICLO(type:integer)","ANO":"$ANO(type:integer)","PERIODO":"$PERIODO","NIT":"$NIT","ESTADO":"$ESTADO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="PERIODO" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="ESTADO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
