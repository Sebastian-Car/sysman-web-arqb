		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT SP_USUARIO.CODIGORUTA, CONCAT(SP_USUARIO.PRIMERAPELLIDO,CONCAT(' ',CONCAT(SP_USUARIO.SEGUNDOAPELLIDO,CONCAT(' ',SP_USUARIO.NOMBRES) ) ) ) NOMBRE, SP_USUARIO.DIRTECNICA, SP_USUARIO.TELEFONO, SP_USUARIO.PRIMERAPELLIDO, SP_USUARIO.SEGUNDOAPELLIDO, SP_USUARIO.NOMBRES, SP_USUARIO.AFORADOR, SP_USUARIO.ANO, SP_USUARIO.PERIODO, SP_USUARIO.TOTFACTURAPERACTUAL, SP_USUARIO.FACTURA, SP_USUARIO.BANCOPERPROCESO, SP_USUARIO.CODIGOINTERNO FROM SP_USUARIO WHERE SP_USUARIO.COMPANIA =:COMPANIA AND SP_USUARIO.CICLO =:CICLO ORDER BY SP_USUARIO.CODIGORUTA) INI WHERE (CASE WHEN CODIGORUTA IS NULL THEN ' ' ELSE UPPER(CODIGORUTA) END) LIKE UPPER(CONCAT(:CODIGORUTA, '%')) AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE), '%')) AND (CASE WHEN DIRTECNICA IS NULL THEN ' ' ELSE UPPER(DIRTECNICA) END) LIKE UPPER(CONCAT(CONCAT('%',:DIRTECNICA), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CICLO" sqlType="STRING"/>
		<param name="CODIGORUTA" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="DIRTECNICA" sqlType="STRING"/>

	</query>
