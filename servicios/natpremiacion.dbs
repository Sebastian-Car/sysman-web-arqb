<data name="natpremiacion" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertNatpremiacion" keyColumns="COMPANIA,IDEVENTO,TIPOEVENTO,NUMERO_DCTO,SUCURSAL" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO NAT_PREMIACION (COMPANIA, IDEVENTO, TIPOEVENTO, NUMERO_DCTO, SUCURSAL, BENEFICIARIO, PREMIO, CALIFICACION, OBSERVACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :IDEVENTO, :TIPOEVENTO, :NUMERO_DCTO, :SUCURSAL, :BENEFICIARIO, :PREMIO, :CALIFICACION, :OBSERVACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_IDEVENTO":"$IDEVENTO","KEY_TIPOEVENTO":"$TIPOEVENTO","KEY_NUMERO_DCTO":"$NUMERO_DCTO","KEY_SUCURSAL":"$SUCURSAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="0" name="BENEFICIARIO" sqlType="STRING"/>
		<param name="PREMIO" sqlType="STRING"/>
		<param defaultValue="0" name="CALIFICACION" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="natpremiacion">
		<call-query href="insertNatpremiacion">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="PREMIO" query-param="PREMIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteNatpremiacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM NAT_PREMIACION WHERE NAT_PREMIACION.COMPANIA= :KEY_COMPANIA AND NAT_PREMIACION.IDEVENTO= :KEY_IDEVENTO AND NAT_PREMIACION.TIPOEVENTO= :KEY_TIPOEVENTO AND NAT_PREMIACION.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_PREMIACION.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="natpremiacion">
		<call-query href="deleteNatpremiacion">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>
	<query id="getNatpremiacionPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  PRE.COMPANIA, PRE.IDEVENTO, PRE.TIPOEVENTO, PRE.NUMERO_DCTO, PRE.SUCURSAL, TIAC.NOMBRE NOMBRE_TIPOEVENTO, AP.NOMBREEVENTO EVENTO, FAM.NOMBRE ASISTENTE,(CASE PRE.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, PRE.CALIFICACION, PREM.NOMBRE_TIPO_PREMIO NOMBRE_PREMIO, PRE.OBSERVACION, PRE.PREMIO  FROM NAT_PREMIACION PRE INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AI.COMPANIA = PRE.COMPANIA AND AI.IDEVENTO = PRE.IDEVENTO AND AI.TIPOEVENTO = PRE.TIPOEVENTO AND AI.NUMERO_DCTO = PRE.NUMERO_DCTO AND AI.SUCURSAL = PRE.SUCURSAL INNER JOIN NAT_ACTIVIDADESPROGRAMADAS AP ON AP.COMPANIA = PRE.COMPANIA AND AP.IDEVENTO = PRE.IDEVENTO AND AP.TIPOEVENTO = PRE.TIPOEVENTO INNER JOIN NAT_TIPOACTIVIDADES TIAC ON TIAC.COMPANIA = PRE.COMPANIA AND TIAC.CODIGO = PRE.TIPOEVENTO INNER JOIN FAMILIARES FAM ON FAM.COMPANIA = PRE.COMPANIA AND FAM.IDENTIFICACION = PRE.NUMERO_DCTO AND FAM.SUCURSAL = PRE.SUCURSAL INNER JOIN NAT_TIPO_PREMIO PREM ON PREM.COMPANIA = PRE.COMPANIA AND PREM.ID_TIPO_PREMIO = PRE.PREMIO WHERE PRE.COMPANIA =:COMPANIA UNION SELECT PRE.COMPANIA, PRE.IDEVENTO, PRE.TIPOEVENTO, PRE.NUMERO_DCTO, PRE.SUCURSAL, TIAC.NOMBRE NOMBRE_TIPOEVENTO, AP.NOMBREEVENTO EVENTO, TER.NOMBRE ASISTENTE, (CASE PRE.BENEFICIARIO WHEN 0  THEN 'false'   ELSE 'true' END) BENEFICIARIO, PRE.CALIFICACION, PREM.NOMBRE_TIPO_PREMIO NOMBRE_PREMIO, PRE.OBSERVACION, PRE.PREMIO FROM NAT_PREMIACION PRE INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AI.COMPANIA = PRE.COMPANIA AND AI.IDEVENTO = PRE.IDEVENTO AND AI.TIPOEVENTO = PRE.TIPOEVENTO AND AI.NUMERO_DCTO = PRE.NUMERO_DCTO AND AI.SUCURSAL = PRE.SUCURSAL INNER JOIN NAT_ACTIVIDADESPROGRAMADAS AP ON AP.COMPANIA = PRE.COMPANIA AND AP.IDEVENTO = PRE.IDEVENTO AND AP.TIPOEVENTO = PRE.TIPOEVENTO INNER JOIN NAT_TIPOACTIVIDADES TIAC ON TIAC.COMPANIA = PRE.COMPANIA AND TIAC.CODIGO = PRE.TIPOEVENTO INNER JOIN TERCERO TER ON TER.COMPANIA = PRE.COMPANIA AND TER.NIT = PRE.NUMERO_DCTO AND TER.SUCURSAL = PRE.SUCURSAL INNER JOIN NAT_TIPO_PREMIO PREM ON PREM.COMPANIA = PRE.COMPANIA AND PREM.ID_TIPO_PREMIO = PRE.PREMIO WHERE PRE.COMPANIA =:COMPANIA) WHERE (CASE WHEN NOMBRE_TIPOEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOEVENTO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOEVENTO || '%')  AND (CASE WHEN EVENTO IS NULL THEN ' ' ELSE UPPER(EVENTO) END)  LIKE UPPER( '%' || :EVENTO || '%')  AND (CASE WHEN ASISTENTE IS NULL THEN ' ' ELSE UPPER(ASISTENTE) END)  LIKE UPPER( '%' || :ASISTENTE || '%')  AND (CASE WHEN BENEFICIARIO IS NULL THEN ' ' ELSE UPPER(BENEFICIARIO) END)  LIKE UPPER( '%' || :BENEFICIARIO || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER(:CALIFICACION || '%')  AND (CASE WHEN NOMBRE_PREMIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PREMIO) END)  LIKE UPPER(:NOMBRE_PREMIO || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","IDEVENTO":"$IDEVENTO","TIPOEVENTO":"$TIPOEVENTO","NUMERO_DCTO":"$NUMERO_DCTO","SUCURSAL":"$SUCURSAL","NOMBRE_TIPOEVENTO":"$NOMBRE_TIPOEVENTO","EVENTO":"$EVENTO","ASISTENTE":"$ASISTENTE","BENEFICIARIO":"$BENEFICIARIO(type:boolean)","CALIFICACION":"$CALIFICACION(type:integer)","NOMBRE_PREMIO":"$NOMBRE_PREMIO","OBSERVACION":"$OBSERVACION","PREMIO":"$PREMIO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE_TIPOEVENTO" sqlType="STRING"/>
		<param name="EVENTO" sqlType="STRING"/>
		<param name="ASISTENTE" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="NOMBRE_PREMIO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="natpremiacion">
		<call-query href="getNatpremiacionPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE_TIPOEVENTO" query-param="NOMBRE_TIPOEVENTO"/>
			<with-param name="EVENTO" query-param="EVENTO"/>
			<with-param name="ASISTENTE" query-param="ASISTENTE"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="NOMBRE_PREMIO" query-param="NOMBRE_PREMIO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getNatpremiacionNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  PRE.COMPANIA, PRE.IDEVENTO, PRE.TIPOEVENTO, PRE.NUMERO_DCTO, PRE.SUCURSAL, TIAC.NOMBRE NOMBRE_TIPOEVENTO, AP.NOMBREEVENTO EVENTO, FAM.NOMBRE ASISTENTE,(CASE PRE.BENEFICIARIO WHEN 0 THEN 'false' ELSE 'true' END) BENEFICIARIO, PRE.CALIFICACION, PREM.NOMBRE_TIPO_PREMIO NOMBRE_PREMIO, PRE.OBSERVACION, PRE.PREMIO  FROM NAT_PREMIACION PRE INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AI.COMPANIA = PRE.COMPANIA AND AI.IDEVENTO = PRE.IDEVENTO AND AI.TIPOEVENTO = PRE.TIPOEVENTO AND AI.NUMERO_DCTO = PRE.NUMERO_DCTO AND AI.SUCURSAL = PRE.SUCURSAL INNER JOIN NAT_ACTIVIDADESPROGRAMADAS AP ON AP.COMPANIA = PRE.COMPANIA AND AP.IDEVENTO = PRE.IDEVENTO AND AP.TIPOEVENTO = PRE.TIPOEVENTO INNER JOIN NAT_TIPOACTIVIDADES TIAC ON TIAC.COMPANIA = PRE.COMPANIA AND TIAC.CODIGO = PRE.TIPOEVENTO INNER JOIN FAMILIARES FAM ON FAM.COMPANIA = PRE.COMPANIA AND FAM.IDENTIFICACION = PRE.NUMERO_DCTO AND FAM.SUCURSAL = PRE.SUCURSAL INNER JOIN NAT_TIPO_PREMIO PREM ON PREM.COMPANIA = PRE.COMPANIA AND PREM.ID_TIPO_PREMIO = PRE.PREMIO WHERE PRE.COMPANIA =:COMPANIA UNION SELECT PRE.COMPANIA, PRE.IDEVENTO, PRE.TIPOEVENTO, PRE.NUMERO_DCTO, PRE.SUCURSAL, TIAC.NOMBRE NOMBRE_TIPOEVENTO, AP.NOMBREEVENTO EVENTO, TER.NOMBRE ASISTENTE, (CASE PRE.BENEFICIARIO WHEN 0  THEN 'false'   ELSE 'true' END) BENEFICIARIO, PRE.CALIFICACION, PREM.NOMBRE_TIPO_PREMIO NOMBRE_PREMIO, PRE.OBSERVACION, PRE.PREMIO FROM NAT_PREMIACION PRE INNER JOIN NAT_ACTIVIDADESINSCRITOS AI ON AI.COMPANIA = PRE.COMPANIA AND AI.IDEVENTO = PRE.IDEVENTO AND AI.TIPOEVENTO = PRE.TIPOEVENTO AND AI.NUMERO_DCTO = PRE.NUMERO_DCTO AND AI.SUCURSAL = PRE.SUCURSAL INNER JOIN NAT_ACTIVIDADESPROGRAMADAS AP ON AP.COMPANIA = PRE.COMPANIA AND AP.IDEVENTO = PRE.IDEVENTO AND AP.TIPOEVENTO = PRE.TIPOEVENTO INNER JOIN NAT_TIPOACTIVIDADES TIAC ON TIAC.COMPANIA = PRE.COMPANIA AND TIAC.CODIGO = PRE.TIPOEVENTO INNER JOIN TERCERO TER ON TER.COMPANIA = PRE.COMPANIA AND TER.NIT = PRE.NUMERO_DCTO AND TER.SUCURSAL = PRE.SUCURSAL INNER JOIN NAT_TIPO_PREMIO PREM ON PREM.COMPANIA = PRE.COMPANIA AND PREM.ID_TIPO_PREMIO = PRE.PREMIO WHERE PRE.COMPANIA =:COMPANIA) WHERE (CASE WHEN NOMBRE_TIPOEVENTO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOEVENTO) END)  LIKE UPPER( '%' || :NOMBRE_TIPOEVENTO || '%')  AND (CASE WHEN EVENTO IS NULL THEN ' ' ELSE UPPER(EVENTO) END)  LIKE UPPER( '%' || :EVENTO || '%')  AND (CASE WHEN ASISTENTE IS NULL THEN ' ' ELSE UPPER(ASISTENTE) END)  LIKE UPPER( '%' || :ASISTENTE || '%')  AND (CASE WHEN BENEFICIARIO IS NULL THEN ' ' ELSE UPPER(BENEFICIARIO) END)  LIKE UPPER( '%' || :BENEFICIARIO || '%')  AND (CASE WHEN CALIFICACION IS NULL THEN ' ' ELSE UPPER(CALIFICACION) END)  LIKE UPPER(:CALIFICACION || '%')  AND (CASE WHEN NOMBRE_PREMIO IS NULL THEN ' ' ELSE UPPER(NOMBRE_PREMIO) END)  LIKE UPPER(:NOMBRE_PREMIO || '%')  AND (CASE WHEN OBSERVACION IS NULL THEN ' ' ELSE UPPER(OBSERVACION) END)  LIKE UPPER( '%' || :OBSERVACION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NOMBRE_TIPOEVENTO" sqlType="STRING"/>
		<param name="EVENTO" sqlType="STRING"/>
		<param name="ASISTENTE" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="NOMBRE_PREMIO" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="natpremiacion/numero">
		<call-query href="getNatpremiacionNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NOMBRE_TIPOEVENTO" query-param="NOMBRE_TIPOEVENTO"/>
			<with-param name="EVENTO" query-param="EVENTO"/>
			<with-param name="ASISTENTE" query-param="ASISTENTE"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="NOMBRE_PREMIO" query-param="NOMBRE_PREMIO"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>

		</call-query>
	</resource>
	<query id="updateNatpremiacion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE NAT_PREMIACION SET IDEVENTO=:IDEVENTO, TIPOEVENTO=:TIPOEVENTO, NUMERO_DCTO=:NUMERO_DCTO, SUCURSAL=:SUCURSAL, BENEFICIARIO=:BENEFICIARIO, PREMIO=:PREMIO, CALIFICACION=:CALIFICACION, OBSERVACION=:OBSERVACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE NAT_PREMIACION.COMPANIA= :KEY_COMPANIA AND NAT_PREMIACION.IDEVENTO= :KEY_IDEVENTO AND NAT_PREMIACION.TIPOEVENTO= :KEY_TIPOEVENTO AND NAT_PREMIACION.NUMERO_DCTO= :KEY_NUMERO_DCTO AND NAT_PREMIACION.SUCURSAL= :KEY_SUCURSAL</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="IDEVENTO" sqlType="STRING"/>
		<param name="TIPOEVENTO" sqlType="STRING"/>
		<param name="NUMERO_DCTO" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="BENEFICIARIO" sqlType="STRING"/>
		<param name="PREMIO" sqlType="STRING"/>
		<param name="CALIFICACION" sqlType="STRING"/>
		<param name="OBSERVACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_IDEVENTO" sqlType="STRING"/>
		<param name="KEY_TIPOEVENTO" sqlType="STRING"/>
		<param name="KEY_NUMERO_DCTO" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="natpremiacion">
		<call-query href="updateNatpremiacion">
			<with-param name="IDEVENTO" query-param="IDEVENTO"/>
			<with-param name="TIPOEVENTO" query-param="TIPOEVENTO"/>
			<with-param name="NUMERO_DCTO" query-param="NUMERO_DCTO"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="BENEFICIARIO" query-param="BENEFICIARIO"/>
			<with-param name="PREMIO" query-param="PREMIO"/>
			<with-param name="CALIFICACION" query-param="CALIFICACION"/>
			<with-param name="OBSERVACION" query-param="OBSERVACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_IDEVENTO" query-param="KEY_IDEVENTO"/>
			<with-param name="KEY_TIPOEVENTO" query-param="KEY_TIPOEVENTO"/>
			<with-param name="KEY_NUMERO_DCTO" query-param="KEY_NUMERO_DCTO"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>

		</call-query>
	</resource>

</data>