<data name="bpodsmeta" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="insertBpodsmeta" keyColumns="COMPANIA,VIGENCIA_ODS,CODIGO_ODS,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_ODS_META (COMPANIA, VIGENCIA_ODS, CODIGO_ODS, CODIGO, DESCRIPCION, PORCENTAJE_PARTICIPACION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :VIGENCIA_ODS, :CODIGO_ODS, :CODIGO, :DESCRIPCION, :PORCENTAJE_PARTICIPACION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_VIGENCIA_ODS":"$VIGENCIA_ODS(type:integer)","KEY_CODIGO_ODS":"$CODIGO_ODS","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_ODS" sqlType="STRING"/>
		<param name="CODIGO_ODS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param defaultValue="0" name="PORCENTAJE_PARTICIPACION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpodsmeta">
		<call-query href="insertBpodsmeta">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_ODS" query-param="VIGENCIA_ODS"/>
			<with-param name="CODIGO_ODS" query-param="CODIGO_ODS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PORCENTAJE_PARTICIPACION" query-param="PORCENTAJE_PARTICIPACION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpodsmeta" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_ODS_META WHERE BP_ODS_META.COMPANIA= :KEY_COMPANIA AND BP_ODS_META.VIGENCIA_ODS= :KEY_VIGENCIA_ODS AND BP_ODS_META.CODIGO_ODS= :KEY_CODIGO_ODS AND BP_ODS_META.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_ODS" sqlType="INTEGER"/>
		<param name="KEY_CODIGO_ODS" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpodsmeta">
		<call-query href="deleteBpodsmeta">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA_ODS" query-param="KEY_VIGENCIA_ODS"/>
			<with-param name="KEY_CODIGO_ODS" query-param="KEY_CODIGO_ODS"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="getBpodsmetaPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, VIGENCIA_ODS, CODIGO_ODS, CODIGO, DESCRIPCION, PORCENTAJE_PARTICIPACION FROM BP_ODS_META WHERE COMPANIA = :COMPANIA AND VIGENCIA_ODS = :VIGENCIA_ODS AND CODIGO_ODS = :CODIGO_ODS ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN PORCENTAJE_PARTICIPACION IS NULL THEN ' ' ELSE UPPER(PORCENTAJE_PARTICIPACION) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJE_PARTICIPACION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VIGENCIA_ODS":"$VIGENCIA_ODS(type:integer)","CODIGO_ODS":"$CODIGO_ODS","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","PORCENTAJE_PARTICIPACION":"$PORCENTAJE_PARTICIPACION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_ODS" sqlType="STRING"/>
		<param name="CODIGO_ODS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PORCENTAJE_PARTICIPACION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpodsmeta">
		<call-query href="getBpodsmetaPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_ODS" query-param="VIGENCIA_ODS"/>
			<with-param name="CODIGO_ODS" query-param="CODIGO_ODS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PORCENTAJE_PARTICIPACION" query-param="PORCENTAJE_PARTICIPACION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpodsmetaNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, VIGENCIA_ODS, CODIGO_ODS, CODIGO, DESCRIPCION, PORCENTAJE_PARTICIPACION FROM BP_ODS_META WHERE COMPANIA = :COMPANIA AND VIGENCIA_ODS = :VIGENCIA_ODS AND CODIGO_ODS = :CODIGO_ODS ORDER BY CODIGO) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(:DESCRIPCION, '%')) AND (CASE WHEN PORCENTAJE_PARTICIPACION IS NULL THEN ' ' ELSE UPPER(PORCENTAJE_PARTICIPACION) END) LIKE UPPER(CONCAT(CONCAT('%',:PORCENTAJE_PARTICIPACION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA_ODS" sqlType="STRING"/>
		<param name="CODIGO_ODS" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PORCENTAJE_PARTICIPACION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpodsmeta/numero">
		<call-query href="getBpodsmetaNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA_ODS" query-param="VIGENCIA_ODS"/>
			<with-param name="CODIGO_ODS" query-param="CODIGO_ODS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PORCENTAJE_PARTICIPACION" query-param="PORCENTAJE_PARTICIPACION"/>

		</call-query>
	</resource>
	<query id="getBpodsmetaRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, VIGENCIA_ODS, CODIGO_ODS, CODIGO, DESCRIPCION, PORCENTAJE_PARTICIPACION FROM BP_ODS_META WHERE BP_ODS_META.COMPANIA= :KEY_COMPANIA AND BP_ODS_META.VIGENCIA_ODS= :KEY_VIGENCIA_ODS AND BP_ODS_META.CODIGO_ODS= :KEY_CODIGO_ODS AND BP_ODS_META.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","VIGENCIA_ODS":"$VIGENCIA_ODS(type:integer)","CODIGO_ODS":"$CODIGO_ODS","CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION","PORCENTAJE_PARTICIPACION":"$PORCENTAJE_PARTICIPACION"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_ODS" sqlType="STRING"/>
		<param name="KEY_CODIGO_ODS" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpodsmeta/data">
		<call-query href="getBpodsmetaRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA_ODS" query-param="KEY_VIGENCIA_ODS"/>
			<with-param name="KEY_CODIGO_ODS" query-param="KEY_CODIGO_ODS"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
	<query id="updateBpodsmeta" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_ODS_META SET CODIGO=:CODIGO, DESCRIPCION=:DESCRIPCION, PORCENTAJE_PARTICIPACION=:PORCENTAJE_PARTICIPACION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_ODS_META.COMPANIA= :KEY_COMPANIA AND BP_ODS_META.VIGENCIA_ODS= :KEY_VIGENCIA_ODS AND BP_ODS_META.CODIGO_ODS= :KEY_CODIGO_ODS AND BP_ODS_META.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PORCENTAJE_PARTICIPACION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_VIGENCIA_ODS" sqlType="STRING"/>
		<param name="KEY_CODIGO_ODS" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="bpodsmeta">
		<call-query href="updateBpodsmeta">
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PORCENTAJE_PARTICIPACION" query-param="PORCENTAJE_PARTICIPACION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_VIGENCIA_ODS" query-param="KEY_VIGENCIA_ODS"/>
			<with-param name="KEY_CODIGO_ODS" query-param="KEY_CODIGO_ODS"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>

</data>