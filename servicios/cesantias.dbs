<data name="cesantias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCesantiasTodosPorSumatoriaGrillaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(CESANTIA) AS CESANTIA, SUM(INTERES) AS INTERES, SUM(PROMVARIABLES) AS PROMVARIABLES, SUM(RETIRADAS) AS RETIRADAS, SUM(DIAS) AS DIAS, SUM(DIAS_LICENCIAS) AS DIAS_LICENCIAS, SUM(PARCIALES) AS PARCIALES  FROM CESANTIAS WHERE COMPANIA =:COMPANIA AND ID_DE_EMPLEADO=:ID_DE_EMPLEADO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CESANTIA":"$CESANTIA","INTERES":"$INTERES","PROMVARIABLES":"$PROMVARIABLES","RETIRADAS":"$RETIRADAS","DIAS":"$DIAS","DIAS_LICENCIAS":"$DIAS_LICENCIAS","PARCIALES":"$PARCIALES"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cesantias/todosporsumatoriagrilla">
		<call-query href="getCesantiasTodosPorSumatoriaGrillaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="getCesantiasPagGrillaCesantiasHvQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  CESANTIAS.COMPANIA, CESANTIAS.ID_DE_EMPLEADO,(TO_CHAR(CESANTIAS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CESANTIAS.NUMAUTO,(TO_CHAR(CESANTIAS.FECHA_AUTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_AUTO, CESANTIAS.FONDO, CESANTIAS.TIPO_CESANTIA, CESANTIAS.CESANTIA, CESANTIAS.INTERES, CESANTIAS.DETALLE, CESANTIAS.NUMEROFORMULARIO, V_FONDO_DE_CESANTIAS.NOMBRE_FONDO_CESANTIAS NOMBRE_FONDO  FROM CESANTIAS LEFT JOIN V_FONDO_DE_CESANTIAS ON CESANTIAS.COMPANIA = V_FONDO_DE_CESANTIAS.COMPANIA AND CESANTIAS.FONDO = V_FONDO_DE_CESANTIAS.FONDO_CESANTIAS WHERE CESANTIAS.COMPANIA = :COMPANIA AND CESANTIAS.ID_DE_EMPLEADO = :ID_EMPLEADO) WHERE (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN NUMAUTO IS NULL THEN ' ' ELSE UPPER(NUMAUTO) END)  LIKE UPPER(:NUMAUTO || '%')  AND (CASE WHEN FECHA_AUTO IS NULL THEN ' ' ELSE UPPER(FECHA_AUTO) END)  LIKE UPPER( '%' || :FECHA_AUTO || '%')  AND (CASE WHEN FONDO IS NULL THEN ' ' ELSE UPPER(FONDO) END)  LIKE UPPER( '%' || :FONDO || '%')  AND (CASE WHEN TIPO_CESANTIA IS NULL THEN ' ' ELSE UPPER(TIPO_CESANTIA) END)  LIKE UPPER(:TIPO_CESANTIA || '%')  AND (CASE WHEN CESANTIA IS NULL THEN ' ' ELSE UPPER(CESANTIA) END)  LIKE UPPER(:CESANTIA || '%')  AND (CASE WHEN INTERES IS NULL THEN ' ' ELSE UPPER(INTERES) END)  LIKE UPPER(:INTERES || '%')  AND (CASE WHEN DETALLE IS NULL THEN ' ' ELSE UPPER(DETALLE) END)  LIKE UPPER( '%' || :DETALLE || '%')  AND (CASE WHEN NUMEROFORMULARIO IS NULL THEN ' ' ELSE UPPER(NUMEROFORMULARIO) END)  LIKE UPPER(:NUMEROFORMULARIO || '%')  AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_FONDO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","FECHA":"$FECHA","NUMAUTO":"$NUMAUTO","FECHA_AUTO":"$FECHA_AUTO","FONDO":"$FONDO","TIPO_CESANTIA":"$TIPO_CESANTIA","CESANTIA":"$CESANTIA","INTERES":"$INTERES","DETALLE":"$DETALLE","NUMEROFORMULARIO":"$NUMEROFORMULARIO","NOMBRE_FONDO":"$NOMBRE_FONDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMAUTO" sqlType="STRING"/>
		<param name="FECHA_AUTO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param name="TIPO_CESANTIA" sqlType="STRING"/>
		<param name="CESANTIA" sqlType="STRING"/>
		<param name="INTERES" sqlType="STRING"/>
		<param name="DETALLE" sqlType="STRING"/>
		<param name="NUMEROFORMULARIO" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cesantias/grillacesantiashv/pag">
		<call-query href="getCesantiasPagGrillaCesantiasHvQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NUMAUTO" query-param="NUMAUTO"/>
			<with-param name="FECHA_AUTO" query-param="FECHA_AUTO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="TIPO_CESANTIA" query-param="TIPO_CESANTIA"/>
			<with-param name="CESANTIA" query-param="CESANTIA"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="DETALLE" query-param="DETALLE"/>
			<with-param name="NUMEROFORMULARIO" query-param="NUMEROFORMULARIO"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCesantiasNumGrillaCesantiasHvQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  CESANTIAS.COMPANIA, CESANTIAS.ID_DE_EMPLEADO,(TO_CHAR(CESANTIAS.FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, CESANTIAS.NUMAUTO,(TO_CHAR(CESANTIAS.FECHA_AUTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_AUTO, CESANTIAS.FONDO, CESANTIAS.TIPO_CESANTIA, CESANTIAS.CESANTIA, CESANTIAS.INTERES, CESANTIAS.DETALLE, CESANTIAS.NUMEROFORMULARIO, V_FONDO_DE_CESANTIAS.NOMBRE_FONDO_CESANTIAS NOMBRE_FONDO  FROM CESANTIAS LEFT JOIN V_FONDO_DE_CESANTIAS ON CESANTIAS.COMPANIA = V_FONDO_DE_CESANTIAS.COMPANIA AND CESANTIAS.FONDO = V_FONDO_DE_CESANTIAS.FONDO_CESANTIAS WHERE CESANTIAS.COMPANIA = :COMPANIA AND CESANTIAS.ID_DE_EMPLEADO = :ID_EMPLEADO) WHERE (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN NUMAUTO IS NULL THEN ' ' ELSE UPPER(NUMAUTO) END)  LIKE UPPER(:NUMAUTO || '%')  AND (CASE WHEN FECHA_AUTO IS NULL THEN ' ' ELSE UPPER(FECHA_AUTO) END)  LIKE UPPER( '%' || :FECHA_AUTO || '%')  AND (CASE WHEN FONDO IS NULL THEN ' ' ELSE UPPER(FONDO) END)  LIKE UPPER( '%' || :FONDO || '%')  AND (CASE WHEN TIPO_CESANTIA IS NULL THEN ' ' ELSE UPPER(TIPO_CESANTIA) END)  LIKE UPPER(:TIPO_CESANTIA || '%')  AND (CASE WHEN CESANTIA IS NULL THEN ' ' ELSE UPPER(CESANTIA) END)  LIKE UPPER(:CESANTIA || '%')  AND (CASE WHEN INTERES IS NULL THEN ' ' ELSE UPPER(INTERES) END)  LIKE UPPER(:INTERES || '%')  AND (CASE WHEN DETALLE IS NULL THEN ' ' ELSE UPPER(DETALLE) END)  LIKE UPPER( '%' || :DETALLE || '%')  AND (CASE WHEN NUMEROFORMULARIO IS NULL THEN ' ' ELSE UPPER(NUMEROFORMULARIO) END)  LIKE UPPER(:NUMEROFORMULARIO || '%')  AND (CASE WHEN NOMBRE_FONDO IS NULL THEN ' ' ELSE UPPER(NOMBRE_FONDO) END)  LIKE UPPER( '%' || :NOMBRE_FONDO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_EMPLEADO" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="NUMAUTO" sqlType="STRING"/>
		<param name="FECHA_AUTO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param name="TIPO_CESANTIA" sqlType="STRING"/>
		<param name="CESANTIA" sqlType="STRING"/>
		<param name="INTERES" sqlType="STRING"/>
		<param name="DETALLE" sqlType="STRING"/>
		<param name="NUMEROFORMULARIO" sqlType="STRING"/>
		<param name="NOMBRE_FONDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cesantias/grillacesantiashv/num">
		<call-query href="getCesantiasNumGrillaCesantiasHvQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_EMPLEADO" query-param="ID_EMPLEADO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="NUMAUTO" query-param="NUMAUTO"/>
			<with-param name="FECHA_AUTO" query-param="FECHA_AUTO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="TIPO_CESANTIA" query-param="TIPO_CESANTIA"/>
			<with-param name="CESANTIA" query-param="CESANTIA"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="DETALLE" query-param="DETALLE"/>
			<with-param name="NUMEROFORMULARIO" query-param="NUMEROFORMULARIO"/>
			<with-param name="NOMBRE_FONDO" query-param="NOMBRE_FONDO"/>

		</call-query>
	</resource>
	<query id="updateCesantiasUpdateCesantiasHv" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CESANTIAS SET COMPANIA=:COMPANIA, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, NUMAUTO=:NUMAUTO, FECHA_AUTO=TO_DATE(:FECHA_AUTO,'DD/MM/YYYY HH24:MI:SS'), FONDO=:FONDO, TIPO_CESANTIA=:TIPO_CESANTIA, DETALLE=:DETALLE, NUMEROFORMULARIO=:NUMEROFORMULARIO, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CESANTIAS.COMPANIA= :KEY_COMPANIA AND CESANTIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND CESANTIAS.FECHA= TO_DATE(:KEY_FECHA,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="NUMAUTO" sqlType="STRING"/>
		<param name="FECHA_AUTO" sqlType="STRING"/>
		<param name="FONDO" sqlType="STRING"/>
		<param name="TIPO_CESANTIA" sqlType="STRING"/>
		<param name="DETALLE" sqlType="STRING"/>
		<param name="NUMEROFORMULARIO" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_FECHA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cesantias/updatecesantiashv">
		<call-query href="updateCesantiasUpdateCesantiasHv">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="NUMAUTO" query-param="NUMAUTO"/>
			<with-param name="FECHA_AUTO" query-param="FECHA_AUTO"/>
			<with-param name="FONDO" query-param="FONDO"/>
			<with-param name="TIPO_CESANTIA" query-param="TIPO_CESANTIA"/>
			<with-param name="DETALLE" query-param="DETALLE"/>
			<with-param name="NUMEROFORMULARIO" query-param="NUMEROFORMULARIO"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_FECHA" query-param="KEY_FECHA"/>

		</call-query>
	</resource>
	<query id="insertCesantias" keyColumns="COMPANIA,ID_DE_EMPLEADO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO CESANTIAS (CONSIGNADAS, NUMRESOLUCION, FECHARESOLUCION, CESANTIA, INTERES, FECHA_INI_ANT_CES, FECHA, PROMVARIABLES, RETIRADAS, DIAS, DIAS_LICENCIAS, PARCIALES, OBSERVACIONES_C, ID_DE_EMPLEADO, COMPANIA, DATE_CREATED, CREATED_BY) VALUES (:CONSIGNADAS, :NUMRESOLUCION, TO_DATE(:FECHARESOLUCION,'DD/MM/YYYY HH24:MI:SS'), :CESANTIA, :INTERES, TO_DATE(:FECHA_INI_ANT_CES,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :PROMVARIABLES, :RETIRADAS, :DIAS, :DIAS_LICENCIAS, :PARCIALES, :OBSERVACIONES_C, :ID_DE_EMPLEADO, :COMPANIA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","KEY_FECHA":"$FECHA"}]}}		</result>
		<param defaultValue="0" name="CONSIGNADAS" sqlType="STRING"/>
		<param defaultValue="" name="NUMRESOLUCION" sqlType="STRING"/>
		<param defaultValue="" name="FECHARESOLUCION" sqlType="STRING"/>
		<param defaultValue="0" name="CESANTIA" sqlType="STRING"/>
		<param defaultValue="0" name="INTERES" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INI_ANT_CES" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param defaultValue="0" name="PROMVARIABLES" sqlType="STRING"/>
		<param defaultValue="0" name="RETIRADAS" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS" sqlType="STRING"/>
		<param defaultValue="0" name="DIAS_LICENCIAS" sqlType="STRING"/>
		<param defaultValue="0" name="PARCIALES" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES_C" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="cesantias">
		<call-query href="insertCesantias">
			<with-param name="CONSIGNADAS" query-param="CONSIGNADAS"/>
			<with-param name="NUMRESOLUCION" query-param="NUMRESOLUCION"/>
			<with-param name="FECHARESOLUCION" query-param="FECHARESOLUCION"/>
			<with-param name="CESANTIA" query-param="CESANTIA"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="FECHA_INI_ANT_CES" query-param="FECHA_INI_ANT_CES"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PROMVARIABLES" query-param="PROMVARIABLES"/>
			<with-param name="RETIRADAS" query-param="RETIRADAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="DIAS_LICENCIAS" query-param="DIAS_LICENCIAS"/>
			<with-param name="PARCIALES" query-param="PARCIALES"/>
			<with-param name="OBSERVACIONES_C" query-param="OBSERVACIONES_C"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteCesantias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM CESANTIAS WHERE CESANTIAS.COMPANIA= :KEY_COMPANIA AND CESANTIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND CESANTIAS.FECHA= TO_DATE(:KEY_FECHA,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="INTEGER"/>
		<param name="KEY_FECHA" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="cesantias">
		<call-query href="deleteCesantias">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_FECHA" query-param="KEY_FECHA"/>

		</call-query>
	</resource>
	<query id="getCesantiasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT (CASE CONSIGNADAS WHEN 0 THEN 'false' ELSE 'true' END) CONSIGNADAS, NUMRESOLUCION,(TO_CHAR(FECHARESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHARESOLUCION, CESANTIA, INTERES,(TO_CHAR(FECHA_INI_ANT_CES,'DD/MM/YYYY HH24:MI:SS')) FECHA_INI_ANT_CES,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, PROMVARIABLES, RETIRADAS, DIAS, DIAS_LICENCIAS, PARCIALES, OBSERVACIONES_C, ID_DE_EMPLEADO, COMPANIA  FROM CESANTIAS WHERE COMPANIA=:COMPANIA AND ID_DE_EMPLEADO=:ID_DE_EMPLEADO_AUX) WHERE (CASE WHEN CONSIGNADAS IS NULL THEN ' ' ELSE UPPER(CONSIGNADAS) END)  LIKE UPPER(:CONSIGNADAS || '%')  AND (CASE WHEN NUMRESOLUCION IS NULL THEN ' ' ELSE UPPER(NUMRESOLUCION) END)  LIKE UPPER(:NUMRESOLUCION || '%')  AND (CASE WHEN FECHARESOLUCION IS NULL THEN ' ' ELSE UPPER(FECHARESOLUCION) END)  LIKE UPPER(:FECHARESOLUCION || '%')  AND (CASE WHEN CESANTIA IS NULL THEN ' ' ELSE UPPER(CESANTIA) END)  LIKE UPPER(:CESANTIA || '%')  AND (CASE WHEN INTERES IS NULL THEN ' ' ELSE UPPER(INTERES) END)  LIKE UPPER(:INTERES || '%')  AND (CASE WHEN FECHA_INI_ANT_CES IS NULL THEN ' ' ELSE UPPER(FECHA_INI_ANT_CES) END)  LIKE UPPER(:FECHA_INI_ANT_CES || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN PROMVARIABLES IS NULL THEN ' ' ELSE UPPER(PROMVARIABLES) END)  LIKE UPPER(:PROMVARIABLES || '%')  AND (CASE WHEN RETIRADAS IS NULL THEN ' ' ELSE UPPER(RETIRADAS) END)  LIKE UPPER(:RETIRADAS || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN DIAS_LICENCIAS IS NULL THEN ' ' ELSE UPPER(DIAS_LICENCIAS) END)  LIKE UPPER(:DIAS_LICENCIAS || '%')  AND (CASE WHEN PARCIALES IS NULL THEN ' ' ELSE UPPER(PARCIALES) END)  LIKE UPPER(:PARCIALES || '%')  AND (CASE WHEN OBSERVACIONES_C IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES_C) END)  LIKE UPPER(:OBSERVACIONES_C || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CONSIGNADAS":"$CONSIGNADAS(type:boolean)","NUMRESOLUCION":"$NUMRESOLUCION","FECHARESOLUCION":"$FECHARESOLUCION","CESANTIA":"$CESANTIA","INTERES":"$INTERES","FECHA_INI_ANT_CES":"$FECHA_INI_ANT_CES","FECHA":"$FECHA","PROMVARIABLES":"$PROMVARIABLES","RETIRADAS":"$RETIRADAS","DIAS":"$DIAS","DIAS_LICENCIAS":"$DIAS_LICENCIAS","PARCIALES":"$PARCIALES","OBSERVACIONES_C":"$OBSERVACIONES_C","ID_DE_EMPLEADO":"$ID_DE_EMPLEADO(type:integer)","COMPANIA":"$COMPANIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO_AUX" sqlType="STRING"/>
		<param name="CONSIGNADAS" sqlType="STRING"/>
		<param name="NUMRESOLUCION" sqlType="STRING"/>
		<param name="FECHARESOLUCION" sqlType="STRING"/>
		<param name="CESANTIA" sqlType="STRING"/>
		<param name="INTERES" sqlType="STRING"/>
		<param name="FECHA_INI_ANT_CES" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PROMVARIABLES" sqlType="STRING"/>
		<param name="RETIRADAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="DIAS_LICENCIAS" sqlType="STRING"/>
		<param name="PARCIALES" sqlType="STRING"/>
		<param name="OBSERVACIONES_C" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="cesantias">
		<call-query href="getCesantiasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO_AUX" query-param="ID_DE_EMPLEADO_AUX"/>
			<with-param name="CONSIGNADAS" query-param="CONSIGNADAS"/>
			<with-param name="NUMRESOLUCION" query-param="NUMRESOLUCION"/>
			<with-param name="FECHARESOLUCION" query-param="FECHARESOLUCION"/>
			<with-param name="CESANTIA" query-param="CESANTIA"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="FECHA_INI_ANT_CES" query-param="FECHA_INI_ANT_CES"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PROMVARIABLES" query-param="PROMVARIABLES"/>
			<with-param name="RETIRADAS" query-param="RETIRADAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="DIAS_LICENCIAS" query-param="DIAS_LICENCIAS"/>
			<with-param name="PARCIALES" query-param="PARCIALES"/>
			<with-param name="OBSERVACIONES_C" query-param="OBSERVACIONES_C"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getCesantiasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT (CASE CONSIGNADAS WHEN 0 THEN 'false' ELSE 'true' END) CONSIGNADAS, NUMRESOLUCION,(TO_CHAR(FECHARESOLUCION,'DD/MM/YYYY HH24:MI:SS')) FECHARESOLUCION, CESANTIA, INTERES,(TO_CHAR(FECHA_INI_ANT_CES,'DD/MM/YYYY HH24:MI:SS')) FECHA_INI_ANT_CES,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, PROMVARIABLES, RETIRADAS, DIAS, DIAS_LICENCIAS, PARCIALES, OBSERVACIONES_C, ID_DE_EMPLEADO, COMPANIA  FROM CESANTIAS WHERE COMPANIA=:COMPANIA AND ID_DE_EMPLEADO=:ID_DE_EMPLEADO_AUX) WHERE (CASE WHEN CONSIGNADAS IS NULL THEN ' ' ELSE UPPER(CONSIGNADAS) END)  LIKE UPPER(:CONSIGNADAS || '%')  AND (CASE WHEN NUMRESOLUCION IS NULL THEN ' ' ELSE UPPER(NUMRESOLUCION) END)  LIKE UPPER(:NUMRESOLUCION || '%')  AND (CASE WHEN FECHARESOLUCION IS NULL THEN ' ' ELSE UPPER(FECHARESOLUCION) END)  LIKE UPPER(:FECHARESOLUCION || '%')  AND (CASE WHEN CESANTIA IS NULL THEN ' ' ELSE UPPER(CESANTIA) END)  LIKE UPPER(:CESANTIA || '%')  AND (CASE WHEN INTERES IS NULL THEN ' ' ELSE UPPER(INTERES) END)  LIKE UPPER(:INTERES || '%')  AND (CASE WHEN FECHA_INI_ANT_CES IS NULL THEN ' ' ELSE UPPER(FECHA_INI_ANT_CES) END)  LIKE UPPER(:FECHA_INI_ANT_CES || '%')  AND (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER(:FECHA || '%')  AND (CASE WHEN PROMVARIABLES IS NULL THEN ' ' ELSE UPPER(PROMVARIABLES) END)  LIKE UPPER(:PROMVARIABLES || '%')  AND (CASE WHEN RETIRADAS IS NULL THEN ' ' ELSE UPPER(RETIRADAS) END)  LIKE UPPER(:RETIRADAS || '%')  AND (CASE WHEN DIAS IS NULL THEN ' ' ELSE UPPER(DIAS) END)  LIKE UPPER(:DIAS || '%')  AND (CASE WHEN DIAS_LICENCIAS IS NULL THEN ' ' ELSE UPPER(DIAS_LICENCIAS) END)  LIKE UPPER(:DIAS_LICENCIAS || '%')  AND (CASE WHEN PARCIALES IS NULL THEN ' ' ELSE UPPER(PARCIALES) END)  LIKE UPPER(:PARCIALES || '%')  AND (CASE WHEN OBSERVACIONES_C IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES_C) END)  LIKE UPPER(:OBSERVACIONES_C || '%')  AND (CASE WHEN ID_DE_EMPLEADO IS NULL THEN ' ' ELSE UPPER(ID_DE_EMPLEADO) END)  LIKE UPPER(:ID_DE_EMPLEADO || '%')  AND (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO_AUX" sqlType="STRING"/>
		<param name="CONSIGNADAS" sqlType="STRING"/>
		<param name="NUMRESOLUCION" sqlType="STRING"/>
		<param name="FECHARESOLUCION" sqlType="STRING"/>
		<param name="CESANTIA" sqlType="STRING"/>
		<param name="INTERES" sqlType="STRING"/>
		<param name="FECHA_INI_ANT_CES" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PROMVARIABLES" sqlType="STRING"/>
		<param name="RETIRADAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="DIAS_LICENCIAS" sqlType="STRING"/>
		<param name="PARCIALES" sqlType="STRING"/>
		<param name="OBSERVACIONES_C" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="cesantias/numero">
		<call-query href="getCesantiasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_DE_EMPLEADO_AUX" query-param="ID_DE_EMPLEADO_AUX"/>
			<with-param name="CONSIGNADAS" query-param="CONSIGNADAS"/>
			<with-param name="NUMRESOLUCION" query-param="NUMRESOLUCION"/>
			<with-param name="FECHARESOLUCION" query-param="FECHARESOLUCION"/>
			<with-param name="CESANTIA" query-param="CESANTIA"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="FECHA_INI_ANT_CES" query-param="FECHA_INI_ANT_CES"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PROMVARIABLES" query-param="PROMVARIABLES"/>
			<with-param name="RETIRADAS" query-param="RETIRADAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="DIAS_LICENCIAS" query-param="DIAS_LICENCIAS"/>
			<with-param name="PARCIALES" query-param="PARCIALES"/>
			<with-param name="OBSERVACIONES_C" query-param="OBSERVACIONES_C"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>

		</call-query>
	</resource>
	<query id="updateCesantias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE CESANTIAS SET CONSIGNADAS=:CONSIGNADAS, NUMRESOLUCION=:NUMRESOLUCION, FECHARESOLUCION=TO_DATE(:FECHARESOLUCION,'DD/MM/YYYY HH24:MI:SS'), CESANTIA=:CESANTIA, INTERES=:INTERES, FECHA_INI_ANT_CES=TO_DATE(:FECHA_INI_ANT_CES,'DD/MM/YYYY HH24:MI:SS'), FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), PROMVARIABLES=:PROMVARIABLES, RETIRADAS=:RETIRADAS, DIAS=:DIAS, DIAS_LICENCIAS=:DIAS_LICENCIAS, PARCIALES=:PARCIALES, OBSERVACIONES_C=:OBSERVACIONES_C, ID_DE_EMPLEADO=:ID_DE_EMPLEADO, COMPANIA=:COMPANIA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE CESANTIAS.COMPANIA= :KEY_COMPANIA AND CESANTIAS.ID_DE_EMPLEADO= :KEY_ID_DE_EMPLEADO AND CESANTIAS.FECHA= TO_DATE(:KEY_FECHA,'DD/MM/YYYY HH24:MI:SS') </sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="CONSIGNADAS" sqlType="STRING"/>
		<param name="NUMRESOLUCION" sqlType="STRING"/>
		<param name="FECHARESOLUCION" sqlType="STRING"/>
		<param name="CESANTIA" sqlType="STRING"/>
		<param name="INTERES" sqlType="STRING"/>
		<param name="FECHA_INI_ANT_CES" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="PROMVARIABLES" sqlType="STRING"/>
		<param name="RETIRADAS" sqlType="STRING"/>
		<param name="DIAS" sqlType="STRING"/>
		<param name="DIAS_LICENCIAS" sqlType="STRING"/>
		<param name="PARCIALES" sqlType="STRING"/>
		<param name="OBSERVACIONES_C" sqlType="STRING"/>
		<param name="ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ID_DE_EMPLEADO" sqlType="STRING"/>
		<param name="KEY_FECHA" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="cesantias">
		<call-query href="updateCesantias">
			<with-param name="CONSIGNADAS" query-param="CONSIGNADAS"/>
			<with-param name="NUMRESOLUCION" query-param="NUMRESOLUCION"/>
			<with-param name="FECHARESOLUCION" query-param="FECHARESOLUCION"/>
			<with-param name="CESANTIA" query-param="CESANTIA"/>
			<with-param name="INTERES" query-param="INTERES"/>
			<with-param name="FECHA_INI_ANT_CES" query-param="FECHA_INI_ANT_CES"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="PROMVARIABLES" query-param="PROMVARIABLES"/>
			<with-param name="RETIRADAS" query-param="RETIRADAS"/>
			<with-param name="DIAS" query-param="DIAS"/>
			<with-param name="DIAS_LICENCIAS" query-param="DIAS_LICENCIAS"/>
			<with-param name="PARCIALES" query-param="PARCIALES"/>
			<with-param name="OBSERVACIONES_C" query-param="OBSERVACIONES_C"/>
			<with-param name="ID_DE_EMPLEADO" query-param="ID_DE_EMPLEADO"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ID_DE_EMPLEADO" query-param="KEY_ID_DE_EMPLEADO"/>
			<with-param name="KEY_FECHA" query-param="KEY_FECHA"/>

		</call-query>
	</resource>

</data>