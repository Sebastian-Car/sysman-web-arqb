<data name="adicionesvias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getAdicionesviasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COMPANIA, ID_VIA, SERIE_PLACA,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, ANO_CONSTRUCCION, VALOR_CONSTRUCCION, COD_INVENTARIO, VIDA_UTIL, DESCRIPCION  FROM ADICION_VIAS WHERE COMPANIA=:COMPANIA AND ID_VIA =:ID_VIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ID_VIA":"$ID_VIA","SERIE_PLACA":"$SERIE_PLACA(type:long)","FECHA":"$FECHA","ANO_CONSTRUCCION":"$ANO_CONSTRUCCION(type:integer)","VALOR_CONSTRUCCION":"$VALOR_CONSTRUCCION","COD_INVENTARIO":"$COD_INVENTARIO","VIDA_UTIL":"$VIDA_UTIL","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ID_VIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="adicionesvias">
		<call-query href="getAdicionesviasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ID_VIA" query-param="ID_VIA"/>

		</call-query>
	</resource>

</data>