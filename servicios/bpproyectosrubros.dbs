<data name="bpproyectosrubros" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getBpproyectosrubrosTodosPorNombreSegunProyectoQuery"  useConfig="sysmandsunist">
		<sql>SELECT CONCAT(BP_PROYECTOSRUBROS.RUBROPPTALES ,CONCAT( ' - ' , PLAN_PRESUPUESTAL.NOMBRE)) RUBRO FROM BP_PROYECTOSRUBROS INNER JOIN PLAN_PRESUPUESTAL ON BP_PROYECTOSRUBROS.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = PLAN_PRESUPUESTAL.VIGENCIA AND BP_PROYECTOSRUBROS.RUBROPPTALES = PLAN_PRESUPUESTAL.CODIGO WHERE BP_PROYECTOSRUBROS.COMPANIA =:COMPANIA AND BP_PROYECTOSRUBROS.PROYECTO =:CODIGOPROYECTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RUBRO":"$RUBRO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOPROYECTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectosrubros/todospornombresegunproyecto">
		<call-query href="getBpproyectosrubrosTodosPorNombreSegunProyectoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOPROYECTO" query-param="CODIGOPROYECTO"/>

		</call-query>
	</resource>
	<query id="getBpproyectosrubrosPagGfuenterecursosrubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO, FUENTE_RECURSOS.NOMBRE  FROM BP_PROYECTOSRUBROS INNER JOIN FUENTE_RECURSOS ON BP_PROYECTOSRUBROS.COMPANIA = FUENTE_RECURSOS.COMPANIA AND (BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = FUENTE_RECURSOS.CODIGO) AND (BP_PROYECTOSRUBROS.VIGENCIA = FUENTE_RECURSOS.ANO) WHERE BP_PROYECTOSRUBROS.COMPANIA = :COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = :VIGENCIA AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO) WHERE (CASE WHEN FUENTERECURSOSRUBRO IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOSRUBRO) END)  LIKE UPPER(:FUENTERECURSOSRUBRO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"FUENTERECURSOSRUBRO":"$FUENTERECURSOSRUBRO","NOMBRE":"$NOMBRE"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpproyectosrubros/gfuenterecursosrubro/pag">
		<call-query href="getBpproyectosrubrosPagGfuenterecursosrubroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="FUENTERECURSOSRUBRO" query-param="FUENTERECURSOSRUBRO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpproyectosrubrosNumGfuenterecursosrubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO, FUENTE_RECURSOS.NOMBRE  FROM BP_PROYECTOSRUBROS INNER JOIN FUENTE_RECURSOS ON BP_PROYECTOSRUBROS.COMPANIA = FUENTE_RECURSOS.COMPANIA AND (BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = FUENTE_RECURSOS.CODIGO) AND (BP_PROYECTOSRUBROS.VIGENCIA = FUENTE_RECURSOS.ANO) WHERE BP_PROYECTOSRUBROS.COMPANIA = :COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = :VIGENCIA AND BP_PROYECTOSRUBROS.PROYECTO = :PROYECTO) WHERE (CASE WHEN FUENTERECURSOSRUBRO IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOSRUBRO) END)  LIKE UPPER(:FUENTERECURSOSRUBRO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectosrubros/gfuenterecursosrubro/num">
		<call-query href="getBpproyectosrubrosNumGfuenterecursosrubroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="FUENTERECURSOSRUBRO" query-param="FUENTERECURSOSRUBRO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getBpproyectosrubrosGetsectorprogramasubprogramarubroQuery"  useConfig="sysmandsunist">
		<sql>SELECT SECTOR, PROGRAMA, SUBPROGRAMA FROM BP_PROYECTOSRUBROS WHERE BP_PROYECTOSRUBROS.COMPANIA = :COMPANIA AND BP_PROYECTOSRUBROS.RUBROPPTALES = :CODIGO ORDER BY SECTOR, PROGRAMA, SUBPROGRAMA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectosrubros/getsectorprogramasubprogramarubro">
		<call-query href="getBpproyectosrubrosGetsectorprogramasubprogramarubroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="insertBpproyectosrubros" keyColumns="COMPANIA,PROYECTO,VIGENCIA,DIMENSION,SECTOR,PROGRAMA,SUBPROGRAMA,RUBROPPTALES,FUENTERECURSOSRUBRO,CENTRO_COSTO,REFERENCIA,AUXILIAR" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO BP_PROYECTOSRUBROS (COMPANIA, PROYECTO, VIGENCIA, DIMENSION, SECTOR, PROGRAMA, SUBPROGRAMA, RUBROPPTALES, FUENTERECURSOSRUBRO, CENTRO_COSTO, REFERENCIA, AUXILIAR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :PROYECTO, :VIGENCIA, :DIMENSION, :SECTOR, :PROGRAMA, :SUBPROGRAMA, :RUBROPPTALES, :FUENTERECURSOSRUBRO, :CENTRO_COSTO, :REFERENCIA, :AUXILIAR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_PROYECTO":"$PROYECTO","KEY_VIGENCIA":"$VIGENCIA(type:integer)","KEY_DIMENSION":"$DIMENSION","KEY_SECTOR":"$SECTOR","KEY_PROGRAMA":"$PROGRAMA","KEY_SUBPROGRAMA":"$SUBPROGRAMA","KEY_RUBROPPTALES":"$RUBROPPTALES","KEY_FUENTERECURSOSRUBRO":"$FUENTERECURSOSRUBRO","KEY_CENTRO_COSTO":"$CENTRO_COSTO","KEY_REFERENCIA":"$REFERENCIA","KEY_AUXILIAR":"$AUXILIAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PROYECTO" sqlType="STRING"/>
		<param defaultValue="0" name="VIGENCIA" sqlType="STRING"/>
		<param name="DIMENSION" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="SUBPROGRAMA" sqlType="STRING"/>
		<param name="RUBROPPTALES" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRO_COSTO" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="REFERENCIA" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="AUXILIAR" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="bpproyectosrubros">
		<call-query href="insertBpproyectosrubros">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PROYECTO" query-param="PROYECTO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DIMENSION" query-param="DIMENSION"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="PROGRAMA" query-param="PROGRAMA"/>
			<with-param name="SUBPROGRAMA" query-param="SUBPROGRAMA"/>
			<with-param name="RUBROPPTALES" query-param="RUBROPPTALES"/>
			<with-param name="FUENTERECURSOSRUBRO" query-param="FUENTERECURSOSRUBRO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteBpproyectosrubros" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM BP_PROYECTOSRUBROS WHERE BP_PROYECTOSRUBROS.COMPANIA= :KEY_COMPANIA AND BP_PROYECTOSRUBROS.PROYECTO= :KEY_PROYECTO AND BP_PROYECTOSRUBROS.VIGENCIA= :KEY_VIGENCIA AND BP_PROYECTOSRUBROS.DIMENSION= :KEY_DIMENSION AND BP_PROYECTOSRUBROS.SECTOR= :KEY_SECTOR AND BP_PROYECTOSRUBROS.PROGRAMA= :KEY_PROGRAMA AND BP_PROYECTOSRUBROS.SUBPROGRAMA= :KEY_SUBPROGRAMA AND BP_PROYECTOSRUBROS.RUBROPPTALES= :KEY_RUBROPPTALES AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO= :KEY_FUENTERECURSOSRUBRO AND BP_PROYECTOSRUBROS.CENTRO_COSTO= :KEY_CENTRO_COSTO AND BP_PROYECTOSRUBROS.REFERENCIA= :KEY_REFERENCIA AND BP_PROYECTOSRUBROS.AUXILIAR= :KEY_AUXILIAR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="INTEGER"/>
		<param name="KEY_DIMENSION" sqlType="STRING"/>
		<param name="KEY_SECTOR" sqlType="STRING"/>
		<param name="KEY_PROGRAMA" sqlType="STRING"/>
		<param name="KEY_SUBPROGRAMA" sqlType="STRING"/>
		<param name="KEY_RUBROPPTALES" sqlType="STRING"/>
		<param name="KEY_FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>
		<param name="KEY_REFERENCIA" sqlType="STRING"/>
		<param name="KEY_AUXILIAR" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="bpproyectosrubros">
		<call-query href="deleteBpproyectosrubros">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROYECTO" query-param="KEY_PROYECTO"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
			<with-param name="KEY_DIMENSION" query-param="KEY_DIMENSION"/>
			<with-param name="KEY_SECTOR" query-param="KEY_SECTOR"/>
			<with-param name="KEY_PROGRAMA" query-param="KEY_PROGRAMA"/>
			<with-param name="KEY_SUBPROGRAMA" query-param="KEY_SUBPROGRAMA"/>
			<with-param name="KEY_RUBROPPTALES" query-param="KEY_RUBROPPTALES"/>
			<with-param name="KEY_FUENTERECURSOSRUBRO" query-param="KEY_FUENTERECURSOSRUBRO"/>
			<with-param name="KEY_CENTRO_COSTO" query-param="KEY_CENTRO_COSTO"/>
			<with-param name="KEY_REFERENCIA" query-param="KEY_REFERENCIA"/>
			<with-param name="KEY_AUXILIAR" query-param="KEY_AUXILIAR"/>

		</call-query>
	</resource>
	<query id="getBpproyectosrubrosPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT COMPANIA, PROYECTO, VIGENCIA, DIMENSION, SECTOR, PROGRAMA, SUBPROGRAMA, RUBROPPTALES, FUENTERECURSOSRUBRO, CENTRO_COSTO, REFERENCIA, AUXILIAR FROM BP_PROYECTOSRUBROS WHERE BP_PROYECTOSRUBROS.COMPANIA = :COMPANIA AND BP_PROYECTOSRUBROS.PROYECTO = :CODIGO ORDER BY VIGENCIA, DIMENSION, SECTOR, PROGRAMA, SUBPROGRAMA) INI WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END) LIKE UPPER(CONCAT(:VIGENCIA, '%')) AND (CASE WHEN DIMENSION IS NULL THEN ' ' ELSE UPPER(DIMENSION) END) LIKE UPPER(CONCAT(:DIMENSION, '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(:SECTOR, '%')) AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END) LIKE UPPER(CONCAT(:PROGRAMA, '%')) AND (CASE WHEN SUBPROGRAMA IS NULL THEN ' ' ELSE UPPER(SUBPROGRAMA) END) LIKE UPPER(CONCAT(:SUBPROGRAMA, '%')) AND (CASE WHEN RUBROPPTALES IS NULL THEN ' ' ELSE UPPER(RUBROPPTALES) END) LIKE UPPER(CONCAT(:RUBROPPTALES, '%')) AND (CASE WHEN FUENTERECURSOSRUBRO IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOSRUBRO) END) LIKE UPPER(CONCAT(:FUENTERECURSOSRUBRO, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROYECTO":"$PROYECTO","VIGENCIA":"$VIGENCIA(type:integer)","DIMENSION":"$DIMENSION","SECTOR":"$SECTOR","PROGRAMA":"$PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","RUBROPPTALES":"$RUBROPPTALES","FUENTERECURSOSRUBRO":"$FUENTERECURSOSRUBRO","CENTRO_COSTO":"$CENTRO_COSTO","REFERENCIA":"$REFERENCIA","AUXILIAR":"$AUXILIAR"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="DIMENSION" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="SUBPROGRAMA" sqlType="STRING"/>
		<param name="RUBROPPTALES" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="bpproyectosrubros">
		<call-query href="getBpproyectosrubrosPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>
			<with-param name="DIMENSION" query-param="DIMENSION"/>
			<with-param name="SECTOR" query-param="SECTOR"/>
			<with-param name="PROGRAMA" query-param="PROGRAMA"/>
			<with-param name="SUBPROGRAMA" query-param="SUBPROGRAMA"/>
			<with-param name="RUBROPPTALES" query-param="RUBROPPTALES"/>
			<with-param name="FUENTERECURSOSRUBRO" query-param="FUENTERECURSOSRUBRO"/>
			<with-param name="CENTRO_COSTO" query-param="CENTRO_COSTO"/>
			<with-param name="REFERENCIA" query-param="REFERENCIA"/>
			<with-param name="AUXILIAR" query-param="AUXILIAR"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getBpproyectosrubrosNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, PROYECTO, VIGENCIA, DIMENSION, SECTOR, PROGRAMA, SUBPROGRAMA, RUBROPPTALES, FUENTERECURSOSRUBRO, CENTRO_COSTO, REFERENCIA, AUXILIAR FROM BP_PROYECTOSRUBROS WHERE BP_PROYECTOSRUBROS.COMPANIA = :COMPANIA AND BP_PROYECTOSRUBROS.PROYECTO = :CODIGO ORDER BY VIGENCIA, DIMENSION, SECTOR, PROGRAMA, SUBPROGRAMA) INI WHERE (CASE WHEN VIGENCIA IS NULL THEN ' ' ELSE UPPER(VIGENCIA) END) LIKE UPPER(CONCAT(:VIGENCIA, '%')) AND (CASE WHEN DIMENSION IS NULL THEN ' ' ELSE UPPER(DIMENSION) END) LIKE UPPER(CONCAT(:DIMENSION, '%')) AND (CASE WHEN SECTOR IS NULL THEN ' ' ELSE UPPER(SECTOR) END) LIKE UPPER(CONCAT(:SECTOR, '%')) AND (CASE WHEN PROGRAMA IS NULL THEN ' ' ELSE UPPER(PROGRAMA) END) LIKE UPPER(CONCAT(:PROGRAMA, '%')) AND (CASE WHEN SUBPROGRAMA IS NULL THEN ' ' ELSE UPPER(SUBPROGRAMA) END) LIKE UPPER(CONCAT(:SUBPROGRAMA, '%')) AND (CASE WHEN RUBROPPTALES IS NULL THEN ' ' ELSE UPPER(RUBROPPTALES) END) LIKE UPPER(CONCAT(:RUBROPPTALES, '%')) AND (CASE WHEN FUENTERECURSOSRUBRO IS NULL THEN ' ' ELSE UPPER(FUENTERECURSOSRUBRO) END) LIKE UPPER(CONCAT(:FUENTERECURSOSRUBRO, '%')) AND (CASE WHEN CENTRO_COSTO IS NULL THEN ' ' ELSE UPPER(CENTRO_COSTO) END) LIKE UPPER(CONCAT(:CENTRO_COSTO, '%')) AND (CASE WHEN REFERENCIA IS NULL THEN ' ' ELSE UPPER(REFERENCIA) END) LIKE UPPER(CONCAT(:REFERENCIA, '%')) AND (CASE WHEN AUXILIAR IS NULL THEN ' ' ELSE UPPER(AUXILIAR) END) LIKE UPPER(CONCAT(:AUXILIAR, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="DIMENSION" sqlType="STRING"/>
		<param name="SECTOR" sqlType="STRING"/>
		<param name="PROGRAMA" sqlType="STRING"/>
		<param name="SUBPROGRAMA" sqlType="STRING"/>
		<param name="RUBROPPTALES" sqlType="STRING"/>
		<param name="FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param name="CENTRO_COSTO" sqlType="STRING"/>
		<param name="REFERENCIA" sqlType="STRING"/>
		<param name="AUXILIAR" sqlType="STRING"/>

	</query>
