	</resource>
	<query id="getBpproyectosrubrosRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT BP_PROYECTOSRUBROS.COMPANIA, BP_PROYECTOSRUBROS.PROYECTO, BP_PROYECTOSRUBROS.VIGENCIA, PARA_DIMENSION.CODIGO DIMENSION, PARA_DIMENSION.NOMBRE NOMBRE_DIMENSION, PARA_SECTOR.CODIGO SECTOR, PARA_SECTOR.NOMBRE NOMBRE_SECTOR, PARA_PORGRAMA.CODIGO PROGRAMA, PARA_PORGRAMA.NOMBRE NOMBRE_PROGRAMA, PARA_SUB_PORGRAMA.CODIGO SUBPROGRAMA, PARA_SUB_PORGRAMA.NOMBRE NOMBRE_SUB_PROGRAMA, PARA_RUBROS.CODIGO RUBROPPTALES, PARA_RUBROS.NOMBRE NOMBRE_RUBRO, BP_PROYECTOSRUBROS.CENTRO_COSTO, CENTRO_COSTO.NOMBRE NOMBRE_CENTRO_COSTO, BP_PROYECTOSRUBROS.REFERENCIA, REFERENCIA.NOMBRE NOMBRE_REFERENCIA, BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO, FUENTE_RECURSOS.NOMBRE NOMBRE_FUENTE_RECURSOS, BP_PROYECTOSRUBROS.CREATED_BY,(TO_CHAR(BP_PROYECTOSRUBROS.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, BP_PROYECTOSRUBROS.MODIFIED_BY,(TO_CHAR(BP_PROYECTOSRUBROS.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, BP_PROYECTOSRUBROS.AUXILIAR, AUXILIAR.NOMBRE NOMBRE_AUXILIAR_GENERAL FROM BP_PROYECTOSRUBROS INNER JOIN V_PLAN_PRESUPUESTAL PARA_DIMENSION ON BP_PROYECTOSRUBROS.DIMENSION = PARA_DIMENSION.CODIGO AND BP_PROYECTOSRUBROS.COMPANIA = PARA_DIMENSION.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = PARA_DIMENSION.ANO INNER JOIN V_PLAN_PRESUPUESTAL PARA_SECTOR ON BP_PROYECTOSRUBROS.SECTOR = PARA_SECTOR.CODIGO AND BP_PROYECTOSRUBROS.COMPANIA = PARA_SECTOR.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = PARA_SECTOR.ANO INNER JOIN V_PLAN_PRESUPUESTAL PARA_PORGRAMA ON BP_PROYECTOSRUBROS.PROGRAMA = PARA_PORGRAMA.ID AND BP_PROYECTOSRUBROS.COMPANIA = PARA_PORGRAMA.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = PARA_PORGRAMA.ANO INNER JOIN V_PLAN_PRESUPUESTAL PARA_SUB_PORGRAMA ON BP_PROYECTOSRUBROS.SUBPROGRAMA = PARA_SUB_PORGRAMA.ID AND BP_PROYECTOSRUBROS.COMPANIA = PARA_SUB_PORGRAMA.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = PARA_SUB_PORGRAMA.ANO INNER JOIN V_PLAN_PRESUPUESTAL PARA_RUBROS ON BP_PROYECTOSRUBROS.RUBROPPTALES = PARA_RUBROS.ID AND BP_PROYECTOSRUBROS.COMPANIA = PARA_RUBROS.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = PARA_RUBROS.ANO LEFT JOIN CENTRO_COSTO ON BP_PROYECTOSRUBROS.COMPANIA = CENTRO_COSTO.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = CENTRO_COSTO.ANO AND BP_PROYECTOSRUBROS.CENTRO_COSTO = CENTRO_COSTO.CODIGO LEFT JOIN FUENTE_RECURSOS ON BP_PROYECTOSRUBROS.COMPANIA = FUENTE_RECURSOS.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = FUENTE_RECURSOS.ANO AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO = FUENTE_RECURSOS.CODIGO LEFT JOIN REFERENCIA ON BP_PROYECTOSRUBROS.COMPANIA = REFERENCIA.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = REFERENCIA.ANO AND BP_PROYECTOSRUBROS.REFERENCIA = REFERENCIA.CODIGO LEFT JOIN AUXILIAR ON BP_PROYECTOSRUBROS.COMPANIA = AUXILIAR.COMPANIA AND BP_PROYECTOSRUBROS.VIGENCIA = AUXILIAR.ANO AND BP_PROYECTOSRUBROS.AUXILIAR = AUXILIAR.CODIGO WHERE BP_PROYECTOSRUBROS.COMPANIA= :KEY_COMPANIA AND BP_PROYECTOSRUBROS.PROYECTO= :KEY_PROYECTO AND BP_PROYECTOSRUBROS.VIGENCIA= :KEY_VIGENCIA AND BP_PROYECTOSRUBROS.DIMENSION= :KEY_DIMENSION AND BP_PROYECTOSRUBROS.SECTOR= :KEY_SECTOR AND BP_PROYECTOSRUBROS.PROGRAMA= :KEY_PROGRAMA AND BP_PROYECTOSRUBROS.SUBPROGRAMA= :KEY_SUBPROGRAMA AND BP_PROYECTOSRUBROS.RUBROPPTALES= :KEY_RUBROPPTALES AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO= :KEY_FUENTERECURSOSRUBRO AND BP_PROYECTOSRUBROS.CENTRO_COSTO= :KEY_CENTRO_COSTO AND BP_PROYECTOSRUBROS.REFERENCIA= :KEY_REFERENCIA AND BP_PROYECTOSRUBROS.AUXILIAR= :KEY_AUXILIAR</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PROYECTO":"$PROYECTO","VIGENCIA":"$VIGENCIA(type:integer)","DIMENSION":"$DIMENSION","NOMBRE_DIMENSION":"$NOMBRE_DIMENSION","SECTOR":"$SECTOR","NOMBRE_SECTOR":"$NOMBRE_SECTOR","PROGRAMA":"$PROGRAMA","NOMBRE_PROGRAMA":"$NOMBRE_PROGRAMA","SUBPROGRAMA":"$SUBPROGRAMA","NOMBRE_SUB_PROGRAMA":"$NOMBRE_SUB_PROGRAMA","RUBROPPTALES":"$RUBROPPTALES","NOMBRE_RUBRO":"$NOMBRE_RUBRO","CENTRO_COSTO":"$CENTRO_COSTO","NOMBRE_CENTRO_COSTO":"$NOMBRE_CENTRO_COSTO","REFERENCIA":"$REFERENCIA","NOMBRE_REFERENCIA":"$NOMBRE_REFERENCIA","FUENTERECURSOSRUBRO":"$FUENTERECURSOSRUBRO","NOMBRE_FUENTE_RECURSOS":"$NOMBRE_FUENTE_RECURSOS","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED","AUXILIAR":"$AUXILIAR","NOMBRE_AUXILIAR_GENERAL":"$NOMBRE_AUXILIAR_GENERAL"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_PROYECTO" sqlType="STRING"/>
		<param name="KEY_VIGENCIA" sqlType="STRING"/>
		<param name="KEY_DIMENSION" sqlType="STRING"/>
		<param name="KEY_SECTOR" sqlType="STRING"/>
		<param name="KEY_PROGRAMA" sqlType="STRING"/>
		<param name="KEY_SUBPROGRAMA" sqlType="STRING"/>
		<param name="KEY_RUBROPPTALES" sqlType="STRING"/>
		<param name="KEY_FUENTERECURSOSRUBRO" sqlType="STRING"/>
		<param name="KEY_CENTRO_COSTO" sqlType="STRING"/>
		<param name="KEY_REFERENCIA" sqlType="STRING"/>
		<param name="KEY_AUXILIAR" sqlType="STRING"/>

	</query>
	<resource method="GET" path="bpproyectosrubros/data">
		<call-query href="getBpproyectosrubrosRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_PROYECTO" query-param="KEY_PROYECTO"/>
			<with-param name="KEY_VIGENCIA" query-param="KEY_VIGENCIA"/>
