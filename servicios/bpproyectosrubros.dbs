		</call-query>
	</resource>
	<query id="updateBpproyectosrubros" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE BP_PROYECTOSRUBROS SET VIGENCIA=:VIGENCIA, DIMENSION=:DIMENSION, SECTOR=:SECTOR, PROGRAMA=:PROGRAMA, SUBPROGRAMA=:SUBPROGRAMA, RUBROPPTALES=:RUBROPPTALES, FUENTERECURSOSRUBRO=:FUENTERECURSOSRUBRO, CENTRO_COSTO=:CENTRO_COSTO, REFERENCIA=:REFERENCIA, AUXILIAR=:AUXILIAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE BP_PROYECTOSRUBROS.COMPANIA= :KEY_COMPANIA AND BP_PROYECTOSRUBROS.PROYECTO= :KEY_PROYECTO AND BP_PROYECTOSRUBROS.VIGENCIA= :KEY_VIGENCIA AND BP_PROYECTOSRUBROS.DIMENSION= :KEY_DIMENSION AND BP_PROYECTOSRUBROS.SECTOR= :KEY_SECTOR AND BP_PROYECTOSRUBROS.PROGRAMA= :KEY_PROGRAMA AND BP_PROYECTOSRUBROS.SUBPROGRAMA= :KEY_SUBPROGRAMA AND BP_PROYECTOSRUBROS.RUBROPPTALES= :KEY_RUBROPPTALES AND BP_PROYECTOSRUBROS.FUENTERECURSOSRUBRO= :KEY_FUENTERECURSOSRUBRO AND BP_PROYECTOSRUBROS.CENTRO_COSTO= :KEY_CENTRO_COSTO AND BP_PROYECTOSRUBROS.REFERENCIA= :KEY_REFERENCIA AND BP_PROYECTOSRUBROS.AUXILIAR= :KEY_AUXILIAR</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

