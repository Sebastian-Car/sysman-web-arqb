<data name="codigocncertificadodian" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getCodigocncertificadodianTodosQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CODIGO,DESCRIPCION  FROM CODIGOCN_CERTIFICADODIAN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGO":"$CODIGO","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
 
	</query>
	<resource method="GET" path="codigocncertificadodian/todos">
		<call-query href="getCodigocncertificadodianTodosQuery">
 
		</call-query>
	</resource>

</data>