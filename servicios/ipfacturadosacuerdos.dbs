			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosacuerdosRegistrosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(*) CANT  FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :PREDIO AND NUMERO_ORDEN = :NUMERO_ORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANT":"$CANT(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>

	</query>
