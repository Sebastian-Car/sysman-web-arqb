	<query id="getIpfacturadosacuerdosCodigoacuerdosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOSACUERDOS.CODIGOACUERDO  FROM IP_FACTURADOSACUERDOS WHERE IP_FACTURADOSACUERDOS.COMPANIA = :COMPANIA AND IP_FACTURADOSACUERDOS.PREDIO = :PREDIO GROUP BY IP_FACTURADOSACUERDOS.CODIGOACUERDO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CODIGOACUERDO":"$CODIGOACUERDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturadosacuerdos/codigoacuerdosporpredio">
		<call-query href="getIpfacturadosacuerdosCodigoacuerdosPorPredioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosacuerdosListarCuotasPorCodigoacuerdoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  IP_FACTURADOSACUERDOS.CUOTA  FROM IP_FACTURADOSACUERDOS WHERE IP_FACTURADOSACUERDOS.COMPANIA = :COMPANIA AND IP_FACTURADOSACUERDOS.CODIGOACUERDO = :CODIGOACUERDO AND PAGADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CUOTA":"$CUOTA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturadosacuerdos/listarcuotasporcodigoacuerdo">
		<call-query href="getIpfacturadosacuerdosListarCuotasPorCodigoacuerdoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosacuerdosPagadoPorCiaCodQuery"  useConfig="sysmandsunist">
		<sql>SELECT (CASE PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO FROM IP_FACTURADOS WHERE COMPANIA = :COMPANIA AND CODIGO = :CODIGO AND PAGADO = 0</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAGADO":"$PAGADO(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturadosacuerdos/pagadoporciacod">
		<call-query href="getIpfacturadosacuerdosPagadoPorCiaCodQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosacuerdosTotalFacturaAcuerdoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  TOTAL  FROM IP_FACTURADOSACUERDOS WHERE IP_FACTURADOSACUERDOS.COMPANIA = :COMPANIA AND IP_FACTURADOSACUERDOS.CODIGOACUERDO = :CODIGOACUERDO AND IP_FACTURADOSACUERDOS.CUOTA = :CUOTA AND PAGADO IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturadosacuerdos/totalfacturaacuerdo">
