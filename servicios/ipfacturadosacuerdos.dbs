<data name="ipfacturadosacuerdos" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getIpfacturadosacuerdosPagListarHistoricoAcuerdosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, PREDIO, NUMERO_ORDEN, CUOTA,(TO_CHAR(FECHAFACTURADO,'DD/MM/YYYY HH24:MI:SS')) FECHAFACTURADO, CAPITAL, INTERESES, INTERES_ACUERDO, INTERES_RECARGO, TOTAL,(CASE PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, DOCNUM,(TO_CHAR(FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, PAG_BAN, CODIGOACUERDO  FROM IP_FACTURADOSACUERDOS WHERE COMPANIA = :COMPANIA AND CODIGOACUERDO = :CODIGOACUERDO) WHERE (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN FECHAFACTURADO IS NULL THEN ' ' ELSE UPPER(FECHAFACTURADO) END)  LIKE UPPER( '%' || :FECHAFACTURADO || '%')  AND (CASE WHEN CAPITAL IS NULL THEN ' ' ELSE UPPER(CAPITAL) END)  LIKE UPPER( '%' || :CAPITAL || '%')  AND (CASE WHEN INTERESES IS NULL THEN ' ' ELSE UPPER(INTERESES) END)  LIKE UPPER( '%' || :INTERESES || '%')  AND (CASE WHEN INTERES_ACUERDO IS NULL THEN ' ' ELSE UPPER(INTERES_ACUERDO) END)  LIKE UPPER( '%' || :INTERES_ACUERDO || '%')  AND (CASE WHEN INTERES_RECARGO IS NULL THEN ' ' ELSE UPPER(INTERES_RECARGO) END)  LIKE UPPER( '%' || :INTERES_RECARGO || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER( '%' || :PAGADO || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%')  AND (CASE WHEN PAG_BAN IS NULL THEN ' ' ELSE UPPER(PAG_BAN) END)  LIKE UPPER( '%' || :PAG_BAN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","PREDIO":"$PREDIO","NUMERO_ORDEN":"$NUMERO_ORDEN","CUOTA":"$CUOTA","FECHAFACTURADO":"$FECHAFACTURADO","CAPITAL":"$CAPITAL","INTERESES":"$INTERESES","INTERES_ACUERDO":"$INTERES_ACUERDO","INTERES_RECARGO":"$INTERES_RECARGO","TOTAL":"$TOTAL","PAGADO":"$PAGADO(type:boolean)","DOCNUM":"$DOCNUM","FECHAPAGO":"$FECHAPAGO","PAG_BAN":"$PAG_BAN","CODIGOACUERDO":"$CODIGOACUERDO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="FECHAFACTURADO" sqlType="STRING"/>
		<param name="CAPITAL" sqlType="STRING"/>
		<param name="INTERESES" sqlType="STRING"/>
		<param name="INTERES_ACUERDO" sqlType="STRING"/>
		<param name="INTERES_RECARGO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="PAGADO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="ipfacturadosacuerdos/listarhistoricoacuerdosporpredio/pag">
		<call-query href="getIpfacturadosacuerdosPagListarHistoricoAcuerdosPorPredioQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="CUOTA" query-param="CUOTA"/>
			<with-param name="FECHAFACTURADO" query-param="FECHAFACTURADO"/>
			<with-param name="CAPITAL" query-param="CAPITAL"/>
			<with-param name="INTERESES" query-param="INTERESES"/>
			<with-param name="INTERES_ACUERDO" query-param="INTERES_ACUERDO"/>
			<with-param name="INTERES_RECARGO" query-param="INTERES_RECARGO"/>
			<with-param name="TOTAL" query-param="TOTAL"/>
			<with-param name="PAGADO" query-param="PAGADO"/>
			<with-param name="DOCNUM" query-param="DOCNUM"/>
			<with-param name="FECHAPAGO" query-param="FECHAPAGO"/>
			<with-param name="PAG_BAN" query-param="PAG_BAN"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosacuerdosNumListarHistoricoAcuerdosPorPredioQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, PREDIO, NUMERO_ORDEN, CUOTA,(TO_CHAR(FECHAFACTURADO,'DD/MM/YYYY HH24:MI:SS')) FECHAFACTURADO, CAPITAL, INTERESES, INTERES_ACUERDO, INTERES_RECARGO, TOTAL,(CASE PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, DOCNUM,(TO_CHAR(FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, PAG_BAN, CODIGOACUERDO  FROM IP_FACTURADOSACUERDOS WHERE COMPANIA = :COMPANIA AND CODIGOACUERDO = :CODIGOACUERDO) WHERE (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER(:CUOTA || '%')  AND (CASE WHEN FECHAFACTURADO IS NULL THEN ' ' ELSE UPPER(FECHAFACTURADO) END)  LIKE UPPER( '%' || :FECHAFACTURADO || '%')  AND (CASE WHEN CAPITAL IS NULL THEN ' ' ELSE UPPER(CAPITAL) END)  LIKE UPPER( '%' || :CAPITAL || '%')  AND (CASE WHEN INTERESES IS NULL THEN ' ' ELSE UPPER(INTERESES) END)  LIKE UPPER( '%' || :INTERESES || '%')  AND (CASE WHEN INTERES_ACUERDO IS NULL THEN ' ' ELSE UPPER(INTERES_ACUERDO) END)  LIKE UPPER( '%' || :INTERES_ACUERDO || '%')  AND (CASE WHEN INTERES_RECARGO IS NULL THEN ' ' ELSE UPPER(INTERES_RECARGO) END)  LIKE UPPER( '%' || :INTERES_RECARGO || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER( '%' || :PAGADO || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%')  AND (CASE WHEN PAG_BAN IS NULL THEN ' ' ELSE UPPER(PAG_BAN) END)  LIKE UPPER( '%' || :PAG_BAN || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="FECHAFACTURADO" sqlType="STRING"/>
		<param name="CAPITAL" sqlType="STRING"/>
		<param name="INTERESES" sqlType="STRING"/>
		<param name="INTERES_ACUERDO" sqlType="STRING"/>
		<param name="INTERES_RECARGO" sqlType="STRING"/>
		<param name="TOTAL" sqlType="STRING"/>
		<param name="PAGADO" sqlType="STRING"/>
		<param name="DOCNUM" sqlType="STRING"/>
		<param name="FECHAPAGO" sqlType="STRING"/>
		<param name="PAG_BAN" sqlType="STRING"/>

	</query>
