	<query id="getIpfacturadosacuerdosPagDetAcuerdosPagoPorCodQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, CODIGOACUERDO, PREDIO, NUMERO_ORDEN, CUOTA,(TO_CHAR(FECHAFACTURADO,'DD/MM/YYYY HH24:MI:SS')) FECHAFACTURADO, C1, C2, C3, C4, C5, C6, C7, C8, C9, C10, C11, C12, C13, C14, C15, C16, C17, C18, C19, C20, CAPITAL, INTERESES, INTERES_ACUERDO, INTERES_RECARGO, TOTAL,(CASE PAGADO WHEN 0 THEN 'false' ELSE 'true' END) PAGADO, DOCNUM,(TO_CHAR(FECHAPAGO,'DD/MM/YYYY HH24:MI:SS')) FECHAPAGO, PAG_BAN  FROM IP_FACTURADOSACUERDOS WHERE COMPANIA = :COMPANIA AND CODIGOACUERDO = :CODIGO) WHERE (CASE WHEN COMPANIA IS NULL THEN ' ' ELSE UPPER(COMPANIA) END)  LIKE UPPER( '%' || :COMPANIA || '%')  AND (CASE WHEN CODIGOACUERDO IS NULL THEN ' ' ELSE UPPER(CODIGOACUERDO) END)  LIKE UPPER( '%' || :CODIGOACUERDO || '%')  AND (CASE WHEN PREDIO IS NULL THEN ' ' ELSE UPPER(PREDIO) END)  LIKE UPPER( '%' || :PREDIO || '%')  AND (CASE WHEN NUMERO_ORDEN IS NULL THEN ' ' ELSE UPPER(NUMERO_ORDEN) END)  LIKE UPPER( '%' || :NUMERO_ORDEN || '%')  AND (CASE WHEN CUOTA IS NULL THEN ' ' ELSE UPPER(CUOTA) END)  LIKE UPPER( '%' || :CUOTA || '%')  AND (CASE WHEN FECHAFACTURADO IS NULL THEN ' ' ELSE UPPER(FECHAFACTURADO) END)  LIKE UPPER( '%' || :FECHAFACTURADO || '%')  AND (CASE WHEN C1 IS NULL THEN ' ' ELSE UPPER(C1) END)  LIKE UPPER( '%' || :C1 || '%')  AND (CASE WHEN C2 IS NULL THEN ' ' ELSE UPPER(C2) END)  LIKE UPPER( '%' || :C2 || '%')  AND (CASE WHEN C3 IS NULL THEN ' ' ELSE UPPER(C3) END)  LIKE UPPER( '%' || :C3 || '%')  AND (CASE WHEN C4 IS NULL THEN ' ' ELSE UPPER(C4) END)  LIKE UPPER( '%' || :C4 || '%')  AND (CASE WHEN C5 IS NULL THEN ' ' ELSE UPPER(C5) END)  LIKE UPPER( '%' || :C5 || '%')  AND (CASE WHEN C6 IS NULL THEN ' ' ELSE UPPER(C6) END)  LIKE UPPER( '%' || :C6 || '%')  AND (CASE WHEN C7 IS NULL THEN ' ' ELSE UPPER(C7) END)  LIKE UPPER( '%' || :C7 || '%')  AND (CASE WHEN C8 IS NULL THEN ' ' ELSE UPPER(C8) END)  LIKE UPPER( '%' || :C8 || '%')  AND (CASE WHEN C9 IS NULL THEN ' ' ELSE UPPER(C9) END)  LIKE UPPER( '%' || :C9 || '%')  AND (CASE WHEN C10 IS NULL THEN ' ' ELSE UPPER(C10) END)  LIKE UPPER( '%' || :C10 || '%')  AND (CASE WHEN C11 IS NULL THEN ' ' ELSE UPPER(C11) END)  LIKE UPPER( '%' || :C11 || '%')  AND (CASE WHEN C12 IS NULL THEN ' ' ELSE UPPER(C12) END)  LIKE UPPER( '%' || :C12 || '%')  AND (CASE WHEN C13 IS NULL THEN ' ' ELSE UPPER(C13) END)  LIKE UPPER( '%' || :C13 || '%')  AND (CASE WHEN C14 IS NULL THEN ' ' ELSE UPPER(C14) END)  LIKE UPPER( '%' || :C14 || '%')  AND (CASE WHEN C15 IS NULL THEN ' ' ELSE UPPER(C15) END)  LIKE UPPER( '%' || :C15 || '%')  AND (CASE WHEN C16 IS NULL THEN ' ' ELSE UPPER(C16) END)  LIKE UPPER( '%' || :C16 || '%')  AND (CASE WHEN C17 IS NULL THEN ' ' ELSE UPPER(C17) END)  LIKE UPPER( '%' || :C17 || '%')  AND (CASE WHEN C18 IS NULL THEN ' ' ELSE UPPER(C18) END)  LIKE UPPER( '%' || :C18 || '%')  AND (CASE WHEN C19 IS NULL THEN ' ' ELSE UPPER(C19) END)  LIKE UPPER( '%' || :C19 || '%')  AND (CASE WHEN C20 IS NULL THEN ' ' ELSE UPPER(C20) END)  LIKE UPPER( '%' || :C20 || '%')  AND (CASE WHEN CAPITAL IS NULL THEN ' ' ELSE UPPER(CAPITAL) END)  LIKE UPPER( '%' || :CAPITAL || '%')  AND (CASE WHEN INTERESES IS NULL THEN ' ' ELSE UPPER(INTERESES) END)  LIKE UPPER( '%' || :INTERESES || '%')  AND (CASE WHEN INTERES_ACUERDO IS NULL THEN ' ' ELSE UPPER(INTERES_ACUERDO) END)  LIKE UPPER( '%' || :INTERES_ACUERDO || '%')  AND (CASE WHEN INTERES_RECARGO IS NULL THEN ' ' ELSE UPPER(INTERES_RECARGO) END)  LIKE UPPER( '%' || :INTERES_RECARGO || '%')  AND (CASE WHEN TOTAL IS NULL THEN ' ' ELSE UPPER(TOTAL) END)  LIKE UPPER( '%' || :TOTAL || '%')  AND (CASE WHEN PAGADO IS NULL THEN ' ' ELSE UPPER(PAGADO) END)  LIKE UPPER( '%' || :PAGADO || '%')  AND (CASE WHEN DOCNUM IS NULL THEN ' ' ELSE UPPER(DOCNUM) END)  LIKE UPPER( '%' || :DOCNUM || '%')  AND (CASE WHEN FECHAPAGO IS NULL THEN ' ' ELSE UPPER(FECHAPAGO) END)  LIKE UPPER( '%' || :FECHAPAGO || '%')  AND (CASE WHEN PAG_BAN IS NULL THEN ' ' ELSE UPPER(PAG_BAN) END)  LIKE UPPER( '%' || :PAG_BAN || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CODIGOACUERDO":"$CODIGOACUERDO","PREDIO":"$PREDIO","NUMERO_ORDEN":"$NUMERO_ORDEN","CUOTA":"$CUOTA","FECHAFACTURADO":"$FECHAFACTURADO","C1":"$C1","C2":"$C2","C3":"$C3","C4":"$C4","C5":"$C5","C6":"$C6","C7":"$C7","C8":"$C8","C9":"$C9","C10":"$C10","C11":"$C11","C12":"$C12","C13":"$C13","C14":"$C14","C15":"$C15","C16":"$C16","C17":"$C17","C18":"$C18","C19":"$C19","C20":"$C20","CAPITAL":"$CAPITAL","INTERESES":"$INTERESES","INTERES_ACUERDO":"$INTERES_ACUERDO","INTERES_RECARGO":"$INTERES_RECARGO","TOTAL":"$TOTAL","PAGADO":"$PAGADO(type:boolean)","DOCNUM":"$DOCNUM","FECHAPAGO":"$FECHAPAGO","PAG_BAN":"$PAG_BAN"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>
		<param name="NUMERO_ORDEN" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>
		<param name="FECHAFACTURADO" sqlType="STRING"/>
