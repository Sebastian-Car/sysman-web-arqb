			<with-param name="CODIGOACUERDO" query-param="CODIGOACUERDO"/>
			<with-param name="PREDIO" query-param="PREDIO"/>

		</call-query>
	</resource>
	<query id="getIpfacturadosacuerdosCuotasNoPagasPorAcuerdoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(0) CANT  FROM IP_FACTURADOSACUERDOS WHERE CODIGOACUERDO = :CODIGOACUERDO AND CUOTA &lt; :CUOTA AND PAGADO IN(0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CANT":"$CANT(type:integer)"}]}}		</result>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="CUOTA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturadosacuerdos/cuotasnopagasporacuerdo">
