	<query id="getIpfacturadosacuerdosNumeroDePagosPorAcuerdoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  COUNT(PAGADO) PAGO  FROM IP_FACTURADOSACUERDOS WHERE COMPANIA = :COMPANIA AND CODIGOACUERDO = :CODIGOACUERDO AND PAGADO NOT IN (0) AND PREDIO = :PREDIO AND TOTAL NOT IN (0)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PAGO":"$PAGO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODIGOACUERDO" sqlType="STRING"/>
		<param name="PREDIO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="ipfacturadosacuerdos/numerodepagosporacuerdo">
