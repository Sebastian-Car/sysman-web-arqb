	<query id="updateDmantenimientos" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_MANTENIMIENTO SET ANO=:ANO, TIPO_CPTE=:TIPO_CPTE, COMPROBANTE=:COMPROBANTE, CONSECUTIVO=:CONSECUTIVO, TIPO_CPTE_AFECT=:TIPO_CPTE_AFECT, COMPROBANTE_AFECT=:COMPROBANTE_AFECT, CODIGOELEMENTO=:CODIGOELEMENTO, NOMBRELEMENTO=:NOMBRELEMENTO, TAREAMANTENIMIENTO=:TAREAMANTENIMIENTO, PLACA=:PLACA, DESCRIPCION=:DESCRIPCION, FECHAINICIAL=TO_DATE(:FECHAINICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHAFINAL=TO_DATE(:FECHAFINAL,'DD/MM/YYYY HH24:MI:SS'), CANTIDAD=:CANTIDAD, VALORUNITARIO=:VALORUNITARIO, VALORTOTAL=:VALORTOTAL, NIT_TALLER=:NIT_TALLER, SUCURSAL=:SUCURSAL, RESPONSABLE=:RESPONSABLE, SUCURSAL_RESPONSABLE=:SUCURSAL_RESPONSABLE, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), TIPO_MANTENIMIENTO=:TIPO_MANTENIMIENTO, KILOMETRAJE=:KILOMETRAJE WHERE D_MANTENIMIENTO.COMPANIA= :KEY_COMPANIA AND D_MANTENIMIENTO.ANO= :KEY_ANO AND D_MANTENIMIENTO.TIPO_CPTE= :KEY_TIPO_CPTE AND D_MANTENIMIENTO.COMPROBANTE= :KEY_COMPROBANTE AND D_MANTENIMIENTO.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CPTE" sqlType="STRING"/>
		<param name="COMPROBANTE" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
