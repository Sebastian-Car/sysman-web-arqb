<data name="tercerosops" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getTercerosopsPagListaterceroopsQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, NIT, SUCURSAL, ANO, TIPO_CONTRATO, NUMERO_CONTRATO, VALOR,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, MESES, IBC, APORTESVOLUNTARIOS, AFC, DEDUCIBLE_VIVIENDA, MEDPREPAGADA, APORTESARL, DESCRIPCION  FROM TERCERO_OPS WHERE NIT = :NIT AND SUCURSAL= :SUCURSAL AND COMPANIA= :COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPO_CONTRATO IS NULL THEN ' ' ELSE UPPER(TIPO_CONTRATO) END)  LIKE UPPER( '%' || :TIPO_CONTRATO || '%')  AND (CASE WHEN NUMERO_CONTRATO IS NULL THEN ' ' ELSE UPPER(NUMERO_CONTRATO) END)  LIKE UPPER( '%' || :NUMERO_CONTRATO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END)  LIKE UPPER(:FECHA_INICIAL || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER(:FECHA_FINAL || '%')  AND (CASE WHEN MESES IS NULL THEN ' ' ELSE UPPER(MESES) END)  LIKE UPPER( '%' || :MESES || '%')  AND (CASE WHEN IBC IS NULL THEN ' ' ELSE UPPER(IBC) END)  LIKE UPPER( '%' || :IBC || '%')  AND (CASE WHEN APORTESVOLUNTARIOS IS NULL THEN ' ' ELSE UPPER(APORTESVOLUNTARIOS) END)  LIKE UPPER( '%' || :APORTESVOLUNTARIOS || '%')  AND (CASE WHEN AFC IS NULL THEN ' ' ELSE UPPER(AFC) END)  LIKE UPPER( '%' || :AFC || '%')  AND (CASE WHEN DEDUCIBLE_VIVIENDA IS NULL THEN ' ' ELSE UPPER(DEDUCIBLE_VIVIENDA) END)  LIKE UPPER( '%' || :DEDUCIBLE_VIVIENDA || '%')  AND (CASE WHEN MEDPREPAGADA IS NULL THEN ' ' ELSE UPPER(MEDPREPAGADA) END)  LIKE UPPER( '%' || :MEDPREPAGADA || '%')  AND (CASE WHEN APORTESARL IS NULL THEN ' ' ELSE UPPER(APORTESARL) END)  LIKE UPPER( '%' || :APORTESARL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","SUCURSAL":"$SUCURSAL","ANO":"$ANO(type:integer)","TIPO_CONTRATO":"$TIPO_CONTRATO","NUMERO_CONTRATO":"$NUMERO_CONTRATO","VALOR":"$VALOR","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL","MESES":"$MESES(type:integer)","IBC":"$IBC","APORTESVOLUNTARIOS":"$APORTESVOLUNTARIOS","AFC":"$AFC","DEDUCIBLE_VIVIENDA":"$DEDUCIBLE_VIVIENDA","MEDPREPAGADA":"$MEDPREPAGADA","APORTESARL":"$APORTESARL","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="NUMERO_CONTRATO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="MESES" sqlType="STRING"/>
		<param name="IBC" sqlType="STRING"/>
		<param name="APORTESVOLUNTARIOS" sqlType="STRING"/>
		<param name="AFC" sqlType="STRING"/>
		<param name="DEDUCIBLE_VIVIENDA" sqlType="STRING"/>
		<param name="MEDPREPAGADA" sqlType="STRING"/>
		<param name="APORTESARL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="tercerosops/listaterceroops/pag">
		<call-query href="getTercerosopsPagListaterceroopsQuery">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="NUMERO_CONTRATO" query-param="NUMERO_CONTRATO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="MESES" query-param="MESES"/>
			<with-param name="IBC" query-param="IBC"/>
			<with-param name="APORTESVOLUNTARIOS" query-param="APORTESVOLUNTARIOS"/>
			<with-param name="AFC" query-param="AFC"/>
			<with-param name="DEDUCIBLE_VIVIENDA" query-param="DEDUCIBLE_VIVIENDA"/>
			<with-param name="MEDPREPAGADA" query-param="MEDPREPAGADA"/>
			<with-param name="APORTESARL" query-param="APORTESARL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getTercerosopsNumListaterceroopsQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NIT, SUCURSAL, ANO, TIPO_CONTRATO, NUMERO_CONTRATO, VALOR,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, MESES, IBC, APORTESVOLUNTARIOS, AFC, DEDUCIBLE_VIVIENDA, MEDPREPAGADA, APORTESARL, DESCRIPCION  FROM TERCERO_OPS WHERE NIT = :NIT AND SUCURSAL= :SUCURSAL AND COMPANIA= :COMPANIA) WHERE (CASE WHEN NIT IS NULL THEN ' ' ELSE UPPER(NIT) END)  LIKE UPPER( '%' || :NIT || '%')  AND (CASE WHEN SUCURSAL IS NULL THEN ' ' ELSE UPPER(SUCURSAL) END)  LIKE UPPER( '%' || :SUCURSAL || '%')  AND (CASE WHEN ANO IS NULL THEN ' ' ELSE UPPER(ANO) END)  LIKE UPPER(:ANO || '%')  AND (CASE WHEN TIPO_CONTRATO IS NULL THEN ' ' ELSE UPPER(TIPO_CONTRATO) END)  LIKE UPPER( '%' || :TIPO_CONTRATO || '%')  AND (CASE WHEN NUMERO_CONTRATO IS NULL THEN ' ' ELSE UPPER(NUMERO_CONTRATO) END)  LIKE UPPER( '%' || :NUMERO_CONTRATO || '%')  AND (CASE WHEN VALOR IS NULL THEN ' ' ELSE UPPER(VALOR) END)  LIKE UPPER(:VALOR || '%')  AND (CASE WHEN FECHA_INICIAL IS NULL THEN ' ' ELSE UPPER(FECHA_INICIAL) END)  LIKE UPPER(:FECHA_INICIAL || '%')  AND (CASE WHEN FECHA_FINAL IS NULL THEN ' ' ELSE UPPER(FECHA_FINAL) END)  LIKE UPPER(:FECHA_FINAL || '%')  AND (CASE WHEN MESES IS NULL THEN ' ' ELSE UPPER(MESES) END)  LIKE UPPER( '%' || :MESES || '%')  AND (CASE WHEN IBC IS NULL THEN ' ' ELSE UPPER(IBC) END)  LIKE UPPER( '%' || :IBC || '%')  AND (CASE WHEN APORTESVOLUNTARIOS IS NULL THEN ' ' ELSE UPPER(APORTESVOLUNTARIOS) END)  LIKE UPPER( '%' || :APORTESVOLUNTARIOS || '%')  AND (CASE WHEN AFC IS NULL THEN ' ' ELSE UPPER(AFC) END)  LIKE UPPER( '%' || :AFC || '%')  AND (CASE WHEN DEDUCIBLE_VIVIENDA IS NULL THEN ' ' ELSE UPPER(DEDUCIBLE_VIVIENDA) END)  LIKE UPPER( '%' || :DEDUCIBLE_VIVIENDA || '%')  AND (CASE WHEN MEDPREPAGADA IS NULL THEN ' ' ELSE UPPER(MEDPREPAGADA) END)  LIKE UPPER( '%' || :MEDPREPAGADA || '%')  AND (CASE WHEN APORTESARL IS NULL THEN ' ' ELSE UPPER(APORTESARL) END)  LIKE UPPER( '%' || :APORTESARL || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="NUMERO_CONTRATO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="MESES" sqlType="STRING"/>
		<param name="IBC" sqlType="STRING"/>
		<param name="APORTESVOLUNTARIOS" sqlType="STRING"/>
		<param name="AFC" sqlType="STRING"/>
		<param name="DEDUCIBLE_VIVIENDA" sqlType="STRING"/>
		<param name="MEDPREPAGADA" sqlType="STRING"/>
		<param name="APORTESARL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tercerosops/listaterceroops/num">
		<call-query href="getTercerosopsNumListaterceroopsQuery">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="NUMERO_CONTRATO" query-param="NUMERO_CONTRATO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="MESES" query-param="MESES"/>
			<with-param name="IBC" query-param="IBC"/>
			<with-param name="APORTESVOLUNTARIOS" query-param="APORTESVOLUNTARIOS"/>
			<with-param name="AFC" query-param="AFC"/>
			<with-param name="DEDUCIBLE_VIVIENDA" query-param="DEDUCIBLE_VIVIENDA"/>
			<with-param name="MEDPREPAGADA" query-param="MEDPREPAGADA"/>
			<with-param name="APORTESARL" query-param="APORTESARL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="insertTercerosops" keyColumns="COMPANIA,NIT,SUCURSAL,TIPO_CONTRATO,NUMERO_CONTRATO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO TERCERO_OPS (COMPANIA, NIT, SUCURSAL, ANO, TIPO_CONTRATO, NUMERO_CONTRATO, VALOR, FECHA_INICIAL, FECHA_FINAL, MESES, IBC, APORTESVOLUNTARIOS, AFC, DEDUCIBLE_VIVIENDA, MEDPREPAGADA, APORTESARL, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NIT, :SUCURSAL, :ANO, :TIPO_CONTRATO, :NUMERO_CONTRATO, :VALOR, TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), :MESES, :IBC, :APORTESVOLUNTARIOS, :AFC, :DEDUCIBLE_VIVIENDA, :MEDPREPAGADA, :APORTESARL, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NIT":"$NIT","KEY_SUCURSAL":"$SUCURSAL","KEY_TIPO_CONTRATO":"$TIPO_CONTRATO","KEY_NUMERO_CONTRATO":"$NUMERO_CONTRATO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param defaultValue="" name="ANO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="NUMERO_CONTRATO" sqlType="STRING"/>
		<param defaultValue="" name="VALOR" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_INICIAL" sqlType="STRING"/>
		<param defaultValue="" name="FECHA_FINAL" sqlType="STRING"/>
		<param defaultValue="" name="MESES" sqlType="STRING"/>
		<param defaultValue="" name="IBC" sqlType="STRING"/>
		<param defaultValue="" name="APORTESVOLUNTARIOS" sqlType="STRING"/>
		<param defaultValue="" name="AFC" sqlType="STRING"/>
		<param defaultValue="" name="DEDUCIBLE_VIVIENDA" sqlType="STRING"/>
		<param defaultValue="" name="MEDPREPAGADA" sqlType="STRING"/>
		<param defaultValue="" name="APORTESARL" sqlType="STRING"/>
		<param defaultValue="" name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="tercerosops">
		<call-query href="insertTercerosops">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="NUMERO_CONTRATO" query-param="NUMERO_CONTRATO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="MESES" query-param="MESES"/>
			<with-param name="IBC" query-param="IBC"/>
			<with-param name="APORTESVOLUNTARIOS" query-param="APORTESVOLUNTARIOS"/>
			<with-param name="AFC" query-param="AFC"/>
			<with-param name="DEDUCIBLE_VIVIENDA" query-param="DEDUCIBLE_VIVIENDA"/>
			<with-param name="MEDPREPAGADA" query-param="MEDPREPAGADA"/>
			<with-param name="APORTESARL" query-param="APORTESARL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteTercerosops" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM TERCERO_OPS WHERE TERCERO_OPS.COMPANIA= :KEY_COMPANIA AND TERCERO_OPS.NIT= :KEY_NIT AND TERCERO_OPS.SUCURSAL= :KEY_SUCURSAL AND TERCERO_OPS.TIPO_CONTRATO= :KEY_TIPO_CONTRATO AND TERCERO_OPS.NUMERO_CONTRATO= :KEY_NUMERO_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_TIPO_CONTRATO" sqlType="STRING"/>
		<param name="KEY_NUMERO_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="tercerosops">
		<call-query href="deleteTercerosops">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_TIPO_CONTRATO" query-param="KEY_TIPO_CONTRATO"/>
			<with-param name="KEY_NUMERO_CONTRATO" query-param="KEY_NUMERO_CONTRATO"/>

		</call-query>
	</resource>
	<query id="getTercerosopsPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, NIT, SUCURSAL, ANO, TIPO_CONTRATO, NUMERO_CONTRATO, VALOR,(TO_CHAR(FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_INICIAL,(TO_CHAR(FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS')) FECHA_FINAL, MESES, IBC, APORTESVOLUNTARIOS, AFC, DEDUCIBLE_VIVIENDA, MEDPREPAGADA, APORTESARL, DESCRIPCION FROM TERCERO_OPS WHERE NIT = :NIT AND SUCURSAL= :SUCURSAL AND COMPANIA= :COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NIT":"$NIT","SUCURSAL":"$SUCURSAL","ANO":"$ANO(type:integer)","TIPO_CONTRATO":"$TIPO_CONTRATO","NUMERO_CONTRATO":"$NUMERO_CONTRATO","VALOR":"$VALOR","FECHA_INICIAL":"$FECHA_INICIAL","FECHA_FINAL":"$FECHA_FINAL","MESES":"$MESES(type:integer)","IBC":"$IBC","APORTESVOLUNTARIOS":"$APORTESVOLUNTARIOS","AFC":"$AFC","DEDUCIBLE_VIVIENDA":"$DEDUCIBLE_VIVIENDA","MEDPREPAGADA":"$MEDPREPAGADA","APORTESARL":"$APORTESARL","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="NIT" sqlType="STRING"/>
		<param name="SUCURSAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="tercerosops">
		<call-query href="getTercerosopsPaginaQuery">
			<with-param name="NIT" query-param="NIT"/>
			<with-param name="SUCURSAL" query-param="SUCURSAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>

		</call-query>
	</resource>
	<query id="updateTercerosops" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE TERCERO_OPS SET ANO=:ANO, TIPO_CONTRATO=:TIPO_CONTRATO, NUMERO_CONTRATO=:NUMERO_CONTRATO, VALOR=:VALOR, FECHA_INICIAL=TO_DATE(:FECHA_INICIAL,'DD/MM/YYYY HH24:MI:SS'), FECHA_FINAL=TO_DATE(:FECHA_FINAL,'DD/MM/YYYY HH24:MI:SS'), MESES=:MESES, IBC=:IBC, APORTESVOLUNTARIOS=:APORTESVOLUNTARIOS, AFC=:AFC, DEDUCIBLE_VIVIENDA=:DEDUCIBLE_VIVIENDA, MEDPREPAGADA=:MEDPREPAGADA, APORTESARL=:APORTESARL, DESCRIPCION=:DESCRIPCION, MODIFIED_BY=:MODIFIED_BY, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS') WHERE TERCERO_OPS.COMPANIA= :KEY_COMPANIA AND TERCERO_OPS.NIT= :KEY_NIT AND TERCERO_OPS.SUCURSAL= :KEY_SUCURSAL AND TERCERO_OPS.TIPO_CONTRATO= :KEY_TIPO_CONTRATO AND TERCERO_OPS.NUMERO_CONTRATO= :KEY_NUMERO_CONTRATO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="ANO" sqlType="STRING"/>
		<param name="TIPO_CONTRATO" sqlType="STRING"/>
		<param name="NUMERO_CONTRATO" sqlType="STRING"/>
		<param name="VALOR" sqlType="STRING"/>
		<param name="FECHA_INICIAL" sqlType="STRING"/>
		<param name="FECHA_FINAL" sqlType="STRING"/>
		<param name="MESES" sqlType="STRING"/>
		<param name="IBC" sqlType="STRING"/>
		<param name="APORTESVOLUNTARIOS" sqlType="STRING"/>
		<param name="AFC" sqlType="STRING"/>
		<param name="DEDUCIBLE_VIVIENDA" sqlType="STRING"/>
		<param name="MEDPREPAGADA" sqlType="STRING"/>
		<param name="APORTESARL" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NIT" sqlType="STRING"/>
		<param name="KEY_SUCURSAL" sqlType="STRING"/>
		<param name="KEY_TIPO_CONTRATO" sqlType="STRING"/>
		<param name="KEY_NUMERO_CONTRATO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="tercerosops">
		<call-query href="updateTercerosops">
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="TIPO_CONTRATO" query-param="TIPO_CONTRATO"/>
			<with-param name="NUMERO_CONTRATO" query-param="NUMERO_CONTRATO"/>
			<with-param name="VALOR" query-param="VALOR"/>
			<with-param name="FECHA_INICIAL" query-param="FECHA_INICIAL"/>
			<with-param name="FECHA_FINAL" query-param="FECHA_FINAL"/>
			<with-param name="MESES" query-param="MESES"/>
			<with-param name="IBC" query-param="IBC"/>
			<with-param name="APORTESVOLUNTARIOS" query-param="APORTESVOLUNTARIOS"/>
			<with-param name="AFC" query-param="AFC"/>
			<with-param name="DEDUCIBLE_VIVIENDA" query-param="DEDUCIBLE_VIVIENDA"/>
			<with-param name="MEDPREPAGADA" query-param="MEDPREPAGADA"/>
			<with-param name="APORTESARL" query-param="APORTESARL"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NIT" query-param="KEY_NIT"/>
			<with-param name="KEY_SUCURSAL" query-param="KEY_SUCURSAL"/>
			<with-param name="KEY_TIPO_CONTRATO" query-param="KEY_TIPO_CONTRATO"/>
			<with-param name="KEY_NUMERO_CONTRATO" query-param="KEY_NUMERO_CONTRATO"/>

		</call-query>
	</resource>

</data>