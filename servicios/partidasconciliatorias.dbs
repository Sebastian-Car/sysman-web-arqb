<data name="partidasconciliatorias" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPartidasconciliatoriasTodosporanomespartidaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, ANO, CUENTA, PARTIDA_DEBITO, PARTIDA_CREDITO, OBSERVACIONES,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA FROM PARTIDAS_CONCILIATORIAS WHERE MES_PARTIDA = :MES AND COMPANIA = :COMPANIA AND ANO = :ANO AND CUENTA = :CODCUENTA AND (COMPANIA, ANO, CUENTA, PARTIDA_DEBITO, PARTIDA_CREDITO, OBSERVACIONES, FECHA) NOT IN ( SELECT COMPANIA, ANO, CUENTA, PARTIDA_DEBITO, PARTIDA_CREDITO, OBSERVACIONES, FECHA FROM PARTIDAS_CONCILIATORIAS WHERE MES_PARTIDA = :MES_D AND COMPANIA = :COMPANIA AND ANO = :ANO_D AND CUENTA = :CODCUENTA)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","PARTIDA_DEBITO":"$PARTIDA_DEBITO","PARTIDA_CREDITO":"$PARTIDA_CREDITO","OBSERVACIONES":"$OBSERVACIONES","FECHA":"$FECHA"}]}}		</result>
		<param name="MES" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CODCUENTA" sqlType="STRING"/>
		<param name="MES_D" sqlType="STRING"/>
		<param name="ANO_D" sqlType="STRING"/>

	</query>
	<resource method="GET" path="partidasconciliatorias/todosporanomespartida">
		<call-query href="getPartidasconciliatoriasTodosporanomespartidaQuery">
			<with-param name="MES" query-param="MES"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CODCUENTA" query-param="CODCUENTA"/>
			<with-param name="MES_D" query-param="MES_D"/>
			<with-param name="ANO_D" query-param="ANO_D"/>

		</call-query>
	</resource>
	<query id="insertPartidasconciliatoriasTodosporanomespartida" keyColumns="COMPANIA,ANO,CUENTA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PARTIDAS_CONCILIATORIAS (COMPANIA, ANO, CUENTA, CONSECUTIVO, PARTIDA_DEBITO, PARTIDA_CREDITO, OBSERVACIONES, MES_PARTIDA, CREATED_BY, FECHA, DATE_CREATED) VALUES (:COMPANIA, :ANO, :CUENTA, :CONSECUTIVO, :PARTIDA_DEBITO, :PARTIDA_CREDITO, :OBSERVACIONES, :MES_PARTIDA, :CREATED_BY, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CUENTA":"$CUENTA","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="0" name="PARTIDA_DEBITO" sqlType="STRING"/>
		<param defaultValue="0" name="PARTIDA_CREDITO" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param name="MES_PARTIDA" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>

	</query>
	<resource method="POST" path="partidasconciliatorias/todosporanomespartida">
		<call-query href="insertPartidasconciliatoriasTodosporanomespartida">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="PARTIDA_DEBITO" query-param="PARTIDA_DEBITO"/>
			<with-param name="PARTIDA_CREDITO" query-param="PARTIDA_CREDITO"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="MES_PARTIDA" query-param="MES_PARTIDA"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>

		</call-query>
	</resource>
	<query id="insertPartidasconciliatorias" keyColumns="COMPANIA,ANO,CUENTA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PARTIDAS_CONCILIATORIAS (COMPANIA, ANO, CUENTA, CONSECUTIVO, FECHA, OBSERVACIONES, PARTIDA_DEBITO, PARTIDA_CREDITO, MES_PARTIDA, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :ANO, :CUENTA, :CONSECUTIVO, TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), :OBSERVACIONES, :PARTIDA_DEBITO, :PARTIDA_CREDITO, :MES_PARTIDA, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_ANO":"$ANO(type:integer)","KEY_CUENTA":"$CUENTA","KEY_CONSECUTIVO":"$CONSECUTIVO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="CUENTA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param defaultValue="" name="FECHA" sqlType="STRING"/>
		<param defaultValue="" name="OBSERVACIONES" sqlType="STRING"/>
		<param defaultValue="0" name="PARTIDA_DEBITO" sqlType="STRING"/>
		<param defaultValue="0" name="PARTIDA_CREDITO" sqlType="STRING"/>
		<param name="MES_PARTIDA" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="partidasconciliatorias">
		<call-query href="insertPartidasconciliatorias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="CUENTA" query-param="CUENTA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PARTIDA_DEBITO" query-param="PARTIDA_DEBITO"/>
			<with-param name="PARTIDA_CREDITO" query-param="PARTIDA_CREDITO"/>
			<with-param name="MES_PARTIDA" query-param="MES_PARTIDA"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deletePartidasconciliatorias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PARTIDAS_CONCILIATORIAS WHERE PARTIDAS_CONCILIATORIAS.COMPANIA= :KEY_COMPANIA AND PARTIDAS_CONCILIATORIAS.ANO= :KEY_ANO AND PARTIDAS_CONCILIATORIAS.CUENTA= :KEY_CUENTA AND PARTIDAS_CONCILIATORIAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="INTEGER"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="INTEGER"/>

	</query>
	<resource method="DELETE" path="partidasconciliatorias">
		<call-query href="deletePartidasconciliatorias">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getPartidasconciliatoriasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, ANO, CUENTA, CONSECUTIVO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, OBSERVACIONES, PARTIDA_DEBITO, PARTIDA_CREDITO, MES_PARTIDA  FROM PARTIDAS_CONCILIATORIAS WHERE COMPANIA =:COMPANIA AND ANO = :ANO AND MES_PARTIDA = :MES AND CUENTA = :CODIGOCUENTA) WHERE (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN PARTIDA_DEBITO IS NULL THEN ' ' ELSE UPPER(PARTIDA_DEBITO) END)  LIKE UPPER( '%' || :PARTIDA_DEBITO || '%')  AND (CASE WHEN PARTIDA_CREDITO IS NULL THEN ' ' ELSE UPPER(PARTIDA_CREDITO) END)  LIKE UPPER( '%' || :PARTIDA_CREDITO || '%')  AND (CASE WHEN MES_PARTIDA IS NULL THEN ' ' ELSE UPPER(MES_PARTIDA) END)  LIKE UPPER(:MES_PARTIDA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANO":"$ANO(type:integer)","CUENTA":"$CUENTA","CONSECUTIVO":"$CONSECUTIVO(type:integer)","FECHA":"$FECHA","OBSERVACIONES":"$OBSERVACIONES","PARTIDA_DEBITO":"$PARTIDA_DEBITO","PARTIDA_CREDITO":"$PARTIDA_CREDITO","MES_PARTIDA":"$MES_PARTIDA(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CODIGOCUENTA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PARTIDA_DEBITO" sqlType="STRING"/>
		<param name="PARTIDA_CREDITO" sqlType="STRING"/>
		<param name="MES_PARTIDA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="partidasconciliatorias">
		<call-query href="getPartidasconciliatoriasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CODIGOCUENTA" query-param="CODIGOCUENTA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PARTIDA_DEBITO" query-param="PARTIDA_DEBITO"/>
			<with-param name="PARTIDA_CREDITO" query-param="PARTIDA_CREDITO"/>
			<with-param name="MES_PARTIDA" query-param="MES_PARTIDA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getPartidasconciliatoriasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, ANO, CUENTA, CONSECUTIVO,(TO_CHAR(FECHA,'DD/MM/YYYY HH24:MI:SS')) FECHA, OBSERVACIONES, PARTIDA_DEBITO, PARTIDA_CREDITO, MES_PARTIDA  FROM PARTIDAS_CONCILIATORIAS WHERE COMPANIA =:COMPANIA AND ANO = :ANO AND MES_PARTIDA = :MES AND CUENTA = :CODIGOCUENTA) WHERE (CASE WHEN FECHA IS NULL THEN ' ' ELSE UPPER(FECHA) END)  LIKE UPPER( '%' || :FECHA || '%')  AND (CASE WHEN OBSERVACIONES IS NULL THEN ' ' ELSE UPPER(OBSERVACIONES) END)  LIKE UPPER( '%' || :OBSERVACIONES || '%')  AND (CASE WHEN PARTIDA_DEBITO IS NULL THEN ' ' ELSE UPPER(PARTIDA_DEBITO) END)  LIKE UPPER( '%' || :PARTIDA_DEBITO || '%')  AND (CASE WHEN PARTIDA_CREDITO IS NULL THEN ' ' ELSE UPPER(PARTIDA_CREDITO) END)  LIKE UPPER( '%' || :PARTIDA_CREDITO || '%')  AND (CASE WHEN MES_PARTIDA IS NULL THEN ' ' ELSE UPPER(MES_PARTIDA) END)  LIKE UPPER( '%' || :MES_PARTIDA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANO" sqlType="STRING"/>
		<param name="MES" sqlType="STRING"/>
		<param name="CODIGOCUENTA" sqlType="STRING"/>
		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PARTIDA_DEBITO" sqlType="STRING"/>
		<param name="PARTIDA_CREDITO" sqlType="STRING"/>
		<param name="MES_PARTIDA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="partidasconciliatorias/numero">
		<call-query href="getPartidasconciliatoriasNumeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANO" query-param="ANO"/>
			<with-param name="MES" query-param="MES"/>
			<with-param name="CODIGOCUENTA" query-param="CODIGOCUENTA"/>
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PARTIDA_DEBITO" query-param="PARTIDA_DEBITO"/>
			<with-param name="PARTIDA_CREDITO" query-param="PARTIDA_CREDITO"/>
			<with-param name="MES_PARTIDA" query-param="MES_PARTIDA"/>

		</call-query>
	</resource>
	<query id="updatePartidasconciliatorias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PARTIDAS_CONCILIATORIAS SET FECHA=TO_DATE(:FECHA,'DD/MM/YYYY HH24:MI:SS'), OBSERVACIONES=:OBSERVACIONES, PARTIDA_DEBITO=:PARTIDA_DEBITO, PARTIDA_CREDITO=:PARTIDA_CREDITO, MES_PARTIDA=:MES_PARTIDA, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PARTIDAS_CONCILIATORIAS.COMPANIA= :KEY_COMPANIA AND PARTIDAS_CONCILIATORIAS.ANO= :KEY_ANO AND PARTIDAS_CONCILIATORIAS.CUENTA= :KEY_CUENTA AND PARTIDAS_CONCILIATORIAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="FECHA" sqlType="STRING"/>
		<param name="OBSERVACIONES" sqlType="STRING"/>
		<param name="PARTIDA_DEBITO" sqlType="STRING"/>
		<param name="PARTIDA_CREDITO" sqlType="STRING"/>
		<param name="MES_PARTIDA" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_ANO" sqlType="STRING"/>
		<param name="KEY_CUENTA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="partidasconciliatorias">
		<call-query href="updatePartidasconciliatorias">
			<with-param name="FECHA" query-param="FECHA"/>
			<with-param name="OBSERVACIONES" query-param="OBSERVACIONES"/>
			<with-param name="PARTIDA_DEBITO" query-param="PARTIDA_DEBITO"/>
			<with-param name="PARTIDA_CREDITO" query-param="PARTIDA_CREDITO"/>
			<with-param name="MES_PARTIDA" query-param="MES_PARTIDA"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_ANO" query-param="KEY_ANO"/>
			<with-param name="KEY_CUENTA" query-param="KEY_CUENTA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>

</data>