	<query id="getEvcompetenciasRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  EV_COMPETENCIAS.COMPANIA, EV_COMPETENCIAS.CONSECUTIVO, EV_COMPETENCIAS.TIPO_COMPETENCIA, EV_COMPETENCIAS.NUMERO_MANUAL, EV_MANUAL.NOMBRE_MANUAL, EV_COMPETENCIAS.VERSION, EV_TIPO_COMPETENCIAS.NOMBRE NOMBRE_COMPETENCIA, EV_COMPETENCIAS.DESCRIPCION, EV_MANUAL.SIGLA  FROM EV_COMPETENCIAS LEFT JOIN EV_TIPO_COMPETENCIAS ON EV_TIPO_COMPETENCIAS.COMPANIA = EV_COMPETENCIAS.COMPANIA AND EV_TIPO_COMPETENCIAS.CODIGO = EV_COMPETENCIAS.TIPO_COMPETENCIA LEFT JOIN EV_MANUAL ON EV_COMPETENCIAS.COMPANIA = EV_MANUAL.COMPANIA AND EV_COMPETENCIAS.NUMERO_MANUAL =EV_MANUAL.NUMERO_MANUAL AND EV_COMPETENCIAS.VERSION = EV_MANUAL.VERSION WHERE EV_COMPETENCIAS.COMPANIA= :KEY_COMPANIA AND EV_COMPETENCIAS.NUMERO_MANUAL= :KEY_NUMERO_MANUAL AND EV_COMPETENCIAS.VERSION= :KEY_VERSION AND EV_COMPETENCIAS.TIPO_COMPETENCIA= :KEY_TIPO_COMPETENCIA AND EV_COMPETENCIAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","TIPO_COMPETENCIA":"$TIPO_COMPETENCIA","NUMERO_MANUAL":"$NUMERO_MANUAL","NOMBRE_MANUAL":"$NOMBRE_MANUAL","VERSION":"$VERSION","NOMBRE_COMPETENCIA":"$NOMBRE_COMPETENCIA","DESCRIPCION":"$DESCRIPCION","SIGLA":"$SIGLA"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_MANUAL" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcompetencias/data">
		<call-query href="getEvcompetenciasRegistroQuery">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_MANUAL" query-param="KEY_NUMERO_MANUAL"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>
			<with-param name="KEY_TIPO_COMPETENCIA" query-param="KEY_TIPO_COMPETENCIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="updateEvcompetencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE EV_COMPETENCIAS SET COMPANIA=:COMPANIA, NUMERO_MANUAL=:NUMERO_MANUAL, VERSION=:VERSION, TIPO_COMPETENCIA=:TIPO_COMPETENCIA, CONSECUTIVO=:CONSECUTIVO, DESCRIPCION=:DESCRIPCION, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE EV_COMPETENCIAS.COMPANIA= :KEY_COMPANIA AND EV_COMPETENCIAS.NUMERO_MANUAL= :KEY_NUMERO_MANUAL AND EV_COMPETENCIAS.VERSION= :KEY_VERSION AND EV_COMPETENCIAS.TIPO_COMPETENCIA= :KEY_TIPO_COMPETENCIA AND EV_COMPETENCIAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_MANUAL" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="PUT" path="evcompetencias">
		<call-query href="updateEvcompetencias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="TIPO_COMPETENCIA" query-param="TIPO_COMPETENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_MODIFIED" query-param="DATE_MODIFIED"/>
			<with-param name="MODIFIED_BY" query-param="MODIFIED_BY"/>
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_MANUAL" query-param="KEY_NUMERO_MANUAL"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>
			<with-param name="KEY_TIPO_COMPETENCIA" query-param="KEY_TIPO_COMPETENCIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEvcompetenciasNumConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, NUMERO_MANUAL, VERSION, TIPO_COMPETENCIA, CONSECUTIVO, TO_CHAR (DESCRIPCION) DESCRIPCION  FROM EV_COMPETENCIAS WHERE COMPANIA =:COMPANIA ORDER BY CONSECUTIVO ASC) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER( '%' || :VERSION || '%')  AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcompetencias/consecutivo/num">
		<call-query href="getEvcompetenciasNumConsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getEvcompetenciasPagPorManualQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, TIPO_COMPETENCIA, CONSECUTIVO, TO_CHAR (DESCRIPCION) DESCRIPCION  FROM EV_COMPETENCIAS WHERE COMPANIA =:COMPANIA AND NUMERO_MANUAL = :NUMERO_MANUAL AND VERSION = :VERSION ORDER BY CONSECUTIVO ASC) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_COMPETENCIA":"$TIPO_COMPETENCIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
