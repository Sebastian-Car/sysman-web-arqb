	<query id="getEvcompetenciasNumPorManualQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  COMPANIA, TIPO_COMPETENCIA, CONSECUTIVO, TO_CHAR (DESCRIPCION) DESCRIPCION  FROM EV_COMPETENCIAS WHERE COMPANIA =:COMPANIA AND NUMERO_MANUAL = :NUMERO_MANUAL AND VERSION = :VERSION ORDER BY CONSECUTIVO ASC) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
