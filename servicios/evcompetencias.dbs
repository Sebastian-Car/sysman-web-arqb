	<query id="getEvcompetenciasNumLlaveporcompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT COMPANIA, NUMERO_MANUAL, VERSION, TIPO_COMPETENCIA, CONSECUTIVO, CONCAT(TO_CHAR(SUBSTR(DESCRIPCION,0,100) ), '...') DESCRIPCION FROM EV_COMPETENCIAS WHERE COMPANIA =:COMPANIA) INI WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END) LIKE UPPER(CONCAT(:NUMERO_MANUAL, '%')) AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END) LIKE UPPER(CONCAT(:VERSION, '%')) AND (CASE WHEN TIPO_COMPETENCIA IS NULL THEN ' ' ELSE UPPER(TIPO_COMPETENCIA) END) LIKE UPPER(CONCAT(:TIPO_COMPETENCIA, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
