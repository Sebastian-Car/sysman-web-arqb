	<query id="getEvcompetenciasPagCompetenciaconcomportamentalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT ECO.COMPANIA, ECO.NUMERO_MANUAL, ECO.VERSION, ECO.TIPO_COMPETENCIA, ECO.CONSECUTIVO, CONCAT(TO_CHAR(SUBSTR(ECO.DESCRIPCION,0,100) ), '...') DESCRIPCION FROM EV_COMPETENCIAS ECO INNER JOIN EV_COMPETENCIA_COMPORTAMENTALE ECC ON ECO.COMPANIA = ECC.COMPANIA WHERE ECO.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END) LIKE UPPER(CONCAT(:NUMERO_MANUAL, '%')) AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END) LIKE UPPER(CONCAT(:VERSION, '%')) AND (CASE WHEN TIPO_COMPETENCIA IS NULL THEN ' ' ELSE UPPER(TIPO_COMPETENCIA) END) LIKE UPPER(CONCAT(:TIPO_COMPETENCIA, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","NUMERO_MANUAL":"$NUMERO_MANUAL","VERSION":"$VERSION","TIPO_COMPETENCIA":"$TIPO_COMPETENCIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evcompetencias/competenciaconcomportamentales/pag">
		<call-query href="getEvcompetenciasPagCompetenciaconcomportamentalesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="TIPO_COMPETENCIA" query-param="TIPO_COMPETENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvcompetenciasNumCompetenciaconcomportamentalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT ECO.COMPANIA, ECO.NUMERO_MANUAL, ECO.VERSION, ECO.TIPO_COMPETENCIA, ECO.CONSECUTIVO, CONCAT(TO_CHAR(SUBSTR(ECO.DESCRIPCION,0,100) ), '...') DESCRIPCION FROM EV_COMPETENCIAS ECO INNER JOIN EV_COMPETENCIA_COMPORTAMENTALE ECC ON ECO.COMPANIA = ECC.COMPANIA WHERE ECO.COMPANIA =:COMPANIA) INI WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END) LIKE UPPER(CONCAT(:NUMERO_MANUAL, '%')) AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END) LIKE UPPER(CONCAT(:VERSION, '%')) AND (CASE WHEN TIPO_COMPETENCIA IS NULL THEN ' ' ELSE UPPER(TIPO_COMPETENCIA) END) LIKE UPPER(CONCAT(:TIPO_COMPETENCIA, '%')) AND (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END) LIKE UPPER(CONCAT(:CONSECUTIVO, '%')) AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION), '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>

	</query>
	<resource method="GET" path="evcompetencias/competenciaconcomportamentales/num">
		<call-query href="getEvcompetenciasNumCompetenciaconcomportamentalesQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="TIPO_COMPETENCIA" query-param="TIPO_COMPETENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>

		</call-query>
	</resource>
	<query id="getEvcompetenciasPagConsecutivoQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  COMPANIA, TIPO_COMPETENCIA, CONSECUTIVO, TO_CHAR (DESCRIPCION) DESCRIPCION  FROM EV_COMPETENCIAS WHERE COMPANIA =:COMPANIA AND NUMERO_MANUAL = :NUMERO_MANUAL AND VERSION = :VERSION ORDER BY CONSECUTIVO ASC) WHERE (CASE WHEN CONSECUTIVO IS NULL THEN ' ' ELSE UPPER(CONSECUTIVO) END)  LIKE UPPER(:CONSECUTIVO || '%')  AND (CASE WHEN DESCRIPCION IS NULL THEN ' ' ELSE UPPER(DESCRIPCION) END)  LIKE UPPER( '%' || :DESCRIPCION || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO_COMPETENCIA":"$TIPO_COMPETENCIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","DESCRIPCION":"$DESCRIPCION"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evcompetencias/consecutivo/pag">
		<call-query href="getEvcompetenciasPagConsecutivoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="insertEvcompetencias" keyColumns="COMPANIA,NUMERO_MANUAL,VERSION,TIPO_COMPETENCIA,CONSECUTIVO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO EV_COMPETENCIAS (COMPANIA, NUMERO_MANUAL, VERSION, TIPO_COMPETENCIA, CONSECUTIVO, DESCRIPCION, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :NUMERO_MANUAL, :VERSION, :TIPO_COMPETENCIA, :CONSECUTIVO, :DESCRIPCION, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_NUMERO_MANUAL":"$NUMERO_MANUAL","KEY_VERSION":"$VERSION","KEY_TIPO_COMPETENCIA":"$TIPO_COMPETENCIA","KEY_CONSECUTIVO":"$CONSECUTIVO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="CONSECUTIVO" sqlType="STRING"/>
		<param name="DESCRIPCION" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="evcompetencias">
		<call-query href="insertEvcompetencias">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="TIPO_COMPETENCIA" query-param="TIPO_COMPETENCIA"/>
			<with-param name="CONSECUTIVO" query-param="CONSECUTIVO"/>
			<with-param name="DESCRIPCION" query-param="DESCRIPCION"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="deleteEvcompetencias" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM EV_COMPETENCIAS WHERE EV_COMPETENCIAS.COMPANIA= :KEY_COMPANIA AND EV_COMPETENCIAS.NUMERO_MANUAL= :KEY_NUMERO_MANUAL AND EV_COMPETENCIAS.VERSION= :KEY_VERSION AND EV_COMPETENCIAS.TIPO_COMPETENCIA= :KEY_TIPO_COMPETENCIA AND EV_COMPETENCIAS.CONSECUTIVO= :KEY_CONSECUTIVO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_NUMERO_MANUAL" sqlType="STRING"/>
		<param name="KEY_VERSION" sqlType="STRING"/>
		<param name="KEY_TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="KEY_CONSECUTIVO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="evcompetencias">
		<call-query href="deleteEvcompetencias">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_NUMERO_MANUAL" query-param="KEY_NUMERO_MANUAL"/>
			<with-param name="KEY_VERSION" query-param="KEY_VERSION"/>
			<with-param name="KEY_TIPO_COMPETENCIA" query-param="KEY_TIPO_COMPETENCIA"/>
			<with-param name="KEY_CONSECUTIVO" query-param="KEY_CONSECUTIVO"/>

		</call-query>
	</resource>
	<query id="getEvcompetenciasPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  EV_COMPETENCIAS.COMPANIA, EV_COMPETENCIAS.CONSECUTIVO, EV_COMPETENCIAS.TIPO_COMPETENCIA, EV_COMPETENCIAS.NUMERO_MANUAL, EV_COMPETENCIAS.VERSION, EV_MANUAL.NOMBRE_MANUAL, EV_MANUAL.SIGLA, EV_TIPO_COMPETENCIAS.NOMBRE NOMBRE_TIPO_COMPETENCIA  FROM EV_COMPETENCIAS LEFT JOIN EV_TIPO_COMPETENCIAS ON EV_TIPO_COMPETENCIAS.CODIGO = EV_COMPETENCIAS.TIPO_COMPETENCIA AND EV_TIPO_COMPETENCIAS.COMPANIA = EV_COMPETENCIAS.COMPANIA LEFT JOIN EV_MANUAL ON EV_COMPETENCIAS.COMPANIA = EV_MANUAL.COMPANIA AND EV_COMPETENCIAS.NUMERO_MANUAL =EV_MANUAL.NUMERO_MANUAL AND EV_COMPETENCIAS.VERSION = EV_MANUAL.VERSION WHERE EV_COMPETENCIAS.COMPANIA = :COMPANIA AND EV_COMPETENCIAS.NUMERO_MANUAL = (CASE WHEN (:NUM_MANUAL) = '0' THEN EV_COMPETENCIAS.NUMERO_MANUAL ELSE (:NUM_MANUAL) END)) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER( '%' || :VERSION || '%')  AND (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END)  LIKE UPPER(:NOMBRE_MANUAL || '%')  AND (CASE WHEN SIGLA IS NULL THEN ' ' ELSE UPPER(SIGLA) END)  LIKE UPPER( '%' || :SIGLA || '%')  AND (CASE WHEN NOMBRE_TIPO_COMPETENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO_COMPETENCIA) END)  LIKE UPPER( '%' || :NOMBRE_TIPO_COMPETENCIA || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CONSECUTIVO":"$CONSECUTIVO(type:long)","TIPO_COMPETENCIA":"$TIPO_COMPETENCIA","NUMERO_MANUAL":"$NUMERO_MANUAL","VERSION":"$VERSION","NOMBRE_MANUAL":"$NOMBRE_MANUAL","SIGLA":"$SIGLA","NOMBRE_TIPO_COMPETENCIA":"$NOMBRE_TIPO_COMPETENCIA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUM_MANUAL" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="NOMBRE_MANUAL" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="NOMBRE_TIPO_COMPETENCIA" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="evcompetencias">
		<call-query href="getEvcompetenciasPaginaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUM_MANUAL" query-param="NUM_MANUAL"/>
			<with-param name="NUMERO_MANUAL" query-param="NUMERO_MANUAL"/>
			<with-param name="VERSION" query-param="VERSION"/>
			<with-param name="NOMBRE_MANUAL" query-param="NOMBRE_MANUAL"/>
			<with-param name="SIGLA" query-param="SIGLA"/>
			<with-param name="NOMBRE_TIPO_COMPETENCIA" query-param="NOMBRE_TIPO_COMPETENCIA"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getEvcompetenciasNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  EV_COMPETENCIAS.COMPANIA, EV_COMPETENCIAS.CONSECUTIVO, EV_COMPETENCIAS.TIPO_COMPETENCIA, EV_COMPETENCIAS.NUMERO_MANUAL, EV_COMPETENCIAS.VERSION, EV_MANUAL.NOMBRE_MANUAL, EV_MANUAL.SIGLA, EV_TIPO_COMPETENCIAS.NOMBRE NOMBRE_TIPO_COMPETENCIA  FROM EV_COMPETENCIAS LEFT JOIN EV_TIPO_COMPETENCIAS ON EV_TIPO_COMPETENCIAS.CODIGO = EV_COMPETENCIAS.TIPO_COMPETENCIA AND EV_TIPO_COMPETENCIAS.COMPANIA = EV_COMPETENCIAS.COMPANIA LEFT JOIN EV_MANUAL ON EV_COMPETENCIAS.COMPANIA = EV_MANUAL.COMPANIA AND EV_COMPETENCIAS.NUMERO_MANUAL =EV_MANUAL.NUMERO_MANUAL AND EV_COMPETENCIAS.VERSION = EV_MANUAL.VERSION WHERE EV_COMPETENCIAS.COMPANIA = :COMPANIA AND EV_COMPETENCIAS.NUMERO_MANUAL = (CASE WHEN (:NUM_MANUAL) = '0' THEN EV_COMPETENCIAS.NUMERO_MANUAL ELSE (:NUM_MANUAL) END)) WHERE (CASE WHEN NUMERO_MANUAL IS NULL THEN ' ' ELSE UPPER(NUMERO_MANUAL) END)  LIKE UPPER(:NUMERO_MANUAL || '%')  AND (CASE WHEN VERSION IS NULL THEN ' ' ELSE UPPER(VERSION) END)  LIKE UPPER( '%' || :VERSION || '%')  AND (CASE WHEN NOMBRE_MANUAL IS NULL THEN ' ' ELSE UPPER(NOMBRE_MANUAL) END)  LIKE UPPER(:NOMBRE_MANUAL || '%')  AND (CASE WHEN SIGLA IS NULL THEN ' ' ELSE UPPER(SIGLA) END)  LIKE UPPER( '%' || :SIGLA || '%')  AND (CASE WHEN NOMBRE_TIPO_COMPETENCIA IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPO_COMPETENCIA) END)  LIKE UPPER( '%' || :NOMBRE_TIPO_COMPETENCIA || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUM_MANUAL" sqlType="STRING"/>
		<param name="NUMERO_MANUAL" sqlType="STRING"/>
		<param name="VERSION" sqlType="STRING"/>
		<param name="NOMBRE_MANUAL" sqlType="STRING"/>
		<param name="SIGLA" sqlType="STRING"/>
		<param name="NOMBRE_TIPO_COMPETENCIA" sqlType="STRING"/>

	</query>
