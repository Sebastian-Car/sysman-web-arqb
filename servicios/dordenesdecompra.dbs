	<query id="getDordenesdecompraPagPorElementoYNombreCortoFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  DISTINCT D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRECORTO  FROM D_ORDENDECOMPRA INNER JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA = INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.ELEMENTO &gt;= :CODELEMENTO ORDER BY D_ORDENDECOMPRA.ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END)  LIKE UPPER( '%' || :NOMBRECORTO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTO":"$ELEMENTO","NOMBRECORTO":"$NOMBRECORTO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CODELEMENTO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRECORTO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
