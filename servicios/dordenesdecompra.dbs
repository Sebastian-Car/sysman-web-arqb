	<query id="getDordenesdecompraPagItemsContratoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_ORDENDECOMPRA.COMPANIA, D_ORDENDECOMPRA.CLASEORDEN, D_ORDENDECOMPRA.ORDENDECOMPRA, D_ORDENDECOMPRA.CODIGO, D_ORDENDECOMPRA.ORDENDESUMINISTRO, D_ORDENDECOMPRA.ELEMENTO, D_ORDENDECOMPRA.CANTIDAD, D_ORDENDECOMPRA.VALORUNITARIO, D_ORDENDECOMPRA.VLRTOTAL, D_ORDENDECOMPRA.VALORUNITARIODI  FROM D_ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDENINI AND ORDENDECOMPRA = :ORDENDECOMPRAINI) WHERE (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END)  LIKE UPPER(:CLASEORDEN || '%')  AND (CASE WHEN ORDENDECOMPRA IS NULL THEN ' ' ELSE UPPER(ORDENDECOMPRA) END)  LIKE UPPER(:ORDENDECOMPRA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ORDENDESUMINISTRO IS NULL THEN ' ' ELSE UPPER(ORDENDESUMINISTRO) END)  LIKE UPPER(:ORDENDESUMINISTRO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER(:CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END)  LIKE UPPER(:VLRTOTAL || '%')  AND (CASE WHEN VALORUNITARIODI IS NULL THEN ' ' ELSE UPPER(VALORUNITARIODI) END)  LIKE UPPER(:VALORUNITARIODI || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA","CODIGO":"$CODIGO","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO","ELEMENTO":"$ELEMENTO","CANTIDAD":"$CANTIDAD","VALORUNITARIO":"$VALORUNITARIO","VLRTOTAL":"$VLRTOTAL","VALORUNITARIODI":"$VALORUNITARIODI"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDENINI" sqlType="STRING"/>
		<param name="ORDENDECOMPRAINI" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ORDENDESUMINISTRO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="VALORUNITARIODI" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dordenesdecompra/itemscontratoporcompania/pag">
		<call-query href="getDordenesdecompraPagItemsContratoPorCompaniaQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDENINI" query-param="CLASEORDENINI"/>
			<with-param name="ORDENDECOMPRAINI" query-param="ORDENDECOMPRAINI"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ORDENDESUMINISTRO" query-param="ORDENDESUMINISTRO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="VALORUNITARIODI" query-param="VALORUNITARIODI"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraNumItemsContratoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_ORDENDECOMPRA.COMPANIA, D_ORDENDECOMPRA.CLASEORDEN, D_ORDENDECOMPRA.ORDENDECOMPRA, D_ORDENDECOMPRA.CODIGO, D_ORDENDECOMPRA.ORDENDESUMINISTRO, D_ORDENDECOMPRA.ELEMENTO, D_ORDENDECOMPRA.CANTIDAD, D_ORDENDECOMPRA.VALORUNITARIO, D_ORDENDECOMPRA.VLRTOTAL, D_ORDENDECOMPRA.VALORUNITARIODI  FROM D_ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDENINI AND ORDENDECOMPRA = :ORDENDECOMPRAINI) WHERE (CASE WHEN CLASEORDEN IS NULL THEN ' ' ELSE UPPER(CLASEORDEN) END)  LIKE UPPER(:CLASEORDEN || '%')  AND (CASE WHEN ORDENDECOMPRA IS NULL THEN ' ' ELSE UPPER(ORDENDECOMPRA) END)  LIKE UPPER(:ORDENDECOMPRA || '%')  AND (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END)  LIKE UPPER(:CODIGO || '%')  AND (CASE WHEN ORDENDESUMINISTRO IS NULL THEN ' ' ELSE UPPER(ORDENDESUMINISTRO) END)  LIKE UPPER(:ORDENDESUMINISTRO || '%')  AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER( '%' || :ELEMENTO || '%')  AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END)  LIKE UPPER(:CANTIDAD || '%')  AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END)  LIKE UPPER(:VALORUNITARIO || '%')  AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END)  LIKE UPPER(:VLRTOTAL || '%')  AND (CASE WHEN VALORUNITARIODI IS NULL THEN ' ' ELSE UPPER(VALORUNITARIODI) END)  LIKE UPPER(:VALORUNITARIODI || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDENINI" sqlType="STRING"/>
		<param name="ORDENDECOMPRAINI" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ORDENDESUMINISTRO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="VALORUNITARIODI" sqlType="STRING"/>

	</query>
