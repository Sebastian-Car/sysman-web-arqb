	<query id="deleteDordenesdecompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_ORDENDECOMPRA WHERE D_ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND D_ORDENDECOMPRA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dordenesdecompra">
		<call-query href="deleteDordenesdecompra">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_ORDENDECOMPRA" query-param="KEY_ORDENDECOMPRA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>

		</call-query>
	</resource>
<query id="getDordenesdecompraPaginaQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT D_ORDENDECOMPRA.COMPANIA, D_ORDENDECOMPRA.CLASEORDEN, D_ORDENDECOMPRA.CODIGO, D_ORDENDECOMPRA.ELEMENTO, D_ORDENDECOMPRA.CODIGOCUBS, D_ORDENDECOMPRA.ORDENDECOMPRA, D_ORDENDECOMPRA.DEPENDENCIA, D_ORDENDECOMPRA.ESPECIFICACION, D_ORDENDECOMPRA.MARCA, D_ORDENDECOMPRA.CANTIDAD, D_ORDENDECOMPRA.SALDOCANT, D_ORDENDECOMPRA.VALORUNITARIO, D_ORDENDECOMPRA.PORCDESC, D_ORDENDECOMPRA.VLRDESCUENTO, D_ORDENDECOMPRA.PORC_AIU, D_ORDENDECOMPRA.VALOR_AIU, D_ORDENDECOMPRA.PORCIVA, D_ORDENDECOMPRA.VLRIVA, D_ORDENDECOMPRA.VLRTOTAL, INVENTARIO.NOMBRELARGO, D_ORDENDECOMPRA.IMPCONSUMO, D_ORDENDECOMPRA.VALORIMPCONSUMO FROM D_ORDENDECOMPRA INNER JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA = INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA = :NUMEROORDEN AND D_ORDENDECOMPRA.TIPOORIGEN IS NULL) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCUBS), '%')) AND (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:ESPECIFICACION), '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(:MARCA, '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:CANTIDAD), '%')) AND (CASE WHEN SALDOCANT IS NULL THEN ' ' ELSE UPPER(SALDOCANT) END) LIKE UPPER(CONCAT(:SALDOCANT, '%')) AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END) LIKE UPPER(CONCAT(:VALORUNITARIO, '%')) AND (CASE WHEN PORCDESC IS NULL THEN ' ' ELSE UPPER(PORCDESC) END) LIKE UPPER(CONCAT(:PORCDESC, '%')) AND (CASE WHEN VLRDESCUENTO IS NULL THEN ' ' ELSE UPPER(VLRDESCUENTO) END) LIKE UPPER(CONCAT(:VLRDESCUENTO, '%')) AND (CASE WHEN PORC_AIU IS NULL THEN ' ' ELSE UPPER(PORC_AIU) END) LIKE UPPER(CONCAT(:PORC_AIU, '%')) AND (CASE WHEN VALOR_AIU IS NULL THEN ' ' ELSE UPPER(VALOR_AIU) END) LIKE UPPER(CONCAT(:VALOR_AIU, '%')) AND (CASE WHEN PORCIVA IS NULL THEN ' ' ELSE UPPER(PORCIVA) END) LIKE UPPER(CONCAT(:PORCIVA, '%')) AND (CASE WHEN VLRIVA IS NULL THEN ' ' ELSE UPPER(VLRIVA) END) LIKE UPPER(CONCAT(:VLRIVA, '%')) AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END) LIKE UPPER(CONCAT(:VLRTOTAL, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN IMPCONSUMO IS NULL THEN ' ' ELSE UPPER(IMPCONSUMO) END) LIKE UPPER(CONCAT(:IMPCONSUMO, '%')) AND (CASE WHEN VALORIMPCONSUMO IS NULL THEN ' ' ELSE UPPER(VALORIMPCONSUMO) END) LIKE UPPER(CONCAT(:VALORIMPCONSUMO, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","CODIGO":"$CODIGO","ELEMENTO":"$ELEMENTO","CODIGOCUBS":"$CODIGOCUBS","ORDENDECOMPRA":"$ORDENDECOMPRA","DEPENDENCIA":"$DEPENDENCIA","ESPECIFICACION":"$ESPECIFICACION","MARCA":"$MARCA","CANTIDAD":"$CANTIDAD","SALDOCANT":"$SALDOCANT","VALORUNITARIO":"$VALORUNITARIO","PORCDESC":"$PORCDESC","VLRDESCUENTO":"$VLRDESCUENTO","PORC_AIU":"$PORC_AIU","VALOR_AIU":"$VALOR_AIU","PORCIVA":"$PORCIVA","VLRIVA":"$VLRIVA","VLRTOTAL":"$VLRTOTAL","NOMBRELARGO":"$NOMBRELARGO","IMPCONSUMO":"$IMPCONSUMO","VALORIMPCONSUMO":"$VALORIMPCONSUMO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="CODIGOCUBS" sqlType="STRING"/>
		<param name="ESPECIFICACION" sqlType="STRING"/>
		<param name="MARCA" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="SALDOCANT" sqlType="STRING"/>
		<param name="VALORUNITARIO" sqlType="STRING"/>
		<param name="PORCDESC" sqlType="STRING"/>
		<param name="VLRDESCUENTO" sqlType="STRING"/>
		<param name="PORC_AIU" sqlType="STRING"/>
		<param name="VALOR_AIU" sqlType="STRING"/>
		<param name="PORCIVA" sqlType="STRING"/>
		<param name="VLRIVA" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="IMPCONSUMO" sqlType="STRING"/>
		<param name="VALORIMPCONSUMO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
