	<query id="getDordenesdecompraItemsContratoPorCompaniaQuery"  useConfig="sysmandsunist">
		<sql>SELECT  D_ORDENDECOMPRA.COMPANIA, D_ORDENDECOMPRA.CLASEORDEN, D_ORDENDECOMPRA.ORDENDECOMPRA, D_ORDENDECOMPRA.CODIGO, D_ORDENDECOMPRA.ORDENDESUMINISTRO, D_ORDENDECOMPRA.DEPENDENCIA, D_ORDENDECOMPRA.ELEMENTO, D_ORDENDECOMPRA.ESPECIFICACION, D_ORDENDECOMPRA.CENTRODECOSTO, D_ORDENDECOMPRA.CANTIDAD, D_ORDENDECOMPRA.SALDOCANT, D_ORDENDECOMPRA.VALORUNITARIO, D_ORDENDECOMPRA.PORCIVA, D_ORDENDECOMPRA.PORCDESC, D_ORDENDECOMPRA.VLRTOTAL, D_ORDENDECOMPRA.MARCA, D_ORDENDECOMPRA.VALORUNITARIODI, D_ORDENDECOMPRA.VLRIVA, D_ORDENDECOMPRA.VLRDESCUENTO, D_ORDENDECOMPRA.ANOPPTO, D_ORDENDECOMPRA.TIPOPPTO, D_ORDENDECOMPRA.NUMEROPPTO, D_ORDENDECOMPRA.CONSECUTIVOPPTO, D_ORDENDECOMPRA.RUBROPPTO, D_ORDENDECOMPRA.VALORPPTO, D_ORDENDECOMPRA.BIENSERVICIO, D_ORDENDECOMPRA.ITEMORIGEN, D_ORDENDECOMPRA.ADMINISTRACION, D_ORDENDECOMPRA.UTILIDAD, D_ORDENDECOMPRA.IMPREVISTOS, D_ORDENDECOMPRA.PAGOTERCEROS, D_ORDENDECOMPRA.CREATED_BY,(TO_CHAR(D_ORDENDECOMPRA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED, D_ORDENDECOMPRA.MODIFIED_BY,(TO_CHAR(D_ORDENDECOMPRA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED FROM D_ORDENDECOMPRA WHERE COMPANIA = :KEY_COMPANIA AND CLASEORDEN = :KEY_CLASEORDEN AND ORDENDECOMPRA = :KEY_ORDENDECOMPRA AND CODIGO = :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA","CODIGO":"$CODIGO","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO","DEPENDENCIA":"$DEPENDENCIA","ELEMENTO":"$ELEMENTO","ESPECIFICACION":"$ESPECIFICACION","CENTRODECOSTO":"$CENTRODECOSTO","CANTIDAD":"$CANTIDAD","SALDOCANT":"$SALDOCANT","VALORUNITARIO":"$VALORUNITARIO","PORCIVA":"$PORCIVA","PORCDESC":"$PORCDESC","VLRTOTAL":"$VLRTOTAL","MARCA":"$MARCA","VALORUNITARIODI":"$VALORUNITARIODI","VLRIVA":"$VLRIVA","VLRDESCUENTO":"$VLRDESCUENTO","ANOPPTO":"$ANOPPTO(type:integer)","TIPOPPTO":"$TIPOPPTO","NUMEROPPTO":"$NUMEROPPTO","CONSECUTIVOPPTO":"$CONSECUTIVOPPTO(type:integer)","RUBROPPTO":"$RUBROPPTO","VALORPPTO":"$VALORPPTO","BIENSERVICIO":"$BIENSERVICIO","ITEMORIGEN":"$ITEMORIGEN","ADMINISTRACION":"$ADMINISTRACION","UTILIDAD":"$UTILIDAD","IMPREVISTOS":"$IMPREVISTOS","PAGOTERCEROS":"$PAGOTERCEROS","CREATED_BY":"$CREATED_BY","DATE_CREATED":"$DATE_CREATED","MODIFIED_BY":"$MODIFIED_BY","DATE_MODIFIED":"$DATE_MODIFIED"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
