	<query id="getDordenesdecompraOrigenesQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL(NUMEROORIGEN,' ') NUMEROO, NVL(TIPOORIGEN,' ') TIPOO, NVL(ITEMORIGEN,' ') ITEMO  FROM D_ORDENDECOMPRA WHERE COMPANIA= :COMPANIA AND CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA = :NUMEROORDEN AND CODIGO= :CODIGO AND TIPOORIGEN IS NOT NULL</sql>
		<result outputType="json">{"elementos":{"elemento":[{"NUMEROO":"$NUMEROO(type:integer)","TIPOO":"$TIPOO","ITEMO":"$ITEMO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
