	<query id="getDordenesdecompraNumeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT D_ORDENDECOMPRA.COMPANIA, D_ORDENDECOMPRA.CLASEORDEN, D_ORDENDECOMPRA.CODIGO, D_ORDENDECOMPRA.ELEMENTO, D_ORDENDECOMPRA.CODIGOCUBS, D_ORDENDECOMPRA.ORDENDECOMPRA, D_ORDENDECOMPRA.DEPENDENCIA, D_ORDENDECOMPRA.ESPECIFICACION, D_ORDENDECOMPRA.MARCA, D_ORDENDECOMPRA.CANTIDAD, D_ORDENDECOMPRA.SALDOCANT, D_ORDENDECOMPRA.VALORUNITARIO, D_ORDENDECOMPRA.PORCDESC, D_ORDENDECOMPRA.VLRDESCUENTO, D_ORDENDECOMPRA.PORC_AIU, D_ORDENDECOMPRA.VALOR_AIU, D_ORDENDECOMPRA.PORCIVA, D_ORDENDECOMPRA.VLRIVA, D_ORDENDECOMPRA.VLRTOTAL, INVENTARIO.NOMBRELARGO, D_ORDENDECOMPRA.IMPCONSUMO, D_ORDENDECOMPRA.VALORIMPCONSUMO FROM D_ORDENDECOMPRA INNER JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA = INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA = :NUMEROORDEN AND D_ORDENDECOMPRA.TIPOORIGEN IS NULL) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(CONCAT('%',:ELEMENTO), '%')) AND (CASE WHEN CODIGOCUBS IS NULL THEN ' ' ELSE UPPER(CODIGOCUBS) END) LIKE UPPER(CONCAT(CONCAT('%',:CODIGOCUBS), '%')) AND (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:ESPECIFICACION), '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(:MARCA, '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:CANTIDAD), '%')) AND (CASE WHEN SALDOCANT IS NULL THEN ' ' ELSE UPPER(SALDOCANT) END) LIKE UPPER(CONCAT(:SALDOCANT, '%')) AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END) LIKE UPPER(CONCAT(:VALORUNITARIO, '%')) AND (CASE WHEN PORCDESC IS NULL THEN ' ' ELSE UPPER(PORCDESC) END) LIKE UPPER(CONCAT(:PORCDESC, '%')) AND (CASE WHEN VLRDESCUENTO IS NULL THEN ' ' ELSE UPPER(VLRDESCUENTO) END) LIKE UPPER(CONCAT(:VLRDESCUENTO, '%')) AND (CASE WHEN PORC_AIU IS NULL THEN ' ' ELSE UPPER(PORC_AIU) END) LIKE UPPER(CONCAT(:PORC_AIU, '%')) AND (CASE WHEN VALOR_AIU IS NULL THEN ' ' ELSE UPPER(VALOR_AIU) END) LIKE UPPER(CONCAT(:VALOR_AIU, '%')) AND (CASE WHEN PORCIVA IS NULL THEN ' ' ELSE UPPER(PORCIVA) END) LIKE UPPER(CONCAT(:PORCIVA, '%')) AND (CASE WHEN VLRIVA IS NULL THEN ' ' ELSE UPPER(VLRIVA) END) LIKE UPPER(CONCAT(:VLRIVA, '%')) AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END) LIKE UPPER(CONCAT(:VLRTOTAL, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN IMPCONSUMO IS NULL THEN ' ' ELSE UPPER(IMPCONSUMO) END) LIKE UPPER(CONCAT(:IMPCONSUMO, '%')) AND (CASE WHEN VALORIMPCONSUMO IS NULL THEN ' ' ELSE UPPER(VALORIMPCONSUMO) END) LIKE UPPER(CONCAT(:VALORIMPCONSUMO, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
