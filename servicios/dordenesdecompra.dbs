	<query id="getDordenesdecompraRegistroQuery"  useConfig="sysmandsunist">
		<sql>SELECT D_ORDENDECOMPRA.COMPANIA, D_ORDENDECOMPRA.ANOPPTO, D_ORDENDECOMPRA.CLASEORDEN, D_ORDENDECOMPRA.ORDENDECOMPRA, D_ORDENDECOMPRA.CODIGO, D_ORDENDECOMPRA.CODIGOCUBS, D_ORDENDECOMPRA.ORDENDESUMINISTRO, D_ORDENDECOMPRA.DEPENDENCIA, D_ORDENDECOMPRA.ELEMENTO, D_ORDENDECOMPRA.ESPECIFICACION, D_ORDENDECOMPRA.CENTRODECOSTO, D_ORDENDECOMPRA.CANTIDAD, D_ORDENDECOMPRA.SALDOCANT, D_ORDENDECOMPRA.VALORUNITARIO, D_ORDENDECOMPRA.PORCIVA, D_ORDENDECOMPRA.PORCDESC, D_ORDENDECOMPRA.VLRTOTAL, D_ORDENDECOMPRA.MARCA, D_ORDENDECOMPRA.VLRIVA, D_ORDENDECOMPRA.VLRDESCUENTO, D_ORDENDECOMPRA.CUATROXMIL, D_ORDENDECOMPRA.IMPREVISTOS, D_ORDENDECOMPRA.REGISTRO, D_ORDENDECOMPRA.TIPO_REGISTRO, D_ORDENDECOMPRA.RUBROPPTO, D_ORDENDECOMPRA.TIPOPPTO, D_ORDENDECOMPRA.VALORPPTO, D_ORDENDECOMPRA.NUMEROPPTO, D_ORDENDECOMPRA.CONSECUTIVOPPTO, D_ORDENDECOMPRA.PAGOTERCEROS, D_ORDENDECOMPRA.VALORUNITARIODI, D_ORDENDECOMPRA.ITEMORIGEN,(TO_CHAR(D_ORDENDECOMPRA.DATE_CREATED,'DD/MM/YYYY HH24:MI:SS')) DATE_CREATED,(TO_CHAR(D_ORDENDECOMPRA.DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS')) DATE_MODIFIED, D_ORDENDECOMPRA.MODIFIED_BY, D_ORDENDECOMPRA.CREATED_BY, INVENTARIO.NOMBRELARGO, D_ORDENDECOMPRA.IMPCONSUMO, D_ORDENDECOMPRA.VALORIMPCONSUMO,D_ORDENDECOMPRA.REFERENCIA,D_ORDENDECOMPRA.UNIDAD,D_ORDENDECOMPRA.LOTE,D_ORDENDECOMPRA.TEMPERATURA,(TO_CHAR(D_ORDENDECOMPRA.FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO,D_ORDENDECOMPRA.REGISTRO_SANITARIO,(CASE INVENTARIO.PIDE_VENCIMIENTO WHEN 0 THEN 'false' ELSE 'true' END) PIDE_VENCIMIENTO,D_ORDENDECOMPRA.NIIF_VIDA_UTIL, D_ORDENDECOMPRA.PORC_AIU, D_ORDENDECOMPRA.VALOR_AIU FROM D_ORDENDECOMPRA INNER JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA = INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND D_ORDENDECOMPRA.CODIGO= :KEY_CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","ANOPPTO":"$ANOPPTO(type:integer)","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA","CODIGO":"$CODIGO","CODIGOCUBS":"$CODIGOCUBS","ORDENDESUMINISTRO":"$ORDENDESUMINISTRO","DEPENDENCIA":"$DEPENDENCIA","ELEMENTO":"$ELEMENTO","ESPECIFICACION":"$ESPECIFICACION","CENTRODECOSTO":"$CENTRODECOSTO","CANTIDAD":"$CANTIDAD","SALDOCANT":"$SALDOCANT","VALORUNITARIO":"$VALORUNITARIO","PORCIVA":"$PORCIVA","PORCDESC":"$PORCDESC","VLRTOTAL":"$VLRTOTAL","MARCA":"$MARCA","VLRIVA":"$VLRIVA","VLRDESCUENTO":"$VLRDESCUENTO","CUATROXMIL":"$CUATROXMIL","IMPREVISTOS":"$IMPREVISTOS","REGISTRO":"$REGISTRO","TIPO_REGISTRO":"$TIPO_REGISTRO","RUBROPPTO":"$RUBROPPTO","TIPOPPTO":"$TIPOPPTO","VALORPPTO":"$VALORPPTO","NUMEROPPTO":"$NUMEROPPTO","CONSECUTIVOPPTO":"$CONSECUTIVOPPTO(type:integer)","PAGOTERCEROS":"$PAGOTERCEROS","VALORUNITARIODI":"$VALORUNITARIODI","ITEMORIGEN":"$ITEMORIGEN","DATE_CREATED":"$DATE_CREATED","DATE_MODIFIED":"$DATE_MODIFIED","MODIFIED_BY":"$MODIFIED_BY","CREATED_BY":"$CREATED_BY","NOMBRELARGO":"$NOMBRELARGO","IMPCONSUMO":"$IMPCONSUMO","VALORIMPCONSUMO":"$VALORIMPCONSUMO","REFERENCIA":"$REFERENCIA","UNIDAD":"$UNIDAD","LOTE":"$LOTE","TEMPERATURA":"$TEMPERATURA","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","REGISTRO_SANITARIO":"$REGISTRO_SANITARIO","PIDE_VENCIMIENTO":"$PIDE_VENCIMIENTO(type:boolean)","NIIF_VIDA_UTIL":"$NIIF_VIDA_UTIL","PORC_AIU":"$PORC_AIU","VALOR_AIU":"$VALOR_AIU"}]}}		</result>
		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/data">
