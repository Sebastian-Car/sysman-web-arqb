	<query id="updateDordenesdecompraDetalleOrdenInventarioInicial" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_ORDENDECOMPRA SET ELEMENTO          = :ELEMENTO,   SERIE               = :SERIE,   MARCA               = :MARCA,   ESPECIFICACION      = :ESPECIFICACION,   SERIEDEVOLUTIVO     = :SERIEDEVOLUTIVO,   CANTIDAD            = :CANTIDAD,   SALDOCANT           = :SALDOCANT,   VALORUNITARIO       = :VALORUNITARIO,   VLRTOTAL            = :VLRTOTAL,   FECHAADQUISICION    = :FECHAADQUISICION,   FECHASALIDASERVICIO = :FECHASALIDASERVICIO,   FECHABODEGA         = :FECHABODEGA,   ESTADO              = :ESTADO,   APLICA_NIIF         = :APLICA_NIIF,    NIIF_TIPO_ACTIVO    = :NIIF_TIPO_ACTIVO,    NIIF_VIDA_UTIL      = :NIIF_VIDA_UTIL,   MODIFIED_BY         = :MODIFIED_BY,   DATE_MODIFIED       = :DATE_MODIFIED WHERE COMPANIA        = :KEY_COMPANIA AND CLASEORDEN        = :KEY_CLASEORDEN AND ORDENDECOMPRA     = :KEY_ORDENDECOMPRA AND CODIGO            = :KEY_CODIGO</sql>
