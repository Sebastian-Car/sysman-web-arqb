		<sql>INSERT INTO D_ORDENDECOMPRA (COMPANIA, CLASEORDEN, ORDENDECOMPRA, CODIGO, ORDENDESUMINISTRO, DEPENDENCIA, ELEMENTO, ESPECIFICACION, CENTRODECOSTO, CANTIDAD, SALDOCANT, VALORUNITARIO, PORCIVA, PORCDESC, VLRTOTAL, MARCA, VALORUNITARIODI, VLRIVA, VLRDESCUENTO, ANOPPTO, TIPOPPTO, NUMEROPPTO, CONSECUTIVOPPTO, RUBROPPTO, VALORPPTO, BIENSERVICIO, ITEMORIGEN, ADMINISTRACION, UTILIDAD, IMPREVISTOS, PAGOTERCEROS, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN, :ORDENDECOMPRA, :CODIGO, :ORDENDESUMINISTRO, :DEPENDENCIA, :ELEMENTO, :ESPECIFICACION, :CENTRODECOSTO, :CANTIDAD, :SALDOCANT, :VALORUNITARIO, :PORCIVA, :PORCDESC, :VLRTOTAL, :MARCA, :VALORUNITARIODI, :VLRIVA, :VLRDESCUENTO, :ANOPPTO, :TIPOPPTO, :NUMEROPPTO, :CONSECUTIVOPPTO, :RUBROPPTO, :VALORPPTO, :BIENSERVICIO, :ITEMORIGEN, :ADMINISTRACION, :UTILIDAD, :IMPREVISTOS, :PAGOTERCEROS, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
