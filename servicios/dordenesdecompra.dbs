	<query id="updateDordenesdecompraValorYCantidad" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_ORDENDECOMPRA SET VALORUNITARIO = :VALOR,   CANTIDAD        = :CANTIDAD,   VLRIVA          = :VLRIVA,   VLRDESCUENTO    = :VLRDESCUENTO,   VLRTOTAL        = :VLRTOTAL,   CUATROXMIL      = :CUATROXMIL,    DATE_MODIFIED   =TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'),   MODIFIED_BY     =:MODIFIED_BY WHERE COMPANIA    = :COMPANIA AND ORDENDECOMPRA = :NUMERO AND CLASEORDEN    = :CLASEORDEN AND CODIGO        = :CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="VALOR" sqlType="STRING"/>
		<param name="CANTIDAD" sqlType="STRING"/>
		<param name="VLRIVA" sqlType="STRING"/>
		<param name="VLRDESCUENTO" sqlType="STRING"/>
		<param name="VLRTOTAL" sqlType="STRING"/>
		<param name="CUATROXMIL" sqlType="STRING"/>
		<param name="DATE_MODIFIED" sqlType="STRING"/>
		<param name="MODIFIED_BY" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
