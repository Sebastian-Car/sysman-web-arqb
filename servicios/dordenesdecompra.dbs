	<query id="insertDordenesdecompraDetalleInventarioInicial" keyColumns="COMPANIA,CLASEORDEN,ORDENDECOMPRA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_ORDENDECOMPRA (COMPANIA, CLASEORDEN, ORDENDECOMPRA, CODIGO, ELEMENTO, MARCA, SERIE, ESPECIFICACION, CANTIDAD, SALDOCANT, VALORUNITARIO, VLRTOTAL, ESTADO, FECHAADQUISICION, FECHASALIDASERVICIO, FECHABODEGA, APLICA_NIIF, SERIEDEVOLUTIVO, NIIF_TIPO_ACTIVO, NIIF_VIDA_UTIL, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN, :ORDENDECOMPRA, :CODIGO, :ELEMENTO, :MARCA, :SERIE, :ESPECIFICACION, :CANTIDAD, :SALDOCANT, :VALORUNITARIO, :VLRTOTAL, :ESTADO, TO_DATE(:FECHAADQUISICION,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHASALIDASERVICIO,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHABODEGA,'DD/MM/YYYY HH24:MI:SS'), :APLICA_NIIF, :SERIEDEVOLUTIVO, :NIIF_TIPO_ACTIVO, :NIIF_VIDA_UTIL, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_ORDENDECOMPRA":"$ORDENDECOMPRA","KEY_CODIGO":"$CODIGO"}]}}		</result>
