		<param defaultValue="0" name="VALOR_AIU" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dordenesdecompra">
		<call-query href="insertDordenesdecompra">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ANOPPTO" query-param="ANOPPTO"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ORDENDESUMINISTRO" query-param="ORDENDESUMINISTRO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CENTRODECOSTO" query-param="CENTRODECOSTO"/>
