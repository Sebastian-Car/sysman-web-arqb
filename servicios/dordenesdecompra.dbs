	<query id="updateDordenesdecompra" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_ORDENDECOMPRA SET COMPANIA=:COMPANIA, ANOPPTO=:ANOPPTO, CLASEORDEN=:CLASEORDEN, ORDENDECOMPRA=:ORDENDECOMPRA, CODIGO=:CODIGO, ORDENDESUMINISTRO=:ORDENDESUMINISTRO, DEPENDENCIA=:DEPENDENCIA, ELEMENTO=:ELEMENTO, ESPECIFICACION=:ESPECIFICACION, CENTRODECOSTO=:CENTRODECOSTO, CANTIDAD=:CANTIDAD, SALDOCANT=:SALDOCANT, VALORUNITARIO=:VALORUNITARIO, PORCIVA=:PORCIVA, PORCDESC=:PORCDESC, VLRTOTAL=:VLRTOTAL, MARCA=:MARCA, VLRIVA=:VLRIVA, VLRDESCUENTO=:VLRDESCUENTO, CUATROXMIL=:CUATROXMIL, CODIGOCUBS=:CODIGOCUBS, IMPREVISTOS=:IMPREVISTOS, REGISTRO=:REGISTRO, TIPO_REGISTRO=:TIPO_REGISTRO, RUBROPPTO=:RUBROPPTO, ITEM_AFECT=:ITEM_AFECT, TIPOPPTO=:TIPOPPTO, VALORPPTO=:VALORPPTO, NUMEROPPTO=:NUMEROPPTO, CONSECUTIVOPPTO=:CONSECUTIVOPPTO, PAGOTERCEROS=:PAGOTERCEROS, VALORUNITARIODI=:VALORUNITARIODI, ITEMORIGEN=:ITEMORIGEN, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY, IMPCONSUMO=:IMPCONSUMO, VALORIMPCONSUMO=:VALORIMPCONSUMO, REFERENCIA=:REFERENCIA, UNIDAD=:UNIDAD, LOTE=:LOTE, TEMPERATURA=:TEMPERATURA, FECHA_VENCIMIENTO=TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), REGISTRO_SANITARIO=:REGISTRO_SANITARIO, NIIF_VIDA_UTIL=:NIIF_VIDA_UTIL, PORC_AIU=:PORC_AIU, VALOR_AIU=:VALOR_AIU WHERE D_ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND D_ORDENDECOMPRA.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ANOPPTO" sqlType="STRING"/>
