	<query id="getDordenesdecompraPagRubropptoYNombreInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_ORDENDECOMPRA.RUBROPPTO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.CODIGO  FROM D_ORDENDECOMPRA LEFT JOIN PLAN_PRESUPUESTAL ON D_ORDENDECOMPRA.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND D_ORDENDECOMPRA.RUBROPPTO = PLAN_PRESUPUESTAL.CODIGO AND D_ORDENDECOMPRA.ANOPPTO = PLAN_PRESUPUESTAL.ANO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.RUBROPPTO IS NOT NULL GROUP BY D_ORDENDECOMPRA.RUBROPPTO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.CODIGO ORDER BY 1) WHERE (CASE WHEN RUBROPPTO IS NULL THEN ' ' ELSE UPPER(RUBROPPTO) END)  LIKE UPPER(:RUBROPPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RUBROPPTO":"$RUBROPPTO","NOMBRE":"$NOMBRE","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RUBROPPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dordenesdecompra/rubropptoynombreinicial/pag">
		<call-query href="getDordenesdecompraPagRubropptoYNombreInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RUBROPPTO" query-param="RUBROPPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraNumRubropptoYNombreInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_ORDENDECOMPRA.RUBROPPTO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.CODIGO  FROM D_ORDENDECOMPRA LEFT JOIN PLAN_PRESUPUESTAL ON D_ORDENDECOMPRA.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND D_ORDENDECOMPRA.RUBROPPTO = PLAN_PRESUPUESTAL.CODIGO AND D_ORDENDECOMPRA.ANOPPTO = PLAN_PRESUPUESTAL.ANO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.RUBROPPTO IS NOT NULL GROUP BY D_ORDENDECOMPRA.RUBROPPTO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.CODIGO ORDER BY 1) WHERE (CASE WHEN RUBROPPTO IS NULL THEN ' ' ELSE UPPER(RUBROPPTO) END)  LIKE UPPER(:RUBROPPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RUBROPPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/rubropptoynombreinicial/num">
		<call-query href="getDordenesdecompraNumRubropptoYNombreInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RUBROPPTO" query-param="RUBROPPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraPagRubropptoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_ORDENDECOMPRA.RUBROPPTO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.CODIGO  FROM D_ORDENDECOMPRA LEFT JOIN PLAN_PRESUPUESTAL ON D_ORDENDECOMPRA.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND D_ORDENDECOMPRA.RUBROPPTO = PLAN_PRESUPUESTAL.CODIGO AND D_ORDENDECOMPRA.ANOPPTO = PLAN_PRESUPUESTAL.ANO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.RUBROPPTO IS NOT NULL AND D_ORDENDECOMPRA.RUBROPPTO &gt;= :RUBROINICIAL GROUP BY D_ORDENDECOMPRA.RUBROPPTO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.CODIGO ORDER BY 1) WHERE (CASE WHEN RUBROPPTO IS NULL THEN ' ' ELSE UPPER(RUBROPPTO) END)  LIKE UPPER(:RUBROPPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"RUBROPPTO":"$RUBROPPTO","NOMBRE":"$NOMBRE","CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RUBROINICIAL" sqlType="STRING"/>
		<param name="RUBROPPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dordenesdecompra/rubropptoynombrefinal/pag">
		<call-query href="getDordenesdecompraPagRubropptoYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RUBROINICIAL" query-param="RUBROINICIAL"/>
			<with-param name="RUBROPPTO" query-param="RUBROPPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraNumRubropptoYNombreFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_ORDENDECOMPRA.RUBROPPTO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.CODIGO  FROM D_ORDENDECOMPRA LEFT JOIN PLAN_PRESUPUESTAL ON D_ORDENDECOMPRA.COMPANIA = PLAN_PRESUPUESTAL.COMPANIA AND D_ORDENDECOMPRA.RUBROPPTO = PLAN_PRESUPUESTAL.CODIGO AND D_ORDENDECOMPRA.ANOPPTO = PLAN_PRESUPUESTAL.ANO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.RUBROPPTO IS NOT NULL AND D_ORDENDECOMPRA.RUBROPPTO &gt;= :RUBROINICIAL GROUP BY D_ORDENDECOMPRA.RUBROPPTO, PLAN_PRESUPUESTAL.NOMBRE, PLAN_PRESUPUESTAL.CODIGO ORDER BY 1) WHERE (CASE WHEN RUBROPPTO IS NULL THEN ' ' ELSE UPPER(RUBROPPTO) END)  LIKE UPPER(:RUBROPPTO || '%')  AND (CASE WHEN NOMBRE IS NULL THEN ' ' ELSE UPPER(NOMBRE) END)  LIKE UPPER( '%' || :NOMBRE || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="RUBROINICIAL" sqlType="STRING"/>
		<param name="RUBROPPTO" sqlType="STRING"/>
		<param name="NOMBRE" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/rubropptoynombrefinal/num">
		<call-query href="getDordenesdecompraNumRubropptoYNombreFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="RUBROINICIAL" query-param="RUBROINICIAL"/>
			<with-param name="RUBROPPTO" query-param="RUBROPPTO"/>
			<with-param name="NOMBRE" query-param="NOMBRE"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraCargarvaloresafectacionQuery"  useConfig="sysmandsunist">
		<sql>SELECT COMPANIA, CLASEORDEN, ORDENDECOMPRA,ELEMENTO, CODIGO, CANTIDAD, VALORUNITARIO, VLRTOTAL,VLRIVA, REFERENCIA, UNIDAD, LOTE, TEMPERATURA,(TO_CHAR(FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS')) FECHA_VENCIMIENTO, REGISTRO_SANITARIO, VALORUNITARIODI,PORCIVA FROM D_ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA = :NUMERO AND ELEMENTO = :ELEMENTO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA","ELEMENTO":"$ELEMENTO","CODIGO":"$CODIGO","CANTIDAD":"$CANTIDAD","VALORUNITARIO":"$VALORUNITARIO","VLRTOTAL":"$VLRTOTAL","VLRIVA":"$VLRIVA","REFERENCIA":"$REFERENCIA","UNIDAD":"$UNIDAD","LOTE":"$LOTE","TEMPERATURA":"$TEMPERATURA","FECHA_VENCIMIENTO":"$FECHA_VENCIMIENTO","REGISTRO_SANITARIO":"$REGISTRO_SANITARIO","VALORUNITARIODI":"$VALORUNITARIODI","PORCIVA":"$PORCIVA"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/cargarvaloresafectacion">
		<call-query href="getDordenesdecompraCargarvaloresafectacionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>

		</call-query>
	</resource>
	<query id="deleteDordenesdecompraBorrarpororigen" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM D_ORDENDECOMPRA WHERE D_ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND D_ORDENDECOMPRA.CODIGO= :KEY_CODIGO AND TIPOORIGEN = :TIPOORIGEN</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="KEY_COMPANIA" sqlType="STRING"/>
		<param name="KEY_CLASEORDEN" sqlType="STRING"/>
		<param name="KEY_ORDENDECOMPRA" sqlType="STRING"/>
		<param name="KEY_CODIGO" sqlType="STRING"/>
		<param name="TIPOORIGEN" sqlType="STRING"/>

	</query>
	<resource method="DELETE" path="dordenesdecompra/borrarpororigen">
		<call-query href="deleteDordenesdecompraBorrarpororigen">
			<with-param name="KEY_COMPANIA" query-param="KEY_COMPANIA"/>
			<with-param name="KEY_CLASEORDEN" query-param="KEY_CLASEORDEN"/>
			<with-param name="KEY_ORDENDECOMPRA" query-param="KEY_ORDENDECOMPRA"/>
			<with-param name="KEY_CODIGO" query-param="KEY_CODIGO"/>
			<with-param name="TIPOORIGEN" query-param="TIPOORIGEN"/>

		</call-query>
	</resource>
	
