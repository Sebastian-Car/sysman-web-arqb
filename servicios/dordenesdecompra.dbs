	<query id="getDordenesdecompraTodosPorItemAfectadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  CLASEORDEN, ORDENDECOMPRA, CODIGO  FROM D_ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND TIPOAFECTADO = :CLASEORDEN AND NUMEROAFECTADO = :NUMEROORDEN AND ITEMAFECTADO = :CODIGO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"CLASEORDEN":"$CLASEORDEN","ORDENDECOMPRA":"$ORDENDECOMPRA(type:long)","CODIGO":"$CODIGO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/todosporitemafectado">
		<call-query href="getDordenesdecompraTodosPorItemAfectadoQuery">
