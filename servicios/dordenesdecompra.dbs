	<query id="getDordenesdecompraTotalSubDetalleDeOrdencompraQuery"  useConfig="sysmandsunist">
		<sql>SELECT TRIM(TO_CHAR(NVL(SUM(VLRTOTAL),0),'9G999G999G999G999G990D99')) AS TOTAL FROM D_ORDENDECOMPRA WHERE COMPANIA = :COMPANIA AND CLASEORDEN = :CLASEORDEN AND ORDENDECOMPRA = :ORDENDECOMPRA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL"}]}}		</result>
