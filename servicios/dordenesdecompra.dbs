<data name="dordenesdecompra" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getDordenesdecompraValorSubQuery"  useConfig="sysmandsunist">
		<sql>SELECT  NVL((CANTIDAD*VALORUNITARIO)-VLRDESCUENTO+VLRIVA,0) AS VALORSUB  FROM D_ORDENDECOMPRA WHERE D_ORDENDECOMPRA.COMPANIA=:COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN=:CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA=:ORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VALORSUB":"$VALORSUB(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/valorsub">
		<call-query href="getDordenesdecompraValorSubQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ORDEN" query-param="ORDEN"/>

		</call-query>
	</resource>
	<query id="insertDordenesdecompraDesdeOrdenDeSuministro" keyColumns="COMPANIA,CLASEORDEN,ORDENDECOMPRA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_ORDENDECOMPRA (COMPANIA, CLASEORDEN, ORDENDECOMPRA, CODIGO, ELEMENTO, ESPECIFICACION, CANTIDAD, SALDOCANT, VALORUNITARIO, PORCIVA, PORCDESC, VLRTOTAL, ORDENDESUMINISTRO, DEPENDENCIA, VALORUNITARIODI, VLRDESCUENTO, VLRIVA, ITEMORIGEN, CODIGOCUBS, PERIODICIDAD, NUMERO_ENTREGAS, UNIDAD_TIEMPO, PLAZO, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :CLASEORDEN, :ORDENDECOMPRA, :CODIGO, :ELEMENTO, :ESPECIFICACION, :CANTIDAD, :SALDOCANT, :VALORUNITARIO, :PORCIVA, :PORCDESC, :VLRTOTAL, :ORDENDESUMINISTRO, :DEPENDENCIA, :VALORUNITARIODI, :VLRDESCUENTO, :VLRIVA, :ITEMORIGEN, :CODIGOCUBS, :PERIODICIDAD, :NUMERO_ENTREGAS, :UNIDAD_TIEMPO, :PLAZO, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_ORDENDECOMPRA":"$ORDENDECOMPRA(type:long)","KEY_CODIGO":"$CODIGO(type:long)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param defaultValue="" name="ESPECIFICACION" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="SALDOCANT" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVA" sqlType="STRING"/>
		<param defaultValue="0" name="PORCDESC" sqlType="STRING"/>
		<param defaultValue="0" name="VLRTOTAL" sqlType="STRING"/>
		<param defaultValue="0" name="ORDENDESUMINISTRO" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUNITARIODI" sqlType="STRING"/>
		<param defaultValue="0" name="VLRDESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="VLRIVA" sqlType="STRING"/>
		<param defaultValue="0" name="ITEMORIGEN" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCUBS" sqlType="STRING"/>
		<param defaultValue="" name="PERIODICIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="NUMERO_ENTREGAS" sqlType="STRING"/>
		<param defaultValue="" name="UNIDAD_TIEMPO" sqlType="STRING"/>
		<param defaultValue="0" name="PLAZO" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>

	</query>
	<resource method="POST" path="dordenesdecompra/desdeordendesuministro">
		<call-query href="insertDordenesdecompraDesdeOrdenDeSuministro">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="ORDENDECOMPRA" query-param="ORDENDECOMPRA"/>
			<with-param name="CODIGO" query-param="CODIGO"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="ESPECIFICACION" query-param="ESPECIFICACION"/>
			<with-param name="CANTIDAD" query-param="CANTIDAD"/>
			<with-param name="SALDOCANT" query-param="SALDOCANT"/>
			<with-param name="VALORUNITARIO" query-param="VALORUNITARIO"/>
			<with-param name="PORCIVA" query-param="PORCIVA"/>
			<with-param name="PORCDESC" query-param="PORCDESC"/>
			<with-param name="VLRTOTAL" query-param="VLRTOTAL"/>
			<with-param name="ORDENDESUMINISTRO" query-param="ORDENDESUMINISTRO"/>
			<with-param name="DEPENDENCIA" query-param="DEPENDENCIA"/>
			<with-param name="VALORUNITARIODI" query-param="VALORUNITARIODI"/>
			<with-param name="VLRDESCUENTO" query-param="VLRDESCUENTO"/>
			<with-param name="VLRIVA" query-param="VLRIVA"/>
			<with-param name="ITEMORIGEN" query-param="ITEMORIGEN"/>
			<with-param name="CODIGOCUBS" query-param="CODIGOCUBS"/>
			<with-param name="PERIODICIDAD" query-param="PERIODICIDAD"/>
			<with-param name="NUMERO_ENTREGAS" query-param="NUMERO_ENTREGAS"/>
			<with-param name="UNIDAD_TIEMPO" query-param="UNIDAD_TIEMPO"/>
			<with-param name="PLAZO" query-param="PLAZO"/>
			<with-param name="DATE_CREATED" query-param="DATE_CREATED"/>
			<with-param name="CREATED_BY" query-param="CREATED_BY"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraPagElementoInventarioInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_ORDENDECOMPRA.ELEMENTO,INVENTARIO.NOMBRELARGO,INVENTARIO.TIPO  FROM D_ORDENDECOMPRA LEFT JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA=INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO=INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA GROUP BY D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.TIPO ORDER BY D_ORDENDECOMPRA.ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dordenesdecompra/elementoinventarioinicial/pag">
		<call-query href="getDordenesdecompraPagElementoInventarioInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraNumElementoInventarioInicialQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_ORDENDECOMPRA.ELEMENTO,INVENTARIO.NOMBRELARGO,INVENTARIO.TIPO  FROM D_ORDENDECOMPRA LEFT JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA=INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO=INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA GROUP BY D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.TIPO ORDER BY D_ORDENDECOMPRA.ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/elementoinventarioinicial/num">
		<call-query href="getDordenesdecompraNumElementoInventarioInicialQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraPagElementoInventarioFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT  D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.TIPO  FROM D_ORDENDECOMPRA LEFT JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA = INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.ELEMENTO &gt;= :ELEMENTOINICIAL GROUP BY D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.TIPO ORDER BY D_ORDENDECOMPRA.ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ) A WHERE ROWNUM &lt;=  (:PAGINICIO + :PAGTAMANIO)) WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"ELEMENTO":"$ELEMENTO","NOMBRELARGO":"$NOMBRELARGO","TIPO":"$TIPO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTOINICIAL" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="dordenesdecompra/elementoinventariofinal/pag">
		<call-query href="getDordenesdecompraPagElementoInventarioFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTOINICIAL" query-param="ELEMENTOINICIAL"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>
			<with-param name="PAGINICIO" query-param="PAGINICIO"/>
			<with-param name="PAGTAMANIO" query-param="PAGTAMANIO"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraNumElementoInventarioFinalQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.TIPO  FROM D_ORDENDECOMPRA LEFT JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA = INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.ELEMENTO &gt;= :ELEMENTOINICIAL GROUP BY D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.TIPO ORDER BY D_ORDENDECOMPRA.ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END)  LIKE UPPER( '%' || :NOMBRELARGO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="ELEMENTOINICIAL" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param name="NOMBRELARGO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/elementoinventariofinal/num">
		<call-query href="getDordenesdecompraNumElementoInventarioFinalQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="ELEMENTOINICIAL" query-param="ELEMENTOINICIAL"/>
			<with-param name="ELEMENTO" query-param="ELEMENTO"/>
			<with-param name="NOMBRELARGO" query-param="NOMBRELARGO"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraPrimeroQuery"  useConfig="sysmandsunist">
		<sql>SELECT  MIN(D_ORDENDECOMPRA.NUMEROPPTO) KEEP (DENSE_RANK FIRST ORDER BY ROWNUM) PRIMERO  FROM D_ORDENDECOMPRA WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA = :NUMEROORDEN GROUP BY D_ORDENDECOMPRA.ORDENDECOMPRA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"PRIMERO":"$PRIMERO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/primero">
		<call-query href="getDordenesdecompraPrimeroQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraTotalParaOdcQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(D_ORDENDECOMPRA.VLRTOTAL) TOTVLRTOTAL  FROM D_ORDENDECOMPRA WHERE D_ORDENDECOMPRA.COMPANIA= :COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN = 'ODC'AND D_ORDENDECOMPRA.ORDENDECOMPRA = :NUMEROORDEN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTVLRTOTAL":"$TOTVLRTOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/totalparaodc">
		<call-query href="getDordenesdecompraTotalParaOdcQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraTotalPorOrdenQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(D_ORDENDECOMPRA.VLRTOTAL) VLRTOTALF  FROM D_ORDENDECOMPRA WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.ORDENDECOMPRA = :NUMEROORDEN AND D_ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN GROUP BY D_ORDENDECOMPRA.ORDENDECOMPRA, D_ORDENDECOMPRA.CLASEORDEN, D_ORDENDECOMPRA.COMPANIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"VLRTOTALF":"$VLRTOTALF(type:double)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="NUMEROORDEN" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/totalpororden">
		<call-query href="getDordenesdecompraTotalPorOrdenQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>

		</call-query>
	</resource>
	<query id="insertDordenesdecompra" keyColumns="COMPANIA,CLASEORDEN,ORDENDECOMPRA,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO D_ORDENDECOMPRA (COMPANIA, ANOPPTO, CLASEORDEN, ORDENDECOMPRA, CODIGOCUBS, CODIGO, ORDENDESUMINISTRO, DEPENDENCIA, ELEMENTO, ESPECIFICACION, CENTRODECOSTO, CANTIDAD, SALDOCANT, VALORUNITARIO, PORCIVA, PORCDESC, VLRTOTAL, MARCA, VLRIVA, VLRDESCUENTO, CUATROXMIL, IMPREVISTOS, ITEM_AFECT, REGISTRO, TIPO_REGISTRO, RUBROPPTO, TIPOPPTO, VALORPPTO, NUMEROPPTO, CONSECUTIVOPPTO, PAGOTERCEROS, VALORUNITARIODI, ITEMORIGEN, DATE_CREATED, CREATED_BY, IMPCONSUMO, VALORIMPCONSUMO, REFERENCIA, UNIDAD, LOTE, TEMPERATURA, FECHA_VENCIMIENTO, REGISTRO_SANITARIO, NIIF_VIDA_UTIL, PORC_AIU, VALOR_AIU) VALUES (:COMPANIA, :ANOPPTO, :CLASEORDEN, :ORDENDECOMPRA, :CODIGOCUBS, :CODIGO, :ORDENDESUMINISTRO, :DEPENDENCIA, :ELEMENTO, :ESPECIFICACION, :CENTRODECOSTO, :CANTIDAD, :SALDOCANT, :VALORUNITARIO, :PORCIVA, :PORCDESC, :VLRTOTAL, :MARCA, :VLRIVA, :VLRDESCUENTO, :CUATROXMIL, :IMPREVISTOS, :ITEM_AFECT, :REGISTRO, :TIPO_REGISTRO, :RUBROPPTO, :TIPOPPTO, :VALORPPTO, :NUMEROPPTO, :CONSECUTIVOPPTO, :PAGOTERCEROS, :VALORUNITARIODI, :ITEMORIGEN, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY, :IMPCONSUMO, :VALORIMPCONSUMO, :REFERENCIA, :UNIDAD, :LOTE, :TEMPERATURA, TO_DATE(:FECHA_VENCIMIENTO,'DD/MM/YYYY HH24:MI:SS'), :REGISTRO_SANITARIO, :NIIF_VIDA_UTIL, :PORC_AIU, :VALOR_AIU)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_CLASEORDEN":"$CLASEORDEN","KEY_ORDENDECOMPRA":"$ORDENDECOMPRA","KEY_CODIGO":"$CODIGO"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param defaultValue="" name="ANOPPTO" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="ORDENDECOMPRA" sqlType="STRING"/>
		<param defaultValue="" name="CODIGOCUBS" sqlType="STRING"/>
		<param defaultValue="0" name="CODIGO" sqlType="STRING"/>
		<param defaultValue="0" name="ORDENDESUMINISTRO" sqlType="STRING"/>
		<param defaultValue="999999999999" name="DEPENDENCIA" sqlType="STRING"/>
		<param name="ELEMENTO" sqlType="STRING"/>
		<param defaultValue="" name="ESPECIFICACION" sqlType="STRING"/>
		<param defaultValue="99999999999999999999" name="CENTRODECOSTO" sqlType="STRING"/>
		<param defaultValue="0" name="CANTIDAD" sqlType="STRING"/>
		<param defaultValue="0" name="SALDOCANT" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUNITARIO" sqlType="STRING"/>
		<param defaultValue="0" name="PORCIVA" sqlType="STRING"/>
		<param defaultValue="0" name="PORCDESC" sqlType="STRING"/>
		<param defaultValue="0" name="VLRTOTAL" sqlType="STRING"/>
		<param defaultValue="" name="MARCA" sqlType="STRING"/>
		<param defaultValue="0" name="VLRIVA" sqlType="STRING"/>
		<param defaultValue="0" name="VLRDESCUENTO" sqlType="STRING"/>
		<param defaultValue="0" name="CUATROXMIL" sqlType="STRING"/>
		<param defaultValue="0" name="IMPREVISTOS" sqlType="STRING"/>
		<param defaultValue="0" name="ITEM_AFECT" sqlType="STRING"/>
		<param defaultValue="0" name="REGISTRO" sqlType="STRING"/>
		<param defaultValue="" name="TIPO_REGISTRO" sqlType="STRING"/>
		<param defaultValue="" name="RUBROPPTO" sqlType="STRING"/>
		<param defaultValue="" name="TIPOPPTO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORPPTO" sqlType="STRING"/>
		<param defaultValue="0" name="NUMEROPPTO" sqlType="STRING"/>
		<param defaultValue="" name="CONSECUTIVOPPTO" sqlType="STRING"/>
		<param defaultValue="0" name="PAGOTERCEROS" sqlType="STRING"/>
		<param defaultValue="0" name="VALORUNITARIODI" sqlType="STRING"/>
		<param defaultValue="0" name="ITEMORIGEN" sqlType="STRING"/>
		<param name="DATE_CREATED" sqlType="STRING"/>
		<param name="CREATED_BY" sqlType="STRING"/>
		<param defaultValue="0" name="IMPCONSUMO" sqlType="STRING"/>
		<param defaultValue="0" name="VALORIMPCONSUMO" sqlType="STRING"/>
