	<query id="getDordenesdecompraNumTodosPorClaseOrdenYOrdenDeCompraQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT D_ORDENDECOMPRA.COMPANIA, D_ORDENDECOMPRA.CLASEORDEN, D_ORDENDECOMPRA.ORDENDECOMPRA, D_ORDENDECOMPRA.CODIGO, D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRELARGO, INVENTARIO.UNIDAD, D_ORDENDECOMPRA.MARCA, D_ORDENDECOMPRA.SERIE, D_ORDENDECOMPRA.ESPECIFICACION, D_ORDENDECOMPRA.CANTIDAD, D_ORDENDECOMPRA.SALDOCANT, D_ORDENDECOMPRA.VALORUNITARIO, D_ORDENDECOMPRA.VLRTOTAL, D_ORDENDECOMPRA.ESTADO,(TO_CHAR(D_ORDENDECOMPRA.FECHAADQUISICION,'DD/MM/YYYY HH24:MI:SS')) FECHAADQUISICION,(TO_CHAR(D_ORDENDECOMPRA.FECHASALIDASERVICIO,'DD/MM/YYYY HH24:MI:SS')) FECHASALIDASERVICIO,(TO_CHAR(D_ORDENDECOMPRA.FECHABODEGA,'DD/MM/YYYY HH24:MI:SS')) FECHABODEGA, D_ORDENDECOMPRA.NIIF_TIPO_ACTIVO, TIPO_ACTIVO.NOMBRE_TIPOACTIVO, D_ORDENDECOMPRA.NIIF_VIDA_UTIL,(CASE D_ORDENDECOMPRA.APLICA_NIIF WHEN 0 THEN 'false' ELSE 'true' END) APLICA_NIIF FROM D_ORDENDECOMPRA INNER JOIN INVENTARIO ON INVENTARIO.COMPANIA = D_ORDENDECOMPRA.COMPANIA AND INVENTARIO.CODIGOELEMENTO = D_ORDENDECOMPRA.ELEMENTO LEFT JOIN TIPO_ACTIVO ON TIPO_ACTIVO.COMPANIA = D_ORDENDECOMPRA.COMPANIA AND TIPO_ACTIVO.CODIGO_TIPOACTIVO = D_ORDENDECOMPRA.NIIF_TIPO_ACTIVO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA = :ORDENDECOMPRA) INI WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END) LIKE UPPER(CONCAT(:ELEMENTO, '%')) AND (CASE WHEN NOMBRELARGO IS NULL THEN ' ' ELSE UPPER(NOMBRELARGO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRELARGO), '%')) AND (CASE WHEN UNIDAD IS NULL THEN ' ' ELSE UPPER(UNIDAD) END) LIKE UPPER(CONCAT(:UNIDAD, '%')) AND (CASE WHEN MARCA IS NULL THEN ' ' ELSE UPPER(MARCA) END) LIKE UPPER(CONCAT(CONCAT('%',:MARCA), '%')) AND (CASE WHEN SERIE IS NULL THEN ' ' ELSE UPPER(SERIE) END) LIKE UPPER(CONCAT(:SERIE, '%')) AND (CASE WHEN ESPECIFICACION IS NULL THEN ' ' ELSE UPPER(ESPECIFICACION) END) LIKE UPPER(CONCAT(CONCAT('%',:ESPECIFICACION), '%')) AND (CASE WHEN CANTIDAD IS NULL THEN ' ' ELSE UPPER(CANTIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:CANTIDAD), '%')) AND (CASE WHEN SALDOCANT IS NULL THEN ' ' ELSE UPPER(SALDOCANT) END) LIKE UPPER(CONCAT(:SALDOCANT, '%')) AND (CASE WHEN VALORUNITARIO IS NULL THEN ' ' ELSE UPPER(VALORUNITARIO) END) LIKE UPPER(CONCAT(:VALORUNITARIO, '%')) AND (CASE WHEN VLRTOTAL IS NULL THEN ' ' ELSE UPPER(VLRTOTAL) END) LIKE UPPER(CONCAT(:VLRTOTAL, '%')) AND (CASE WHEN ESTADO IS NULL THEN ' ' ELSE UPPER(ESTADO) END) LIKE UPPER(CONCAT(:ESTADO, '%')) AND (CASE WHEN FECHAADQUISICION IS NULL THEN ' ' ELSE UPPER(FECHAADQUISICION) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHAADQUISICION), '%')) AND (CASE WHEN FECHASALIDASERVICIO IS NULL THEN ' ' ELSE UPPER(FECHASALIDASERVICIO) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHASALIDASERVICIO), '%')) AND (CASE WHEN FECHABODEGA IS NULL THEN ' ' ELSE UPPER(FECHABODEGA) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHABODEGA), '%')) AND (CASE WHEN NOMBRE_TIPOACTIVO IS NULL THEN ' ' ELSE UPPER(NOMBRE_TIPOACTIVO) END) LIKE UPPER(CONCAT(CONCAT('%',:NOMBRE_TIPOACTIVO), '%')) AND (CASE WHEN NIIF_VIDA_UTIL IS NULL THEN ' ' ELSE UPPER(NIIF_VIDA_UTIL) END) LIKE UPPER(CONCAT(CONCAT('%',:NIIF_VIDA_UTIL), '%')) AND (CASE WHEN APLICA_NIIF IS NULL THEN ' ' ELSE UPPER(APLICA_NIIF) END) LIKE UPPER(CONCAT(:APLICA_NIIF, '%')) ) A) FIN</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
