	</resource>
	<query id="getDordenesdecompraNumPorElementoYNombreCortoFinQuery"  useConfig="sysmandsunist">
		<sql>SELECT COUNT(1) AS TOTAL FROM(SELECT * FROM (SELECT * FROM (SELECT  DISTINCT D_ORDENDECOMPRA.ELEMENTO, INVENTARIO.NOMBRECORTO  FROM D_ORDENDECOMPRA INNER JOIN INVENTARIO ON D_ORDENDECOMPRA.COMPANIA = INVENTARIO.COMPANIA AND D_ORDENDECOMPRA.ELEMENTO = INVENTARIO.CODIGOELEMENTO WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.ELEMENTO &gt;= :CODELEMENTO ORDER BY D_ORDENDECOMPRA.ELEMENTO) WHERE (CASE WHEN ELEMENTO IS NULL THEN ' ' ELSE UPPER(ELEMENTO) END)  LIKE UPPER(:ELEMENTO || '%')  AND (CASE WHEN NOMBRECORTO IS NULL THEN ' ' ELSE UPPER(NOMBRECORTO) END)  LIKE UPPER( '%' || :NOMBRECORTO || '%') ))</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
