			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMEROORDEN" query-param="NUMEROORDEN"/>
			<with-param name="CODIGO" query-param="CODIGO"/>

		</call-query>
	</resource>
	<query id="getDordenesdecompraExtraertotalesQuery"  useConfig="sysmandsunist">
		<sql>SELECT SUM(D_ORDENDECOMPRA.VLRTOTAL) TXTTOTAL, SUM(D_ORDENDECOMPRA.VLRDESCUENTO) TXTTOTALDESCUENTO, SUM(D_ORDENDECOMPRA.CUATROXMIL) TXTTOTALCUATRO, SUM(D_ORDENDECOMPRA.VLRIVA) TXTIVA, CAST(SUM(D_ORDENDECOMPRA.VALORIMPCONSUMO) AS NUMBER(18, 2)) TXTIMPCONSUMO, SUM(D_ORDENDECOMPRA.VALOR_AIU) TXTVALOR_AIU, PCK_SYSMAN_UTL.FC_ROUND(SUM( CASE WHEN D_ORDENDECOMPRA.CANTIDAD NOT IN(0) THEN D_ORDENDECOMPRA.VALORUNITARIO * D_ORDENDECOMPRA.CANTIDAD ELSE D_ORDENDECOMPRA.VLRTOTAL + D_ORDENDECOMPRA.VLRDESCUENTO - D_ORDENDECOMPRA.VLRIVA END ), 2) TXTSUBTOTAL, SUM(D_ORDENDECOMPRA.VLRTOTAL) - PCK_SYSMAN_UTL.FC_ROUND(SUM( CASE WHEN D_ORDENDECOMPRA.CANTIDAD NOT IN(0) THEN D_ORDENDECOMPRA.VALORUNITARIO * D_ORDENDECOMPRA.CANTIDAD ELSE D_ORDENDECOMPRA.VLRTOTAL + D_ORDENDECOMPRA.VLRDESCUENTO - D_ORDENDECOMPRA.VLRIVA END ), 2) + SUM(D_ORDENDECOMPRA.VLRDESCUENTO) TXTTOTALIVA, PCK_SYSMAN_UTL.FC_ROUND(PCK_SYSMAN_UTL.FC_ROUND(PCK_SYSMAN_UTL.FC_ROUND(SUM( CASE WHEN D_ORDENDECOMPRA.CANTIDAD NOT IN(0) THEN D_ORDENDECOMPRA.VALORUNITARIO * D_ORDENDECOMPRA.CANTIDAD ELSE D_ORDENDECOMPRA.VLRTOTAL + D_ORDENDECOMPRA.VLRDESCUENTO - D_ORDENDECOMPRA.VLRIVA END ), 2) - SUM(D_ORDENDECOMPRA.VLRDESCUENTO) + SUM(D_ORDENDECOMPRA.VLRIVA ), :DIGITOSREDONDEOGRANTOTAL) -((PCK_SYSMAN_UTL.FC_ROUND(SUM( CASE WHEN D_ORDENDECOMPRA.CANTIDAD NOT IN(0) THEN D_ORDENDECOMPRA.VALORUNITARIO * D_ORDENDECOMPRA.CANTIDAD ELSE D_ORDENDECOMPRA.VLRTOTAL + D_ORDENDECOMPRA.VLRDESCUENTO - D_ORDENDECOMPRA.VLRIVA END ), 2) - SUM(D_ORDENDECOMPRA.VLRDESCUENTO )) + SUM(D_ORDENDECOMPRA.VLRIVA )), 2) TXTAJUSTEALPESO, PCK_SYSMAN_UTL.FC_ROUND(SUM( CASE WHEN D_ORDENDECOMPRA.CANTIDAD NOT IN(0) THEN D_ORDENDECOMPRA.VALORUNITARIO * D_ORDENDECOMPRA.CANTIDAD ELSE D_ORDENDECOMPRA.VLRTOTAL + D_ORDENDECOMPRA.VLRDESCUENTO - D_ORDENDECOMPRA.VLRIVA END ), 2) + SUM(D_ORDENDECOMPRA.VALOR_AIU) + SUM(D_ORDENDECOMPRA.VLRIVA) + SUM(D_ORDENDECOMPRA.VALORIMPCONSUMO) TOTALCONAIU FROM D_ORDENDECOMPRA INNER JOIN ORDENDECOMPRA ON ORDENDECOMPRA.COMPANIA = D_ORDENDECOMPRA.COMPANIA AND ORDENDECOMPRA.CLASEORDEN = D_ORDENDECOMPRA.CLASEORDEN AND ORDENDECOMPRA.NUMERO = D_ORDENDECOMPRA.ORDENDECOMPRA WHERE D_ORDENDECOMPRA.COMPANIA = :COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN = :CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA = :NUMERO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TXTTOTAL":"$TXTTOTAL","TXTTOTALDESCUENTO":"$TXTTOTALDESCUENTO","TXTTOTALCUATRO":"$TXTTOTALCUATRO","TXTIVA":"$TXTIVA","TXTIMPCONSUMO":"$TXTIMPCONSUMO","TXTVALOR_AIU":"$TXTVALOR_AIU","TXTSUBTOTAL":"$TXTSUBTOTAL","TXTTOTALIVA":"$TXTTOTALIVA","TXTAJUSTEALPESO":"$TXTAJUSTEALPESO","TOTALCONAIU":"$TOTALCONAIU"}]}}		</result>
		<param name="DIGITOSREDONDEOGRANTOTAL" sqlType="STRING"/>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="CLASEORDEN" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>

	</query>
	<resource method="GET" path="dordenesdecompra/extraertotales">
		<call-query href="getDordenesdecompraExtraertotalesQuery">
			<with-param name="DIGITOSREDONDEOGRANTOTAL" query-param="DIGITOSREDONDEOGRANTOTAL"/>
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="CLASEORDEN" query-param="CLASEORDEN"/>
			<with-param name="NUMERO" query-param="NUMERO"/>

		</call-query>
	</resource>
