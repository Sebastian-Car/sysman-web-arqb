	<query id="updateDordenesdecompraItemsContratoPorCompania" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE D_ORDENDECOMPRA SET COMPANIA=:COMPANIA, CLASEORDEN=:CLASEORDEN, ORDENDECOMPRA=:ORDENDECOMPRA, CODIGO=:CODIGO, ORDENDESUMINISTRO=:ORDENDESUMINISTRO, DEPENDENCIA=:DEPENDENCIA, ELEMENTO=:ELEMENTO, ESPECIFICACION=:ESPECIFICACION, CENTRODECOSTO=:CENTRODECOSTO, CANTIDAD=:CANTIDAD, SALDOCANT=:SALDOCANT, VALORUNITARIO=:VALORUNITARIO, PORCIVA=:PORCIVA, PORCDESC=:PORCDESC, VLRTOTAL=:VLRTOTAL, MARCA=:MARCA, VALORUNITARIODI=:VALORUNITARIODI, VLRIVA=:VLRIVA, VLRDESCUENTO=:VLRDESCUENTO, ANOPPTO=:ANOPPTO, TIPOPPTO=:TIPOPPTO, NUMEROPPTO=:NUMEROPPTO, CONSECUTIVOPPTO=:CONSECUTIVOPPTO, RUBROPPTO=:RUBROPPTO, VALORPPTO=:VALORPPTO, BIENSERVICIO=:BIENSERVICIO, ITEMORIGEN=:ITEMORIGEN, ADMINISTRACION=:ADMINISTRACION, UTILIDAD=:UTILIDAD, IMPREVISTOS=:IMPREVISTOS, PAGOTERCEROS=:PAGOTERCEROS, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE D_ORDENDECOMPRA.COMPANIA= :KEY_COMPANIA AND D_ORDENDECOMPRA.CLASEORDEN= :KEY_CLASEORDEN AND D_ORDENDECOMPRA.ORDENDECOMPRA= :KEY_ORDENDECOMPRA AND D_ORDENDECOMPRA.CODIGO= :KEY_CODIGO</sql>
