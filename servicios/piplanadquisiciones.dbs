	<query id="getPiplanadquisicionesValorTotalEstimadoQuery"  useConfig="sysmandsunist">
		<sql>SELECT  SUM(PA.VALOR_ESTIMADO_FIN) TOTAL  FROM PI_PLAN_ADQUISICIONES PA LEFT JOIN PI_PLAN_ADQUISICIONES_VIGENCIA PAV ON PA.COMPANIA = PAV.COMPANIA AND PA.TIPO = PAV.TIPO AND PA.NUMERO = PAV.NUMERO AND PA.VIGENCIA_INICIAL = PAV.VIGENCIA_INICIAL AND PA.ID_PLAN = PAV.ID_PLAN AND PA.CODIGO = PAV.CODIGO WHERE PA.COMPANIA = :COMPANIA AND PA.TIPO = :TIPO AND PA.NUMERO = :NUMERO AND PA.VIGENCIA_INICIAL = :VIGENCIAGUB AND PA.ID_PLAN = :ID_PLAN AND PAV.VIGENCIA = :VIGENCIA</sql>
		<result outputType="json">{"elementos":{"elemento":[{"TOTAL":"$TOTAL(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIAGUB" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>

	</query>
	<resource method="GET" path="piplanadquisiciones/valortotalestimado">
		<call-query href="getPiplanadquisicionesValorTotalEstimadoQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIAGUB" query-param="VIGENCIAGUB"/>
			<with-param name="ID_PLAN" query-param="ID_PLAN"/>
			<with-param name="VIGENCIA" query-param="VIGENCIA"/>

		</call-query>
	</resource>
	<query id="deletePiplanadquisiciones" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>DELETE FROM PI_PLAN_ADQUISICIONES WHERE PI_PLAN_ADQUISICIONES.COMPANIA= :KEY_COMPANIA AND PI_PLAN_ADQUISICIONES.TIPO= :KEY_TIPO AND PI_PLAN_ADQUISICIONES.NUMERO= :KEY_NUMERO AND PI_PLAN_ADQUISICIONES.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PLAN_ADQUISICIONES.ID_PLAN= :KEY_ID_PLAN AND PI_PLAN_ADQUISICIONES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
