	<query id="updatePiplanadquisicionesPlandeaccion" returnUpdatedRowCount="true" useConfig="sysmandsunist">
		<sql>UPDATE PI_PLAN_ADQUISICIONES SET TIPO=:TIPO, NUMERO=:NUMERO, VIGENCIA_INICIAL=:VIGENCIA_INICIAL, ID_PLAN=:ID_PLAN, CODIGO=:CODIGO, DESCRIPCION_FIN=:DESCRIPCION_FIN, CODIGO_UNSPSC_FIN=:CODIGO_UNSPSC_FIN, MODALIDAD_FIN=:MODALIDAD_FIN, VALOR_ESTIMADO_FIN=:VALOR_ESTIMADO_FIN, F_ESTUDIO_PLAN_FIN=TO_DATE(:F_ESTUDIO_PLAN_FIN,'DD/MM/YYYY HH24:MI:SS'), F_CONTRATO_PLAN_FIN=TO_DATE(:F_CONTRATO_PLAN_FIN,'DD/MM/YYYY HH24:MI:SS'), FECHA_INI_ACT=TO_DATE(:FECHA_INI_ACT,'DD/MM/YYYY HH24:MI:SS'), FECHA_FIN_ACT=TO_DATE(:FECHA_FIN_ACT,'DD/MM/YYYY HH24:MI:SS'), CONTRATO_FIN=:CONTRATO_FIN, EST_PREVIO_FIN=:EST_PREVIO_FIN, F_ESTUDIO_EJEC_FIN=TO_DATE(:F_ESTUDIO_EJEC_FIN,'DD/MM/YYYY HH24:MI:SS'), F_CONTRATO_EJEC_FIN=TO_DATE(:F_CONTRATO_EJEC_FIN,'DD/MM/YYYY HH24:MI:SS'), F_INICIO_EJECUTADA_FIN=TO_DATE(:F_INICIO_EJECUTADA_FIN,'DD/MM/YYYY HH24:MI:SS'), F_FIN_EJECUTADA_FIN=TO_DATE(:F_FIN_EJECUTADA_FIN,'DD/MM/YYYY HH24:MI:SS'), VIGENCIAS_FUTURAS_FIN=:VIGENCIAS_FUTURAS_FIN, ESTADO_SOLICITUD_FIN=:ESTADO_SOLICITUD_FIN, DEBE_ELIMINAR=:DEBE_ELIMINAR, DATE_MODIFIED=TO_DATE(:DATE_MODIFIED,'DD/MM/YYYY HH24:MI:SS'), MODIFIED_BY=:MODIFIED_BY WHERE PI_PLAN_ADQUISICIONES.COMPANIA= :KEY_COMPANIA AND PI_PLAN_ADQUISICIONES.TIPO= :KEY_TIPO AND PI_PLAN_ADQUISICIONES.NUMERO= :KEY_NUMERO AND PI_PLAN_ADQUISICIONES.VIGENCIA_INICIAL= :KEY_VIGENCIA_INICIAL AND PI_PLAN_ADQUISICIONES.ID_PLAN= :KEY_ID_PLAN AND PI_PLAN_ADQUISICIONES.CODIGO= :KEY_CODIGO</sql>
 		<result element="elementos" rowName="elemento" useColumnNumbers="true"> 
    		<element column="1" name="TOTAL" xsdType="integer"/> 
 		</result> 

		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIA_INICIAL" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
