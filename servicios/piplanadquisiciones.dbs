<data name="piplanadquisiciones" transports="http https local">
	<config enableOData="false" id="sysmandsunist">
		<property name="carbon_datasource_name">SYSMANDSUNIST</property>
	</config>
	<query id="getPiplanadquisicionesPagPlanDeAccionQuery"  useConfig="sysmandsunist">
		<sql>SELECT * FROM ( SELECT A.*, ROWNUM RNUM FROM(SELECT * FROM (SELECT PA.COMPANIA, PA.TIPO, PA.NUMERO, PA.VIGENCIA_INICIAL, PA.ID_PLAN, PA.CODIGO, PA.DESCRIPCION_FIN, PA.CODIGO_UNSPSC_FIN, PA.MODALIDAD_FIN, ADJ.DESCRIPCION NOM_MODALIDAD, PA.VALOR_ESTIMADO_FIN,(TO_CHAR(PA.F_ESTUDIO_PLAN_FIN,'DD/MM/YYYY HH24:MI:SS')) F_ESTUDIO_PLAN_FIN,(TO_CHAR(PA.F_CONTRATO_PLAN_FIN,'DD/MM/YYYY HH24:MI:SS')) F_CONTRATO_PLAN_FIN,(TO_CHAR(PA.FECHA_INI_ACT,'DD/MM/YYYY HH24:MI:SS')) FECHA_INI_ACT,(TO_CHAR(PA.FECHA_FIN_ACT,'DD/MM/YYYY HH24:MI:SS')) FECHA_FIN_ACT, PA.CONTRATO_FIN, PA.EST_PREVIO_FIN,(TO_CHAR(PA.F_ESTUDIO_EJEC_FIN,'DD/MM/YYYY HH24:MI:SS')) F_ESTUDIO_EJEC_FIN,(TO_CHAR(PA.F_CONTRATO_EJEC_FIN,'DD/MM/YYYY HH24:MI:SS')) F_CONTRATO_EJEC_FIN,(TO_CHAR(PA.F_INICIO_EJECUTADA_FIN,'DD/MM/YYYY HH24:MI:SS')) F_INICIO_EJECUTADA_FIN,(TO_CHAR(PA.F_FIN_EJECUTADA_FIN,'DD/MM/YYYY HH24:MI:SS')) F_FIN_EJECUTADA_FIN,(CASE PA.VIGENCIAS_FUTURAS_FIN WHEN 0 THEN 'false' ELSE 'true' END) VIGENCIAS_FUTURAS_FIN, PA.ESTADO_SOLICITUD_FIN,(CASE PA.DEBE_ELIMINAR WHEN 0 THEN 'false' ELSE 'true' END) DEBE_ELIMINAR FROM PI_PLAN_ADQUISICIONES PA LEFT JOIN PI_PLAN_ADQUISICIONES_VIGENCIA PAV ON PA.COMPANIA = PAV.COMPANIA AND PA.TIPO = PAV.TIPO AND PA.NUMERO = PAV.NUMERO AND PA.VIGENCIA_INICIAL = PAV.VIGENCIA_INICIAL AND PA.ID_PLAN = PAV.ID_PLAN AND PA.CODIGO = PAV.CODIGO INNER JOIN TIPOADJUDICACION ADJ ON ADJ.CODIGO = PA.MODALIDAD_FIN AND PA.COMPANIA =ADJ.COMPANIA AND ADJ.MOVIMIENTO &lt;&gt; 0 WHERE PA.COMPANIA = :COMPANIA AND PA.TIPO = :TIPO AND PA.NUMERO = :NUMERO AND PA.VIGENCIA_INICIAL = :VIGENCIAGUB AND PA.ID_PLAN = :ID_PLAN AND PAV.VIGENCIA = :VIGENCIA) INI WHERE (CASE WHEN CODIGO IS NULL THEN ' ' ELSE UPPER(CODIGO) END) LIKE UPPER(CONCAT(:CODIGO, '%')) AND (CASE WHEN DESCRIPCION_FIN IS NULL THEN ' ' ELSE UPPER(DESCRIPCION_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:DESCRIPCION_FIN), '%')) AND (CASE WHEN CODIGO_UNSPSC_FIN IS NULL THEN ' ' ELSE UPPER(CODIGO_UNSPSC_FIN) END) LIKE UPPER(CONCAT(:CODIGO_UNSPSC_FIN, '%')) AND (CASE WHEN MODALIDAD_FIN IS NULL THEN ' ' ELSE UPPER(MODALIDAD_FIN) END) LIKE UPPER(CONCAT(:MODALIDAD_FIN, '%')) AND (CASE WHEN NOM_MODALIDAD IS NULL THEN ' ' ELSE UPPER(NOM_MODALIDAD) END) LIKE UPPER(CONCAT(CONCAT('%',:NOM_MODALIDAD), '%')) AND (CASE WHEN VALOR_ESTIMADO_FIN IS NULL THEN ' ' ELSE UPPER(VALOR_ESTIMADO_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:VALOR_ESTIMADO_FIN), '%')) AND (CASE WHEN F_ESTUDIO_PLAN_FIN IS NULL THEN ' ' ELSE UPPER(F_ESTUDIO_PLAN_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:F_ESTUDIO_PLAN_FIN), '%')) AND (CASE WHEN F_CONTRATO_PLAN_FIN IS NULL THEN ' ' ELSE UPPER(F_CONTRATO_PLAN_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:F_CONTRATO_PLAN_FIN), '%')) AND (CASE WHEN FECHA_INI_ACT IS NULL THEN ' ' ELSE UPPER(FECHA_INI_ACT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_INI_ACT), '%')) AND (CASE WHEN FECHA_FIN_ACT IS NULL THEN ' ' ELSE UPPER(FECHA_FIN_ACT) END) LIKE UPPER(CONCAT(CONCAT('%',:FECHA_FIN_ACT), '%')) AND (CASE WHEN CONTRATO_FIN IS NULL THEN ' ' ELSE UPPER(CONTRATO_FIN) END) LIKE UPPER(CONCAT(:CONTRATO_FIN, '%')) AND (CASE WHEN EST_PREVIO_FIN IS NULL THEN ' ' ELSE UPPER(EST_PREVIO_FIN) END) LIKE UPPER(CONCAT(:EST_PREVIO_FIN, '%')) AND (CASE WHEN F_ESTUDIO_EJEC_FIN IS NULL THEN ' ' ELSE UPPER(F_ESTUDIO_EJEC_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:F_ESTUDIO_EJEC_FIN), '%')) AND (CASE WHEN F_CONTRATO_EJEC_FIN IS NULL THEN ' ' ELSE UPPER(F_CONTRATO_EJEC_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:F_CONTRATO_EJEC_FIN), '%')) AND (CASE WHEN F_INICIO_EJECUTADA_FIN IS NULL THEN ' ' ELSE UPPER(F_INICIO_EJECUTADA_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:F_INICIO_EJECUTADA_FIN), '%')) AND (CASE WHEN F_FIN_EJECUTADA_FIN IS NULL THEN ' ' ELSE UPPER(F_FIN_EJECUTADA_FIN) END) LIKE UPPER(CONCAT(CONCAT('%',:F_FIN_EJECUTADA_FIN), '%')) AND (CASE WHEN VIGENCIAS_FUTURAS_FIN IS NULL THEN ' ' ELSE UPPER(VIGENCIAS_FUTURAS_FIN) END) LIKE UPPER(CONCAT(:VIGENCIAS_FUTURAS_FIN, '%')) AND (CASE WHEN ESTADO_SOLICITUD_FIN IS NULL THEN ' ' ELSE UPPER(ESTADO_SOLICITUD_FIN) END) LIKE UPPER(CONCAT(:ESTADO_SOLICITUD_FIN, '%')) AND (CASE WHEN DEBE_ELIMINAR IS NULL THEN ' ' ELSE UPPER(DEBE_ELIMINAR) END) LIKE UPPER(CONCAT(:DEBE_ELIMINAR, '%')) ) A WHERE ROWNUM &lt;= (:PAGINICIO + :PAGTAMANIO)) FIN WHERE RNUM &gt; :PAGINICIO</sql>
		<result outputType="json">{"elementos":{"elemento":[{"COMPANIA":"$COMPANIA","TIPO":"$TIPO","NUMERO":"$NUMERO(type:long)","VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","ID_PLAN":"$ID_PLAN","CODIGO":"$CODIGO(type:integer)","DESCRIPCION_FIN":"$DESCRIPCION_FIN","CODIGO_UNSPSC_FIN":"$CODIGO_UNSPSC_FIN","MODALIDAD_FIN":"$MODALIDAD_FIN","NOM_MODALIDAD":"$NOM_MODALIDAD","VALOR_ESTIMADO_FIN":"$VALOR_ESTIMADO_FIN","F_ESTUDIO_PLAN_FIN":"$F_ESTUDIO_PLAN_FIN","F_CONTRATO_PLAN_FIN":"$F_CONTRATO_PLAN_FIN","FECHA_INI_ACT":"$FECHA_INI_ACT","FECHA_FIN_ACT":"$FECHA_FIN_ACT","CONTRATO_FIN":"$CONTRATO_FIN","EST_PREVIO_FIN":"$EST_PREVIO_FIN","F_ESTUDIO_EJEC_FIN":"$F_ESTUDIO_EJEC_FIN","F_CONTRATO_EJEC_FIN":"$F_CONTRATO_EJEC_FIN","F_INICIO_EJECUTADA_FIN":"$F_INICIO_EJECUTADA_FIN","F_FIN_EJECUTADA_FIN":"$F_FIN_EJECUTADA_FIN","VIGENCIAS_FUTURAS_FIN":"$VIGENCIAS_FUTURAS_FIN(type:boolean)","ESTADO_SOLICITUD_FIN":"$ESTADO_SOLICITUD_FIN","DEBE_ELIMINAR":"$DEBE_ELIMINAR(type:boolean)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
		<param name="NUMERO" sqlType="STRING"/>
		<param name="VIGENCIAGUB" sqlType="STRING"/>
		<param name="ID_PLAN" sqlType="STRING"/>
		<param name="VIGENCIA" sqlType="STRING"/>
		<param name="CODIGO" sqlType="STRING"/>
		<param name="DESCRIPCION_FIN" sqlType="STRING"/>
		<param name="CODIGO_UNSPSC_FIN" sqlType="STRING"/>
		<param name="MODALIDAD_FIN" sqlType="STRING"/>
		<param name="NOM_MODALIDAD" sqlType="STRING"/>
		<param name="VALOR_ESTIMADO_FIN" sqlType="STRING"/>
		<param name="F_ESTUDIO_PLAN_FIN" sqlType="STRING"/>
		<param name="F_CONTRATO_PLAN_FIN" sqlType="STRING"/>
		<param name="FECHA_INI_ACT" sqlType="STRING"/>
		<param name="FECHA_FIN_ACT" sqlType="STRING"/>
		<param name="CONTRATO_FIN" sqlType="STRING"/>
		<param name="EST_PREVIO_FIN" sqlType="STRING"/>
		<param name="F_ESTUDIO_EJEC_FIN" sqlType="STRING"/>
		<param name="F_CONTRATO_EJEC_FIN" sqlType="STRING"/>
		<param name="F_INICIO_EJECUTADA_FIN" sqlType="STRING"/>
		<param name="F_FIN_EJECUTADA_FIN" sqlType="STRING"/>
		<param name="VIGENCIAS_FUTURAS_FIN" sqlType="STRING"/>
		<param name="ESTADO_SOLICITUD_FIN" sqlType="STRING"/>
		<param name="DEBE_ELIMINAR" sqlType="STRING"/>
		<param name="PAGINICIO" sqlType="INTEGER"/>
		<param name="PAGTAMANIO" sqlType="INTEGER"/>

	</query>
	<resource method="GET" path="piplanadquisiciones/plandeaccion/pag">
		<call-query href="getPiplanadquisicionesPagPlanDeAccionQuery">
			<with-param name="COMPANIA" query-param="COMPANIA"/>
			<with-param name="TIPO" query-param="TIPO"/>
			<with-param name="NUMERO" query-param="NUMERO"/>
			<with-param name="VIGENCIAGUB" query-param="VIGENCIAGUB"/>
