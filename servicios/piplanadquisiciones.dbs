	<query id="insertPiplanadquisicionesPlandeaccion" keyColumns="COMPANIA,TIPO,NUMERO,VIGENCIA_INICIAL,ID_PLAN,CODIGO" returnGeneratedKeys="true" useConfig="sysmandsunist">
		<sql>INSERT INTO PI_PLAN_ADQUISICIONES (COMPANIA, TIPO, NUMERO, VIGENCIA_INICIAL, ID_PLAN, CODIGO, DESCRIPCION_FIN, CODIGO_UNSPSC_FIN, MODALIDAD_FIN, VALOR_ESTIMADO_FIN, F_ESTUDIO_PLAN_FIN, F_CONTRATO_PLAN_FIN, FECHA_INI_ACT, FECHA_FIN_ACT, CONTRATO_FIN, EST_PREVIO_FIN, F_ESTUDIO_EJEC_FIN, F_CONTRATO_EJEC_FIN, F_INICIO_EJECUTADA_FIN, F_FIN_EJECUTADA_FIN, VIGENCIAS_FUTURAS_FIN, ESTADO_SOLICITUD_FIN, ESNUEVO, DEBE_ELIMINAR, DATE_CREATED, CREATED_BY) VALUES (:COMPANIA, :TIPO, :NUMERO, :VIGENCIA_INICIAL, :ID_PLAN, :CODIGO, :DESCRIPCION_FIN, :CODIGO_UNSPSC_FIN, :MODALIDAD_FIN, :VALOR_ESTIMADO_FIN, TO_DATE(:F_ESTUDIO_PLAN_FIN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:F_CONTRATO_PLAN_FIN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_INI_ACT,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:FECHA_FIN_ACT,'DD/MM/YYYY HH24:MI:SS'), :CONTRATO_FIN, :EST_PREVIO_FIN, TO_DATE(:F_ESTUDIO_EJEC_FIN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:F_CONTRATO_EJEC_FIN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:F_INICIO_EJECUTADA_FIN,'DD/MM/YYYY HH24:MI:SS'), TO_DATE(:F_FIN_EJECUTADA_FIN,'DD/MM/YYYY HH24:MI:SS'), :VIGENCIAS_FUTURAS_FIN, :ESTADO_SOLICITUD_FIN, :ESNUEVO, :DEBE_ELIMINAR, TO_DATE(:DATE_CREATED,'DD/MM/YYYY HH24:MI:SS'), :CREATED_BY)</sql>
		<result outputType="json">{"elementos":{"elemento":[{"KEY_COMPANIA":"$COMPANIA","KEY_TIPO":"$TIPO","KEY_NUMERO":"$NUMERO(type:long)","KEY_VIGENCIA_INICIAL":"$VIGENCIA_INICIAL(type:integer)","KEY_ID_PLAN":"$ID_PLAN","KEY_CODIGO":"$CODIGO(type:integer)"}]}}		</result>
		<param name="COMPANIA" sqlType="STRING"/>
		<param name="TIPO" sqlType="STRING"/>
